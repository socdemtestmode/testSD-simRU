[? if dnvp_ideology == "Умеренные": {!<tr><td><div class="box" style='background-color:#11DD11'> </div> !}СЗН:{!</td><td>!} [+ farm_saxony_elections_vote +]% {!</td><td>!} [+ farm_r_saxony +]% {!</td></tr>!}  ?]

