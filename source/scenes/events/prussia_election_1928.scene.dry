[? if z_leader != "Штегервальд": Адам Штегервальд ?][? if z_leader == "Штегервальд": Генрих Брюнинг ?]из[? if z_party_name != "ХНП": <span style="color: #000000;">Партии Центра</span> ?][? if z_party_name == "ХНП": <span style="color: #000000;">**ХНП**</span> ?] избран на пост министра-президента Пруссии.


@bourgeois_coalition_kvp_prussia
title: Отказаться от формирования правительства, чтобы мог быть сформирован Буржуазный блок.
unavailable-subtitle: <span style="color: #000000;">[+ z_party_name +]</span> +[? if not lvp_formed: <span style="color: #D3C24D;">[+ ddp_name +]</span>[? if dvp_exist: &nbsp;+ <span style="color: #C0A054;">ННП</span> ?] ?][? if lvp_formed: <span style="color: #FFCC00;">ЛНП</span> ?]+ Другие[? if kvp_formed: &nbsp;+ <span style="color: #0087DC;">**КНП**</span> ?]([+ bourgeois_coalition_prussia +]%)
subtitle: <span style="color: #000000;">**[+ z_party_name +]**</span> +[? if not lvp_formed: <span style="color: #D3C24D;">**[+ ddp_name +]**</span>[? if dvp_exist: &nbsp;+ <span style="color: #C0A054;">**ННП**</span> ?] ?][? if lvp_formed: <span style="color: #FFCC00;">**ЛНП**</span> ?]+**Прочие**[? if kvp_formed: &nbsp;+ <span style="color: #0087DC;">**КНП**</span> ?]([+ bourgeois_coalition_prussia +]%)
view-if: bourgeois_coalition_prussia >= 50 and not cvp_formed
on-arrival: in_center_right_coalition_prussia = 1; hands_tied_prussia = 0; hands_tied_prussia = 1 if ((ddp_relation < 35 and not lvp_formed) or (lvp_relation < 40 and lvp_formed) or weimar_coalition_prussia < 45 or cvp_formed); prussia_leader = "Штегервальд"; prussia_leader = "Брюнинг" if z_leader == "Штегервальд"; new_middle_spd -= 4; rural_spd -= 2; ddp_right += 1; ddp_cohesion -= 1; dvp_right += 1; lvp_right += 1; center_dissent += 10 if hands_tied_prussia; left_dissent += 5 if hands_tied_prussia; labor_dissent += 20 if hands_tied_prussia; reformist_dissent += 20 if hands_tied_prussia; neorevisionist_dissent += 10 if hands_tied_prussia; prussian_police_loyalty -= 0.06; prussian_police_strength -= 8; pro_republic -= 3; ddp_relation -= 4; z_relation -= 4; dvp_relation -= 4; lvp_relation -= 4; hands_tied_prussia = 0

[? if not ((ddp_relation < 35 and not lvp_formed) or (lvp_relation < 40 and lvp_formed) or weimar_coalition_prussia < 45 or cvp_formed): Сдача оплота демократии правым крайне непопулярна среди всех членов партии и не даёт никаких видимых преимуществ. ?][? if ((ddp_relation < 35 and not lvp_formed) or (lvp_relation < 40 and lvp_formed) or weimar_coalition_prussia < 45 or cvp_formed): К сожалению, текущая политическая ситуация не оставляет нам иного выбора, кроме как отказаться от оплота демократии. Будем надеяться, что через несколько лет мы сможем восстановить контроль.  ?]

[? if z_leader != "Штегервальд": Адам Штегервальд ?][? if z_leader == "Штегервальд": Генрих Брюнинг ?]из[? if z_party_name != "ХНП": <span style="color: #000000;">Партии Центра</span> ?][? if z_party_name == "ХНП": <span style="color: #000000;">**ХНП**</span> ?]назначается министром-президентом Пруссии.


@call_new_elections
subtitle: Будут назначены новые выборы.
view-if: (((grand_coalition_prussia < 50) or ((grand_coalition_prussia >= 50 and (((dvp_relation < 40 or dvp_ideology == "Правые") and not lvp_formed) or ((lvp_relation < 40 or lvp_ideology == "Правые") and lvp_formed) or z_relation < 35)))) and far_right_coalition_prussia < 50 and (center_right_coalition_prussia < 50 or ((center_right_coalition_prussia >= 50 and ((dnvp_ideology == "Радикалы" and not dnvp_westarp) or (year = 1929 and month >= 7)))) and (right_coalition_prussia < 50 or (right_coalition_prussia >= 50 and ((dnvp_ideology == "Радикалы" and not dnvp_westarp) or (year = 1929 and month >= 7)))))) and not rubicon
go-to: call_new_elections_2 if no_majority_elections_prussia < 1 or (neo_weimar_coalition_prussia + kvp_r_prussia < 50 and dnvp_ideology == "Радикалы") or (neo_weimar_coalition_prussia + dnvp_r_prussia < 50 and dnvp_ideology == "Умеренные"); toleration_dilemma if no_majority_elections_prussia >= 1 and ((neo_weimar_coalition_prussia + kvp_r_prussia >= 50 and dnvp_ideology == "Радикалы") or (neo_weimar_coalition_prussia + dnvp_r_prussia >= 50 and dnvp_ideology == "Умеренные"))


@toleration_dilemma

Создать правительство большинства невозможно. Один из вариантов — допустить широкое буржуазное правительство меньшинства без участия в правительстве <span style="color: #c00000;">**СДПГ**</span>. По сути мы будем «терпеть» их правительство. Это единственный возможный вариант правительства, поскольку буржуазные партии отказываются сотрудничать с нами на других условиях.

В противном случае придётся объявлять новые выборы, на которых могут усилиться экстремистские партии.

- @call_new_elections_2: Нас ждут новые выборы.
- @tolerate_bourgeois_coalition: Мы «потерпим» буржуазное правительство меньшинства, чтобы избежать новых выборов.


@call_new_elections_2
on-arrival: pro_republic -= 5 if anti_democratic_coalition_prussia >= 30; workers_nsdap += 3 if anti_democratic_coalition_prussia >= 30; workers_kpd += 3 if anti_democratic_coalition_prussia >= 30; workers_spd -= 3 if anti_democratic_coalition_prussia >= 30; new_middle_nsdap += 2 if anti_democratic_coalition_prussia >= 30; old_middle_nsdap += 2 if anti_democratic_coalition_prussia >= 30; rural_nsdap += 2 if anti_democratic_coalition_prussia >= 30; new_middle_ddp -= 2 if anti_democratic_coalition_prussia >= 30; old_middle_ddp -= 2 if anti_democratic_coalition_prussia >= 30; rural_ddp -= 2 if anti_democratic_coalition_prussia >= 30; new_middle_dvp -= 2 if anti_democratic_coalition_prussia >= 30; old_middle_dvp -= 2 if anti_democratic_coalition_prussia >= 30; rural_dvp -= 2 if anti_democratic_coalition_prussia >= 30; new_middle_lvp -= 2 if anti_democratic_coalition_prussia >= 30; old_middle_lvp -= 2 if anti_democratic_coalition_prussia >= 30; rural_lvp -= 2 if anti_democratic_coalition_prussia >= 30; no_majority_elections_prussia += 1; next_election_week_prussia = next_election_week if rubicon and next_election_time - time < 3; next_election_week_prussia = week + 6 if rubicon and next_election_time - time >= 3; next_election_week_prussia -= 4 if rubicon and next_election_week_prussia > 4; next_election_week_prussia -= 4 if rubicon and next_election_week_prussia > 4
call: set_next_election_time_prussia

[? if far_right_coalition_prussia + z_r_prussia >= 50: Провал попытки <span style="color: #000000;">Партии Центра</span> сформировать коалицию с <span style="color: #7A3C00;">**НСДАП**</span> из-за настойчивого требования последней получить и пост министра-президента, и контроль над прусской полицией, не оставил иного выбора, кроме как объявить новые выборы.  ?]

Новые выборы в Пруссии назначены на [+ next_election_month_prussia : month +] [+ next_election_year_prussia +][? if rubicon: , неделя [+ next_election_week +]  ?].

[? if anti_democratic_coalition_prussia >= 30: Вера народа в демократию пошатнулась из-за этих испытаний. Разумеется, <span style="color: #7A3C00;">нацисты</span> пользуются нестабильностью, заявляя: демократия нежизнеспособна, Германии нужен сильный лидер. ?]


@tolerate_bourgeois_coalition
title: Мы должны проявить терпимость к буржуазной коалиции.
on-arrival: prussia_leader = "Штегервальд" if z_leader != "Штегервальд"; prussia_leader = "Брюнинг" if z_leader == "Штегервальд"; prussia_leader = "Лютер" if (dvp_leader == "Лютер" or lvp_leader == "Лютер" and lvp_formed); spd_toleration_prussia = 1; new_middle_spd -= 4; ddp_right += 1; ddp_cohesion -= 1; dvp_right += 1; lvp_right += 1; center_dissent += 5; left_dissent += 10; prussian_police_loyalty -= 0.05; prussian_police_strength -= 10; pro_republic -= 3; right_prussia = 1

Мы решили «терпеть»  буржуазное правительство меньшинства. Мы будем голосовать против вотумов недоверия, чтобы они не прошли, но при этом не будем напрямую участвовать в правительстве. Таким образом, мы сможем предотвратить новые выборы и не допустить <span style="color: #7A3C00;">крайне</span> <span style="color: #3E88B3;">правых</span> в правительство.

[? if prussia_leader != "Браун": [+ prussia_leader +] избран министром-президентом Пруссии. ?]


@call_new_elections_rubicon
subtitle: Будут назначены новые выборы.
view-if: (((grand_coalition_prussia < 50) or ((grand_coalition_prussia >= 50 and (dvp_relation < 40 or (lvp_relation < 40 and lvp_formed) or z_relation < 35)))) and far_right_coalition_prussia < 50 and (center_right_coalition_prussia < 50 or ((center_right_coalition_prussia >= 50 and ((dnvp_ideology == "Радикалы" and not dnvp_westarp) or (year = 1929 and month >= 7)))) and (right_coalition_prussia < 50 or (right_coalition_prussia >= 50 and ((dnvp_ideology == "Радикалы" and not dnvp_westarp) or (year = 1929 and month >= 7)))))) and rubicon
on-arrival: no_majority_elections_prussia_schleicher = 1
go-to: call_new_elections_2_rubicon if prussia_leader != "Браун" and prussia_leader != "Штегервальд" and prussia_leader != "Лютер" and prussia_leader != "Брюнинг"; prussia_explode if prussia_leader == "Браун" or prussia_leader == "Штегервальд" or prussia_leader == "Лютер" or prussia_leader == "Брюнинг"


@call_new_elections_2_rubicon
view-if: dnef_r_prussia < 50 and (schleicher_right_coalition_prussia < 50 or dsu_leader == "Отто Штрассер")
on-arrival: next_election_week_prussia = next_election_week if rubicon and next_election_time - time < 3; next_election_week_prussia = week + 6 if rubicon and next_election_time - time >= 3; next_election_week_prussia -= 4 if rubicon and next_election_week_prussia > 4; next_election_week_prussia -= 4 if rubicon and next_election_week_prussia > 4
call: set_next_election_time_prussia

Возможно, в ходе новых выборов удастся сформировать более стабильное большинство.

Новые выборы в Пруссии назначены на [+ next_election_month_prussia : month +] [+ next_election_year_prussia +], неделя [+ next_election_week +].


@prussia_explode
go-to: prussian_coup_schleicher
