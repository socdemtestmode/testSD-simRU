[? if nvf_exist and nvf_dnef: {!<tr><td><div class="box2" style='background-color:#0F2116'> </div> !}ННФ:{!</td><td>!} [+ nvf_votes_prussia +]%{!</td><td>!} [+ str_votes_change_nvf_prussia +] {!</td><td>!} [+ nvf_r_prussia +]%{!</td><td>!} [+ str_change_nvf_prussia +] {!</td></tr>!}  ?]

