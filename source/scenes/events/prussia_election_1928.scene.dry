[? if dnef_formed: {!<tr><td><div class="box" style='background-color:#E3000F;'> </div> !}СДПГ:{!</td><td>!} [+ spd_votes_prussia +]%{!</td><td>!} [+ str_votes_change_spd_prussia +] {!</td><td>!} [+ spd_r_prussia +]%{!</td><td>!} [+ str_change_spd_prussia +] {!</td></tr>!}  ?]

[? if sapd_formed : {!<tr><td><div class="box" style='background-color:#9B0000'> </div> !}СРПГ:{!</td><td>!} [+ sapd_votes_prussia +]%{!</td><td>!} [+ str_votes_change_sapd_prussia +] {!</td><td>!} [+ sapd_r_prussia +]%{!</td><td>!} [+ str_change_sapd_prussia +] {!</td></tr>!}  ?]

{!<tr><td><div class="box" style='background-color:#700000'> </div> !}КПГ:{!</td><td>!} [+ kpd_votes_prussia +]%{!</td><td>!} [+ str_votes_change_kpd_prussia +] {!</td><td>!} [+ kpd_r_prussia +]%{!</td><td>!} [+ str_change_kpd_prussia +] {!</td></tr>!}

[? if not lvp_formed and not dstp_dnef: {!<tr><td><div class="box" style='background-color:#D3C24D'> </div> !} [+ ddp_name +]:{!</td><td>!} [+ ddp_votes_prussia +]%{!</td><td>!} [+ str_votes_change_ddp_prussia +] {!</td><td>!} [+ ddp_r_prussia +]%{!</td><td>!} [+ str_change_ddp_prussia +] {!</td></tr>!}  ?]

[? if lvp_formed and not lvp_dnef: {!<tr><td><div class="box" style='background-color:#FFCC00'> </div> !}ЛНП:{!</td><td>!} [+ lvp_votes_prussia +]%{!</td><td>!} [+ str_votes_change_lvp_prussia +] {!</td><td>!} [+ lvp_r_prussia +]%{!</td><td>!} [+ str_change_lvp_prussia +] {!</td></tr>!}  ?]

[? if not z_dnef: {!<tr><td><div class="box" style='background-color:#000'> </div> !} [+ z_party_name +]:{!</td><td>!} [+ z_votes_prussia +]%{!</td><td>!} [+ str_votes_change_z_prussia +] {!</td><td>!} [+ z_r_prussia +]%{!</td><td>!} [+ str_change_z_prussia +] {!</td></tr>!}  ?]

[? if not lvp_formed and dvp_exist and not dvp_dnef: {!<tr><td><div class="box" style='background-color:#D5AC27'> </div> !}ННП:{!</td><td>!} [+ dvp_votes_prussia +]%{!</td><td>!} [+ str_votes_change_dvp_prussia +] {!</td><td>!} [+ dvp_r_prussia +]%{!</td><td>!} [+ str_change_dvp_prussia +] {!</td></tr>!}  ?]

[? if not other_dnef: {!<tr><td><div class="box" style='background-color:#a0a0a0'> </div> !}Прочие:{!</td><td>!} [+ other_votes_prussia +]%{!</td><td>!} [+ str_votes_change_other_prussia +] {!</td><td>!} [+ other_r_prussia +]%{!</td><td>!} [+ str_change_other_prussia +] {!</td></tr>!}  ?]

[? if kvp_formed and not cvp_kvp_formed and not kvp_dnef: {!<tr><td><div class="box" style='background-color:#0087DC'> </div> !}КНП:{!</td><td>!} [+ kvp_votes_prussia +]%{!</td><td>!} [+ str_votes_change_kvp_prussia +] {!</td><td>!} [+ kvp_r_prussia +]%{!</td><td>!} [+ str_change_kvp_prussia +] {!</td></tr>!}  ?]

[? if not cvp_formed and not dnvp_dnef: {!<tr><td><div class="box" style='background-color:#3E88B3'> </div> !}НННП:{!</td><td>!} [+ dnvp_votes_prussia +]%{!</td><td>!} [+ str_votes_change_dnvp_prussia +] {!</td><td>!} [+ dnvp_r_prussia +]%{!</td><td>!} [+ str_change_dnvp_prussia +] {!</td></tr>!} ?]

[? if dnf_formed : {!<tr><td><div class="box" style='background-color:#003755'> </div> !}НФГ:{!</td><td>!} [+ dnf_votes_prussia +]%{!</td><td>!} [+ str_votes_change_dnf_prussia +] {!</td><td>!} [+ dnf_r_prussia +]%{!</td><td>!} [+ str_change_dnf_prussia +] {!</td></tr>!}  ?]

[? if dsu_exist: {!<tr><td><div class="box" style='background-color:#6A1E1E'> </div> !}НСС:{!</td><td>!} [+ dsu_votes_prussia +]%{!</td><td>!} [+ str_votes_change_dsu_prussia +] {!</td><td>!} [+ dsu_r_prussia +]%{!</td><td>!} [+ str_change_dsu_prussia +] {!</td></tr>!}  ?]

[? if not nsdap_split: {!<tr><td><div class="box" style='background-color:#7A3C00'> </div> !}НСДАП:{!</td><td>!} [+ nsdap_votes_prussia +]%{!</td><td>!} [+ str_votes_change_nsdap_prussia +] {!</td><td>!} [+ nsdap_r_prussia +]%{!</td><td>!} [+ str_change_nsdap_prussia +] {!</td></tr>!}  ?]

[? if nsdap_split: {!<tr><td><div class="box" style='background-color:#7A3C00'> </div> !}НСДАП:{!</td><td>!} [+ nsdap_hitler_votes_prussia +]%{!</td><td>!} [+ str_votes_change_nsdap_hitler_prussia +] {!</td><td>!} [+ nsdap_hitler_r_prussia +]%{!</td><td>!} [+ str_change_nsdap_hitler_prussia +] {!</td></tr>!}  ?]

[? if nvf_exist and not nvf_dnef: {!<tr><td><div class="box" style='background-color:#142e20'> </div> !}ННФ:{!</td><td>!} [+ nvf_votes_prussia +]%{!</td><td>!} [+ str_votes_change_nvf_prussia +] {!</td><td>!} [+ nvf_r_prussia +]%{!</td><td>!} [+ str_change_nvf_prussia +] {!</td></tr>!}  ?] {!</table>!}

[? if nazi_urgency <= 1 and nsdap_r_prussia >= 15 : Стремительный рост <span style="color: #7A3C00;">**НСДАП**</span> вызывает крайнее беспокойство. Многие считали: партия <span style="color: #ff0000;">на последнем издыхании</span>, но теперь некоторые из нас видят в ней величайшую угрозу для демократии в Германии.  ?]

[? if anti_democratic_coalition_prussia >= 50 and dnvp_ideology == "Радикалы": Вместе антидемократические <span style="color: #700000;">**КПГ**</span>, <span style="color: #3E88B3;">**НННП**</span> и <span style="color: #7A3C00;">**НСДАП**</span> имеют большинство в ландтаге. Сформировать стабильное правящее большинство будет практически невозможно. ?]

[? if anti_democratic_coalition_prussia >= 50 and dnvp_ideology == "Умеренные": Вместе антидемократические <span style="color: #700000;">**КПГ**</span>, <span style="color: #003755;">**НФГ**</span> и <span style="color: #7A3C00;">**НСДАП**</span> имеют большинство в ландтаге. Сформировать стабильное правящее большинство будет практически невозможно. ?]

[? if hindenburg_angry_prussia : Стремительный рост <span style="color: #7A3C00;">**НСДАП**</span> в Пруссии, традиционном оплоте демократии, значительно изменил настроения в стране. Для консервативных элит, включая президента Гинденбурга, этот всплеск популярности укрепил убеждение: <span style="color: #7A3C00;">**НСДАП**</span> необходимо включить в состав федерального правительства. Теперь, когда их поддерживают [+ nsdap_votes +]% населения, партию больше нельзя игнорировать.  ?]

[? if left_coalition_prussia >= 50: <span style="color: #9B0000;">Марксистские</span> партии теперь составляют большинство в ландтаге! Это побудило рядовых членов обеих партий требовать более тесного сотрудничества. ?]


