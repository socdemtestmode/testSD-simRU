title: Выборы в прусский ландтаг
view-if: ((year = next_election_year_prussia and month >= next_election_month_prussia) and (next_election_week_prussia == week or not rubicon or not next_election_week_prussia)) or (year > next_election_year_prussia)
new-page: true
tags: event
priority: 2
on-arrival: was_in_social_catholic_coalition_prussia = 0; was_in_social_liberal_coalition_prussia = 0; was_in_weimar_coalition_prussia = 0; was_in_grand_coalition_prussia = 0; was_in_social_catholic_coalition_prussia = 1 if in_social_catholic_coalition_prussia == 1 or in_minority_social_catholic_coalition_prussia == 1; was_in_social_liberal_coalition_prussia = 1 if in_social_liberal_coalition_prussia == 1 or in_minority_social_liberal_coalition_prussia == 1; was_in_weimar_coalition_prussia = 1 if ((in_weimar_coalition_prussia == 1 or in_minority_weimar_coalition_prussia == 1) or (in_grand_coalition_prussia == 1 and lvp_formed)); was_in_grand_coalition_prussia = 1 if (in_grand_coalition_prussia == 1 or in_minority_grand_coalition_prussia == 1); in_right_coalition_prussia = 0; in_social_catholic_coalition_prussia = 0; in_social_liberal_coalition_prussia = 0; in_weimar_coalition_prussia = 0; in_grand_coalition_prussia = 0; in_minority_grand_coalition_prussia = 0; in_popular_front_prussia = 0; in_left_front_prussia = 0; in_spd_majority_prussia = 0; in_center_right_coalition_prussia = 0; in_far_right_coalition_prussia = 0; in_minority_weimar_coalition_prussia = 0; in_minority_social_catholic_coalition_prussia = 0; in_minority_social_liberal_coalition_prussia = 0; spd_prussia = 0; right_prussia = 0; ddp_in_popular_front_prussia = 0; kpd_goals_seen_prussia = 0; spd_toleration_prussia = 0
on-departure: {! 
Q.in_election_prussia = 0;
Q.next_election_year_prussia = Q.next_election_year_prussia + 4; 
Q.n_elections_prussia += 1;
Q.next_election_time_prussia = Q.time + 48;
if (Q.n_elections_prussia == 1) {
    Q.next_election_month_prussia -= 1;
}
if (Q.in_social_catholic_coalition_prussia || Q.in_social_liberal_coalition_prussia || Q.in_weimar_coalition_prussia == 1 || Q.in_grand_coalition_prussia == 1 || Q.in_popular_front_prussia == 1 || Q.in_left_front_prussia == 1 || Q.in_spd_majority_prussia == 1 || Q.in_minority_weimar_coalition_prussia == 1 || Q.in_minority_grand_coalition_prussia == 1) {
    Q.spd_prussia = 1;
    Q.right_prussia = 0;
} else if (Q.in_right_coalition_prussia == 1 || Q.in_center_right_coalition_prussia == 1 || Q.prussia_leader == "Папен" || Q.prussia_leader == "Геринг" || Q.in_far_right_coalition_prussia == 1) {
    Q.right_prussia = 1;
    Q.spd_prussia = 0;
}
!}
set-jump: new_elections
face-image: img/prussia.png

= Выборы, [+ month : month +] [+ year +]

Сейчас состоятся выборы в прусский ландтаг.

- @new_elections: Сделаем всё возможное…


@new_elections
on-arrival: {!  
for (var c of Q.classes) {
    var class_votes = 0;
    for (var party of Q.parties) {
        if (Q[c + '_' + party] < 0) {
            Q[c + '_' + party] = 0;
        }
        class_votes += Q[c + '_' + party];
    }
    for (var party of Q.parties) {
        Q[c + '_' + party + '_normalized_prussia'] = Math.round(100 * Q[c + '_' + party] / class_votes);
    }
}

// Define adjustment factors
if (Q.year == 1928) {
    var adjustment_factors = {
        spd: 0.98,
        sapd: 0.6,
        kpd: 1.1,
        ddp: 0.95,
        lvp: 0.97,
        z: 1.02,
        dvp: 1.0,
        dnvp: 1.2,
        nsdap: 0.66,
        other: 0.88,
        kvp: 1.2,
        dnf: 0.65
    };
} else if (Q.year == 1929) {
    var adjustment_factors = {
        spd: 0.97,
        sapd: 0.8,
        kpd: 1.08,
        ddp: 0.95,
        lvp: 0.96,
        z: 1.02,
        dvp: 1.025,
        dnvp: 1.3,
        nsdap: 1.0,
        other: 0.85,
        kvp: 1.3,
        dnf: 0.7
    };
} else if (Q.year == 1930 && Q.kvp_formed == 1) {
    var adjustment_factors = {
        spd: 0.95,
        sapd: 1.0,
        kpd: 1.05,
        ddp: 0.95,
        lvp: 0.95,
        z: 1.02,
        dvp: 1.05,
        dnvp: 0.8,
        nsdap: 1.0,
        other: 0.8,
        kvp: 1.3,
        dnf: 0.8
    };
} else if (Q.year == 1930 && Q.kvp_formed == 0) {
    var adjustment_factors = {
        spd: 0.95,
        sapd: 1.0,
        kpd: 1.05,
        ddp: 0.95,
        lvp: 0.95,
        z: 1.02,
        dvp: 1.0,
        dnvp: 1.3,
        nsdap: 1.0,
        other: 0.75,
        kvp: 1.3,
        dnf: 0.8
    };
} else if (Q.year == 1931) {
    var adjustment_factors = {
        spd: 0.95,
        sapd: 1.3,
        kpd: 1.0,
        ddp: 0.95,
        lvp: 1.0,
        z: 1.02,
        dvp: 1.1,
        dnvp: 1.25,
        nsdap: 1.0,
        other: 0.7,
        kvp: 1.0,
        dnf: 0.9
    };
} else if (Q.year >= 1932) {
    var adjustment_factors = {
        spd: 0.95,
        sapd: 1.5,
        kpd: 1.0,
        ddp: 0.95,
        lvp: 1.0,
        z: 1.02,
        dvp: 1.0,
        dnvp: 1.2,
        nsdap: 1.0,
        other: 0.65,
        kvp: 0.8,
        dnf: 1.0
    };
}

if (Q.ddp_votes < 3) Q.adjustmentFactors_ddp_prussia = 0.8;
if (Q.ddp_votes < 2) Q.adjustmentFactors_ddp_prussia = 0.5;
if (Q.ddp_votes < 1.5) Q.adjustmentFactors_ddp_prussia = 0.3;
if (Q.ddp_votes < 1) Q.adjustmentFactors_ddp_prussia = 0.1;
if (Q.ddp_votes >= 3) Q.adjustmentFactors_ddp_prussia = 1.0;

if (Q.dstp_dnef) Q.adjustmentFactors_ddp_prussia = 1.0;

if (Q.other_votes < 10) Q.adjustmentFactors_other_prussia = 0.6;
if (Q.other_votes < 8) Q.adjustmentFactors_other_prussia = 0.5;
if (Q.other_votes < 7) Q.adjustmentFactors_other_prussia = 0.4;
if (Q.other_votes < 6) Q.adjustmentFactors_other_prussia = 0.3;
if (Q.other_votes < 5) Q.adjustmentFactors_other_prussia = 0.15;
if (Q.other_votes >= 10) Q.adjustmentFactors_other_prussia = 0.7;

if (Q.other_dnef) Q.adjustmentFactors_other_prussia = 0;

if (!Q.hugenberg_dvp && !Q.bourgeois_list && !Q.dvp_dnef) {
    if (Q.dvp_votes < 1.2) {
        Q.adjustmentFactors_dvp = 0.5;
    }
    if (Q.dvp_votes < 0.8) {
        Q.adjustmentFactors_dvp = 0.3;
    }
}

// Calculate support for each of the parties
var total_support = 0;
for (var party of Q.parties) {
    var party_support = 0;
    for (var c of Q.classes) {
        if (Q.old_demographics) {
            party_support += Q[c] * Q[c + '_' + party];
        } else {
            party_support += Q[c] * Q[c + '_' + party + '_normalized_prussia'];
        }
    }
    // Apply adjustment factor
    Q[party + '_support'] = party_support * (adjustment_factors[party] || 1.0);
    total_support += Q[party + '_support'];
}

// Normalize support (fraction)
for (var party of Q.parties) {
    Q[party + '_normalized_prussia'] = Q[party + '_support'] / total_support;
    Q[party + '_votes_prussia'] = Math.round(Q[party + '_normalized_prussia'] * 1000) / 10;
}

var new_party_sum_prussia = 0;
var total_reichstag_without_prussia = 0; // Initialize a variable to accumulate 'reichstag_without_' values
var total_other_party_sum_prussia = 0; // Initialize a variable to accumulate '_other_party_sum' values

// Step 1: Calculate adjusted values and the sum for redistribution
for (var party of Q.parties) {
    let factor_prussia = Q['adjustmentFactors_' + party + '_prussia'] || 1.0; // Default to 1.0 if not set

    Q['old_' + party + '_r_prussia'] = Q[party + '_r_prussia']; // Store the original r value for comparison

    // Handle constitutional reform logic: set the party's share to 0 based on conditions
    if ((Q.constitutional_reform > 0 &&
             (Q[party + '_votes_prussia'] < Q.electoral_threshold || 
             (Q.electoral_threshold > 1 && party === 'other'))) 
            || Q[party + '_banned']) {
        Q[party + '_r_prussia'] = 0;
    } else {
        // Adjust `r` based on the adjustment factor if not affected by constitutional reform
        Q['original_' + party + '_r_prussia'] = Math.round(Q[party + '_votes_prussia'] * 10) / 10;
        Q[party + '_r_prussia'] = Math.round(Q[party + '_votes_prussia'] * factor_prussia * 10) / 10;
    }

    if (factor_prussia !== 1.0) { // Only apply to parties with adjustment factors
        // Calculate the Reichstag without the current party's share
        Q['reichstag_without_' + party + '_prussia'] = 100 - Q['original_' + party + '_r_prussia'];
        total_reichstag_without_prussia += Q['reichstag_without_' + party + '_prussia']; // Accumulate the total of 'reichstag_without_' values

        // Calculate the sum of the remaining parties
        Q[party + '_other_party_sum_prussia'] = Q['reichstag_without_' + party + '_prussia'] -
            (Q[party + '_votes_prussia'] - Q[party + '_r_prussia']);
        total_other_party_sum_prussia += Q[party + '_other_party_sum_prussia']; // Accumulate the total of '_other_party_sum' values
    } else {
        // For non-adjusted parties, accumulate their r value for the redistribution
        new_party_sum_prussia += Q[party + '_r_prussia'];
    }
}

// Step 2: Redistribute results among non-adjusted parties to ensure the total is 100%
if (new_party_sum_prussia > 0) {
    for (var party of Q.parties) {
        let factor_prussia = Q['adjustmentFactors_' + party + '_prussia'] || 1.0;

        if (Q[party + '_r_prussia'] === 0) continue;

        var total_reichstag_without_party_prussia = total_reichstag_without_prussia - (100 - Q['original_' + party + '_r_prussia']);
        var total_other_party_sum_party_prussia = total_other_party_sum_prussia - (Q['reichstag_without_' + party + '_prussia'] - (Q[party + '_votes_prussia'] - Q[party + '_r_prussia']));

        if (factor_prussia === 1.0) {
            if (total_other_party_sum_prussia > 0) {
                Q[party + '_r_prussia'] = Math.round((Q[party + '_r_prussia'] * total_reichstag_without_prussia) / total_other_party_sum_prussia * 10) / 10;
            } else {
                Q[party + '_r_prussia'] = Q[party + '_r_prussia'];
            }
        } else if (factor_prussia !== 1.0 && total_reichstag_without_party_prussia > 0 && total_other_party_sum_party_prussia > 0) {
            let scaling_factor_prussia = total_reichstag_without_party_prussia / total_other_party_sum_party_prussia;
            Q[party + '_r_prussia'] = Math.round(Q[party + '_r_prussia'] * scaling_factor_prussia * 10) / 10;
        }
    }

    // Step 3: Normalize to ensure the total sums to exactly 100%
    let total_r_sum_prussia = 0;

    // Calculate the total of all `r` values after redistribution
    for (var party of Q.parties) {
        total_r_sum_prussia += Q[party + '_r_prussia'];
    }

    // Adjust each party's `r` value proportionally if the total isn't 100
    if (total_r_sum_prussia !== 100) {
        let normalization_factor_prussia = 100 / total_r_sum_prussia;
        for (var party of Q.parties) {
            if (Q[party + '_r_prussia'] > 0) {
                Q[party + '_r_prussia'] = Math.round(Q[party + '_r_prussia'] * normalization_factor_prussia * 10) / 10;
            }
        }
    }
}

if (Q.dnef_formed) {
    Q.schleicher_dnef_r_prussia = Q.dnef_r_prussia;
    Q.schleicher_dnef_votes_prussia = Q.dnef_votes_prussia;
    if (Q.other_dnef) {
        if (Q.other_r_prussia) {
            Q.dnef_r_prussia += Q.other_r_prussia;
            Q.other_r_prussia = 0;
        }
        Q.dnef_votes_prussia += Q.other_votes_prussia;
    }
    if (Q.dstp_dnef) {
        if (Q.ddp_r_prussia) {
            Q.dnef_r_prussia += Q.ddp_r_prussia;
            Q.ddp_r_prussia = 0;
        }
        Q.dnef_votes_prussia += Q.ddp_votes_prussia;
    }
    if (Q.lvp_dnef) {
        if (Q.lvp_r_prussia) {
            Q.dnef_r += Q.lvp_r_prussia;
            Q.lvp_r_prussia = 0;
        }
        Q.dnef_votes_prussia += Q.lvp_votes_prussia;
    }
    if (Q.kvp_dnef) {
        if (Q.kvp_r_prussia) {
            Q.dnef_r_prussia += Q.kvp_r_prussia;
            Q.kvp_r_prussia = 0;
        }
        Q.dnef_votes_prussia += Q.kvp_votes_prussia;
    }
    if (Q.dvp_dnef) {
        if (Q.dvp_r_prussia) {
            Q.dnef_r_prussia += Q.dvp_r_prussia;
            Q.dvp_r_prussia = 0;
        }
        Q.dnef_votes_prussia += Q.dvp_votes_prussia;
    }
    if (Q.z_dnef) {
        if (Q.z_r_prussia) {
            Q.dnef_r_prussia += Q.z_r_prussia;
            Q.z_r_prussia = 0;
        }
        Q.dnef_votes_prussia += Q.z_votes_prussia;
    }
    if (Q.dnvp_dnef) {
        if (Q.dnvp_r_prussia) {
            Q.dnef_r_prussia += Q.dnvp_r_prussia;
            Q.dnvp_r_prussia = 0;
        }
        Q.dnef_votes_prussia += Q.dnvp_votes_prussia;
    }
    Q.dnef_votes_prussia = Math.round(Q.dnef_votes_prussia * 10) / 10;
    Q.dnef_r_prussia = Math.round(Q.dnef_r_prussia * 10) / 10;
}

// Step 3: Calculate changes in results
for (var party of Q.parties) {
    Q['change_' + party + '_r_prussia'] = Q[party + '_r_prussia'] - Q['old_' + party + '_r_prussia'];
    var sign_prussia = Q['change_' + party + '_r_prussia'] > 0 ?
        '<img src="img/arrowup.png"> ' :
        Q['change_' + party + '_r_prussia'] < 0 ?
        '<img src="img/arrowdown.png"> ' :
        '<img src="img/steady.png"> ';
    Q['change_' + party + '_r_prussia'] = Math.abs(Q['change_' + party + '_r_prussia']);
    Q['str_change_' + party + '_prussia'] = sign_prussia + parseFloat(Q['change_' + party + '_r_prussia']).toFixed(1);

    // Calculate changes in votes
    Q['change_' + party + '_votes_prussia'] = Q[party + '_votes_prussia'] - Q['previous_' + party + '_last_election_votes_prussia'];
    if (Q['previous_' + party + '_last_election_votes_prussia'] === undefined) {
        Q['change_' + party + '_votes_prussia'] = Q[party + '_votes_prussia'];
    }

    var sign2_prussia = Q['change_' + party + '_votes_prussia'] > 0 ?
        '<img src="img/arrowup.png"> ' :
        Q['change_' + party + '_votes_prussia'] < 0 ?
        '<img src="img/arrowdown.png"> ' :
        '<img src="img/steady.png"> ';
    Q['str_votes_change_' + party + '_prussia'] = sign2_prussia + Math.abs(Q['change_' + party + '_votes_prussia']).toFixed(1);
}

// Store current votes as previous for the next iteration
for (var party of Q.parties) {
    Q[party + '_last_election_votes_prussia'] = parseFloat(Q[party + '_votes_prussia']).toFixed(1);
    Q['previous_' + party + '_last_election_votes_prussia'] = parseFloat(Q[party + '_last_election_votes_prussia']).toFixed(1);
}

if (Q.nsdap_split) {
    if (Q.dsu_exist) {
        Q.dsu_r_prussia = parseFloat(Q.dsu_votes.toFixed(1));
        Q.dsu_votes_prussia = parseFloat(Q.dsu_votes.toFixed(1));
    }
    if (Q.nvf_exist) {
        Q.nvf_r_prussia = parseFloat(Q.nvf_votes.toFixed(1));
        Q.nvf_votes_prussia = parseFloat(Q.nvf_votes.toFixed(1));
    }
    if (Q.dsu_exist || Q.nvf_exist) {
        Q.nsdap_hitler_r_prussia = parseFloat(Q.nsdap_hitler_votes.toFixed(1));
        Q.nsdap_hitler_votes_prussia = parseFloat(Q.nsdap_hitler_votes.toFixed(1));
    }
    if ((Q.dsu_votes_prussia + Q.nvf_votes_prussia + Q.nsdap_hitler_votes_prussia) !== Q.nsdap_votes_prussia) {
        let total = Q.dsu_votes_prussia + Q.nvf_votes_prussia + Q.nsdap_hitler_votes_prussia;
        let factor = Q.nsdap_votes_prussia / total;

        Q.dsu_votes_prussia = parseFloat((Q.dsu_votes_prussia * factor).toFixed(1));
        Q.nvf_votes_prussia = parseFloat((Q.nvf_votes_prussia * factor).toFixed(1));
        Q.nsdap_hitler_votes_prussia = parseFloat((Q.nsdap_hitler_votes_prussia * factor).toFixed(1));
    }
    if ((Q.dsu_r_prussia + Q.nvf_r_prussia + Q.nsdap_hitler_r_prussia) !== Q.nsdap_r) {
        let total = Q.dsu_r_prussia + Q.nvf_r_prussia + Q.nsdap_hitler_r_prussia;
        let factor = Q.nsdap_r_prussia / total;

        Q.dsu_r_prussia = parseFloat((Q.dsu_r_prussia * factor).toFixed(1));
        Q.nvf_r_prussia = parseFloat((Q.nvf_r_prussia * factor).toFixed(1));
        Q.nsdap_hitler_r_prussia = parseFloat((Q.nsdap_hitler_r_prussia * factor).toFixed(1));
    }
    if (Q.dsu_exist) {
        Q.str_votes_change_dsu_prussia = Q.dsu_votes_prussia - Q.previous_dsu_last_election_votes_prussia;
        var sign2 = Q.str_votes_change_dsu_prussia > 0 ?
            '<img src="img/arrowup.png"> ' :
            Q.str_votes_change_dsu_prussia < 0 ?
            '<img src="img/arrowdown.png"> ' :
            '<img src="img/steady.png"> ';
        Q.str_votes_change_dsu_prussia = sign2 + Math.abs(Q.str_votes_change_dsu_prussia).toFixed(1);

        Q.str_change_dsu_prussia = Q.dsu_r_prussia - Q.old_dsu_r_prussia;
        var sign2 = Q.str_change_dsu_prussia > 0 ?
            '<img src="img/arrowup.png"> ' :
            Q.str_change_dsu_prussia < 0 ?
            '<img src="img/arrowdown.png"> ' :
            '<img src="img/steady.png"> ';
        Q.str_change_dsu_prussia = sign2 + Math.abs(Q.str_change_dsu_prussia).toFixed(1);
    }
    if (Q.nvf_exist) {
        Q.str_votes_change_nvf_prussia = Q.nvf_votes_prussia - Q.previous_nvf_last_election_votes_prussia;
        var sign2 = Q.str_votes_change_nvf_prussia > 0 ?
            '<img src="img/arrowup.png"> ' :
            Q.str_votes_change_nvf_prussia < 0 ?
            '<img src="img/arrowdown.png"> ' :
            '<img src="img/steady.png"> ';
        Q.str_votes_change_nvf_prussia = sign2 + Math.abs(Q.str_votes_change_nvf_prussia).toFixed(1);

        Q.str_change_nvf_prussia = Q.nvf_r_prussia - Q.old_nvf_r_prussia;
        var sign2 = Q.str_change_nvf_prussia > 0 ?
            '<img src="img/arrowup.png"> ' :
            Q.str_change_nvf_prussia < 0 ?
            '<img src="img/arrowdown.png"> ' :
            '<img src="img/steady.png"> ';
        Q.str_change_nvf_prussia = sign2 + Math.abs(Q.str_change_nvf_prussia).toFixed(1);
    }
    if (Q.nvf_exist || Q.dsu_exist) {
        if (Q.previous_nsdap_hitler_last_election_votes_prussia == 0) Q.previous_nsdap_hitler_last_election_votes_prussia = Q.previous_nsdap_last_election_votes_prussia
        if (Q.old_nsdap_hitler_r_prussia == 0) Q.old_nsdap_hitler_r_prussia = Q.old_nsdap_r_prussia

        Q.str_votes_change_nsdap_hitler_prussia = Q.nsdap_hitler_votes_prussia - Q.previous_nsdap_hitler_last_election_votes_prussia;
        var sign2 = Q.str_votes_change_nsdap_hitler_prussia > 0 ?
            '<img src="img/arrowup.png"> ' :
            Q.str_votes_change_nsdap_hitler_prussia < 0 ?
            '<img src="img/arrowdown.png"> ' :
            '<img src="img/steady.png"> ';
        Q.str_votes_change_nsdap_hitler_prussia = sign2 + Math.abs(Q.str_votes_change_nsdap_hitler_prussia).toFixed(1);

        Q.str_change_nsdap_hitler_prussia = Q.nsdap_hitler_r_prussia - Q.old_nsdap_hitler_r_prussia;
        var sign2 = Q.str_change_nsdap_hitler_prussia > 0 ?
            '<img src="img/arrowup.png"> ' :
            Q.str_change_nsdap_hitler_prussia < 0 ?
            '<img src="img/arrowdown.png"> ' :
            '<img src="img/steady.png"> ';
        Q.str_change_nsdap_hitler_prussia = sign2 + Math.abs(Q.str_change_nsdap_hitler_prussia).toFixed(1);
    }
    Q.previous_dsu_last_election_votes_prussia = Q.dsu_votes_prussia;
    Q.old_dsu_r_prussia = Q.dsu_r_prussia;
    Q.previous_nvf_last_election_votes_prussia = Q.nvf_votes_prussia;
    Q.old_nvf_r_prussia = Q.nvf_r_prussia;
    Q.previous_nsdap_hitler_last_election_votes_prussia = Q.nsdap_hitler_votes_prussia;
    Q.old_nsdap_hitler_r_prussia = Q.nsdap_hitler_r_prussia;
}

if (Q.dnef_formed && Q.nvf_exist) {
    if (Q.nvf_dnef) {
        if (Q.nvf_r_prussia) {
            Q.dnef_r += Q.nvf_r_prussia;
            Q.nvf_r_prussia = 0;
        }
        Q.dnef_votes_prussia += Q.nvf_votes_prussia;
    }
    Q.dnef_votes_prussia = Math.round(Q.dnef_votes_prussia * 10) / 10;
    Q.dnef_r = Math.round(Q.dnef_r * 10) / 10;
}

if (Q.dnef_formed) {
    Q.str_votes_change_schleicher_dnef_prussia = Q.schleicher_dnef_votes_prussia - Q.previous_schleicher_dnef_last_election_votes_prussia;
    var sign2 = Q.str_votes_change_schleicher_dnef_prussia > 0 ?
        '<img src="img/arrowup.png"> ' :
        Q.str_votes_change_schleicher_dnef_prussia < 0 ?
        '<img src="img/arrowdown.png"> ' :
        '<img src="img/steady.png"> ';
    Q.str_votes_change_schleicher_dnef_prussia = sign2 + Math.abs(Q.str_votes_change_schleicher_dnef_prussia).toFixed(1);
    Q.previous_schleicher_dnef_last_election_votes_prussia = Q.schleicher_dnef_votes_prussia;
}

Q.largest_party_prussia = 'СДПГ';
if (Q.nsdap_r_prussia >= Q.spd_r_prussia && Q.nsdap_r_prussia >= Q.kpd_r_prussia) {
    Q.largest_party_prussia = 'НСДАП';
}
if (Q.kpd_r_prussia >= Q.spd_r_prussia && Q.kpd_r_prussia >= Q.nsdap_r_prussia) {
    Q.largest_party_prussia = 'КПГ';
}

// coalitions
if (Q.lvp_formed) {
    Q.weimar_coalition_prussia = parseFloat((Q.spd_r_prussia + Q.lvp_r_prussia + Q.z_r_prussia ).toFixed(1));
} else {
    Q.weimar_coalition_prussia = parseFloat((Q.spd_r_prussia + Q.ddp_r_prussia + Q.z_r_prussia).toFixed(1));
}

if (Q.lvp_formed) {
    Q.social_liberal_coalition_prussia = parseFloat((Q.spd_r_prussia + Q.lvp_r_prussia).toFixed(1));
} else {
    Q.social_liberal_coalition_prussia = parseFloat((Q.spd_r_prussia + Q.ddp_r_prussia).toFixed(1));
}

Q.social_catholic_coalition_prussia = parseFloat((Q.spd_r_prussia + Q.z_r_prussia).toFixed(1));

if (Q.lvp_formed) {
    Q.grand_coalition_prussia = parseFloat((Q.spd_r_prussia + Q.lvp_r_prussia + Q.z_r_prussia).toFixed(1));
} else {
    Q.grand_coalition_prussia = parseFloat((Q.spd_r_prussia + Q.ddp_r_prussia + Q.z_r_prussia + Q.dvp_r_prussia).toFixed(1));
}

if (Q.kvp_formed && Q.lvp_formed) {
    Q.bourgeois_coalition_prussia = parseFloat((Q.z_r_prussia + Q.lvp_r_prussia + Q.other_r_prussia + Q.kvp_r_prussia).toFixed(1));
} else if (Q.kvp_formed && !Q.lvp_formed) {
    Q.bourgeois_coalition_prussia = parseFloat((Q.ddp_r_prussia + Q.z_r_prussia + Q.dvp_r_prussia + Q.other_r_prussia + Q.kvp_r_prussia).toFixed(1));
} else if (Q.lvp_formed && !Q.kvp_formed) {
    Q.bourgeois_coalition_prussia = parseFloat((Q.z_r_prussia + Q.lvp_r_prussia + Q.other_r_prussia).toFixed(1));
} else {
    Q.bourgeois_coalition_prussia = parseFloat((Q.ddp_r_prussia + Q.z_r_prussia + Q.dvp_r_prussia + Q.other_r_prussia).toFixed(1));
}

if (Q.kvp_formed && Q.lvp_formed) {
    Q.center_right_coalition_prussia = parseFloat((Q.z_r_prussia + Q.lvp_r_prussia + Q.other_r_prussia + Q.dnvp_r_prussia + Q.kvp_r_prussia).toFixed(1));
} else if (Q.kvp_formed && !Q.lvp_formed) {
    Q.center_right_coalition_prussia = parseFloat((Q.z_r_prussia + Q.ddp_r_prussia + Q.dvp_r_prussia + Q.other_r_prussia + Q.dnvp_r_prussia + Q.kvp_r_prussia).toFixed(1));
} else if (!Q.kvp_formed && Q.lvp_formed) {
    Q.center_right_coalition_prussia = parseFloat((Q.z_r_prussia + Q.lvp_r_prussia + Q.other_r_prussia + Q.dnvp_r_prussia).toFixed(1));
} else {
    Q.center_right_coalition_prussia = parseFloat((Q.z_r_prussia + Q.ddp_r_prussia + Q.dvp_r_prussia + Q.other_r_prussia + Q.dnvp_r_prussia).toFixed(1));
}

if (Q.lvp_formed) {
    Q.right_coalition_prussia = parseFloat((Q.z_r_prussia + Q.lvp_r_prussia + Q.other_r_prussia + Q.dnvp_r_prussia).toFixed(1));
} else {
    Q.right_coalition_prussia = parseFloat((Q.z_r_prussia + Q.dvp_r_prussia + Q.other_r_prussia + Q.dnvp_r_prussia).toFixed(1));
}

if (Q.dnvp_ideology === "Умеренные") {
    Q.far_right_coalition_prussia = parseFloat((Q.dnf_r_prussia + Q.nsdap_r_prussia).toFixed(1));
} else {
    Q.far_right_coalition_prussia = parseFloat((Q.dnvp_r_prussia + Q.nsdap_r_prussia).toFixed(1));
}

if (Q.dvp_leader == "Дингельдей" && Q.dvp_ideology == "Правые" && Q.dvp_right - Q.dvp_left >= 15 || Q.hugenberg_dvp) {
    Q.far_right_coalition_prussia = parseFloat((Q.far_right_coalition_prussia + Q.dvp_r_prussia).toFixed(1));
}

Q.left_coalition_prussia = parseFloat((Q.spd_r_prussia + Q.kpd_r_prussia + Q.sapd_r_prussia).toFixed(1));

if (Q.lvp_formed) {
    Q.popular_front_coalition_prussia = parseFloat((Q.spd_r_prussia + Q.kpd_r_prussia + Q.z_r_prussia + Q.sapd_r_prussia).toFixed(1));
} else if (Q.liberal_parliament == 0) {
    Q.popular_front_coalition_prussia = parseFloat((Q.spd_r_prussia + Q.kpd_r_prussia + Q.z_r_prussia + Q.ddp_r_prussia + Q.sapd_r_prussia).toFixed(1));
} else if (Q.liberal_parliament == 1) {
    Q.popular_front_coalition_prussia = parseFloat((Q.spd_r_prussia + Q.kpd_r_prussia + Q.z_r_prussia + Q.sapd_r_prussia).toFixed(1));
}

if (Q.dnvp_ideology === "Умеренные") {
    Q.anti_democratic_coalition_prussia = parseFloat((Q.kpd_r_prussia + Q.nsdap_r_prussia + Q.dnf_r_prussia).toFixed(1));
} else {
    Q.anti_democratic_coalition_prussia = parseFloat((Q.kpd_r_prussia + Q.nsdap_r_prussia + Q.dnvp_r_prussia).toFixed(1));
}

if (Q.lvp_formed) {
    Q.neo_weimar_coalition_prussia = parseFloat((Q.spd_r_prussia + Q.lvp_r_prussia + Q.z_r_prussia + Q.other_r_prussia).toFixed(1));
} else {
    Q.neo_weimar_coalition_prussia = parseFloat((Q.spd_r_prussia + Q.ddp_r_prussia + Q.z_r_prussia + Q.dvp_r_prussia + Q.other_r_prussia).toFixed(1));
}

if (Q.kvp_formed && Q.lvp_formed) {
    Q.cordon_sanitaire_prussia = parseFloat((Q.spd_r_prussia + Q.lvp_r_prussia + Q.z_r_prussia + Q.other_r_prussia + Q.kvp_r_prussia).toFixed(1));
} else if (Q.kvp_formed && !Q.lvp_formed) {
    Q.cordon_sanitaire_prussia = parseFloat((Q.spd_r_prussia + Q.ddp_r_prussia + Q.z_r_prussia + Q.dvp_r_prussia + Q.other_r_prussia + Q.dnvp_r_prussia + Q.kvp_r_prussia).toFixed(1));
} else if (Q.lvp_formed && !Q.kvp_formed) {
    Q.cordon_sanitaire_prussia = parseFloat((Q.spd_r_prussia + Q.z_r_prussia + Q.lvp_r_prussia + Q.other_r_prussia + Q.dnvp_r_prussia).toFixed(1));
} else {
    Q.cordon_sanitaire_prussia = parseFloat((Q.spd_r_prussia + Q.z_r_prussia + Q.ddp_r_prussia + Q.dvp_r_prussia + Q.other_r_prussia + Q.dnvp_r).toFixed(1));
}

// Q.hitler_right_coalition_prussia = parseFloat((Q.z_r_prussia + Q.dnvp_r_prussia + Q.nsdap_r_prussia).toFixed(1));

if (Q.lvp_formed) {
    Q.progressive_coalition_prussia = parseFloat((Q.spd_r_prussia + Q.kpd_r_prussia + (Q.lvp_r_prussia / 2) + Q.sapd_r_prussia).toFixed(1));
} else {
    Q.progressive_coalition_prussia = parseFloat((Q.spd_r_prussia + Q.kpd_r_prussia + Q.ddp_r_prussia + Q.sapd_r_prussia).toFixed(1));
}

if (Q.dnef_formed) {
    Q.schleicher_right_coalition_prussia = parseFloat((Q.dnef_r_prussia + Q.lvp_r_prussia + Q.dvp_r_prussia + Q.ddp_r_prussia + Q.z_r_prussia + Q.other_r_prussia + Q.kvp_r_prussia + Q.dnvp_r_prussia + Q.dnf_r_prussia + Q.dsu_r_prussia).toFixed(1));
    Q.schleicher_left_coalition_prussia = parseFloat((Q.dnef_r_prussia + Q.spd_r_prussia + Q.lvp_r_prussia + Q.ddp_r_prussia + Q.z_r_prussia).toFixed(1));
}

if (Q.kpd_relation >= 30 && Q.sapd_formed == 1) {
    Q.weimar_coalition_prussia += Q.sapd_r_prussia;
}

if ((Q.nsdap_votes_prussia + Q.dnf_votes_prussia >= 30 && Q.dnvp_ideology == "Умеренные" || Q.nsdap_votes_prussia + Q.dnvp_votes_prussia >= 30 && Q.dnvp_ideology == "Радикалы") && Q.weimar_coalition_prussia < 45 && Q.president == "Гинденбург" && !Q.rubicon) {
    Q.hindenburg_angry_bruning += 45;
    Q.hindenburg_angry += 20;
    Q.hindenburg_angry_prussia = 1;
} else {
    Q.hindenburg_angry_prussia = 0;
}

if (Q.left_coalition_prussia >= 50) {
    Q.kpd_relation += 5;
    Q.left_strength += 5;
}

if (Q.year >= 1932) {
    Q.landtag_size = 4.23;
} else {
    Q.landtag_size = 4.5;
}

// not sure why seats decreased from 450 to 423 between 1928 and 1932, considering the turnout vastly increased

!}
on-display: {!
data = [{
    "id": "kpd",
    "legend": "КПГ",
    "name": "КПГ",
    "seats": Math.round(Q.kpd_r_prussia * Q.landtag_size),
}];

if (Q.sapd_formed && Q.sapd_r_prussia) {
    data.push({
        "id": "sapd",
        "legend": "SAPD",
        "name": "SAPD",
        "seats": Math.round(Q.sapd_r_prussia * Q.landtag_size),
    });
}

data = data.concat([{
    "id": "spd",
    "legend": "СДПГ",
    "name": "СДПГ",
    "seats": Math.round(Q.spd_r_prussia * Q.landtag_size),
}]);

if (Q.ddp_r_prussia && !Q.lvp_formed) {
    data.push({
        "id": "ddp",
        "legend": Q.ddp_name,
        "name": Q.ddp_name,
        "seats": Math.round(Q.ddp_r_prussia * Q.landtag_size),
    });
}

if (Q.lvp_r_prussia && Q.lvp_formed) {
    data.push({
        "id": "lvp",
        "legend": "ЛНП",
        "name": "ЛНП",
        "seats": Math.round(Q.lvp_r_prussia * Q.landtag_size),
    });
}

if (Q.z_r_prussia) {
    data.push({
        "id": "z",
        "legend": "Центр",
        "name": "Центр",
        "seats": Math.round(Q.z_r_prussia * Q.landtag_size),
    });
}

if (Q.dvp_r_prussia && !Q.lvp_formed && Q.dvp_exist) {
    data.push({
        "id": "dvp",
        "legend": "ННП",
        "name": "ННП",
        "seats": Math.round(Q.dvp_r_prussia * Q.landtag_size),
    });
}

if (Q.dnef_r_prussia && Q.dnef_formed) {
    data.push({
        "id": "dnef",
        "legend": "ФНЕГ",
        "name": "ФНЕГ",
        "seats": Math.round(Q.dnef_r_prussia * Q.landtag_size),
    });
}

if (Q.other_r_prussia) {
    data.push({
        "id": "other",
        "legend": "Other",
        "name": "Other",
        "seats": Math.round(Q.other_r_prussia * Q.landtag_size),
    });
}

if (Q.kvp_formed && Q.kvp_r_prussia && !Q.dnvp_dvp_formed) {
    data.push({
        "id": "kvp",
        "legend": "KVP",
        "name": "KVP",
        "seats": Math.round(Q.kvp_r_prussia * Q.landtag_size),
    });
}

if (Q.dnvp_dvp_formed) {
    data.push({
        "id": "fkp",
        "legend": "FKP",
        "name": "FKP",
        "seats": Math.round(Q.kvp_r_prussia * Q.landtag_size),
    });
}

if (Q.dnvp_r_prussia) {
    data.push({
        "id": "dnvp",
        "legend": "НННП",
        "name": "НННП",
        "seats": Math.round(Q.dnvp_r_prussia * Q.landtag_size),
    });
}
if (Q.dnf_formed && Q.dnf_r_prussia) {
    data.push({
        "id": "dnf",
        "legend": "DNF",
        "name": "DNF",
        "seats": Math.round(Q.dnf_r_prussia * Q.landtag_size),
    });
}
if (Q.dsu_exist && Q.dsu_r_prussia) {
    data.push({
        "id": "dsu",
        "legend": "НСС",
        "name": "НСС",
        "seats": Math.round(Q.dsu_r_prussia * Q.landtag_size),
    });
}

if (Q.nsdap_split && Q.nsdap_hitler_r_prussia) {
    data.push({
        "id": "nsdap",
        "legend": "НСДАП",
        "name": "НСДАП",
        "seats": Math.round(Q.nsdap_hitler_r_prussia * Q.landtag_size),
    });
}

if (!Q.nsdap_split && Q.nsdap_r_prussia) {
    data.push({
        "id": "nsdap",
        "legend": "НСДАП",
        "name": "НСДАП",
        "seats": Math.round(Q.nsdap_r_prussia * Q.landtag_size),
    });
}

if (Q.nvf_exist && Q.nvf_r_prussia) {
    data.push({
        "id": "nvf",
        "legend": "NVF",
        "name": "NVF",
        "seats": Math.round(Q.nvf_r_prussia * Q.landtag_size),
    });
}

if (window && d3) {
    var width = 500;
    var height = 500;
    var screenWidth = document.getElementById('content').offsetWidth;
    if (screenWidth < width - 50) {
        width = screenWidth - 50;
        height = width;
        document.getElementById("reichstag").style.height = screenWidth/2 + "px";
    }
    var parliament = d3.parliament();
    parliament.width(width).height(height).innerRadiusCoef(0.4);
    parliament.enter.fromCenter(true).smallToBig(true);
    parliament.exit.toCenter(false).bigToSmall(true);
    d3.select("#reichstag").datum(data).call(parliament);
}
!}
