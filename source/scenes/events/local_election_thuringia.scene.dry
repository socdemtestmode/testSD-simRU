{!<tr><td><div class="box" style='background-color:#3E88B3'> </div> !}НННП:{!</td><td>!} [+ dnvp_thuringia_elections_vote +]% {!</td><td>!} [+ dnvp_r_thuringia +]% {!</td></tr>!}

