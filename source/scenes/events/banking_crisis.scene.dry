title: Банковский кризис
subtitle: Крах немецкой банковской системы…
new-page: true
on-arrival: banking_crisis_seen = 1; workers_kpd += 2; unemployed_kpd += 5; workers_nsdap += 3 if chancellor != "Гитлер"; new_middle_nsdap += 5 if chancellor != "Гитлер"; old_middle_nsdap += 5 if chancellor != "Гитлер"; rural_nsdap += 3 if chancellor != "Гитлер"; unemployed += 3; crisis_urgency += 1; workers_spd -= 4 if spd_in_government; new_middle_spd -= 5 if spd_in_government; old_middle_spd -= 5 if spd_in_government; rural_spd -= 4 if spd_in_government; economic_growth -= 1.4; hindenburg_angry_bruning += 20; hindenburg_angry += 40; dnvp_angry += 1 if spd_toleration_right; banking_crisis_fallout_time = time + 6
tags: event
view-if: customs_union = 1 and banking_crisis_timer = 0
