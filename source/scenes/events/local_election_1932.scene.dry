[? if sapd_formed : <tr><td><div class="box" style='background-color:#9B0000'> </div> СРПГ:</td><td> [+ sapd_bavaria_elections_vote +]% </td><td> [+ sapd_r_bavaria +]% </td></tr> ?]

<tr><td><div class="box" style='background-color:#700000'> </div> КПГ:</td><td> [+ kpd_bavaria_elections_vote +]% </td><td> [+ kpd_r_bavaria +]% </td></tr>

[? if not lvp_formed: <tr><td><div class="box" style='background-color:#D3C24D'> </div>  [+ ddp_name +]: </td><td> [+ ddp_bavaria_elections_vote +]% </td><td> [+ ddp_r_bavaria +]% </td></tr> ?]

[? if lvp_formed: <tr><td><div class="box" style='background-color:#FFCC00'> </div> ЛНП:</td><td> [+ lvp_bavaria_elections_vote +]% </td><td> [+ lvp_r_bavaria +]% </td></tr> ?]

<tr><td><div class="box" style='background-color:#A2D8E0'> </div> БНП:</td><td> [+ z_bavaria_elections_vote +]% </td><td> [+ z_r_bavaria +]% </td></tr>

[? if not lvp_formed and dvp_exist: <tr><td><div class="box" style='background-color:#D5AC27'> </div> ННП:</td><td> [+ dvp_bavaria_elections_vote +]% </td><td> [+ dvp_r_bavaria +]% </td></tr> ?]

<tr><td><div class="box" style='background-color:#38C538'> </div> Баварский Крестьянский Союз:</td><td> [+ farm_bavaria_elections_vote +]% </td><td> [+ farm_r_bavaria +]% </td></tr>

<tr><td><div class="box" style='background-color:#a0a0a0'> </div> Прочие партии:</td><td> [+ non_farm_bavaria_elections_vote +]% </td><td> [+ non_farm_r_bavaria +]% </td></tr>

[? if kvp_formed : <tr><td><div class="box" style='background-color:#0087DC'> </div> КНП:</td><td> [+ kvp_bavaria_elections_vote +]% </td><td> [+ kvp_r_bavaria +]% </td></tr> ?]

[? if not cvp_formed: <tr><td><div class="box" style='background-color:#3E88B3'> </div> НННП:</td><td> [+ dnvp_bavaria_elections_vote +]% </td><td> [+ dnvp_r_bavaria +]% </td></tr> ?]

[? if dnf_formed : <tr><td><div class="box" style='background-color:#003755'> </div> НФГ:</td><td> [+ dnf_bavaria_elections_vote +]% </td><td> [+ dnf_r_bavaria +]% </td></tr> ?]

<tr><td><div class="box" style='background-color:#7A3C00'> </div> НСДАП:</td><td> [+ nsdap_bavaria_elections_vote +]% </td><td> [+ nsdap_r_bavaria +]% </td></tr> </table> <hr id="read-marker"> <span style="color: #38C538;">Баварский крестьянский союз</span> служит ядром федеральной <span style="color: #007A00;">Немецкой крестьянской партии</span>, и он на удивление либеральный и <span style="color: #000000;">рес</span><span style="color: #DD0000;">пуб</span><span style="color: #FFCC00;">ликанский</span> по сравнению с другими аграрными партиями и организациями, такими как <span style="color: #7FCEB1;">**ХНПКЗ**</span>. Недавно они даже вышли из кабинета <span style="color: #A2D8E0;">**БНП**</span> из-за спора о налогах.[? if cvp_formed: <br><br> С формированием <span style="color: #000000;">**[+ z_party_name +]**</span>, баварское отделение <span style="color: #3E88B3;">**НННП**</span> в значительной степени слилось с <span style="color: #A2D8E0;">**БНП**</span>, хотя некоторые элементы вместо этого предпочли объединиться с <span style="color: #003755;">**НФГ**</span>. ?] <hr id="read-marker"> Объединенная Левая Коалиция (<span style="color: #c00000;">**СДПГ**</span> + <span style="color: #700000;">**КПГ**</span>[? if sapd_formed: + <span style="color: #9B0000;">**СРПГ**</span> ?]): [+ left_coalition_bavaria +]%

Коалиция «Светофор» (<span style="color: #c00000;">**СДПГ**</span> + [? if not lvp_formed: <span style="color: #D3C24D;">**[+ ddp_name +]**</span> ?][? if lvp_formed: <span style="color: #FFCC00;">**ЛНП**</span> ?] + <span style="color: #38C538;">Баварский Крестьянский Союз</span>): [+ spd_coalition_bavaria +]%

[? if not kvp_formed: Буржуазная коалиция (<span style="color: #A2D8E0;">**БНП**</span> + [? if not lvp_formed: <span style="color: #D3C24D;">**[+ ddp_name +]**</span>[? if dvp_exist: &nbsp;+ <span style="color: #C0A054;">**ННП**</span> ?] ?][? if lvp_formed: <span style="color: #FFCC00;">**ЛНП**</span> ?] + **Прочие**[? if not cvp_formed: &nbsp;+ <span style="color: #3E88B3;">**НННП**</span> ?]): [+ bourgeois_coalition_bavaria +]% ?]

[? if kvp_formed: Буржуазная коалиция (<span style="color: #A2D8E0;">**БНП**</span> + [? if not lvp_formed: <span style="color: #D3C24D;">**[+ ddp_name +]**</span>[? if dvp_exist: &nbsp;+ <span style="color: #C0A054;">**ННП**</span> ?] ?][? if lvp_formed: <span style="color: #FFCC00;">**ЛНП**</span> ?] + **Прочие** + <span style="color: #0087DC;">**КНП**</span>): [+ bourgeois_coalition_bavaria +]% ?]


@bavaria_coalition_menu

- @bvp_toleration
- @bvp_majority
