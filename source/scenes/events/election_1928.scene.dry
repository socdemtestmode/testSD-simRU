@finalize_cvp_demands
title: Мы достигли соглашения с <span style="color: #000000;">**[+ z_party_name +]**</span>.
subtitle: Это неустойчивая договорённость, но она создаст исторический прецедент.
choose-if: cvp_negotiations_points >= cvp_negotiations_min
unavailable-subtitle: <span style="color: #000000;">[+ z_party_name +]</span> не устраивают наши текущие обещания.
on-arrival: {!
if (Q.cvp_reichsbanner_accepted) {
    Q.rb_militancy = 0.02;
    if (Q.rb_strength > 2000) Q.rb_strength = 2000;
    Q.prussian_police_strength += 40;
}
if (Q.cvp_economy_accepted && Q.budget < 0) {
    Q.austerity_budget = Q.budget*-1;
    Q.budget = 0;
    Q.workers_spd -= Q.austerity_budget*3;
    Q.new_middle_spd -= Q.austerity_budget*2;
    Q.old_middle_spd -= Q.austerity_budget;
    Q.unemployed_spd -= Q.austerity_budget*3;
    Q.catholics_spd -= Q.austerity_budget;
    if (Q.welfare >= 1) Q.welfare -= 2;
    Q.workers_kpd += Q.austerity_budget*2;
    Q.workers_nsdap += Q.austerity_budget;
    Q.unemployed_kpd += Q.austerity_budget*2;
    Q.unemployed_nsdap += Q.austerity_budget*2;
    Q.left_dissent += 10*Q.austerity_budget;
    Q.center_dissent += 7*Q.austerity_budget;
    Q.labor_dissent += 10*Q.austerity_budget;
    Q.reformist_dissent += 5*Q.austerity_budget;
    Q.unemployed += Q.austerity_budget;
    Q.kpd_coalition_dissent += 1;
    Q.kpd_relation -= 10;
}
!}
go-to: social_catholic_coalition_cvp_2 if not left_split; social_catholic_coalition_cvp_3 if left_split
achievement: historischer_kompromiss


@social_catholic_coalition_cvp_2
go-to: social_catholic_coalition_cvp_3
achievement: frahm_und_brandt


@social_catholic_coalition_cvp_3
