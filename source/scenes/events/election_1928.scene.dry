+]%[? if n_elections != 1 and demo_change_rural_nsdap_display != 0 : ([+ demo_change_rural_nsdap_display +]) ?]{!</td>!}             {!<td style="background-color: rgba(20, 46, 32, 0.2); font-size: 0.85em;">!}[+ unemployed_nsdap_display +]%[? if n_elections != 1 and demo_change_unemployed_nsdap_display != 0 : ([+ demo_change_unemployed_nsdap_display +]) ?]{!</td>!}             {!<td style="background-color: rgba(122, 60, 0, 0.2); font-size: 0.85em;">!}[+ catholics_nsdap_display +]%[? if n_elections != 1 and demo_change_catholics_nsdap_display != 0 : ([+ demo_change_catholics_nsdap_display +]) ?]{!</td>!}         {!</tr>!}  ?]         {!<tr>!}             {!<td>!}<b>Прочие</b>{!</td>!}             {!<td style="background-color: rgba(144, 144, 144, 0.2); font-size: 0.85em; padding: 10px">!}[+ workers_other_display +]%[? if n_elections != 1 and demo_change_workers_other_display != 0 : ([+ demo_change_workers_other_display +]) ?]{!</td>!}             {!<td style="background-color: rgba(144, 144, 144, 0.2); font-size: 0.85em;">!}[+ new_middle_other_display +]%[? if n_elections != 1 and demo_change_new_middle_other_display != 0 : ([+ demo_change_new_middle_other_display +]) ?]{!</td>!}             {!<td style="background-color: rgba(144, 144, 144, 0.2); font-size: 0.85em;">!}[+ old_middle_other_display +]%[? if n_elections != 1 and demo_change_old_middle_other_display != 0 : ([+ demo_change_old_middle_other_display +]) ?]{!</td>!}             {!<td style="background-color: rgba(144, 144, 144, 0.2); font-size: 0.85em;">!}[+ rural_other_display +]%[? if n_elections != 1 and demo_change_rural_other_display != 0 : ([+ demo_change_rural_other_display +]) ?]{!</td>!}             {!<td style="background-color: rgba(144, 144, 144, 0.2); font-size: 0.85em;">!}[+ unemployed_other_display +]%[? if n_elections != 1 and demo_change_unemployed_other_display != 0 : ([+ demo_change_unemployed_other_display +]) ?]{!</td>!}             {!<td style="background-color: rgba(144, 144, 144, 0.2); font-size: 0.85em;">!}[+ catholics_other_display +]%[? if n_elections != 1 and demo_change_catholics_other_display != 0 : ([+ demo_change_catholics_other_display +]) ?]{!</td>!}         {!</tr>!}     {!</table>!}     {!</div>!} {!</div>!} {!<svg id="election_history" style="width: 500px; height: 400px; display: none;"> </svg>!} {!<svg id="party_support_history" style="width: 500px; height: 400px; display: none;"> </svg>!}

**Возможные коалиции: **

[? if kpd_relation >= 40 and left_coalition >= 45: Коалиция объединённых левых (<span style="color: #c00000;">**СДПГ**</span> + <span style="color: #700000;">**КПГ**</span>[? if sapd_formed: + <span style="color: #9B0000;">**СРПГ**</span> ?]): [+ left_coalition +]% ?]

[? if kpd_relation > 35 and z_relation > 35 and not cvp_formed: Коалиция народного фронта (<span style="color: #c00000;">**СДПГ**</span> + <span style="color: #700000;">**КПГ**</span> + <span style="color: #000000;">**[+ z_party_name +]**</span>[? if (liberal_parliament == 0 and bourgeois_parliament_ddp == 0) and not lvp_formed: &nbsp;+ <span style="color: #D3C24D;">**[+ ddp_name +]**</span> ?][? if sapd_formed: &nbsp;+ <span style="color: #9B0000;">**СРПГ**</span> ?]): [+ popular_front_coalition +]% ?]

[? if not cvp_formed: <span style="color: #000000;">Ве</span><span style="color: #DD0000;">йм</span><span style="color: #FFCC00;">ар</span>ская коалиция (<span style="color: #c00000;">**СДПГ**</span> + <span style="color: #000000;">**[+ z_party_name +]**</span> +[? if not lvp_formed: <span style="color: #D3C24D;">**[+ ddp_name +]**</span> ?][? if lvp_formed: <span style="color: #FFCC00;">**ЛНП**</span> ?][? if sapd_formed and kpd_relation >= 30: &nbsp;+ <span style="color: #9B0000;">**СРПГ**</span> ?]): [+ weimar_coalition +]% ?]

[? if cvp_formed: <span style="color: #c00000;">Социал</span>-[? if not lvp_formed: <span style="color: #D3C24D;">либеральная</span> ?][? if lvp_formed: <span style="color: #FFCC00;">Либеральная</span> ?] Коалиция (<span style="color: #c00000;">**СДПГ**</span> +[? if not lvp_formed: <span style="color: #D3C24D;">**[+ ddp_name +]**</span> ?][? if lvp_formed: <span style="color: #FFCC00;">**ЛНП**</span> ?]): [+ social_liberal_coalition +]% ?]

[? if cvp_formed: <span style="color: #c00000;">Социал</span>-<span style="color: #000000;">христианская</span> коалиция (<span style="color: #c00000;">**СДПГ**</span> + <span style="color: #000000;">**[+ z_party_name +]**</span>): [+ social_catholic_coalition +]% ?]

[? if dvp_exist and not cvp_formed: Большая коалиция (<span style="color: #c00000;">**СДПГ**</span> + <span style="color: #000000;">**[+ z_party_name +]**</span> + <span style="color: #A2D8E0;">**БНП**</span> +[? if not lvp_formed: <span style="color: #D3C24D;">**[+ ddp_name +]**</span> + <span style="color: #C0A054;">**ННП**</span> ?][? if lvp_formed: <span style="color: #FFCC00;">**ЛНП**</span> ?]): [+ grand_coalition +]% ?]

[? if bourgeois_coalition >= 25 and not kvp_formed: Буржуазная коалиция (<span style="color: #000000;">**[+ z_party_name +]**</span> + <span style="color: #A2D8E0;">**БНП**</span> +[? if not lvp_formed: <span style="color: #D3C24D;">**[+ ddp_name +]**</span>[? if dvp_exist: &nbsp;+ <span style="color: #C0A054;">**ННП**</span> ?] ?][? if lvp_formed: <span style="color: #FFCC00;">**ЛНП**</span> ?]+**Прочие**): [+ bourgeois_coalition +]% ?]

[? if bourgeois_coalition >= 25 and kvp_formed: Буржуазная коалиция (<span style="color: #000000;">**[+ z_party_name +]**</span> + <span style="color: #A2D8E0;">**БНП**</span> +[? if not lvp_formed: <span style="color: #D3C24D;">**[+ ddp_name +]**</span>[? if dvp_exist: &nbsp;+ <span style="color: #C0A054;">**ННП**</span> ?] ?][? if lvp_formed: <span style="color: #FFCC00;">**ЛНП**</span> ?]+**Прочие** + <span style="color: #0087DC;">**КНП**</span>): [+ bourgeois_coalition +]% ?]

[? if dnvp_ideology == "Умеренные" and not lvp_formed and not cvp_formed: Правоцентристская коалиция (<span style="color: #000000;">**[+ z_party_name +]**</span> + <span style="color: #A2D8E0;">**БНП**</span> + <span style="color: #D3C24D;">**[+ ddp_name +]**</span>[? if dvp_exist: &nbsp;+ <span style="color: #C0A054;">**ННП**</span> ?]+**Прочие**[? if not cvp_formed: &nbsp;+ <span style="color: #3E88B3;">**НННП**</span> ?]): [+ center_right_coalition +]% ?]

[? if dnvp_ideology == "Радикалы" or lvp_formed and not cvp_formed: Правая коалиция (<span style="color: #000000;">**[+ z_party_name +]**</span> + <span style="color: #A2D8E0;">**БНП**</span> +[? if not lvp_formed and dvp_exist: <span style="color: #C0A054;">**ННП**</span> ?][? if lvp_formed: <span style="color: #FFCC00;">**ЛНП**</span> ?]+**Прочие**[? if not cvp_formed: &nbsp;+ <span style="color: #3E88B3;">**НННП**</span> ?]): [+ right_coalition +]% ?]

[? if (cvp_formed and far_right_coalition >= 25) or (hitler_right_coalition >= 50 and rubicon): Чёрно-коричневая коалиция (<span style="color: #000000;">**[+ z_party_name +]**</span> + <span style="color: #A2D8E0;">**БНП**</span> + <span style="color: #7A3C00;">**НСДАП**</span>): [+ hitler_right_coalition +]% ?]

[? if dnef_formed: Правая коалиция Шлейхера (<span style="color: #BFC8CC;">**ФНЕГ**</span>[? if not z_dnef: &nbsp;+ <span style="color: #000000;">**[+ z_party_name +]**</span> + <span style="color: #A2D8E0;">**БНП**</span> ?][? if not lvp_formed and not dstp_dnef: &nbsp;+ <span style="color: #D3C24D;">**[+ ddp_name +]**</span> ?][? if not lvp_formed and dvp_exist and not dvp_dnef: &nbsp;+ <span style="color: #C0A054;">**ННП**</span> ?][? if lvp_formed and not lvp_dnef: &nbsp;+ <span style="color: #FFCC00;">**ЛНП**</span> ?][? if not other_dnef: &nbsp;+**Прочие** ?][? if kvp_formed and not kvp_dnef: &nbsp;+ <span style="color: #0087DC;">**КНП**</span> ?][? if dnvp_ideology == "Умеренные" and not dnvp_dnef: &nbsp;+ <span style="color: #3E88B3;">**НННП**</span> ?][? if dsu_exist: &nbsp;+ <span style="color: #6A1E1E;">**НСС**</span> ?]): [+ schleicher_right_coalition +]% ?]

[? if dnef_formed: Левая коалиция Шлейхера (<span style="color: #BFC8CC;">**ФНЕГ**</span> + <span style="color: #c00000;">**СДПГ**</span>[? if not z_dnef: &nbsp;+ <span style="color: #000000;">**[+ z_party_name +]**</span> + <span style="color: #A2D8E0;">**БНП**</span> ?][? if not lvp_formed and not dstp_dnef: &nbsp;+ <span style="color: #D3C24D;">**[+ ddp_name +]**</span> ?][? if lvp_formed and not lvp_dnef: &nbsp;+ <span style="color: #FFCC00;">**ЛНП**</span> ?]): [+ schleicher_left_coalition +]% ?]

[? if dnvp_ideology == "Радикалы" and far_right_coalition >= 35 and not cvp_formed: <span style="color: #7A3C00;">Ультра</span>-<span style="color: #3E88B3;">правая</span> коалиция ([? if (dvp_leader == "Дингельдей" and dvp_ideology == "Правые" and dvp_right - dvp_left >= 15) or hugenberg_dvp: <span style="color: #C0A054;">**ННП**</span> + ?]<span style="color: #3E88B3;">**НННП**</span> + <span style="color: #7A3C00;">**НСДАП**</span>): [+ far_right_coalition +]% ?]

[? if dnvp_ideology == "Умеренные" and far_right_coalition >= 30: <span style="color: #7A3C00;">Ультра</span><span style="color: #3E88B3;">правая</span> коалиция ([? if (dvp_leader == "Дингельдей" and dvp_ideology == "Правые" and dvp_right - dvp_left >= 15) or hugenberg_dvp: <span style="color: #C0A054;">**ННП**</span> + ?]<span style="color: #003755;">**НФГ**</span> + <span style="color: #7A3C00;">**НСДАП**</span>): [+ far_right_coalition +]% ?]

[? if nazi_urgency <= 1 and nsdap_r >= 15 : Стремительный рост числа голосов за <span style="color: #7A3C00;">**НСДАП**</span> вызывает крайнее беспокойство. Многие считали партию <span style="color: #ff0000;">умирающей</span>, но теперь некоторые из нас видят в ней величайшую угрозу для демократии в Германии.  ?]

[? if anti_democratic_coalition >= 50 and dnvp_ideology == "Радикалы": Вместе антидемократические <span style="color: #700000;">**КПГ**</span>, <span style="color: #3E88B3;">**НННП**</span> и <span style="color: #7A3C00;">**НСДАП**</span> составляют большинство в рейхстаге. Сформировать стабильное правящее большинство будет практически невозможно. ?]

[? if anti_democratic_coalition >= 50 and dnvp_ideology == "Умеренные": Вместе антидемократические <span style="color: #700000;">**КПГ**</span>, <span style="color: #003755;">**НФГ**</span> и <span style="color: #7A3C00;">**НСДАП**</span> составляют большинство в рейхстаге. Сформировать стабильное правящее большинство будет практически невозможно. ?]

[? if hitler_right_coalition >= 50 and rubicon and hitler_right_coalition_time == time: <span style="color: #000000;">Партия Центра</span> и её <span style="color: #A2D8E0;">баварский</span> аналог вместе с <span style="color: #7A3C00;">**НСДАП**</span>, составляют большинство в рейхстаге. Это породило слухи о возможной парламентской чёрно-коричневой коалиции, которая могла бы сместить [+ chancellor +]— слухи, которым вряд ли суждено сбыться, поскольку идеологическая пропасть между <span style="color: #7A3C00;">нацистами</span> и конституционалистской <span style="color: #000000;">Партией Центра</span> остаётся огромной.  ?]

[? if change_nsdap_votes < -2 and rubicon and nsdap_decline_time == time: Популярность <span style="color: #7A3C00;">нацистов</span> наконец пошла на спад. Многие из тех, кто поддерживал движение в знак протеста, на самом деле не хотели видеть их у власти, а другие просто остались дома. Разочаровавшиеся консерваторы и верующие избиратели вернулись к консервативным и центристским партиям. Возможно, <span style="color: #7A3C00;">нацисты</span> достигли пика: они не могут привлечь новых избирателей, не оттолкнув при этом нынешний электорат.  ?]

[? if spd_votes < 20 and schleicher_spd_r >= 3: Наши низкие результаты на выборах заставили Шлейхера усомниться в целесообразности сотрудничества с партией на грани краха, которая не может набрать и пятой части голосов. Многие в нашей собственной партии теперь считают наши связи с <span style="color: #808080;">реакционным</span> генералом одной из главных причин наших неутешительных результатов.  ?][? if spd_votes < 25 and spd_votes > 20 and schleicher_spd_r >= 5: Наши низкие результаты на выборах заставили Шлейхера усомниться в целесообразности сотрудничества с партией на грани краха, которая не может набрать и четверти голосов. Многие в нашей собственной партии теперь считают наши связи с <span style="color: #808080;">реакционным</span> генералом одной из главных причин наших неутешительных результатов.  ?]

[? if spd_votes >= 35 and left_strength >= reformist_strength + labor_strength: К сожалению, наш успех на выборах побудил бывших буржуазных партнёров по коалиции дистанцироваться от нас. Они винят в своих поражениях союз с нами и отказываются тратить тающее влияние на поддержку правительства, которое сможет повести Германию к <span style="color: #c00000;">социализму</span>.  ?]

[? if left_coalition >= 50: <span style="color: #9B0000;">Марксистские</span> партии теперь составляют большинство в рейхстаге — это воодушевило рядовых членов наших партий к требованию более тесного сотрудничества.  ?]

[? if election_boycott: Мы бойкотировали эти выборы, делегитимизировав их результаты в глазах как рабочих, так и <span style="color: #000000;">респу</span><span style="color: #DD0000;">бли</span><span style="color: #FFCC00;">канцев</span>. Эффект измеряется тем, сколько людей осталось дома, вместо того чтобы голосовать за <span style="color: #BFC8CC;">**ФНЕГ**</span>.[? if boycott_effect < 1.05: В итоге мы добились лишь ограниченного успеха: наш бойкот оказался сравнительно неэффективным. Столько усилий впустую. ?][? if boycott_effect >= 1.05 and boycott_effect < 1.1: В итоге мы добились заметного успеха. ?][? if boycott_effect >= 1.1: В итоге мы добились ошеломительного успеха. ?]  ?]

Есть несколько возможных вариантов коалиции.


