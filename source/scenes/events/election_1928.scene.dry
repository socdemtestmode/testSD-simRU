    Q.foreign_minister_party = "ННП";
} else if (Q.foreign_minister_party !== "СДПГ" && Q.lvp_formed) {
    Q.foreign_minister_party = "ЛНП";
}
if (Q.foreign_minister !== "Брайтшайд") Q.foreign_minister = "Stresemann";
if (Q.foreign_minister !== "Брайтшайд" && Q.stresemann_dead === 1) Q.foreign_minister = "Курциус";
if (Q.foreign_minister_party !== "СДПГ" && (Q.in_weimar_coalition && Q.lvp_formed)) Q.foreign_minister_party = "ЛНП";
if (Q.foreign_minister_party !== "СДПГ" && (Q.in_weimar_coalition && !Q.lvp_formed || Q.in_popular_front || Q.in_social_catholic_coalition)) Q.foreign_minister_party = "Центр";
if (Q.foreign_minister !== "Брайтшайд" && (Q.in_weimar_coalition && !Q.lvp_formed || Q.in_popular_front || Q.in_social_catholic_coalition)) Q.foreign_minister = "Вирт";

if (Q.foreign_minister_party !== "СДПГ" && Q.in_social_liberal_coalition) Q.foreign_minister_party = Q.ddp_name;
if (Q.foreign_minister_party !== "СДПГ" && Q.in_social_liberal_coalition && Q.lvp_formed) Q.foreign_minister_party = "ЛНП";
if (Q.foreign_minister !== "Брайтшайд" && Q.in_social_liberal_coalition) Q.foreign_minister = "Притвиц";

if (Q.agriculture_minister_party !== "СДПГ" && !Q.lvp_formed) {
    Q.agriculture_minister_party = Q.ddp_name;
} else if (Q.agriculture_minister_party !== "СДПГ" && Q.lvp_formed) {
    Q.agriculture_minister_party = "ЛНП";
}
if (Q.agriculture_minister !== "Бааде") Q.agriculture_minister = "Дитрих";

if (Q.agriculture_minister_party !== "СДПГ" && (Q.in_weimar_coalition && !Q.lvp_formed || Q.in_popular_front || Q.in_social_catholic_coalition)) Q.agriculture_minister_party = "Центр";
if (Q.agriculture_minister !== "Бааде" && (Q.in_weimar_coalition && !Q.lvp_formed || Q.in_popular_front || Q.in_social_catholic_coalition)) Q.agriculture_minister = "Гермес";

if (Q.agriculture_minister_party !== "СДПГ" && Q.in_social_liberal_coalition) Q.agriculture_minister_party = Q.ddp_name;
if (Q.agriculture_minister_party !== "СДПГ" && Q.in_social_liberal_coalition && Q.lvp_formed) Q.agriculture_minister_party = "ЛНП";
if (Q.agriculture_minister !== "Бааде" && Q.in_social_liberal_coalition) Q.agriculture_minister = "Дитрих";

if (Q.reichswehr_minister_party !== "СДПГ") Q.reichswehr_minister_party = "I";
if (Q.reichswehr_minister !== "Лебер") Q.reichswehr_minister = "Грёнер";

if (!Q.dvp_exist) {
    if (Q.foreign_minister_party == "ННП") { 
        Q.foreign_minister_party = "Центр";
        Q.foreign_minister = "Брюнинг";
    }
    if (Q.economic_minister_party == "ННП") Q.economic_minister_party = "НННП";
    if (Q.finance_minister_party == "ННП") Q.finance_minister_party = "НННП";
}

const ministries = [
    "foreign_minister_party",
    "interior_minister_party",
    "justice_minister_party",
    "labor_minister_party",
    "reichswehr_minister_party",
    "economic_minister_party",
    "finance_minister_party",
    "agriculture_minister_party"
];

ministries.forEach(ministry => {
    let partyKey = `${ministry}`;
    if (Q[partyKey] == "Центр" || Q[partyKey] == "НННП") {
        Q[partyKey] = "Центр";
    }
});

if (Q.in_wholesome_coalition) {
    ministries.forEach(ministry => {
    let partyKey = `${ministry}`;
    if (Q[partyKey] != "СДПГ") {
        Q[partyKey] = "НННП";
    }
});
}
if (Q.hindenburg_angry_old > 0) Q.hindenburg_angry = Q.hindenburg_angry_old;
!}
subtitle: [? if leverage >= 10 : У нас ещё есть рычаги для получения министерств. ?][? if leverage < 10 : У нас почти не осталось рычагов влияния. ?]
tags: mins_1928

