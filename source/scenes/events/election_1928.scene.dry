        var total_reichstag_without_party = total_reichstag_without - (100 - Q['original_' + party + '_r']);
        var total_other_party_sum_party = total_other_party_sum - (Q['reichstag_without_' + party] - (Q[party + '_votes'] - Q[party + '_r']));

