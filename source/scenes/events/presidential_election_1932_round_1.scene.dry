@convince_z_eckener
view-if: eckener_campaign and not z_support_spd
choose-if: spd_votes >= z_votes and not cvp_formed
unavailable-subtitle: [? if spd_votes < z_votes: The [? if z_party_name != "ХНП": <span style="color: #000000;">Партия Центра</span> ?][? if z_party_name == "ХНП": <span style="color: #000000;">**ХНП**</span> ?] знает, что они популярнее нас, и не видит причин поддерживать нашего кандидата.  ?][? if cvp_formed: <span style="color: #000000;">ХНП</span> никогда не удастся переубедить. ?]
on-arrival: {!
Q.z_support_spd = 0;
if (Q.z_relation >= 45 || (Q.z_relation > 35 && Q.z_ideology == "Левые")) {
    Q.z_support_spd = 1;
} else if (Q.z_relation >= 30) {
    Q.z_support_spd = 2;
} else {
    Q.z_support_spd = 0;
}
if (Q.z_relation >= 65) Q.bvp_support_spd = 1;
!}
