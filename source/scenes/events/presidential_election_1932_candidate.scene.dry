title: Кандидаты на президентских выборах
subtitle: Выдвигать ли нам собственного кандидата?
new-page: true
on-arrival: {!
Q.presidential_election_campaigning_seen = 1;
if (!Q.hitler_deported && Q.hitler_citizen) {
    Q.nsdap_candidate_1932 = "Гитлер";
    Q.nsdap_candidate_1932_disp = "Adolf Hitler";
} else {
    Q.nsdap_candidate_1932 = "Геринг";
    Q.nsdap_candidate_1932_disp = "Hermann Göring";
}
Q.spd_candidate_1932 = "Браун";
if (Q.hindenburg_run) {
    Q.reactionary_candidate_1932 = "Гинденбург";
    // angry that he is running in the first place
    Q.hindenburg_angry_bruning += 20;
}
Q.communist_candidate_1932 = "Тельман";

Q.spd_candidate_1932_disp = "Otto Braun";
if (Q.hindenburg_run) Q.reactionary_candidate_1932_disp = "Paul von Hindenburg";
Q.communist_candidate_1932_disp = "Ernst Thälmann";

if (Q.nsdap_candidate_1932) {
    Q.dnvp_candidate_1932 = "Дюстерберг";
    Q.dnvp_candidate_1932_disp = "Theodor Duesterberg";
}
!}
tags: event
view-if: year = 1932 and month >= 2 and not hindenburg_term_extended
on-display: {!  
    var cardEl = document.createElement('div');  
    cardEl.className = "face-figure2";  

    var image = new Image();  
    image.className = "face-img";  
    image.src = "img/campaign.jpg";  

    cardEl.appendChild(image);  
    var contentDiv = document.querySelector("#page #mid_panel #content");
    contentDiv.appendChild(cardEl);
!}
priority: 1
max-visits: 1
go-to: candidate_selection


= Кандидаты на президентских выборах

В следующем месяце пройдут президентские выборы в Германии 1932 года: нам нужно решить, выдвигать ли собственного кандидата или поддержать кандидата от другой партии. [? if hindenburg_run: Многие призывают нас поддержать действующего президента Гинденбурга, несмотря на его <span style="color: #808080;">реакционные</span> наклонности. Вопреки опасениям, он пока не использовал свой пост для уничтожения республики, так что его поддержка, будем надеяться, не даст победить <span style="color: #7A3C00;">нацистам</span>, которые как раз и выступают за уничтожение республики.  ?][? if not hindenburg_run: После отказа Гинденбурга от участия в выборах немецкие правые находятся в растерянности и пытаются найти кандидата, который смог бы заручиться поддержкой умеренно правых и центристов, а также, подобно Гинденбургу, стать объединяющей фигурой. Вероятно, выдвинутый ими кандидат будет выходцем из военных или промышленных кругов и будет дистанцироваться от партийных политических распрей.  ?]

С другой стороны, многие в нашей партии призывают [+ spd_candidate_1932_disp +]а вновь выдвинуть свою кандидатуру, но он не горит желанием. [? if kpd_relation >= 50 : Ещё одна странная возможность — это единый фронт с <span style="color: #700000;">коммунистами</span>, чтобы поддержать либо их кандидата, либо убедить их поддержать нашего.  ?][? if sapd_formed: <span style="color: #9B0000;">**СРПГ**</span>, наши бывшие левые, вероятно, поддержит того же кандидата, что и <span style="color: #700000;">коммунисты</span>.  ?]

Так или иначе, давайте посмотрим, кто станет кандидатами на <span class="tooltip-text" title="отличная игра">предвыборной гонке</span>.


@candidate_selection


- @view_candidates_1: Посмотреть кандидатов.


@view_candidates_1


- @reactionary: Кто станет преемником Гинденбурга?
- @hindenburg: Гинденбург, конечно же, снова баллотируется.


@reactionary
on-arrival: {!
Q.bourgeois_votes = Q.ddp_votes + Q.dvp_votes + Q.lvp_votes + Q.other_votes + Q.kvp_votes + Q.dnvp_votes + Q.z_votes;

if ((Q.lvp_ideology == "Правые" && Q.lvp_leader == "Дингельдей" && Q.lvp_formed || Q.dvp_votes >= 6 && Q.bourgeois_parliament && Q.bourgeois_votes >= 40 && !Q.lvp_formed) && Q.liberal_vote >= 8) Q.jarres_unlock_pres = 1;
if ((Q.dvp_leader == "Лютер" || Q.lvp_leader == "Лютер") && Q.pro_republic >= 50 && Q.liberal_vote >= 8 && Q.bourgeois_votes >= 35) Q.luther_unlock_pres = 1;
if (((Q.dstp_formed || Q.ddp_relation < 40 || Q.pro_republic < 40) && Q.ddp_ideology != "Левые" && !Q.lvp_formed || Q.lvp_formed && Q.lvp_ideology != "Левые" && Q.pro_republic < 50) && Q.liberal_vote >= 8 && Q.bourgeois_votes >= 35) Q.gessler_unlock_pres = 1;
if (Q.stegerwald_path) Q.adenauer_unlock_pres = 1;
if (!Q.stegerwald_path && Q.z_relation >= 30 && Q.chancellor != "Брюнинг" && Q.bourgeois_votes >= 40) Q.bruning_unlock_pres = 1;
if (!Q.stegerwald_path && !Q.bruning_unlock_pres && !Q.adenauer_unlock_pres) Q.stegerwald_unlock_pres = 1;
if (Q.dnvp_ideology == "Умеренные" && Q.bourgeois_votes < 35 || Q.kvp_formed && Q.bourgeois_votes < 35 || Q.cvp_formed && Q.cvp_ideology == "Правые") Q.vorbeck_unlock_pres = 1;
if (Q.dnvp_ideology == "Умеренные" && Q.bourgeois_votes >= 35) Q.westarp_unlock_pres = 1;

if (!Q.jarres_unlock_pres && !Q.gessler_unlock_pres && !Q.adenauer_unlock_pres && !Q.bruning_unlock_pres && !Q.stegerwald_unlock_pres && !Q.vorbeck_unlock_pres && !Q.westarp_unlock_pres) {
    Q.vorbeck_unlock_pres = 1;
    Q.vorbeck_fallback = 1;
}

if (Q.westarp_unlock_pres && Q.vorbeck_unlock_pres) {
    Q.westarp_unlock_pres = 0;
}

if (Q.vorbeck_unlock_pres && Q.cvp_formed) {
    Q.westarp_unlock_pres = 0;
    Q.jarres_unlock_pres = 0;
    Q.adenauer_unlock_pres = 0;
    Q.bruning_unlock_pres = 0;
    Q.stegerwald_unlock_pres = 0;
}

let count = 0;
if (Q.jarres_unlock_pres) count++;
if (Q.luther_unlock_pres) count++;
if (Q.gessler_unlock_pres) count++;

if (count >= 2 && Q.jarres_unlock_pres) {
    Q.jarres_unlock_pres = 0;
    count--;
}
if (count >= 2 && !Q.jarres_unlock_pres) {
    Q.luther_unlock_pres = 0;
    count--
}


let count2 = 0;
if (Q.jarres_unlock_pres) count2++;
if (Q.luther_unlock_pres) count2++;
if (Q.gessler_unlock_pres) count2++;
if (Q.adenauer_unlock_pres) count2++;
if (Q.bruning_unlock_pres) count2++;
if (Q.stegerwald_unlock_pres) count2++;
if (Q.vorbeck_unlock_pres) count2++;
if (Q.westarp_unlock_pres) count2++;

Q.reactionary_candidate_1932_count = count2;

Q.reactionary_candidate_1932_ideology = 0;
Q.secondary_reactionary_candidate_1932_ideology = 0;

if (Q.reactionary_candidate_1932_count > 0) {
    if (Q.jarres_unlock_pres) {
        Q.jarres_run = 1; 
        if (Q.reactionary_candidate_1932) {
            Q.secondary_reactionary_candidate_1932 = "Яррес";
            Q.secondary_reactionary_candidate_1932_disp = "Karl Jarres";
        }
        if (!Q.reactionary_candidate_1932) {
            Q.reactionary_candidate_1932 = "Яррес";
            Q.reactionary_candidate_1932_disp = "Karl Jarres";
        }
        Q.reactionary_candidate_1932_count -= 1;
    }

    if (Q.luther_unlock_pres) {
        Q.luther_run = 1;
        if (Q.reactionary_candidate_1932) {
            Q.secondary_reactionary_candidate_1932 = "Лютер";
            Q.secondary_reactionary_candidate_1932_disp = "Hans Luther";
        }
        if (!Q.reactionary_candidate_1932) {
            Q.reactionary_candidate_1932 = "Лютер";
            Q.reactionary_candidate_1932_disp = "Hans Luther";
        }
        Q.reactionary_candidate_1932_count -= 1;
    }

    if (Q.gessler_unlock_pres) {
        Q.gessler_run = 1; 
        if (Q.reactionary_candidate_1932) {
            Q.secondary_reactionary_candidate_1932 = "Гесслер";
            Q.secondary_reactionary_candidate_1932_disp = "Otto Gessler";
        }
        if (!Q.reactionary_candidate_1932) {
            Q.reactionary_candidate_1932 = "Гесслер";
            Q.reactionary_candidate_1932_disp = "Otto Gessler";
        }
        Q.reactionary_candidate_1932_count -= 1;
    }

    if (Q.adenauer_unlock_pres) {
        Q.adenauer_run = 1; 
        if (Q.reactionary_candidate_1932) {
            Q.secondary_reactionary_candidate_1932 = "Аденауэр";
            Q.secondary_reactionary_candidate_1932_disp = "Konrad Adenauer";
        }
        if (!Q.reactionary_candidate_1932) {
            Q.reactionary_candidate_1932 = "Аденауэр";
            Q.reactionary_candidate_1932_disp = "Konrad Adenauer";
        }
        Q.reactionary_candidate_1932_count -= 1;
    }

    if (Q.bruning_unlock_pres) {
        Q.bruning_run = 1; 
        if (Q.reactionary_candidate_1932) {
            Q.secondary_reactionary_candidate_1932 = "Брюнинг";
            Q.secondary_reactionary_candidate_1932_disp = "Heinrich Brüning";
        }
        if (!Q.reactionary_candidate_1932) {
            Q.reactionary_candidate_1932 = "Брюнинг";
            Q.reactionary_candidate_1932_disp = "Heinrich Brüning";
        }
        Q.reactionary_candidate_1932_count -= 1;
    }

    if (Q.stegerwald_unlock_pres) {
        Q.stegerwald_run = 1; 
        if (Q.reactionary_candidate_1932) {
            Q.secondary_reactionary_candidate_1932 = "Штегервальд";
            Q.secondary_reactionary_candidate_1932_disp = "Adam Stegerwald";
        }
        if (!Q.reactionary_candidate_1932) {
            Q.reactionary_candidate_1932 = "Штегервальд";
            Q.reactionary_candidate_1932_disp = "Adam Stegerwald";
        }
        Q.reactionary_candidate_1932_count -= 1;
    }

    if (Q.vorbeck_unlock_pres) {
        Q.vorbeck_run = 1; 
        if (Q.reactionary_candidate_1932) {
            Q.secondary_reactionary_candidate_1932 = "Леттов-Форбек";
            Q.secondary_reactionary_candidate_1932_disp = "Paul von Lettow-Vorbeck";
        }
        if (!Q.reactionary_candidate_1932) {
            Q.reactionary_candidate_1932 = "Леттов-Форбек";
            Q.reactionary_candidate_1932_disp = "Paul von Lettow-Vorbeck";
        }
        Q.reactionary_candidate_1932_count -= 1;
    }

    if (Q.westarp_unlock_pres) {
        Q.westarp_run = 1; 
        if (Q.reactionary_candidate_1932) {
            Q.secondary_reactionary_candidate_1932 = "Вестарп";
            Q.secondary_reactionary_candidate_1932_disp = "Kuno von Westarp";
        }
        if (!Q.reactionary_candidate_1932) {
            Q.reactionary_candidate_1932 = "Вестарп";
            Q.reactionary_candidate_1932_disp = "Kuno von Westarp";
        }
        Q.reactionary_candidate_1932_count -= 1;
    }
    
    if (Q.reactionary_candidate_1932 == "Лютер" || Q.reactionary_candidate_1932 == "Гесслер" || Q.reactionary_candidate_1932 == "Яррес") {
        Q.liberal_reactionary_candidate_1932 = 1;
        Q.liberal_reactionary_candidate_1932_name = Q.reactionary_candidate_1932;
    }
    if (Q.reactionary_candidate_1932 == "Аденауэр" || Q.reactionary_candidate_1932 == "Брюнинг" || Q.reactionary_candidate_1932 == "Штегервальд") {
        Q.center_reactionary_candidate_1932 = 1;
        Q.center_reactionary_candidate_1932_name = Q.reactionary_candidate_1932;
    }

    if (Q.secondary_reactionary_candidate_1932 == "Лютер" || Q.secondary_reactionary_candidate_1932 == "Гесслер" || Q.secondary_reactionary_candidate_1932 == "Яррес") {
        Q.liberal_reactionary_candidate_1932 = 1;
        Q.liberal_reactionary_candidate_1932_name = Q.secondary_reactionary_candidate_1932;
    }
    if (Q.secondary_reactionary_candidate_1932 == "Аденауэр" || Q.secondary_reactionary_candidate_1932 == "Брюнинг" || Q.secondary_reactionary_candidate_1932 == "Штегервальд") {
        Q.center_reactionary_candidate_1932 = 1;
        Q.center_reactionary_candidate_1932_name = Q.secondary_reactionary_candidate_1932;
    }

}

Q.z_choice = Q.reactionary_candidate_1932;
Q.ddp_choice = Q.reactionary_candidate_1932;
Q.dvp_choice = Q.reactionary_candidate_1932;
Q.lvp_choice = Q.reactionary_candidate_1932;
Q.other_choice = Q.reactionary_candidate_1932;
Q.kvp_choice = Q.reactionary_candidate_1932;
Q.dnvp_choice = Q.reactionary_candidate_1932;

if (Q.secondary_reactionary_candidate_1932) {
    if (Q.secondary_reactionary_candidate_1932 == "Вестарп") {
        Q.dnvp_choice = Q.secondary_reactionary_candidate_1932;
        Q.kvp_choice = Q.secondary_reactionary_candidate_1932;
        Q.other_choice = Q.secondary_reactionary_candidate_1932;
    } else if (Q.secondary_reactionary_candidate_1932 == "Леттов-Форбек") {
        if (Q.cvp_formed) Q.z_choice = Q.reactionary_candidate_1932;
        Q.dnvp_choice = Q.secondary_reactionary_candidate_1932;
        Q.kvp_choice = Q.secondary_reactionary_candidate_1932;
        if (!Q.liberal_reactionary_candidate_1932) Q.dvp_choice = Q.secondary_reactionary_candidate_1932;
        Q.other_choice = Q.secondary_reactionary_candidate_1932;
    } else if (Q.secondary_reactionary_candidate_1932 == "Брюнинг") {
        Q.z_choice = Q.secondary_reactionary_candidate_1932;
        if (!Q.liberal_reactionary_candidate_1932) Q.ddp_choice = Q.secondary_reactionary_candidate_1932;
        if (!Q.lvp_defect && !Q.liberal_reactionary_candidate_1932) Q.lvp_choice = Q.secondary_reactionary_candidate_1932;
        if (!Q.dvp_defect && !Q.liberal_reactionary_candidate_1932) Q.dvp_choice = Q.secondary_reactionary_candidate_1932;
        if (Q.reactionary_candidate_1932_ideology = "Liberal") Q.other_choice = Q.secondary_reactionary_candidate_1932;
    } else if (Q.secondary_reactionary_candidate_1932 == "Аденауэр") {
        Q.z_choice = Q.secondary_reactionary_candidate_1932;
        if (Q.liberal_reactionary_candidate_1932) Q.kvp_choice = Q.secondary_reactionary_candidate_1932;
        if (Q.liberal_reactionary_candidate_1932) Q.dnvp_choice = Q.secondary_reactionary_candidate_1932;
    } else if (Q.secondary_reactionary_candidate_1932 == "Штегервальд") {
        Q.z_choice = Q.secondary_reactionary_candidate_1932;
        if (Q.liberal_reactionary_candidate_1932) Q.other_choice = Q.secondary_reactionary_candidate_1932;
        if (Q.liberal_reactionary_candidate_1932) Q.kvp_choice = Q.secondary_reactionary_candidate_1932;
        if (Q.liberal_reactionary_candidate_1932) Q.dnvp_choice = Q.secondary_reactionary_candidate_1932;
    } else if (Q.secondary_reactionary_candidate_1932 == "Гесслер") {
        Q.ddp_choice = Q.secondary_reactionary_candidate_1932;
        Q.lvp_choice = Q.secondary_reactionary_candidate_1932;
        Q.dvp_choice = Q.secondary_reactionary_candidate_1932;
        if (Q.reactionary_candidate_1932_ideology != "Conservative") Q.other_choice = Q.secondary_reactionary_candidate_1932;
    } else if (Q.secondary_reactionary_candidate_1932 == "Лютер") {
        Q.ddp_choice = Q.secondary_reactionary_candidate_1932;
        Q.lvp_choice = Q.secondary_reactionary_candidate_1932;
        Q.dvp_choice = Q.secondary_reactionary_candidate_1932;
        if (Q.reactionary_candidate_1932_ideology != "Conservative") Q.other_choice = Q.secondary_reactionary_candidate_1932;
    } else if (Q.secondary_reactionary_candidate_1932 == "Яррес") {
        Q.lvp_choice = Q.secondary_reactionary_candidate_1932;
        Q.dvp_choice = Q.secondary_reactionary_candidate_1932;
        if (Q.reactionary_candidate_1932_ideology != "Conservative") Q.other_choice = Q.secondary_reactionary_candidate_1932;
    }
}

if (Q.reactionary_candidate_1932 == "Лютер" || Q.reactionary_candidate_1932 == "Гесслер" || Q.reactionary_candidate_1932 == "Яррес") {
    Q.reactionary_candidate_1932_ideology = "Liberal";
} else if (Q.reactionary_candidate_1932 == "Вестарп" || Q.reactionary_candidate_1932 == "Леттов-Форбек") {
    Q.reactionary_candidate_1932_ideology = "Conservative";
} else if (Q.reactionary_candidate_1932 == "Аденауэр" || Q.reactionary_candidate_1932 == "Брюнинг" || Q.reactionary_candidate_1932 == "Штегервальд") {
    Q.reactionary_candidate_1932_ideology = "Centrist";
}

if (Q.secondary_reactionary_candidate_1932 == "Лютер" || Q.secondary_reactionary_candidate_1932 == "Гесслер" || Q.secondary_reactionary_candidate_1932 == "Яррес") {
    Q.secondary_reactionary_candidate_1932_ideology = "Liberal";
} else if (Q.secondary_reactionary_candidate_1932 == "Вестарп" || Q.secondary_reactionary_candidate_1932 == "Леттов-Форбек") {
    Q.secondary_reactionary_candidate_1932_ideology = "Conservative";
} else if (Q.secondary_reactionary_candidate_1932 == "Аденауэр" || Q.secondary_reactionary_candidate_1932 == "Брюнинг" || Q.secondary_reactionary_candidate_1932 == "Штегервальд") {
    Q.secondary_reactionary_candidate_1932_ideology = "Centrist";
}

Q.reactionary_candidate_1932_count_2 = 1;
if (Q.secondary_reactionary_candidate_1932) Q.reactionary_candidate_1932_count_2 = 2;
!}
view-if: not hindenburg_run
go-to: reactionary_candidates

Стремительно приближаются местные выборы, и многие партии решили не выставлять собственных кандидатов, а объединить свои силы для поддержки нескольких избранных.


