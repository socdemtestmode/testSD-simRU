go-to: embezzlement_options

Мы встретились с политиками из[? if lvp_formed: <span style="color: #FFCC00;">ЛНП</span> ?][? if not lvp_formed: <span style="color: #D3C24D;">[+ ddp_name +]</span> ?], [? if z_party_name != "ХНП": <span style="color: #000000;">Партии Центра</span> ?][? if z_party_name == "ХНП": <span style="color: #000000;">**ХНП**</span> ?] , Рейхсбаннера и даже нескольких <span style="color: #000000;">рес</span><span style="color: #DD0000;">пуб</span><span style="color: #FFCC00;">ликанских</span> крестьянских союзов. Мы договорились о выделении прусских государственных средств их группам, что укрепит кампанию Гинденбурга среди тех, кто не вошёл в официальный комитет, а также улучшит наши отношения с этими фракциями.


@campaigning_hindenburg_2
on-arrival: {!
if (Q.hindenburg_funds >= 5 && !Q.industrial_hindenburg) {
    Q.new_middle_kvp += Q.hindenburg_funds / 2;
    Q.old_middle_kvp += Q.hindenburg_funds / 2;
    Q.rural_kvp += Q.hindenburg_funds / 2;
    if (Q.dnvp_ideology == "Умеренные") {
        Q.new_middle_dnvp += Q.hindenburg_funds / 2;
        Q.old_middle_dnvp += Q.hindenburg_funds / 2;
        Q.rural_dnvp += Q.hindenburg_funds / 3;
    }
    Q.new_middle_other += Q.hindenburg_funds / 3;
    Q.old_middle_other += Q.hindenburg_funds / 3;
    Q.rural_other += Q.hindenburg_funds / 3;
    Q.new_middle_dvp += Q.hindenburg_funds / 3;
    Q.old_middle_dvp += Q.hindenburg_funds / 3;
    Q.rural_dvp += Q.hindenburg_funds / 4;
    Q.new_middle_lvp += Q.hindenburg_funds / 2;
    Q.old_middle_lvp += Q.hindenburg_funds / 2;
    Q.rural_lvp += Q.hindenburg_funds / 4;
}
Q.industrial_hindenburg = 1;
!}
view-if: hindenburg_funds >= hindenburg_funds_old + 3

