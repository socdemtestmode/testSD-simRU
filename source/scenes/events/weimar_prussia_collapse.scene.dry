title: Правительство Пруссии пало
subtitle: Наши партнёры по коалиции распускают прусское правительство.
view-if: ((z_relation < 30 and z_ideology == "Правые") or (z_relation < 25 and z_leader == "Йоос") or (z_relation < 20 and z_leader == "Кайзер") or ((((ddp_relation < 30 and ddp_ideology == "Правые") or (ddp_relation < 25 and ddp_ideology == "Умеренные") or (ddp_relation < 20 and ddp_ideology == "Левые" and ddp_cohesion < 8)) and not lvp_formed) or (((lvp_relation < 40 and lvp_ideology == "Правые") or (lvp_relation < 35 and lvp_ideology == "Умеренные") or (lvp_relation < 30 and lvp_ideology == "Левые")) and lvp_formed))) and in_weimar_coalition_prussia == 1 and not (year == 1928 and month < 6)
on-arrival: coalition_dissent += 2 if not in_left_front; was_in_social_catholic_coalition_prussia = 0; was_in_social_liberal_coalition_prussia = 0; was_in_weimar_coalition_prussia = 0; was_in_grand_coalition_prussia = 0; was_in_social_catholic_coalition_prussia = 1 if in_social_catholic_coalition_prussia == 1 or in_minority_social_catholic_coalition_prussia == 1; was_in_social_liberal_coalition_prussia = 1 if in_social_liberal_coalition_prussia == 1 or in_minority_social_liberal_coalition_prussia == 1; was_in_weimar_coalition_prussia = 1 if ((in_weimar_coalition_prussia == 1 or in_minority_weimar_coalition_prussia == 1) or (in_grand_coalition_prussia == 1 and lvp_formed)); was_in_grand_coalition_prussia = 1 if (in_grand_coalition_prussia == 1 or in_minority_grand_coalition_prussia == 1); in_right_coalition_prussia = 0; in_social_catholic_coalition_prussia = 0; in_social_liberal_coalition_prussia = 0; in_weimar_coalition_prussia = 0; in_grand_coalition_prussia = 0; in_minority_grand_coalition_prussia = 0; in_popular_front_prussia = 0; in_left_front_prussia = 0; in_spd_majority_prussia = 0; in_center_right_coalition_prussia = 0; in_far_right_coalition_prussia = 0; in_minority_weimar_coalition_prussia = 0; in_minority_social_catholic_coalition_prussia = 0; in_minority_social_liberal_coalition_prussia = 0; spd_prussia = 0; right_prussia = 0; ddp_in_popular_front_prussia = 0; kpd_goals_seen_prussia = 0; spd_toleration_prussia = 0
on-departure: {!
if (Q.in_social_catholic_coalition_prussia || Q.in_social_liberal_coalition_prussia || Q.in_weimar_coalition_prussia == 1 || Q.in_grand_coalition_prussia == 1 || Q.in_popular_front_prussia == 1 || Q.in_left_front_prussia == 1 || Q.in_spd_majority_prussia == 1 || Q.in_minority_weimar_coalition_prussia == 1 || Q.in_minority_grand_coalition_prussia == 1) {
    Q.spd_prussia = 1;
    Q.right_prussia = 0;
} else if (Q.in_right_coalition_prussia == 1 || Q.in_center_right_coalition_prussia == 1 || Q.prussia_leader == "Папен" || Q.prussia_leader == "Геринг" || Q.in_far_right_coalition_prussia == 1) {
    Q.right_prussia = 1;
    Q.spd_prussia = 0;
}
!}
new-page: true
tags: event
face-image: img/weimar_coalition.jpg

= Оплот демократии разрушен

Мы каким-то образом настроили против себя партии, входящие в правящую в Пруссии <span style="color: #000000;">Ве</span><span style="color: #DD0000;">йм</span><span style="color: #FFCC00;">ар</span>скую коалицию: наши партнёры по коалиции вынесли нам вотум недоверия.

[? if spd_r_prussia + kpd_r_prussia + sapd_r_prussia < 50: Единственная альтернативная коалиция, которую можно сформировать при текущем составе ландтага, — это широкая правая коалиция в составе от [? if z_party_name != "ХНП": <span style="color: #000000;">партии Центра</span> ?][? if z_party_name == "ХНП": <span style="color: #000000;">**ХНП**</span> ?] до [? if center_right_coalition_prussia >= 50: <span style="color: #3E88B3;">**НННП**</span> ?][? if center_right_coalition_prussia < 50: <span style="color: #7A3C00;">**НСДАП**</span> ?].[? if dnvp_ideology == "Радикалы" and not dnvp_westarp: Однако это крайне маловероятно из-за позиции <span style="color: #3E88B3;">**НННП**</span> «всё или ничего» в вопросах формирования правительства. ?] ?][? if spd_r_prussia + kpd_r_prussia + sapd_r_prussia >= 50: Придётся объявить новые выборы, поскольку всем партиям правее нас не хватает голосов для формирования альтернативной коалиции большинства — даже если бы они объединились вокруг единого кандидата. ?]

