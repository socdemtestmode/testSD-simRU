choose-if: kpd_relation >= 40 and reformist_strength < left_strength
unavailable-subtitle: [? if kpd_relation < 40 : У нас недостаточно хорошие отношения с <span style="color: #700000;">коммунистами</span>, поэтому они не готовы принять даже нашу поддержку. ?] [? if reformist_strength >= left_strength : Реформистской фракции удаётся отговорить партию от поддержки этой затеи. ?]
on-arrival: spd_candidate = "Münzenberg"; kpd_relation += 5; reformist_dissent += 5; ddp_relation -= 4; dvp_relation -= 8; lvp_relation -= 8; z_relation -= 6; is_unity_candidate = 0
