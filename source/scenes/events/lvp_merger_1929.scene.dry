Q.lvp_formation_points = 0;
if (Q.dvp_relation >= 40) {
    Q.lvp_formation_points += 1;
}
if (Q.liberal_vote < 14) {
    Q.lvp_formation_points += 1;
}
if (Q.dvp_ideology == "Левые") {
    Q.lvp_formation_points += 2;
}
if (Q.ddp_ideology == "Правые") {
    Q.lvp_formation_points += 1;
}
if (Q.pro_republic >= 65) {
    Q.lvp_formation_points += 1;
