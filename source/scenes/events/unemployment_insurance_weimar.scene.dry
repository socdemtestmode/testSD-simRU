title: Кризис страхования по безработице
subtitle: Наши программы страхования по безработице нуждаются в дополнительном финансировании…
new-page: true
view-if: spd_in_government = 1 and (year = 1930 or year = 1931 or year = 1932) and month == 3 and (spd_in_government and (in_grand_coalition = 0 or constructive_vonc or president_ideology == "Left")) and unemployment_insurance_timer = 0 and unemployed >= unemployment_insurance_threshold + 4 and not (lvp_formed and not constructive_vonc)
on-arrival: unemployment_insurance_crisis += 1;  unemployment_insurance_timer = 8; crisis_urgency += 1; unemployment_insurance_threshold = unemployed
