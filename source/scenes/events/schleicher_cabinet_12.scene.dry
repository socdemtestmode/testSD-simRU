Q.unemployed_spd += 4;
Q.workers_kpd += 2;
Q.unemployed_kpd += 2;

Q.workers_dnef -= 4;
Q.new_middle_dnef -= 4;
Q.old_middle_dnef -= 4;
Q.rural_dnef -= 4;
Q.unemployed_dnef -= 4;
