choose-if: (kpd_relation >= 30 or (spd_r_saxony + aspd_r_saxony + ddp_r_saxony >= 50 and ddp_relation >= 80)) and ((ddp_relation >= 80 and (ddp_ideology == "Левые") and left_strength < 20 and saxony_spd) or (ddp_relation >= 60 and spd_r_saxony + sapd_r_saxony + aspd_r_saxony >= 50) or (spd_r_saxony + sapd_r_saxony >= 50))
unavailable-subtitle: [? if kpd_relation < 30 and sapd_formed: <span style="color: #9B0000;">**СРПГ**</span> отказываются.  ?][? if ddp_relation < 60 and (reformists_resign or not aspd_dead): <span style="color: #fe9e00;">**СДПГ(с)**</span> отказываются.  ?][? if (ddp_relation < 80 or ddp_ideology != "Левые" or not spd_r_saxony or left_strength >= 20) and not lvp_formed: <span style="color: #D3C24D;">**[+ ddp_name +]**</span> отказываются. ?]
on-arrival: saxony_spd = 1; saxony_spd_splinter = 1; pro_republic += 1; old_middle_ddp -= 2; new_middle_ddp -= 2; saxony_toleration = 0; saxony_groko = 0; red_saxony = 0; saxony_joever = 0; saxony_right_2 = 0; saxony_nsdap = 0; saxony_soclib = 0; saxony_nsdap_maj = 0; saxony_kpd = 0; saxony_spd_maj = 0

Мы на скорую руку сколотили коалицию большинства с другими конституционными левоцентристскими партиями. Надеемся, она продержится.


