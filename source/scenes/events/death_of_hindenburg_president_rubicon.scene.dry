@round_1
go-to: election_algorithm
set-jump: post_election



@post_election
on-arrival: {!
var candidate_descs = {
  Strasser: "Otto Strasser of the <span style='color: #6A1E1E; font-weight: bold;'>DSU</span>",
  Frick: "Wilhelm Frick of the <span style='color: #6A1E1E; font-weight: bold;'>DSU</span>",
  Goring: "Hermann Göring of the <span style='color: #7A3C00; font-weight: bold;'>NSDAP</span>",
  Hammerstein: "Kurt von Hammerstein-Equord of the <span style='color: #BFC8CC; font-weight: bold;'>DNEF</span>",
  Adenauer: "Konrad Adenauer of the <span style='color: #000000; font-weight: bold;'>Center Party</span>",
  Heuss: "Theodor Heuss of the <span style='color: #D3C24D; font-weight: bold;'>DDP</span>",
  Schumacher: "Kurt Schumacher of the <span style='color: #c00000; font-weight: bold;'>SPD</span>"
};

if (Q.dstp_formed) {
    candidate_descs.Heuss = "Theodor Heuss of the <span style='color: #D3C24D; font-weight: bold;'>DStP</span>";
}
if (Q.lvp_formed) {
    candidate_descs.Heuss = "Theodor Heuss of the <span style='color: #FFCC00; font-weight: bold;'>LVP</span>";
}
if (Q.z_party_name == "CVP") {
    candidate_descs.Adenauer = "Konrad Adenauer of the <span style='color: #000000; font-weight: bold;'>CVP</span>";
}
for (var k in candidate_descs) {
    Q[k + '_running'] = 0;
}
var candidate_votes = {};
Q.parties_election = Q.parties;
if (Q.dsu_exist) {
    Q.parties_election.push('nsdap_hitler');
    Q.parties_election.push('dsu');
    Q.nsdap_normalized = 0;
}
if (Q.nvf_exist) {
    Q.parties_election.push('nvf');
    Q.nsdap_normalized -= Q.nvf_normalized;
    Q.nsdap_normalized = 0;
}
if (Q.center_bvp_votes) {
    Q.bvp_normalized = Q.bvp_votes / 100;
    Q.z_normalized -= Q.bvp_normalized;
    Q.parties_election.push('bvp')
    Q.bvp_candidate = Q.dnef_candidate;
}
for (var party of Q.parties_election) {
    var supported_candidate = Q[party + '_candidate'];
    supported_candidate = supported_candidate.normalize("NFD").replace(/[\u0300-\u036f]/g, "");
    Q[supported_candidate + '_running'] = 1;
    if (supported_candidate in candidate_votes) {
        candidate_votes[supported_candidate] += Q[party + '_normalized'];
    } else {
        candidate_votes[supported_candidate] = Q[party + '_normalized'];
    }
}
var total_votes = 0;
Q.winner = "";  
Q.winner_votes = 0;
Q.has_majority = 0;
for (var k in candidate_votes) {
    total_votes += candidate_votes[k];
    if (candidate_votes[k] > Q.winner_votes) {
        Q.winner = k;
        Q.winner_votes = candidate_votes[k];
    }
    if (candidate_votes[k] >= 0.5) {
        Q.has_majority = 1;
    }
}
for (var k in candidate_votes) {
    Q[k + '_votes'] = Math.round(1000*candidate_votes[k]/total_votes)/10;
    Q[k + '_votes_disp'] = Q[k + '_votes'].toFixed(1);
}
Q.winner_votes = Math.round(1000*Q.winner_votes/total_votes)/10;
Q.winner_votes_disp = Q.winner_votes.toFixed(1);
Q.winner_desc = candidate_descs[Q.winner];

Q.round += 1

if (Q.spd_candidate == "Boycott" || Q.sapd_candidate == "Boycott" || Q.kpd_candidate == "Boycott") {
    Q.boycott_votes = 0;
    if (Q.kpd_candidate == "Boycott") Q.boycott_votes += Q.kpd_votes;
    if (Q.sapd_candidate == "Boycott") Q.boycott_votes += Q.sapd_votes;
    if (Q.spd_candidate == "Boycott") Q.boycott_votes += Q.spd_votes;
}
!}
go-to: r2_start if round = 1 and not has_majority; election_end if round > 1; r1_winner if has_majority

Результаты выборов:

[? if Goring_running : <span style="color: #7A3C00;">**Геринг**</span> - [+ Goring_votes_disp +]% ?]

[? if Strasser_running : <span style="color: #6A1E1E;">**Штрассер**</span> - [+ Strasser_votes_disp +]% ?]

[? if Frick_running : <span style="color: #6A1E1E;">**Фрик**</span> - [+ Frick_votes_disp +]% ?]

[? if Hammerstein_running : <span style="color: #BFC8CC;">**Хаммерштейн**</span> - [+ Hammerstein_votes_disp +]% ?]

[? if Adenauer_running : <span style="color: #000000;">**Аденауэр**</span> - [+ Adenauer_votes_disp +]% ?]

[? if Heuss_running : [? if not lvp_formed: <span style="color: #D3C24D;">**Хойс**</span> ?][? if lvp_formed: <span style="color: #FFCC00;">**Хойс**</span> ?] - [+ Heuss_votes_disp +]% ?]

[? if Schumacher_running : <span style="color: #c00000;">**Шумахер**</span> - [+ Schumacher_votes_disp +]% ?]

[? if spd_candidate == "Boycott" or sapd_candidate == "Boycott" or kpd_candidate == "Boycott" : Недействительные бюллетени —[+ boycott_votes +]% ?]


@r2_start
on-arrival: {!
Q.adenauer_drops_out = 0;
Q.heuss_drops_out = 0;
if (Q.z_candidate == "Adenauer" && (Q.ddp_candidate == "Heuss" || Q.dvp_candidate == "Heuss" || Q.lvp_candidate == "Heuss") && Q.z_candidate != Q.spd_candidate && (Q.ddp_candidate != Q.spd_candidate || Q.dvp_candidate != Q.spd_candidate || Q.lvp_candidate != Q.spd_candidate)) {
    if (Q.Adenauer_votes > Q.Heuss_votes) {
        Q.heuss_drops_out = 1;
        if (Q.ddp_candidate != Q.spd_candidate && Q.ddp_candidate != Q.dnef_candidate) {
            Q.ddp_candidate = "Adenauer";
        }
        if (Q.dvp_candidate != Q.spd_candidate && Q.dvp_candidate != Q.dnef_candidate) {
            Q.dvp_candidate = "Adenauer";
        }
        if (Q.lvp_candidate != Q.spd_candidate && Q.lvp_candidate != Q.dnef_candidate) {
            Q.lvp_candidate = "Adenauer";
        }
    } else {
        Q.adenauer_drops_out = 1;
        Q.z_candidate = "Heuss";
    }
}
!}
go-to: r2_menu

Лидирует [+ winner_desc +]. В первом туре никто не набрал абсолютного большинства. Во втором туре для победы достаточно набрать простое большинство голосов.

<span style="color: #7A3C00;">Нацисты</span> и отколовшиеся от них партии остаются разобщёнными, их разделяет непримиримая вражда. В результате, [+ dsu_candidate +] и [+ nsdap_candidate +] продолжат действовать по отдельности. Их неспособность забыть о взаимной вражде означает фактическую смерть движения, которое тратит больше времени на внутренние распри, чем на борьбу с режимом.

[? if heuss_drops_out : Кандидат от либералов Теодор Хойс снял свою кандидатуру. Его выбор: член [? if z_party_name != "CVP": <span style="color: #000000;">Партии Центра</span> ?][? if z_party_name == "CVP": <span style="color: #000000;">**ХНП**</span> ?] Конрад Аденауэр. Это консолидирует голоса умеренного <i>Буржуазный блок</i>, и, как ожидается, они смогут оказать достойное сопротивление [+ dnef_candidate +]у. ?] [? if adenauer_drops_out : Кандитат от [? if z_party_name != "CVP": <span style="color: #000000;">Партии Центра</span> ?][? if z_party_name == "CVP": <span style="color: #000000;">**ХНП**</span> ?] Конрад Аденауэр снял свою кандидатуру в пользу либерального кандидата Теодора Хойса. Это консолидирует голоса умеренного <i>Буржуазного блока</i>, и ожидается, что они смогут дать достойный бой [+ dnef_candidate +]у. ?]

Что нам делать?


@r2_menu

- @r2_endorse_hammerstein: Наш выбор: кандидат от <span style="color: #BFC8CC;">**ФНЕГ**</span>'s [+ dnef_candidate +].
- @r2_endorse_adenauer
- @r2_endorse_heuss
- @r2_campaigning: Можем ли мы убедить какую-нибудь из партий изменить выбор?
- @r2_vote: Да начнётся голосование.


@r2_endorse_hammerstein
view-if: spd_candidate != dnef_candidate and dnef_candidate == "Hammerstein"
unavailable-subtitle: Мы — демократическая партия.
choose-if: schleicher_spd_influence >= 8
on-arrival: spd_candidate = dnef_candidate; kpd_candidate = "Boycott"; sapd_candidate = "Boycott"
go-to: r1_menu

Надеюсь, у вас была на то причина.


@r2_endorse_adenauer
title: Переключиться на поддержку Конрада Аденауэра от [? if z_party_name != "CVP": <span style="color: #000000;">Партии Центра</span> ?][? if z_party_name == "CVP": <span style="color: #000000;">**ХНП**</span> ?].
view-if: z_candidate = "Adenauer" and spd_candidate != z_candidate
on-departure: kpd_candidate = "Boycott"; sapd_candidate = "Boycott"; spd_candidate = "Adenauer"; z_relation += 5; center_bvp_votes = 1 if z_relation < 50; is_unity_candidate = 1
go-to: r2_campaigning

Мы поддержали Конрада Аденауэра от [? if z_party_name != "CVP": <span style="color: #000000;">Партии Центра</span> ?][? if z_party_name == "CVP": <span style="color: #000000;">**ХНП**</span> ?]. Возможно, мы сможем сформировать <span style="color: #000000;">Вей</span><span style="color: #DD0000;">мар</span><span style="color: #FFCC00;">ский</span> блок против Шлейхера.

[? if z_relation < 50 : Из-за нашей поддержки Аденауэра наиболее консервативное крыло <span style="color: #A2D8E0;">Баварской народной партии</span> откололось от [? if z_party_name != "CVP": <span style="color: #000000;">Партии Центра</span> ?][? if z_party_name == "CVP": <span style="color: #000000;">**ХНП**</span> ?]. Теперь их выбор: [+ dnef_candidate +]. Надеемся, это не приведёт к повторению президентских выборов 1925 года. ?]

[? if kpd_candidate = spd_candidate: The <span style="color: #700000;">**КПГ**</span> теперь выходит из нашей прежней коалиции и вместо этого бойкотирует выборы. ?]


@r2_endorse_heuss
title: Переключиться на поддержку Теодора Хойса.
view-if: (ddp_candidate = "Heuss" or lvp_candidate == "Heuss" or dvp_candidate == "Heuss") and spd_candidate != "Heuss"
on-departure: kpd_candidate = "Boycott"; sapd_candidate = "Boycott"; spd_candidate = "Heuss"; ddp_relation += 8; lvp_relation += 5; dvp_candidate = dnef_candidate if dvp_relation < 60 and dvp_candidate == spd_candidate and dvp_exist and not lvp_formed; is_unity_candidate = 1
go-to: r2_campaigning

Мы поддержали Теодора Хойса из[? if not lvp_formed: <span style="color: #D3C24D;">**[+ ddp_name +]**</span> ?][? if lvp_formed: <span style="color: #FFCC00;">**ЛНП**</span> ?].

[? if dvp_relation < 60 and dvp_candidate == spd_candidate and dvp_exist and not lvp_formed: Из-за нашей поддержки Хойса, его сторонники из <span style="color: #C0A054;">**ННП**</span> откололись. Теперь их выбор: [+ dnef_candidate +] if they haven't already. ?]

[? if kpd_candidate = spd_candidate: The <span style="color: #700000;">**КПГ**</span> выходит из нашей бывшей коалиции и вместо этого бойкотирует выборы. ?]


@r2_campaigning
view-if: round = 1

- @convince_z_unity
- @convince_z_spd
- @convince_lvp_spd
- @convince_lvp_unity
- @convince_ddp_spd
- @convince_ddp_unity
- @convince_dvp_unity
- @r2_vote: Да начнётся голосование.




@r2_vote
go-to: post_election




@r1_winner
go-to: election_end

