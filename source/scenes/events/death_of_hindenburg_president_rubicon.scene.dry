- @round_1: Приступим к голосованию.


# convincing Z to support a unity candidate

@convince_z_unity
title: Убедить [? if z_party_name != "CVP": <span style="color: #000000;">Партию Центра</span> ?][? if z_party_name == "CVP": <span style="color: #000000;">**ХНП**</span> ?]: им нужен [+ spd_candidate +].
view-if: spd_candidate = "Heuss" and z_candidate != spd_candidate
on-arrival: {!
Q.z_support_braun = 0;
if (Q.z_relation >= 60 || (Q.z_relation > 50 && Q.z_ideology == "Left")) {
    Q.z_support_braun = 1;
} else if (Q.z_relation < 35) {
    Q.z_support_braun = 0;
} else {
    Q.z_support_braun = 2;
}
if (Q.z_candidate == Q.dnef_candidate) Q.z_support_braun = 0;
!}
max-visits: 1
