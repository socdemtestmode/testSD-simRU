title: Смерть Гинденбурга
subtitle: Президент умер…
new-page: true
view-if: year = 1934 and month >= 7 and president = "Hindenburg" and dnef_formed
on-arrival: {!
for (var c of Q.classes) {
    var class_votes = 0;
    for (var party of Q.parties) {
        if (Q[c+'_'+party] < 0) {
            Q[c+'_'+party] = 0;
        }
        class_votes += Q[c+'_'+party];
    }
    for (var party of Q.parties) {
        Q[c + '_' + party + '_normalized'] = 100*Q[c+'_'+party]/class_votes;
        Q[c + '_' + party + '_display'] = Math.round(100*Q[c+'_'+party]/class_votes);
    }
}
// calculate support for each of the parties
var total_support = 0; 
for (var party of Q.parties) {
    var party_support = 0;
    for (var c of Q.classes) {
        if (Q.old_demographics) { 
            party_support += Q[c]*Q[c+'_'+party];
        } else  { 
            party_support += Q[c]*Q[c+'_'+party+'_normalized'];
        } 
    }
    Q[party + '_support'] = party_support;
    total_support += party_support; 
    if (party == "nsdap" && Q.nsdap_split) {
        Q.nsdap_hitler_support = Q.rural_nsdap_normalized*Q.rural;
        Q.nsdap_hitler_support += Q.old_middle_nsdap_normalized*Q.old_middle;
        Q.nsdap_hitler_support += Q.catholics_nsdap_normalized*Q.catholics;

        if (Q.dsu_exist && !Q.nvf_exist) {
            Q.dsu_support = Q.workers_nsdap*Q.workers*((120 - Q.sa_force) / 100);
            Q.dsu_support += Q.unemployed_nsdap*Q.unemployed*((80 - Q.sa_force) / 100);
            Q.dsu_support += Q.new_middle_nsdap*Q.new_middle;
        } else if (!Q.dsu_exist && Q.nvf_exist) {
            Q.nvf_support = Q.unemployed_nsdap*Q.unemployed*((120 - Q.sa_force) / 100);
            Q.nvf_support += Q.workers_nsdap*Q.workers*((Q.sa_force - 80) / 100);
            Q.nvf_support += Q.new_middle_nsdap*Q.new_middle;
        } else if (Q.dsu_exist && Q.nvf_exist) {
            Q.dsu_support = Q.workers_nsdap*Q.workers*((120 - Q.sa_force) / 100);
            Q.dsu_support += Q.unemployed_nsdap*Q.unemployed*((80 - Q.sa_force) / 100);
            Q.dsu_support += Q.new_middle_nsdap*Q.new_middle;

            Q.nvf_support = Q.unemployed_nsdap*Q.unemployed*((120 - Q.sa_force) / 100);
            Q.nvf_support += Q.workers_nsdap*Q.workers*((Q.sa_force - 80) / 100);
        } else {
            Q.nsdap_hitler_support += Q.workers_nsdap*Q.workers;
            Q.nsdap_hitler_support += Q.unemployed_nsdap*Q.unemployed;
            Q.nsdap_hitler_support += Q.new_middle_nsdap*Q.new_middle;
        }
    }
}
// 2. normalize support (fraction)
for (var party of Q.parties) {
    Q[party+'_normalized'] = Q[party + '_support']/total_support;
    if (party == "nsdap" && Q.nsdap_split) {
        Q.nsdap_hitler_normalized = Q.nsdap_hitler_support / total_support;
        Q.dsu_normalized = Q.dsu_support / total_support;
        Q.nvf_normalized = Q.nvf_support / total_support;
        Q.nsdap_hitler_votes = Math.round(Q.nsdap_hitler_normalized*1000) / 10;
        Q.dsu_votes = Math.round(Q.dsu_normalized*1000) / 10;
        Q.nvf_votes = Math.round(Q.nvf_normalized*1000) / 10;
    }
    Q[party+'_votes'] = Math.round(Q[party+'_normalized']*1000)/ 10;
}

Q.round = 0;
Q.hindenburg_dead = 1;
Q.president = "Bumke (acting)";
if (Q.judicial_reform >= 4) Q.president = "Großmann (acting)"

Q.Heuss_votes_pre = 0;

Q.dnef_candidate = "Hammerstein";
Q.spd_candidate = "Schumacher";
Q.kpd_candidate = Q.spd_candidate;
Q.z_candidate = "Adenauer";
if (Q.z_leader == "Bracht") Q.z_candidate = Q.dnef_candidate;
Q.ddp_candidate = "Heuss";
Q.lvp_candidate = "Heuss";
Q.dvp_candidate = "Heuss";
if (Q.dstp_dnef) Q.ddp_candidate = Q.dnef_candidate;
if (Q.lvp_dnef) Q.lvp_candidate = Q.dnef_candidate;
if (Q.dvp_dnef) Q.dvp_candidate = Q.dnef_candidate;
Q.heuss_run = 1;
if (Q.ddp_candidate == "Heuss") Q.Heuss_votes_pre += Q.ddp_votes;
if (Q.lvp_candidate == "Heuss") Q.Heuss_votes_pre += Q.lvp_votes;
if (Q.dvp_candidate == "Heuss") Q.Heuss_votes_pre += Q.dvp_votes;
if (Q.Heuss_votes_pre < 8) {
    if (Q.z_candidate != Q.dnef_candidate) Q.ddp_candidate = Q.z_candidate;
    if (Q.z_candidate != Q.dnef_candidate) Q.lvp_candidate = Q.z_candidate;
    if (Q.z_candidate != Q.dnef_candidate) Q.dvp_candidate = Q.z_candidate;
    if (Q.z_candidate == Q.dnef_candidate) Q.ddp_candidate = Q.dnef_candidate;
    if (Q.z_candidate == Q.dnef_candidate) Q.lvp_candidate = Q.dnef_candidate;
    if (Q.z_candidate == Q.dnef_candidate) Q.dvp_candidate = Q.dnef_candidate;
    if (Q.dstp_dnef) Q.ddp_candidate = Q.dnef_candidate;
    if (Q.lvp_dnef) Q.lvp_candidate = Q.dnef_candidate;
    if (Q.dvp_dnef) Q.dvp_candidate = Q.dnef_candidate;
    Q.heuss_run = 0;
}
Q.nsdap_candidate = "Göring";
Q.nsdap_hitler_candidate = "Göring";
if (Q.dsu_leader != "Otto Strasser") Q.dsu_candidate = "Frick";
if (Q.dsu_leader == "Otto Strasser") Q.dsu_candidate = "Strasser";
Q.nvf_candidate = "Boycott";
if (Q.nvf_dnef) Q.nvf_candidate = "Hammerstein";
Q.dnvp_candidate = "Hammerstein";
Q.other_candidate = "Hammerstein";
Q.is_unity_candidate = 0;
Q.sapd_candidate = Q.kpd_candidate;
Q.kvp_candidate = Q.dnvp_candidate;
Q.dnf_candidate = Q.dnvp_candidate;
!}
max-visits: 1
on-display: {!  
    var cardEl = document.createElement('div');  
    cardEl.className = "face-figure2";  

    var image = new Image();  
    image.className = "face-img";  
    image.src = "img/Hindenburg_head.jpg";  

    cardEl.appendChild(image);  
    var contentDiv = document.querySelector("#page #mid_panel #content");
    contentDiv.appendChild(cardEl);
!}
tags: event

= Смерть Гинденбурга

Президент Пауль фон Гинденбург скончался в возрасте 86 лет. Завершается целая историческая эпоха, и что принесёт будущее — пока неизвестно.

Нация скорбит о смерти своего героя войны и президента — хотя траур этот по большей части ограничивается политическими правыми. И поскольку Шлейхеру, как ожидается, тоже недолго осталось жить, эпоха двух сильных лидеров Германии близится к концу. Теперь стране предстоит определить, кто напишет следующую главу в истории <span style="color: #000000;">Вей</span><span style="color: #DD0000;">мар</span><span style="color: #FFCC00;">ской</span> республики — если её ещё можно будет так называть.

Новые президентские выборы должны состояться как можно скорее. От <span style="color: #BFC8CC;">**ФНЕГ**</span> ожидают, что они выдвинут единого кандидата: его победа гарантирует полную консолидацию власти на обозримое будущее — этого исхода необходимо избежать любой ценой. Тем временем председатель Верховного суда [? if judicial_reform < 4 : Эрвин Бумке ?][? if judicial_reform >= 4 : Герман Гроссман ?] исполняет обязанности президента.

- @candidates: Выборы-выборы, кандидаты... какие?


@candidates

The <span style="color: #BFC8CC;">**ФНЕГ**</span> выдвинула кандидатуру Курта фон Хаммерштейн-Экворда — генерала рейхсвера, давнего друга Шлейхера и начальника управления сухопутных войск. Он считает себя слугой государства, а не какой-либо политической партии: в последние месяцы связной Шлейхера по профсоюзам. В этот период он также отвечал за расширение рейхсвера. О его идеологических убеждениях известно немногое; как и Шлейхер, он гибок.

- @candidates_nazis


@candidates_nazis
title: Последний ураган <span style="color: #7A3C00;">нацистов</span>?

Теперь, когда Гитлер сошёл с политической сцены, <span style="color: #7A3C00;">нацисты</span> выдвигают Германа Геринга.

The <span style="color: #6A1E1E;">**НСС**</span> выдвинет [? if dsu_candidate == "Strasser": своего партийного лидера Отто Штрассера отдельным кандидатом. ?][? if dsu_candidate == "Frick": Вильгельма Фрика в качестве отдельного кандидата. ?]

[? if nvf_candidate == dnef_candidate: Остатки <span style="color: #142e20;">**ННФ**</span> поддержат [+ dnef_candidate +], поскольку они остаются в составе <span style="color: #BFC8CC;">**ФНЕГ**</span> umbrella. ?][? if nvf_candidate != dnef_candidate: Остатки <span style="color: #142e20;">**ННФ**</span> полностью бойкотируют выборы, продолжая свой бредовый курс в ожидании «подходящего момента» для разжигания вооружённого восстания. ?]

Поскольку движение <span style="color: #7A3C00;">нацистов</span> остаётся расколотым, ни один из их кандидатов не имеет ни малейшего шанса на победу.

- @candidates_nats


@candidates_nats
title: Перейдём к <span style="color: #3E88B3;">националистам</span>. 

<span style="color: #3E88B3;">Националисты</span> едины. Их кандидат: [+ dnef_candidate +]. К ним присоединились различные отколовшиеся фракции и малые буржуазные партии. Хотя Гугенберг — каким-то образом — всё ещё обдумывает возможность баллотироваться в президенты, недвусмысленная угроза заставила его молчать.

- @candidates_dems


@candidates_dems
title: The <span style="color: #700000;">**Коммунисты**</span>? <span style="color: #000000;">Ве</span><span style="color: #DD0000;">йм</span><span style="color: #FFCC00;">арские</span> партии? Кого они поддержат?

Поскольку <span style="color: #700000;">**коммунисты**</span> подверглись жестоким репрессиям во время пребывания Шлейхера у власти, они сейчас незначительная политическая сила. [? if kpd_banned: Их деятельность и вовсе запрещена, что не позволяет им выдвинуть собственного кандидата. Поскольку бойкот потерял всякий смысл, им ничего не остаётся, кроме как поддержать того, кого выдвинем мы. ?][? if not kpd_banned: В благодарность за то, что несколько месяцев назад мы спасли их от репрессий Шлейхера, они готовы полностью поддержать любого, кого мы решим выдвинуть. ?]

[? if z_candidate == "Adenauer": <span style="color: #000000;">Партия Центра</span> не вполне убеждена. Нужен ли им [+ dnef_candidate +]? Поэтому они выдвинули собственного кандидата: Конрада Аденауэра. Обер-бургомистр Кёльна со времён основания Республики и член прусского ландтага, он выступает за то, чтобы <span style="color: #000000;">Партия Центра</span> «вышла из башни» для расширения поддержки среди протестантов; его кандидатуру изначально предложил сам Штегервальд. Несмотря на принадлежность к правому крылу своей партии, он остаётся твёрдым приверженцем <span style="color: #000000;">Ве</span><span style="color: #DD0000;">йм</span><span style="color: #FFCC00;">арской</span> республики и выступает против угроз Шлейхера в её адрес. ?]

[? if heuss_run: От <span style="color: #FFCC00;">либералов</span> баллотируется Теодор Хойс — журналист, видный сторонник <span style="color: #000000;">Ве</span><span style="color: #DD0000;">йм</span><span style="color: #FFCC00;">арской</span> республики и ярый противник Шлейхера в рядах своей партии. Из-за такой позиции он разошёлся во взглядах с более провластными кругами немецкого среднего класса. Хотя Хойс вряд ли получит значительную поддержку, он позиционирует себя как единый кандидат от <span style="color: #000000;">Ве</span><span style="color: #DD0000;">йм</span><span style="color: #FFCC00;">арской</span> коалиции. Он уверен, что его главный враг на этих выборах: [+ dnef_candidate +]. ?][? if not heuss_run and ddp_candidate == z_candidate and z_candidate != dnef_candidate: <span style="color: #FFCC00;">Либералы</span>, потерпев сокрушительное поражение на выборах, не имеют ни сил, ни средств, чтобы выдвинуть собственного кандидата. Вместо этого их кандидат: [+ z_candidate +] — как буржуазная альтернатива Шлейхеру. Однако их поддержка далеко не монолитна: сторонники Шлейхера продолжают саботаж, поскольку его призыв к национальной солидарности находит отклик в исторически националистическом немецком либеральном движении. ?][? if not heuss_run and ddp_candidate == dnef_candidate: <span style="color: #FFCC00;">Либералы</span>, потерпев сокрушительное поражение на выборах, не имеют ни сил, ни средств, чтобы выдвинуть собственного кандидата. Вместо этого их кандидат: [+ dnef_candidate +], находясь под сильным влиянием сторонников Шлейхера и его пропаганды, которая особенно сильно находит отклик у рядовых членов партии. Многие в партии теперь считают своим национальным долгом поддержать Шлейхера и его преемника, полагая, что это единственный путь к восстановлению великодержавного статуса Германии на международной арене и получению уступок внутри страны. ?]

- @candidates_spd


@candidates_spd
title: И наконец, что же мы?
go-to: candidate_menu

Что касается <span style="color: #c00000;">**СДПГ**</span>, мы могли бы поддержать единого кандидата от <span style="color: #000000;">Ве</span><span style="color: #DD0000;">йм</span><span style="color: #FFCC00;">ар</span>ской коалиции или выдвинуть своего. Однако жизнеспособность единого фронта целиком зависит от наших отношений с бывшими партнёрами по коалиции — и от того, не попали ли они под влияние Шлейхера.

Отто Браун устал. Он баллотировался и проиграл на двух предыдущих президентских выборах и больше не хочет выставлять свою кандидатуру. Его жена больна, и он хочет быть рядом с ней. Что ещё важнее, он с глубоким пессимизмом смотрит на сложившуюся ситуацию.

Курт Шумахер — амбициозная восходящая звезда партии: он бы охотно выставил свою кандидатуру. Он гером Великой войны, но его сравнительно молодой возраст может сказаться на его результатах


@candidate_menu

- @hammerstein_r1: Мы доверим будущее страны <span style="color: #BFC8CC;">**ФНЕГ**</span>'s [+ dnef_candidate +].
- @adenauer_r1: Поддержать Конрада Аденауэра от [? if z_party_name != "CVP": <span style="color: #000000;">Партии Центра</span> ?][? if z_party_name == "CVP": <span style="color: #000000;">**ХНП**</span> ?].
- @heuss_r1: Поддержать Теодора Хойсса от [? if not lvp_formed: <span style="color: #D3C24D;">**[+ ddp_name +]**</span> ?][? if lvp_formed: <span style="color: #FFCC00;">**ЛНП**</span> ?].
- @schumacher_r1: Выдвинуть Курта Шумахера.
- @abstain: Ничего не делать.


@abstain
view-if: resources < 2
on-arrival: spd_candidate = "Boycott"; kpd_candidate = "Boycott"; sapd_candidate = "Boycott"
go-to: r1_menu

Какой бесславный конец.

- @round_1: Да начнётся голосование.


@hammerstein_r1
unavailable-subtitle: Мы — демократическая партия.
choose-if: schleicher_spd_influence >= 8
on-arrival: spd_candidate = dnef_candidate; kpd_candidate = "Boycott"; sapd_candidate = "Boycott"
go-to: r1_menu

Надеюсь, у вас была на то причина.

- @round_1: Да начнётся голосование.


@adenauer_r1
view-if: z_candidate == "Adenauer"
on-arrival: spd_candidate = "Adenauer"; kpd_candidate = "Boycott"; sapd_candidate = "Boycott"; z_relation += 5; center_bvp_votes = 1 if z_relation < 50; is_unity_candidate = 1
go-to: r1_menu

Мы поддержали Конрада Аденауэра из [? if z_party_name != "CVP": <span style="color: #000000;">Партии Центра</span> ?][? if z_party_name == "CVP": <span style="color: #000000;">**ХНП**</span> ?]. Возможно, мы сможем сформировать <span style="color: #000000;">Вей</span><span style="color: #DD0000;">марс</span><span style="color: #FFCC00;">кий</span> блок против Шлейхера.

[? if z_relation < 50 : Из-за нашей поддержки Аденауэра некоторые наиболее консервативные круги <span style="color: #A2D8E0;">Баварской народной партии</span> откололись от [? if z_party_name != "CVP": <span style="color: #000000;">Партии Центра</span> ?][? if z_party_name == "CVP": <span style="color: #000000;">**ХНП**</span> ?]. Теперь их выбор: [+ dnef_candidate +]. Будем надеяться, это не приведёт к повторению президентских выборов 1925 года. ?]


@heuss_r1
view-if: heuss_run
on-arrival: spd_candidate = "Heuss"; kpd_candidate = "Boycott"; sapd_candidate = "Boycott"; ddp_relation += 8; lvp_relation += 5; dvp_candidate = dnef_candidate if dvp_relation < 60 and dvp_candidate == spd_candidate and dvp_exist and not lvp_formed; is_unity_candidate = 1
go-to: r1_menu

Мы поддержали Теодора Хойса, журналиста из [? if not lvp_formed: <span style="color: #D3C24D;">**[+ ddp_name +]**</span> ?][? if lvp_formed: <span style="color: #FFCC00;">**ЛНП**</span> ?]. Возможно, мы сможем сформировать <span style="color: #000000;">Вей</span><span style="color: #DD0000;">мар</span><span style="color: #FFCC00;">ский</span> блок против Шлейхера.

[? if dvp_relation < 60 and dvp_candidate == spd_candidate and dvp_exist and not lvp_formed: Благодаря нашей поддержке Хойса поддерживавшие его фракции <span style="color: #C0A054;">**ННП**</span> откололись. Сейчас их выбор: [+ dnef_candidate +] if they haven't already. ?]


@schumacher_r1
subtitle: -2 ресурса.
unavailable-subtitle: [? if resources < 2 : -2 ресурса. — Недостаточно ресурсов. ?]
choose-if: resources >= 2
on-arrival: spd_candidate = "Schumacher"; resources -= 2; is_unity_candidate = 0
go-to: r1_menu

Мы выдвинули Курта Шумахера кандидатом в президенты. Однако убедить <span style="color: #000000;">Вей</span><span style="color: #DD0000;">мар</span><span style="color: #FFCC00;">ские</span> партии — многие из которых значительно сместились вправо — открыто поддержать <span style="color: #c00000;">социалиста</span> будет непросто.


@r1_menu
view-if: round = 0

