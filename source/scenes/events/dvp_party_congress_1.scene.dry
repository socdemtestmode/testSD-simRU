on-arrival: dvp_right += 3 if dvp_relation < 25; dvp_left += 3 if dvp_relation >= 45; dvp_left += 2 if in_grand_coalition; dvp_left += 3 if dvp_leader == "Лютер"; dvp_right += 3 if foreign_minister_party == "ННП" and dvp_leader == "Курциус"; dvp_left += 3 if liberal_parliament; dvp_right += 3 if bourgeois_parliament
