title: Съезд <span style="color: #3E88B3;">**НННП**</span> Congress
subtitle: <span style="color: #3E88B3;">НННП</span> решает свою судьбу...
view-if: year = 1929 and month = 11 and dnvp_leader = "Triumvirate"
max-visits: 1
tags: event
on-display: {!  
    var cardEl = document.createElement('div');  
    cardEl.className = "face-figure2";  

    var image = new Image();  
