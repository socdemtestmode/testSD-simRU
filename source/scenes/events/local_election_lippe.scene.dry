[? if not lvp_formed: {!<tr><td><div class="box" style='background-color:#D5AC27'> </div> !}ННП:{!</td><td>!} [+ dvp_lippe_elections_vote +]% {!</td><td>!} [+ str_votes_change_dvp_lippe +] {!</td><td>!} [+ dvp_r_lippe +]% {!</td><td>!} [+ str_change_dvp_lippe +] {! </td></tr>!} ?]

