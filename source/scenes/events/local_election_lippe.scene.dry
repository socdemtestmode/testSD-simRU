[? if csvd_formed: {!<tr><td><div class="box" style='background-color:#8ED8E4'> </div> !}ХСНС:{!</td><td>!} [+ csvd_lippe_elections_vote +]% {!</td><td>!} [+ str_votes_change_csvd_lippe +] {!</td><td>!} [+ csvd_r_lippe +]% {!</td><td>!} [+ str_change_csvd_lippe +] {! </td></tr>!} ?]

