[? if dnef_formed: <span class="tooltip-text" title="Фронт Национального Единства Германии" style="color: #BFC8CC;">**ФНЕГ**</span>: [+ dnef_relation : relationships +]  ?]

[? if z_party_name != "ХНП": <span class="tooltip-text" title="Партия Центра" style="color: #000000;">**[+ z_party_name +]**</span> ?][? if z_party_name == "ХНП": <span class="tooltip-text" title="Христианская народная партия" style="color: #000000;">**[+ z_party_name +]**</span> ?]: [+ z_relation : relationships +]

[? if not lvp_formed or not ddp_name: [? if not ddp_name: <span class="tooltip-text" title="Немецкая демократическая партия" style="color: #D3C24D;">**НДП**</span> ?][? if ddp_name = "НДП": <span class="tooltip-text" title="Немецкая демократическая партия" style="color: #D3C24D;">**[+ ddp_name +]**</span> ?][? if ddp_name = "НГП": <span class="tooltip-text" title="Немецкая государственная партия" style="color: #D3C24D;">**[+ ddp_name +]**</span> ?]: [+ ddp_relation : relationships +]  ?]

[? if lvp_formed: <span class="tooltip-text" title="Либеральная народная партия" style="color: #FFCC00;">**ЛНП**</span>: [+ lvp_relation : relationships +] ?]

[? if not lvp_formed and dvp_exist: <span class="tooltip-text" title="Немецкая народная партия" style="color: #C0A054;">**ННП**</span>: [+ dvp_relation : relationships +]  ?]

<span class="tooltip-text" title="Коммунистическая партия Германии" style="color: #700000;">**КПГ**</span>: [+ kpd_relation : relationships +]

[? if kvp_formed and not dnvp_dvp_formed : <span class="tooltip-text" title="Консервативная народная партия" style="color: #0087DC;">**КНП**</span>: [+ kvp_relation : relationships +]  ?]

[? if dnvp_dvp_formed: <span class="tooltip-text" title="Свободно-консервативная партия" style="color: #00C0FF;">**СКП**</span>: [+ fkp_relation : relationships +] ?]

[? if not cvp_formed and not dnvp_defunct: <span class="tooltip-text" title="Немецкая национальная народная партия" style="color: #3E88B3;">**НННП**</span>: [+ dnvp_relation : relationships +] ?]

[? if dnf_formed : <span class="tooltip-text" title="Национальный Фронт Германии" style="color: #003755;">**НФГ**</span>: [+ dnf_relation : relationships +]  ?]

<span class="tooltip-text" title="Национал-социалистическая немецкая рабочая партия (нацисты)" style="color: #7A3C00;">**НСДАП**</span>[? if nsdap_split: (и её осколки) ?]: [+ nsdap_relation : relationships +]

= Партийное руководство

[? if dnef_formed: <span class="tooltip-text" title="Фронт Национального Единства Германии" style="color: #BFC8CC;">**ФНЕГ**</span>: [? if dnef_ideology == "Левые": Синкретизм ?][? if dnef_ideology == "Умеренные": Синкретизм ?][? if dnef_ideology == "Правые": Синкретизм ?] ([+ dnef_leader +]) ?]

[? if not ddp_name: НЕ ИНИЦИАЛИЗИРОВАНО ?][? if ddp_name != 0: [? if z_party_name != "ХНП": <span class="tooltip-text" title="Партия Центра" style="color: #000000;">**[+ z_party_name +]**</span> ?][? if z_party_name == "ХНП": <span class="tooltip-text" title="Христианская народная партия" style="color: #000000;">**[+ z_party_name +]**</span> ?]: [? if not cvp_formed: [? if z_ideology == "Правые" and not cvp_kvp_formed and z_leader != "Йоос" and z_leader != "Брахт": От центризма до правоцентризма ?][? if z_ideology == "Правые" and cvp_kvp_formed: Христианская демократия ?][? if z_leader == "Йоос": От левоцентризма до правоцентризма ?][? if z_leader == "Кайзер": От левоцентризма до центризма ?][? if z_leader == "Брахт": Католический консерватизм ?] ?][? if cvp_formed: [? if cvp_leader == "Ламбах": Христианский корпоративизм ?][? if cvp_leader == "Штегервальд": Патерналистский консерватизм ?][? if cvp_leader == "Гереке": Аграрный консерватизм ?][? if cvp_leader == "Вестарп" or cvp_leader == "Гёрделер" or cvp_leader = "Лежён-Юнг" or cvp_leader == "Леттов-Форбек": Национал-консерватизм ?][? if cvp_leader == "Аденауэр": Христианская демократия ?][? if cvp_leader == "Больц": Христианский консерватизм ?][? if cvp_leader == "Тревиранус": Тори-демократия ?] ?] ([? if not cvp_formed: [+ z_leader +] ?][? if cvp_formed: [+ cvp_leader +] ?]) ?]

[? if not ddp_name and not lvp_formed: НЕ ИНИЦИАЛИЗИРОВАНО ?][? if not lvp_formed and ddp_name != 0 and not dstp_dnef: [? if ddp_name = "НДП" and ddp_ideology == "Правые": <span class="tooltip-text" title="Немецкая демократическая партия" style="color: #D3C24D;">**[+ ddp_name +]**</span>: Классический либерализм ([+ ddp_leader +]) ?][? if ddp_name = "НДП" and ddp_ideology == "Умеренные": <span class="tooltip-text" title="Немецкая демократическая партия" style="color: #D3C24D;">**[+ ddp_name +]**</span>: Левый либерализм ([+ ddp_leader +]) ?][? if ddp_name = "НДП" and ddp_ideology == "Левые": <span class="tooltip-text" title="Немецкая демократическая партия" style="color: #D3C24D;">**[+ ddp_name +]**</span>: Прогрессивный либерализм ([+ ddp_leader +]) ?] ?][? if not lvp_formed and ddp_name = "НДП" and dstp_dnef: <span class="tooltip-text" title="Немецкая демократическая партия" style="color: #D3C24D;">**[+ ddp_name +]**</span>: Либеральный корпоративизм ([+ ddp_leader +]) ?]

[? if ddp_name = "НГП" and not lvp_formed and (not dstp_collapsed or dstp_dnef): <span class="tooltip-text" title="Немецкая государственная партия" style="color: #D3C24D;">**[+ ddp_name +]**</span>: Либеральный корпоративизм ([+ ddp_leader +]) ?][? if ddp_name = "НГП" and not lvp_formed and dstp_collapsed and not dstp_dnef: <span class="tooltip-text" title="Немецкая государственная партия" style="color: #D3C24D;">**[+ ddp_name +]**</span>: [? if ddp_ideology == "Правые": Этатистский либерализм ?][? if ddp_ideology == "Умеренные": Классический либерализм ?][? if ddp_ideology == "Левые": Левый либерализм ?]([+ ddp_leader +]) ?]

[? if lvp_formed and not lvp_dnef: <span class="tooltip-text" title="Либеральная народная партия" style="color: #FFCC00;">**ЛНП**</span>: [? if lvp_ideology == "Левые": Левый либерализм ([+ lvp_leader +]) ?][? if lvp_ideology == "Умеренные": Классический либерализм ([+ lvp_leader +]) ?][? if lvp_ideology == "Правые": Национал-либерализм ([+ lvp_leader +]) ?] ?]

[? if lvp_formed and lvp_dnef: <span class="tooltip-text" title="Либеральная народная партия" style="color: #FFCC00;">**ЛНП**</span>: Либеральный корпоративизм ([+ lvp_leader +]) ?]

[? if not ddp_name and not lvp_formed: НЕИНИЦИАЛИЗИРОВАНО ?][? if not lvp_formed and dvp_exist and ddp_name != 0 and not dvp_dnef: [? if ddp_name != 0 and dvp_leader != "Тиль" and dvp_leader != "Глацель": <span class="tooltip-text" title="Немецкая народная партия" style="color: #C0A054;">**ННП**</span>: [? if dvp_ideology = "Левые": Классический либерализм ?][? if dvp_ideology = "Умеренные": Консервативный либерализм ?][? if dvp_ideology = "Правые" and (dvp_right - dvp_left < 10 or dvp_leader == "Stresemann"): Национал-либерализм ?][? if dvp_ideology = "Правые" and dvp_right - dvp_left >= 10 and dvp_leader != "Stresemann": Национал-капитализм ?] ([+ dvp_leader +]) ?][? if ddp_name != 0 and (dvp_leader == "Тиль" or dvp_leader == "Глацель"): <span class="tooltip-text" title="Немецкая народная партия" style="color: #C0A054;">**ННП**</span>: Патерналистский либерализм ([+ dvp_leader +]) ?] ?]

[? if not lvp_formed and dvp_exist and ddp_name != 0 and dvp_dnef: <span class="tooltip-text" title="Немецкая народная партия" style="color: #C0A054;">**ННП**</span>: Национал-либерализм ([+ dvp_leader +]) ?]

[? if not ddp_name: НЕИНИЦИАЛИЗИРОВАНО ?][? if ddp_name != 0: <span class="tooltip-text" title="Коммунистическая партия Германии" style="color: #700000;">**КПГ**</span>: [? if kpd_leader = "Примиренцы": Марксизм-Ленинизм: народный фронт ?][? if kpd_leader = "Тельман": Марксизм-Ленинизм: класс против класса ?] ([+ kpd_leader +]) ?]

[? if kvp_formed and not dnvp_dvp_formed: <span class="tooltip-text" title="Консервативная народная партия" style="color: #0087DC;">**КНП**</span>: [? if not kvp_dnef: Христианский консерватизм ?][? if kvp_dnef: Национал-консерватизм ?]([+ kvp_leader +]) ?]

[? if dnvp_dvp_formed: <span class="tooltip-text" title="Свободно-консервативная партия" style="color: #00C0FF;">**СКП**</span>: [+ fkp_ideology +]: ([+ fkp_leader +]) ?]

[? if not ddp_name: НЕИНИЦИАЛИЗИРОВАНО ?][? if ddp_name != 0 and not cvp_formed and not dnvp_dnef and not dnvp_defunct: <span class="tooltip-text" title="Немецкая национальная народная партия" style="color: #3E88B3;">**НННП**</span>: [? if dnvp_leader = "Гугенберг" or dnvp_leader = "Триумвират": Авторитарный консерватизм ?][? if dnvp_leader = "Вестарп" or dnvp_leader = "Хергт" or dnvp_leader == "Лежён-Юнг" or dnvp_leader == "Койдель": Национал-консерватизм ?][? if dnvp_leader = "Ламбах": Христианский корпоративизм ?][? if dnvp_leader = "Тревиранус" and not true_christian_democracy: Национал-консерватизм ?][? if dnvp_leader = "Тревиранус" and true_christian_democracy: Тори-демократия ?][? if dnvp_leader = "Шиле": Аграрный консерватизм ?] ([+ dnvp_leader +]) ?]

[? if ddp_name != 0 and not cvp_formed and dnvp_dnef: <span class="tooltip-text" title="Немецкая национальная народная партия" style="color: #3E88B3;">**НННП**</span>: [? if dnvp_leader == "Ламбах": Христианский корпоративизм ?][? if dnvp_leader == "Тревиранус": Национал-консерватизм ?] ([+ dnvp_leader +]) ?]

[? if dnf_formed : <span class="tooltip-text" title="Национальный фронт Германии" style="color: #003755;">**НФГ**</span>: Авторитарный консерватизм (Гугенберг) ?]

[? if dsu_exist: <span class="tooltip-text" title="Немецкий социальный союз" style="color: #6A1E1E;">**НСС**</span>: [? if not dsu_alt: Штрассеризм ?][? if dsu_alt: Центристский нацизм ?] ([+ dsu_leader +]) ?]

[? if not ddp_name: НЕИНИЦИАЛИЗИРОВАНО ?][? if ddp_name != 0: <span class="tooltip-text" title="Национал-социалистическая немецкая рабочая партия (нацисты)" style="color: #7A3C00;">**НСДАП**</span>: Национал-социализм ([+ nsdap_leader +]) ?]

[? if nvf_exist: <span class="tooltip-text" title="Национальный Народный фронт" style="color: #142e20;">**ННФ**</span>: Революционное фёлькише (Рём) ?]

= Поддержка промышленников

[? if dnef_formed: <span class="tooltip-text" title="Фронт Национального Единства Германии" style="color: #BFC8CC;">**ФНЕГ**</span>: [? if industrial_dnef_backing == 3: высокий ?][? if industrial_dnef_backing == 4: высочайший ?]  ?]

[? if z_party_name == "ХНП": <span class="tooltip-text" title="Христианская народная партия" style="color: #000000;">**[+ z_party_name +]**</span>: [? if industrial_z_backing == 3: высокий ?][? if industrial_z_backing == 4: высочайший ?]   ?]

[? if not lvp_formed: [? if ddp_name == "НГП": <span class="tooltip-text" title="Немецкая государственная партия" style="color: #D3C24D;">**[+ ddp_name +]**</span> ?][? if ddp_name == "НДП": <span class="tooltip-text" title="Немецкая демократическая партия" style="color: #D3C24D;">**[+ ddp_name +]**</span> ?]: [? if industrial_ddp_backing == 0: нет ?][? if industrial_ddp_backing == 1: низкий ?][? if industrial_ddp_backing == 2: средний ?]   ?]

[? if lvp_formed: <span class="tooltip-text" title="Liberal People's Party" style="color: #FFCC00;">**ЛНП**</span>: [? if industrial_lvp_backing == 2: средний ?][? if industrial_lvp_backing == 3: высокий ?][? if industrial_lvp_backing == 4: высочайший ?]  ?]

[? if not lvp_formed and dvp_exist: <span class="tooltip-text" title="Немецкая народная партия" style="color: #C0A054;">**ННП**</span>: [? if industrial_dvp_backing == 1: низкий ?][? if industrial_dvp_backing == 2: средний ?][? if industrial_dvp_backing == 3: высокий ?]  ?]

[? if not cvp_formed and not dnvp_defunct: <span class="tooltip-text" title="Немецкая национальная народная партия" style="color: #3E88B3;">**НННП**</span>: [? if industrial_dnvp_backing == 4: наивысший ?][? if industrial_dnvp_backing == 3: высокий ?][? if industrial_dnvp_backing == 2: средний ?][? if industrial_dnvp_backing == 1: низкий ?][? if industrial_dnvp_backing == 0: [? if dnvp_ideology == "Умеренные": нет ?][? if dnvp_ideology == "Радикалы": Финансируется Гугенбергом ?] ?] ?]

[? if dnvp_ideology == "Умеренные": <span class="tooltip-text" title="Национальный Фронт Германии" style="color: #003755;">**НФГ**</span>: Финансируется Гугенбергом ?]

[? if kvp_formed and not dnvp_dvp_formed: <span class="tooltip-text" title="Консервативная народная партия" style="color: #0087DC;">**КНП**</span>: высокий ?]

[? if dnvp_dvp_formed: <span class="tooltip-text" title="Свободно-консервативная партия" style="color: #00C0FF;">**СКП**</span>: высокий ?]

[? if dsu_exist: <span class="tooltip-text" title="Немецкий Социальный союз" style="color: #6A1E1E;">**НСС**</span>: нет ?]

<span class="tooltip-text" title="Национал-социалистическая немецкая рабочая партия (нацисты)" style="color: #7A3C00;">**НСДАП**</span>: [? if industrial_nsdap_backing == 0: нет ?][? if industrial_nsdap_backing == 1: низкий ?][? if industrial_nsdap_backing == 2: средний ?]

[? if nvf_exist: <span class="tooltip-text" title="Национальный Народный фронт" style="color: #142e20;">**ННФ**</span>: нет ?]

= Фракции <span style="color: #c00000;">**СДПГ**</span>

<span class="tooltip-text" title="Левые заинтересованы в радикальной, меняющей общество политике и сотрудничестве с КПГ.">Левые</span> сила: [+ left_strength : strength +], недовольство: [+ left_dissent : dissent +]

<span class="tooltip-text" title="Центр — это фракция центристов-марксистов, находящаяся между реформой и революцией.">Центристы</span> сила: [+ center_strength : strength +], недовольство: [+ center_dissent : dissent +]

<span class="tooltip-text" title="Цель профсоюзного крыла — экономические реформы и льготы для организованных рабочих.">Профсоюзники</span> сила: [+ labor_strength : strength +], недовольство: [+ labor_dissent : dissent +]

<span class="tooltip-text" title="Реформисты — это прагматики, сторонники участия в правительствах. Стремятся к расширению социального государства и защите демократии.">Реформисты</span> сила: [+ reformist_strength : strength +], недовольство: [+ reformist_dissent : dissent +]

[? if neorevisionism: <span class="tooltip-text" title="Неоревизионисты сосредотачиваются на защите республики и расширении демократии, поддерживая новые методы пропаганды и внепарламентские действия">Неоревизионисты</span> сила: [+ neorevisionist_strength : strength +], недовольство: [+ neorevisionist_dissent : dissent +] ?]


@paramilitaries
on-arrival: {!
Q.rb_strength_2 = Q.rb_strength.toFixed(1);
Q.rfb_strength_2 = Q.rfb_strength.toFixed(1);
Q.sh_strength_2 = Q.sh_strength.toFixed(1);
Q.sa_strength_2 = Q.sa_strength.toFixed(1);
!}

= Военизированные организации

<span class="tooltip-text" title="Рейхсбаннер «Шварц-Рот-Гольд» — массовая организация по защите демократии, в основном связанная со СДПГ." style="color: #c00000;">**Рейхсбаннер**</span> Численность: [+ rb_strength_2 +] тыс.

<span style="color: #c00000;">**Рейхсбаннер**</span> Военизация: [+ rb_militancy : militancy +]

<span class="tooltip-text" title="СКФ (Союз красных фронтовиков) — коммунистическая военизированная организация, связанная с КПГ." style="color: #8B0000;">**СКФ**</span> Численность: [+ rfb_strength_2 +] тыс.

<span style="color: #8B0000;">**СКФ**</span> Военизация: [+ rfb_militancy : militancy +]

<span class="tooltip-text" title="Стальной шлем — правая организация ветеранов войны, связанная с НННП." style="color:#3E88B3;">**Стальной Шлем**</span> Численность: [+ sh_strength_2 +] тыс.

<span style="color: #3E88B3;">**Стальной Шлем**</span> Военизация: [+ sh_militancy : militancy +]

<span class="tooltip-text" title="СА (Штурмовые отряды) — военизированное формирование нацистской партии." style="color: #7A3C00;">**СА**</span> Численность: [+ sa_strength_2 +] тыс.

<span style="color: #7A3C00;">**СА**</span> Военизация: [+ sa_militancy : militancy +]

[? if year >= 1930 and not streetfighting_joever: <h1>Распределение сил</h1> ?]

[? if year >= 1930 and not streetfighting_joever: <h4>[? if not kpd_truce: <span style="color: #000000;">Дем</span><span style="color: #DD0000;">окра</span><span style="color: #FFCC00;">тические</span>  ?][? if kpd_truce: анти<span style="color: #7A3C00;">фашистские</span>  ?]силы: [+ democracy_force +]%</h4> ?]

[? if year >= 1930 and not streetfighting_joever: <span style="color: #c00000;">**Рейхсбаннер**</span>: [+ rb_force +]% ?]

[? if year >= 1930 and not streetfighting_joever and prussia_leader != "Папен" and prussia_leader != "Шлейхер" and prussia_leader != "Штрассер": <b>Полиция Пруссии: [+ prussia_force +]%</b> ?]

[? if year >= 1930 and not streetfighting_joever and kpd_truce: <span style="color: #8B0000;">**СКФ**</span>: [+ rfb_force +]% ?]

[? if year >= 1930 and not streetfighting_joever: <h4><span style="color: #7A3C00;">Ультра</span><span style="color: #3E88B3;">правые</span> силы: [+ far_right_force +]%</h4> ?]

[? if year >= 1930 and not streetfighting_joever: <span style="color: #7A3C00;">**СА**</span>: [+ sa_force +]% ?]

[? if year >= 1930 and not streetfighting_joever: <span style="color: #3E88B3;">**Стальной Шлем**</span>: [+ sh_force +]% ?]

[? if year >= 1930 and not streetfighting_joever and not kpd_truce: <span style="color: #8B0000;">**СКФ**</span>: [+ rfb_force +]% ?]

[? if year >= 1930 and not streetfighting_joever and (prussia_leader == "Папен" or prussia_leader == "Шлейхер" or prussia_leader == "Штрассер") or reichswehr_street: <h4><span style="color: #BFC8CC;">**Государственные**</span> силы: [+ state_force +]%</h4> ?]

[? if year >= 1930 and not streetfighting_joever and prussia_leader == "Папен" or prussia_leader == "Шлейхер" or prussia_leader == "Штрассер": <b>Полиция Пруссии: [+ prussia_force +]%</b> ?]

[? if year >= 1930 and not streetfighting_joever and reichswehr_street: <b>Жандармерия рейхсвера: [+ reichswehr_force +]%</b> ?]

[? if year >= 1930 and not streetfighting_joever: Сейчас улицы [? if far_right_paramilitary and rfb_force < far_right_force: [? if far_right_paramilitary_highest: полностью контролируются <span style="color: #7A3C00;">ультра</span><span style="color: #3E88B3;">правыми</span> ?][? if far_right_paramilitary_high: почти полностью контролируются <span style="color: #7A3C00;">ультра</span> <span style="color: #3E88B3;">правыми</span> ?][? if far_right_paramilitary_med: контролируются <span style="color: #7A3C00;">ультра</span><span style="color: #3E88B3;">правыми</span> ?][? if far_right_paramilitary_low: частично контролируются <span style="color: #7A3C00;">ультра</span><span style="color: #3E88B3;">правыми</span> ?][? if sa_paramilitary: , в основном жестокими <span style="color: #7A3C00;">**СА**</span> ?] ?][? if rfb_force >= far_right_force and far_right_paramilitary: контролируются <span style="color: #700000;">**СКФ**</span> ?][? if democracy_paramilitary and rfb_force < democracy_force: [? if democracy_paramilitary_highest: полностью контролируются <span style="color: #000000;">респу</span><span style="color: #DD0000;">бли</span><span style="color: #FFCC00;">канцами</span> ?][? if democracy_paramilitary_high: почти полностью контролируются <span style="color: #000000;">республи</span><span style="color: #DD0000;">кан</span><span style="color: #FFCC00;">цами</span> ?][? if democracy_paramilitary_med: контролируются <span style="color: #000000;">респу</span><span style="color: #DD0000;">бли</span><span style="color: #FFCC00;">канцами</span> ?][? if democracy_paramilitary_low: частично контролируются <span style="color: #000000;">респу</span><span style="color: #DD0000;">бли</span><span style="color: #FFCC00;">канцами</span> ?] ?][? if rfb_force >= democracy_force and democracy_paramilitary: контролируются <span style="color: #700000;">**СКФ**</span> ?][? if state_paramilitary: [? if state_paramilitary_highest: полностью контролируются <span style="color: #BFC8CC;">**государством**</span> ?][? if state_paramilitary_high: почти полностью контролируются <span style="color: #BFC8CC;">**государством**</span> ?][? if state_paramilitary_med: контролируются <span style="color: #BFC8CC;">**государством**</span> ?][? if state_paramilitary_low: частично контролируются <span style="color: #BFC8CC;">**государством**</span> ?] ?]. ?]


= Официальные военные/военизированные формирования

Рейхсвер: [+ reichswehr_strength +] тысяч солдат.

Верность рейхсвера: [+ reichswehr_loyalty : loyalty +]

Прусская полиция: [+ prussian_police_strength +] тысяч сотрудников.

Верность прусской полиции: [+ prussian_police_loyalty : loyalty +]

[? if spd_in_government : Верность полиции министерства внутренних дел: [+ interior_police_loyalty : loyalty +] ?]


@polls
on-arrival: {!
Q.pro_republic_disp = Math.floor(Q.pro_republic);
Q.nationalism_disp = Math.floor(Q.nationalism);
Q.socialism_disp = Math.floor(Q.socialism);
!}

= Прогнозируемые результаты выборов

(если бы выборы состоялись сейчас):

[? if dnef_formed: <span style="color: #BFC8CC;">**ФНЕГ**</span>: [+ dnef_votes +]% ?]

<span style="color: #c00000;">**СДПГ**</span>: [+ spd_votes +]%

[? if sapd_formed: <span style="color: #9B0000;">**СРПГ**</span>: [+ sapd_votes +]% ?]

<span style="color: #000000;">**[+ z_party_name +]**</span> + <span style="color: #A2D8E0;">**БНП**</span>: [+ z_votes +]%

<span style="color: #700000;">**КПГ**</span>: [+ kpd_votes +]%

[? if not lvp_formed: [? if not ddp_name: <span style="color: #D3C24D;">**НДП**</span> ?][? if ddp_name != 0: <span style="color: #D3C24D;">**[+ ddp_name +]**</span> ?]: [+ ddp_votes +]% ?]

[? if lvp_formed: <span style="color: #FFCC00;">**ЛНП**</span>: [+ lvp_votes +]% ?]

[? if not lvp_formed and dvp_exist: <span style="color: #C0A054;">**ННП**</span>: [+ dvp_votes +]% ?]

[? if kvp_formed and not dnvp_dvp_formed: <span style="color: #0087DC;">**КНП**</span>: [+ kvp_votes +]% ?]

[? if dnvp_dvp_formed: <span class="tooltip-text" title="Свободно-консервативная партия" style="color: #00C0FF;">**СКП**</span>: [+ kvp_votes +]% ?]

[? if not cvp_formed and not dnvp_defunct: <span style="color: #3E88B3;">**НННП**</span>: [+ dnvp_votes +]% ?]

