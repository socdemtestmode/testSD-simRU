Бумке (и.о.)" or president == "Зект": <span style="color: #808080;">[+ president +]</span> ?][? if president == "Хаммерштейн": <span style="color: #BFC8CC;">[+ president +]</span> ?][? if president == "Манн" or president == "Осецкий": <span style="color: #E0A0A0;">[+ president +]</span> ?][? if president == "Эйнштейн": <span style="color: #CFC88F;">[+ president +]</span> ?] ([? if (president == "Аденауэр" or president == "Брюнинг" or president == "Штегервальд") or ((president == "Вестарп" or president == "Леттов-Форбек") and cvp_formed): <span style="color: #000000;">**[+ z_party_name +]**</span> ?][? if president == "Браун" or president == "Шумахер" or president == "Вельс" or president == "Юхач" or (president == "Розенфельд" and not left_split): <span style="color: #c00000;">**СДПГ**</span> ?][? if president == "Розенфельд" and left_split: <span style="color: #9B0000;">**СРПГ**</span> ?][? if president == "Тельман" or president == "Мюнценберг": <span style="color: #700000;">**КПГ**</span> ?][? if president == "Зельдте" or president == "Хергт" or ((president == "Вестарп" or president == "Леттов-Форбек") and dnvp_ideology == "Умеренные" and not cvp_formed): <span style="color: #3E88B3;">**НННП**</span> ?][? if (president == "Вестарп" or president == "Леттов-Форбек") and dnvp_ideology == "Радикалы" and not cvp_kvp_formed: <span style="color: #0087DC;">**КНП**</span> ?][? if president == "Гитлер" or president == "Геринг" or president == "Фрик": <span style="color: #7A3C00;">**НСДАП**</span> ?][? if (president == "Гесслер" or president == "Хойс") and not lvp_formed: <span style="color: #D3C24D;">**[+ ddp_name +]**</span> ?][? if (president == "Лютер" or president == "Яррес") and not lvp_formed: <span style="color: #C0A054;">**ННП**</span> ?][? if (president == "Гесслер" or president == "Хойс" or president == "Яррес" or president == "Лютер") and lvp_formed: <span style="color: #FFCC00;">**ЛНП**</span> ?][? if president == "Эккенер" or president == "Гинденбург" or president == "Großmann (acting)" or president == "Бумке (и.о.)" or president == "Зект": <span style="color: #808080;">б/п</span> ?][? if president == "Хаммерштейн": <span style="color: #BFC8CC;">**ФНЕГ**</span> ?][? if president == "Манн" or president == "Осецкий": <span style="color: #E0A0A0;">б/п</span> ?][? if president == "Эйнштейн": <span style="color: #CFC88F;">б/п</span> ?])

Рейхсканцлер: [? if chancellor_party == "СДПГ": <span style="color: #c00000;">[+ chancellor +]</span> ?][? if chancellor_party == "Центр": <span style="color: #000000;">[+ chancellor +]</span> ?][? if chancellor_party == "НСДАП": <span style="color: #7A3C00;">[+ chancellor +]</span> ?][? if chancellor_party == "НСС": <span style="color: #6A1E1E;">[+ chancellor +]</span> ?][? if chancellor_party == "КПГ": <span style="color: #700000;">[+ chancellor +]</span> ?][? if chancellor_party == "НННП": <span style="color: #3E88B3;">[+ chancellor +]</span> ?][? if (chancellor == "Шлейхер" and not dnef_formed) or chancellor == "Папен": <span style="color: #808080;">[+ chancellor +]</span> ?][? if (chancellor == "Шлейхер" or chancellor == "Гёрделер" or chancellor == "Bredow") and dnef_formed: <span style="color: #BFC8CC;">[+ chancellor +]</span> ?][? if chancellor == "Гёрделер" and not dnef_formed: <span style="color: #808080;">[+ chancellor +]</span> ?] ([? if chancellor_party == "Центр": <span style="color: #000000;">**[+ z_party_name +]**</span> ?][? if chancellor_party == "СДПГ": <span style="color: #c00000;">**СДПГ**</span> ?][? if chancellor_party == "КПГ": <span style="color: #700000;">**КПГ**</span> ?][? if chancellor_party == "НННП": <span style="color: #3E88B3;">**НННП**</span> ?][? if chancellor_party == "НСС": <span style="color: #6A1E1E;">**НСС**</span> ?][? if chancellor_party == "НСДАП": <span style="color: #7A3C00;">**НСДАП**</span> ?][? if chancellor_party == "I": <span style="color: #808080;">б/п</span> ?][? if chancellor_party == "ФНЕГ": <span style="color: #BFC8CC;">**ФНЕГ**</span> ?])

Министр-президент Пруссии: [? if prussia_leader = "Браун" and (chancellor != nsdap_chancellor or (rubicon_mini and not game_over)): <span style="color: #c00000;">Браун</span> (<span style="color: #c00000;">**СДПГ**</span>) ?][? if prussia_leader = "Розенфельд" and not left_split and (chancellor != nsdap_chancellor or (rubicon_mini and not game_over)): <span style="color: #c00000;">Розенфельд</span> (<span style="color: #c00000;">**СДПГ**</span>) ?][? if prussia_leader = "Розенфельд" and left_split and (chancellor != nsdap_chancellor or (rubicon_mini and not game_over)): <span style="color: #9B0000;">Розенфельд</span> (<span style="color: #9B0000;">**СРПГ**</span>) ?][? if prussia_leader = "Штегервальд" and (chancellor != nsdap_chancellor or (rubicon_mini and not game_over)): <span style="color: #000000;">Штегервальд</span> (<span style="color: #000000;">**[+ z_party_name +]**</span>) ?][? if prussia_leader = "Брюнинг" and (chancellor != nsdap_chancellor or (rubicon_mini and not game_over)): <span style="color: #000000;">Брюнинг</span> (<span style="color: #000000;">**[+ z_party_name +]**</span>) ?][? if prussia_leader = "Лютер" and (chancellor != nsdap_chancellor or (rubicon_mini and not game_over)) and not lvp_formed and dvp_exist: <span style="color: #C0A054;">Лютер</span> (<span style="color: #C0A054;">**ННП**</span>) ?][? if prussia_leader = "Лютер" and (chancellor != nsdap_chancellor or (rubicon_mini and not game_over)) and not lvp_formed and not dvp_exist: <span style="color: #D3C24D;">Лютер</span> (<span style="color: #D3C24D;">**ННП**</span>) ?][? if prussia_leader = "Лютер" and (chancellor != nsdap_chancellor or (rubicon_mini and not game_over)) and lvp_formed: <span style="color: #FFCC00;">Лютер</span> (<span style="color: #FFCC00;">**ЛНП**</span>) ?][? if prussia_leader = "Геринг": <span style="color: #7A3C00;">Геринг</span> (<span style="color: #7A3C00;">**НСДАП**</span>) ?][? if (prussia_leader = "Папен" or (chancellor == nsdap_chancellor and (not rubicon_mini or game_over)) and not prussia_leader == "Геринг") and started: <span style="color: #808080;">Папен</span> (<span style="color: #808080;">I</span>) ?][? if prussia_leader = "Шлейхер" and (chancellor != nsdap_chancellor or (rubicon_mini and not game_over)): [? if not dnef_formed: <span style="color: #808080;">Шлейхер</span> ?][? if dnef_formed: <span style="color: #BFC8CC;">Шлейхер</span> ?]([? if not dnef_formed: <span style="color: #808080;">б/п</span> ?][? if dnef_formed: <span style="color: #BFC8CC;">**ФНЕГ**</span> ?]) ?][? if prussia_leader = "Гёрделер" and (chancellor != nsdap_chancellor or (rubicon_mini and not game_over)): <span style="color: #808080;">Гёрделер</span> (<span style="color: #808080;">I</span>) ?][? if prussia_leader = "Штрассер" and (chancellor != nsdap_chancellor or (rubicon_mini and not game_over)): <span style="color: #6A1E1E;">Штрассер</span> (<span style="color: #6A1E1E;">**НСС**</span>) ?][? if prussia_leader = "joavig" and (chancellor != nsdap_chancellor or (rubicon_mini and not game_over)): <span style="color: #700000;">joavig</span> (<span style="color: #7A3C00;">**НСДАП**</span>) ?]

Состав Рейхстага:

[? if dnef_formed: <span class="tooltip-text" title="Фронт Национального Единства Германии" style="color: #BFC8CC;">**ФНЕГ**</span>: [+ dnef_r +]% ?] <span class="tooltip-text" title="Социал-демократическая партия Германии" style="color: #c00000;">**СДПГ**</span>: [+ spd_r +]%[? if sapd_formed and sapd_r > 0: <span class="tooltip-text" title="Социалистическая Рабочая Партия Германии" style="color: #9B0000;">**СРПГ**</span>: [+ sapd_r +]% ?] [? if started: [? if z_party_name != "ХНП": <span class="tooltip-text" title="Партия Центра + Баварская народная партия"><span style="color: #000000;">**[+ z_party_name +]**</span> + <span style="color: #A2D8E0;">**БНП**</span></span> ?][? if z_party_name == "ХНП": <span class="tooltip-text" title="Христианская народная партия + Баварская народная партия"><span style="color: #000000;">**[+ z_party_name +]**</span> + <span style="color: #A2D8E0;">**БНП**</span></span> ?] ?][? if not started: <span class="tooltip-text" title="Партия Центра + Баварская народная партия"><span style="color: #000000;">**Центр**</span> + <span style="color: #A2D8E0;">**БНП**</span></span> ?]: [+ z_r +]% <span class="tooltip-text" title="Коммунистическая партия Германии" style="color: #700000;">**КПГ**</span>: [+ kpd_r +]%[? if lvp_formed: <span class="tooltip-text" title="Либеральная Народная партия" style="color: #FFCC00;">**ЛНП**</span>: [+ lvp_r +]% ?] [? if (not lvp_formed or not ddp_name) : [? if not ddp_name: <span class="tooltip-text" title="Немецкая демократическая партия" style="color: #D3C24D;">**НДП**</span> ?][? if ddp_name = "НДП": <span class="tooltip-text" title="Немецкая демократическая партия" style="color: #D3C24D;">**[+ ddp_name +]**</span> ?][? if ddp_name = "НГП": <span class="tooltip-text" title="Немецкая государственная партия" style="color: #D3C24D;">**[+ ddp_name +]**</span> ?]: [+ ddp_r +]% ?] [? if not lvp_formed and dvp_exist : <span class="tooltip-text" title="Немецкая народная партия" style="color: #C0A054;">**ННП**</span>: [+ dvp_r +]% ?] [? if kvp_formed and not dnvp_dvp_formed : <span class="tooltip-text" title="Консервативная народная партия" style="color: #0087DC;">**КНП**</span>: [+ kvp_r +]% ?] [? if dnvp_dvp_formed: <span class="tooltip-text" title="Свободно-консервативная партия" style="color: #00C0FF;">**СКП**</span>: [+ kvp_r +]% ?] [? if not cvp_formed and not dnvp_defunct: <span class="tooltip-text" title="Немецкая национальная народная партия" style="color: #3E88B3;">**НННП**</span>: [+ dnvp_r +]% ?] [? if dnf_formed: <span class="tooltip-text" title="Национальный Фронт Германии" style="color: #003755;">**НФГ**</span>: [+ dnf_r +]% ?] [? if dsu_exist: <span class="tooltip-text" title="Немецкий социальный союз" style="color: #6A1E1E;">**НСС**</span>: [+ dsu_r +]% ?] [? if not nsdap_split: <span class="tooltip-text" title="Национал-социалистическая немецкая рабочая партия (нацисты)" style="color: #7A3C00;">**НСДАП**</span>: [+ nsdap_r +]% ?] [? if nsdap_split: <span class="tooltip-text" title="Национал-социалистическая немецкая рабочая партия (нацисты)" style="color: #7A3C00;">**НСДАП**</span>: [+ nsdap_hitler_r +]% ?] [? if nvf_exist: <span class="tooltip-text" title="Национальный Народный фронт" style="color: #142e20;">**ННФ**</span>: [+ nvf_r +]% ?] **Прочие**: [+ other_r +]%

[? if spd_in_government = 1 : Бюджет: [+ budget +]  ?]

Следующие выборы: [+ next_election_month : month +] [+ next_election_year +]

Следующие выборы в Пруссии: [? if prussia_leader != "Папен" and prussia_leader != "Шлейхер": [+ next_election_month_prussia : month +] [+ next_election_year_prussia +][? if rubicon: , неделя [+ next_election_week_prussia +]  ?]  ?][? if prussia_leader == "Папен" or prussia_leader == "Шлейхер": отложены на неопределённый срок ?]

