 <span style="color: #6A1E1E;">[+ vice_chancellor +]</span> ?][? if vice_chancellor == "Штегервальд": <span style="color: #000000;">[+ vice_chancellor +]</span> ?][? if vice_chancellor == "Папен":  (<span style="color: #808080;">б/п</span>)  ?][? if vice_chancellor == "Штрассер":  (<span style="color: #6A1E1E;">**НСС**</span>) ?][? if vice_chancellor == "Штегервальд": (<span style="color: #000000;">**Центр**</span>) ?][? if vice_chancellor == "Хаммерштейн": (<span style="color: #BFC8CC;">**ФНЕГ**</span>) ?][? if not vice_chancellor: Вакантно ?]</div> <div style="text-align: center;">Министр-президент Пруссии: [? if prussia_leader = "Браун" and chancellor != nsdap_chancellor: <span style="color: #c00000;">Браун</span> (<span style="color: #c00000;">**СДПГ**</span>) ?][? if prussia_leader = "Розенфельд" and not left_split and chancellor != nsdap_chancellor: <span style="color: #c00000;">Розенфельд</span> (<span style="color: #c00000;">**СДПГ**</span>) ?][? if prussia_leader = "Розенфельд" and left_split and chancellor != nsdap_chancellor: <span style="color: #9B0000;">Розенфельд</span> (<span style="color: #9B0000;">**СРПГ**</span>) ?][? if prussia_leader = "Штегервальд" and chancellor != nsdap_chancellor: <span style="color: #000000;">Штегервальд</span> (<span style="color: #000000;">**[+ z_party_name +]**</span>) ?][? if prussia_leader = "Брюнинг" and chancellor != nsdap_chancellor: <span style="color: #000000;">Брюнинг</span> (<span style="color: #000000;">**[+ z_party_name +]**</span>) ?][? if prussia_leader = "Лютер" and chancellor != nsdap_chancellor and not lvp_formed and dvp_exist: <span style="color: #C0A054;">Лютер</span> (<span style="color: #C0A054;">**ННП**</span>) ?][? if prussia_leader = "Лютер" and chancellor != nsdap_chancellor and not lvp_formed and not dvp_exist: <span style="color: #D3C24D;">Лютер</span> (<span style="color: #D3C24D;">**ННП**</span>) ?][? if prussia_leader = "Лютер" and chancellor != nsdap_chancellor and lvp_formed: <span style="color: #FFCC00;">Лютер</span> (<span style="color: #FFCC00;">**ЛНП**</span>) ?][? if prussia_leader = "Геринг": <span style="color: #7A3C00;">Геринг</span> (<span style="color: #7A3C00;">**НСДАП**</span>) ?][? if prussia_leader = "Папен" or (chancellor == nsdap_chancellor and (not rubicon_mini or game_over)) and not prussia_leader == "Геринг": <span style="color: #808080;">Папен</span> (<span style="color: #808080;">I</span>) ?][? if prussia_leader = "Шлейхер" and chancellor != nsdap_chancellor: [? if not dnef_formed: <span style="color: #808080;">Шлейхер</span> ?][? if dnef_formed: <span style="color: #BFC8CC;">Шлейхер</span> ?]([? if not dnef_formed: <span style="color: #808080;">б/п</span> ?][? if dnef_formed: <span style="color: #BFC8CC;">**ФНЕГ**</span> ?]) ?][? if prussia_leader = "Гёрделер" and chancellor != nsdap_chancellor: [? if not dnef_formed: <span style="color: #808080;">Гёрделер</span> (<span style="color: #808080;">I</span>) ?][? if dnef_formed: <span style="color: #BFC8CC;">Гёрделер</span> (<span style="color: #BFC8CC;">**ФНЕГ**</span>) ?] ?][? if prussia_leader = "Штрассер" and chancellor != nsdap_chancellor: <span style="color: #6A1E1E;">Штрассер</span> (<span style="color: #6A1E1E;">**НСС**</span>) ?][? if prussia_leader = "joavig" and chancellor != nsdap_chancellor: <span style="color: #700000;">joavig</span> (<span style="color: #7A3C00;">**НСДАП**</span>) ?]</div>[? if chancellor == "Папен": <div style="display: flex;gap: 5px;margin-bottom: 5px;margin-left: -3px;"><img src="img/portraits/PapenFranz.jpg" alt="Franz von Papen" style="width: 50%;">  ?][? if chancellor == "Шлейхер" and not schleicher_portrait: <div style="display: flex;gap: 5px;margin-bottom: 5px;margin-left: -3px;"><img src="img/portraits/SchleicherKurt.jpg" alt="Курт фон Шлейхер" style="width: 50%;">  ?][? if chancellor == "Шлейхер" and schleicher_portrait: <div style="display: flex;gap: 5px;margin-bottom: 5px;margin-left: -3px;"><img src="img/portraits/schleicher_cooler.jpg" alt="Курт фон Шлейхер" style="width: 50%;">  ?][? if chancellor == "Гёрделер": <div style="display: flex;gap: 5px;margin-bottom: 5px;margin-left: -3px;"><img src="img/portraits/goerdeler.jpg" alt="Carl Friedrich Goerdeler" style="width: 50%;">  ?][? if chancellor == "Bredow": <div style="display: flex;gap: 5px;margin-bottom: 5px;margin-left: -3px;"><img src="img/portraits/bredow.jpg" alt="Фердинанд фон Бредов" style="width: 50%;">  ?][? if chancellor == "Тревиранус": <div style="display: flex;gap: 5px;margin-bottom: 5px;margin-left: -3px;"><img src="img/portraits/Тревиранус.jpg" alt="Gottfried Reinhold Тревиранус" style="width: 50%;">  ?][? if chancellor == "Гитлер": <div style="display: flex;gap: 5px;margin-bottom: 5px;margin-left: -3px;"><img src="img/portraits/hitler2.jpg" alt="Adolf Hitler" style="width: 50%;">  ?][? if chancellor == "Геринг": <div style="display: flex;gap: 5px;margin-bottom: 5px;margin-left: -3px;"><img src="img/portraits/goring.jpg" alt="Hermann Goering" style="width: 50%;">  ?][? if vice_chancellor == "Папен": <img src="img/portraits/PapenFranz.jpg" alt="Franz von Papen" style="width: 50%;"></div>  ?][? if vice_chancellor == "Штрассер": <img src="img/portraits/strasser.jpg" alt="Gregor Strasser" style="width: 50%;"></div>  ?][? if vice_chancellor == "Штегервальд": <img src="img/portraits/stegerwald.jpg" alt="Adam Штегервальд" style="width: 50%;"></div>  ?][? if vice_chancellor == "Хаммерштейн": <img src="img/portraits/hammerstein.jpg" alt="Kurt von Hammerstein" style="width: 50%;"></div>  ?][? if not vice_chancellor: <img src="img/placeholder.jpg" alt="Vacant" style="width: 50%;"></div>  ?]Метод управления: президентские указы [? if chancellor == "Папен": Доверие Гинденбурга: [+ hindenburg_papen_r : confidence +]<br> ?] [? if chancellor == "Шлейхер": Доверие Гинденбурга: [+ hindenburg_schleicher_r : confidence +]<br> ?] [? if chancellor == "Шлейхер" or chancellor == "Bredow" or chancellor == "Гёрделер" or chancellor == "Тревиранус": [+ chancellor +] — популярность в народе: [+ schleicher_approval : schleicher_popularity +]<br> ?] [? if chancellor == "Папен": Доверие Шлейхера: [+ schleicher_papen_r : confidence +]<br> ?] [? if red_general_unlock: [? if chancellor == "Шлейхер" or not schleicher_post: Шлейхер ?][? if chancellor != "Шлейхер" and schleicher_post: Государство ?] — отношения с <span style="color: #c00000;">**СДПГ**</span>: [+ schleicher_spd_r : schleicher_spd +]<br> ?] [? if reichswehr_strength > 100 and chancellor == "Шлейхер": Рейхсвер: 100 тысяч солдат.<br> ?] [? if reichswehr_strength > 100 and chancellor == "Шлейхер": Государственная «милиция»: [+ reichswehr_strength - 100 +] тысяч солдат. ?]

= Правительство

[? if chancellor == "Шлейхер" and not schleicher_economy_time: Общественные работы: готовятся <br> ?][? if chancellor == "Шлейхер" and schleicher_economy_time: Общественные работы: проводятся <br> ?]Рейхстаг: [? if reichstag_rubicon: заседает ?][? if not reichstag_rubicon and not reichstag_break: распущен ?][? if next_reichstag_time > rubicon_time and next_reichstag_time and not reichstag_rubicon and next_election_time - time > 2: , вновь соберётся [+ next_reichstag_month : month +] [+ next_reichstag_year +], неделя [+ next_reichstag_week +]. ?][? if reichstag_break: отложен на неопределённый срок ?]<br> Следующие выборы: [? if not marburg_trigger: [+ next_election_month : month +] [+ next_election_year +], неделя [+ next_election_week +]  ?][? if marburg_trigger: отложены на неопределённый срок ?]<br> Следующие выборы в Пруссии: [? if prussia_leader != "Папен" and prussia_leader != "Шлейхер": [+ next_election_month_prussia : month +] [+ next_election_year_prussia +], неделя [+ next_election_week_prussia +]  ?][? if prussia_leader == "Папен" or prussia_leader == "Шлейхер": отложены на неопределённый срок ?] [? if chancellor == "Шлейхер" and year == 1933 and month < 2 and week < 3: <br>Следующие региональные выборы: январь 1933 г., неделя 3  ?]

= Партия

Доступные ресурсы: [+ resources +]<br> Внутренние разногласия: [+ dissent_percent : dissent +]<br> Поддержка Республики: [+ pro_republic_disp +]%<br>[? if red_general_unlock: Отношение <span style="color: #c00000;">**СДПГ**</span> к [? if chancellor == "Шлейхер" or not schleicher_post: Шлейхеру ?][? if chancellor != "Шлейхер" and schleicher_post: Государству ?]: [+ schleicher_spd_support : schleicher_spd_2 +]<br> ?] [? if schleicher_spd_influence and schleicher_time >= 8: [? if chancellor == "Шлейхер": Шлейхер ?][? if chancellor != "Шлейхер" and schleicher_post: Государство ?] — его влияние на <span style="color: #c00000;">**СДПГ**</span>: [+ schleicher_spd_influence : schleicher_spd_3 +]<br> ?]Финансовое положение <span style="color: #7A3C00;">**НСДАП**</span>: [+ nazi_funds : nazi_funds +]<br>[? if not streetfighting_joever: Сейчас улицы [? if far_right_paramilitary and rfb_force < far_right_force: [? if far_right_paramilitary_highest: полностью контролируются <span style="color: #7A3C00;">ультра</span> <span style="color: #3E88B3;">правыми</span> ?][? if far_right_paramilitary_high: почти полностью контролируются <span style="color: #7A3C00;">ультра</span> <span style="color: #3E88B3;">правыми</span> ?][? if far_right_paramilitary_med: контролируются <span style="color: #7A3C00;">ультра</span> <span style="color: #3E88B3;">правыми</span> ?][? if far_right_paramilitary_low: частично контролируются <span style="color: #7A3C00;">ультра</span><span style="color: #3E88B3;">правыми</span> ?][? if sa_paramilitary: , в основном жестокими <span style="color: #7A3C00;">**СА**</span> ?] ?][? if rfb_force >= far_right_force and far_right_paramilitary: контролируются <span style="color: #700000;">**СКФ**</span> ?][? if democracy_paramilitary and rfb_force < democracy_force: [? if democracy_paramilitary_highest: полностью контролируются <span style="color: #000000;">республи</span><span style="color: #DD0000;">кан</span><span style="color: #FFCC00;">цами</span> ?][? if democracy_paramilitary_high: почти полностью контролируются <span style="color: #000000;">республи</span><span style="color: #DD0000;">кан</span><span style="color: #FFCC00;">цами</span> ?][? if democracy_paramilitary_med: контролируются <span style="color: #000000;">республи</span><span style="color: #DD0000;">кан</span><span style="color: #FFCC00;">цами</span> ?][? if democracy_paramilitary_low: частично контролируются <span style="color: #000000;">респу</span><span style="color: #DD0000;">бли</span><span style="color: #FFCC00;">канцами</span> ?] ?][? if rfb_force >= democracy_force and democracy_paramilitary: контролируются <span style="color: #700000;">**СКФ**</span> ?][? if state_paramilitary: [? if state_paramilitary_highest: полностью контролируются <span style="color: #BFC8CC;">**государством**</span> ?][? if state_paramilitary_high: почти полностью контролируются <span style="color: #BFC8CC;">**государством**</span> ?][? if state_paramilitary_med: контролируются <span style="color: #BFC8CC;">**государством**</span> ?][? if state_paramilitary_low: частично контролируются <span style="color: #BFC8CC;">**Государства**</span> ?] ?]. ?]

