title: Финальные слайды
view-if: (chancellor != "Гитлер" and president != "Гитлер" and president != "Геринг" and (not total_defeat or papen_win)) or rubicon_mini
on-arrival: {!
const toolsWrapper = document.getElementById('tools_wrapper');
if (toolsWrapper) {
  toolsWrapper.style.display = 'none';
}
const elements = document.querySelectorAll('header, #content, footer');
elements.forEach(el => {
  el.style.maxWidth = '800px';
});

if (Q.president != "Хаммерштейн" && Q.president != "Гитлер" && Q.president != "Геринг" && Q.president != "Зельдте" && Q.chancellor != "Гитлер" && !Q.hammerstein_win && !(Q.president == "Хергт" && Q.chancellor == "Зельдте")) {
  Q.weimar_win = 1;
} else {
  Q.weimar_win = 0;
}

if (Q.weimar_win && (Q.president == "Розенфельд" || Q.president == "Тельман" || Q.president == "Мюнценберг" || Q.president == "Осецкий" || Q.president == "Манн") && Q.in_left_front && !Q.civil_war_seen) {
  Q.left_win = 1;
  Q.weimar_win = 0;
  Q.kpd_points = 0;
  Q.kpd_points += Q.rfb_force;
  Q.kpd_points += (100 - Q.pro_republic) / 2;
  Q.kpd_points += Q.unemployed / 2;
  Q.kpd_points += Q.kpd_votes;
  Q.kpd_points += Q.soviet_relation;
  if (Q.president == "Тельман") Q.kpd_points += 16;
  if (Q.president == "Мюнценберг") Q.kpd_points += 10;
  if (Q.kpd_leader == "Примиренцы") Q.kpd_points += 6;
  if (Q.sapd_formed) {
    Q.kpd_points += 2;
    Q.kpd_points += Q.sapd_votes;
  }
  if (Q.spd_votes < 26) Q.kpd_points += 5;
  if (Q.eu) Q.kpd_points -= 10;
  if (Q.spd_votes >= 36) Q.kpd_points -= 5;
  if (Q.spd_votes >= 40) Q.kpd_points -= 5;

  if (Q.kpd_points >= 50) {
    Q.kpd_win = 1;
  } else {
    Q.kpd_win = 0;
  }
}
!}
set-bg: img/paper.jpg
new-page: true

