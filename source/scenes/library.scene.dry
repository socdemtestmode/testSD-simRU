e="background-color: rgba(0, 31, 48, 0.2);">[+ catholics_dnf_display +]%</td>{!</tr>!}  ?]         [? if not nsdap_split: {!<tr>!}                         <td><span style="color: #7A3C00;">**НСДАП**</span></td> <td style="background-color: rgba(122, 60, 0, 0.2); padding: 10px;">[+ workers_nsdap_display +]%</td> <td style="background-color: rgba(122, 60, 0, 0.2);">[+ new_middle_nsdap_display +]%</td> <td style="background-color: rgba(122, 60, 0, 0.2);">[+ old_middle_nsdap_display +]%</td> <td style="background-color: rgba(122, 60, 0, 0.2);">[+ rural_nsdap_display +]%</td> <td style="background-color: rgba(122, 60, 0, 0.2);">[+ unemployed_nsdap_display +]%</td> <td style="background-color: rgba(122, 60, 0, 0.2);">[+ catholics_nsdap_display +]%</td>{!</tr>!}  ?]         [? if nsdap_split: {!<tr>!}                         <td><span style="color: #7A3C00;">**НСДАП**</span></td> <td style="background-color: rgba(106, 30, 30, 0.2); padding: 10px;">[+ workers_nsdap_display +]%</td> <td style="background-color: rgba(106, 30, 30, 0.2);">[+ new_middle_nsdap_display +]%</td> <td style="background-color: rgba(122, 60, 0, 0.2);">[+ old_middle_nsdap_display +]%</td> <td style="background-color: rgba(122, 60, 0, 0.2);">[+ rural_nsdap_display +]%</td> <td style="background-color: rgba(20, 46, 32, 0.2);">[+ unemployed_nsdap_display +]%</td> <td style="background-color: rgba(122, 60, 0, 0.2);">[+ catholics_nsdap_display +]%</td>{!</tr>!}  ?]{!<tr>!} <td>**Прочие**</td> <td style="background-color: rgba(153, 153, 153, 0.1); padding: 10px;">[+ workers_other_display +]%</td> <td style="background-color: rgba(153, 153, 153, 0.1);">[+ new_middle_other_display +]%</td> <td style="background-color: rgba(153, 153, 153, 0.1);">[+ old_middle_other_display +]%</td> <td style="background-color: rgba(153, 153, 153, 0.1);">[+ rural_other_display +]%</td> <td style="background-color: rgba(153, 153, 153, 0.1);">[+ unemployed_other_display +]%</td> <td style="background-color: rgba(153, 153, 153, 0.1)