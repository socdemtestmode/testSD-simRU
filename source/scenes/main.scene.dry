    }
}
// non-dingeldey complains about banking crisis, precursor to curtius resigning
if (Q.total_bruning_time > 0 && !Q.in_center_right_coalition && !Q.in_right_coalition && !Q.spd_toleration_right && Q.banking_crisis_seen && (Q.dvp_leader != "Dingeldey" && Q.dvp_leader != "Scholz") && !Q.lvp_formed && Q.dvp_exist && Q.chancellor == "Brüning" && Q.time !== Q.last_time_updated) {
    Q.flavour_57_trigger += 1; 
