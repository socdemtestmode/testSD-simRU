}
// dnvp spooked at nsdap gains
if (Q.total_bruning_time > 0 && (Q.in_center_right_coalition || Q.in_right_coalition) && Q.dnvp_scared_hitler && Q.chancellor == "Brüning" && Q.time !== Q.last_time_updated) {
