}
// dvp party conflict post 2nd bruning, pt 4
if (Q.dvp_leader == "Dingeldey" && !Q.lvp_formed && Q.time == Q.flavour_49_trigger_time + 1 && !Q.cvp_formed && Q.dnvp_ideology == "Radical" && Q.time !== Q.last_time_updated) {
