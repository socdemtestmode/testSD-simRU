}
// non-dingeldey complains bout emergency decree
if (Q.emergency_decree_seen && !Q.in_center_right_coalition && !Q.in_right_coalition && !Q.bourgeois_parliament && !Q.liberal_parliament && (Q.dvp_leader != "Dingeldey" && Q.dvp_leader != "Scholz") && !Q.dvp_defect && !Q.lvp_formed && Q.dvp_exist && Q.chancellor == "Brüning" && Q.time !== Q.last_time_updated) {
    Q.flavour_55_trigger += 1; 
    if (Q.flavour_55_trigger == 1 && !Q.flavour_55_trigger_shown) {
