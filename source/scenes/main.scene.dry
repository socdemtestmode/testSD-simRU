}
// dvp party conflict post 2nd bruning, pt 2
if (Q.dvp_leader == "Dingeldey" && !Q.lvp_formed && Q.time == Q.flavour_47_trigger_time + 1 && !Q.cvp_formed && Q.time !== Q.last_time_updated) {
