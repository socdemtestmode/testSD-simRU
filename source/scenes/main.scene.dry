}
// lvp complains bout emergency decree, no dingeldey, alt his
if ((Q.emergency_decree_seen || Q.emergency_decree_alt_seen) && (Q.in_center_right_coalition || Q.in_right_coalition || Q.spd_toleration_right) && Q.lvp_leader != "Dingeldey" && Q.lvp_formed && Q.chancellor == "Brüning" && !Q.cvp_formed && Q.time !== Q.last_time_updated) {
