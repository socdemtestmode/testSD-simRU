    }
}
// bruning hitler coalition
if (Q.total_bruning_time >= 21 && !Q.in_center_right_coalition && !Q.in_right_coalition && !Q.spd_toleration_right && Q.chancellor == "Brüning" && Q.time !== Q.last_time_updated) {
    Q.flavour_59_trigger += 1;
