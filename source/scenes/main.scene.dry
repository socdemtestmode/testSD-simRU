}
// dvp party conflict post 2nd bruning, pt 1
if (((Q.year == 1931 && Q.month >= 6 && Q.dvp_defect) || Q.year >= 1932) && Q.dvp_leader == "Dingeldey" && !Q.lvp_formed && Q.time !== Q.last_time_updated) {
