if (Q.total_bruning_time > 0 && (Q.in_center_right_coalition || Q.in_right_coalition || Q.spd_toleration_right) && Q.banking_crisis_seen && Q.lvp_leader == "Dingeldey" && Q.lvp_formed && Q.chancellor == "Brüning" && !Q.cvp_formed && Q.time !== Q.last_time_updated) {
    Q.flavour_44_trigger += 1; 
