!}
on-display: {!
if (!document.getElementById('news_tab')) {
    var button = document.createElement('button');
    button.style.backgroundColor = '#dddddd';
    button.className = 'tab_button';
    button.id = 'news_tab';
    button.textContent = 'View Right-Wing News';
    button.onclick = function () {
        toggleNews();
    };
    var contentDiv = document.getElementById('content');
    contentDiv.appendChild(button);
    const elements = document.querySelectorAll('.dnvp');
    let hasTextContent = false;
    elements.forEach(function (element) {
        if (element.textContent.trim() !== '') {
            hasTextContent = true;
        }
    });
    if (hasTextContent) {
        button.style.backgroundColor = 'rgba(255, 0, 0, 0.5)'; // New color
    } else {
        button.style.backgroundColor = '#dddddd'; // Original color
    }
    document.querySelectorAll('p').forEach(p => {
        if (!p.textContent.trim()) {
            p.remove();
        }
    });
}

const scrollableBox = document.querySelector('div.scrollable-box');

if (scrollableBox && !document.getElementById('ok') && Q.stimulation) {
  const video = document.createElement('video');
  video.id = 'ok';
  video.autoplay = true;
  video.muted = true;
  video.loop = true;
  video.style.width = '100%';

  const source = document.createElement('source');
  source.src = 'img/lol.mp4';
  source.type = 'video/mp4';

  video.appendChild(source);

  const randomStart = Math.random() * 3198;
  video.currentTime = randomStart;

  scrollableBox.parentNode.insertBefore(video, scrollableBox);
}

const boxes = document.querySelectorAll('.scrollable-box');
if (boxes.length >= 2) {
    boxes[1].remove();
}
!}
max-cards: 4

{!<div class="scrollable-box">!}

{!<p class="both">!}[? if year = 1928 and month = 1: Для немецкой демократии настали светлые времена. После периода трудностей, инфляция наконец взята под контроль, а экономика стабильно растёт. Во внешней политике мы достигли соглашений с западными державами и Советским Союзом, которые могут сделать долгосрочный мир реальностью. 

 Теперь задача социал-демократии — подготовиться к следующим выборам. Буржуазно-правое правительство Вильгельма Маркса непопулярно, и у нас есть все шансы на успех. Возможно, в следующем правительстве будет социалистическое большинство. ?]{!</p>!}

{!<p class="both">!}[? if year = 1928 and month = 2 : Нынешнее <span style="color: #000000;">буржуазно</span>-<span style="color: #3E88B3;">правое</span> правительство пало. Следующие выборы назначены на май этого года. ?]{!</p>!}

{!<p class="dnvp">!}[? if year = 1928 and month = 3 : Нишевые партии, такие как <span style="color: #b8996f;">Партия немецкого среднего класса</span> — обычно называемая <span style="color: #b8996f;">Экономической партией (ЭП)</span> (<span style="color: #b8996f;">**ЭП**</span>) — и <span style="color: #7FCEB1;">Христианско-национальная партия крестьян и земледельцев</span> (<span style="color: #7FCEB1;">**ХНПКЗ**</span>), как ожидается, получат значительное число мест в рейхстаге, поскольку многие считают, что признанные политические партии пренебрегают их интересами. Это негативно сказывается на <span style="color: #3E88B3;">**НННП**</span>, входившей в состав прошлого правительства. ?]{!</p>!}

{!<p class="other">!}[? if year = 1928 and month = 4 : Правые промышленники в <span style="color: #C0A054;">Народной партии</span> (<span style="color: #C0A054;">**ННП**</span>) набирают значительное влияние в партии, потому что её лидер и министр иностранных дел Густав Штреземан пренебрегал внутрипартийными делами. Перспектива создания Большой Коалиции с <span style="color: #C0A054;">**ННП**</span> становится всё сложнее, особенно с учётом ухудшающегося здоровья Штреземана. ?]{!</p>!}

{!<p class="other">!}[? if year = 1928 and month = 4 : Наша соседка <span style="color: #002654;">Франция</span> провела парламентские выборы, которые завершились поражением <span style="color: #FFC0C0;">«Картеля левых»</span> и сохранением у власти правительства правых. ?]{!</p>!}

{!<p class="other">!}[? if year = 1928 and month = 5 : Возрастной ценз для женщин в <span style="color: #C8102E;">Великобритании</span> снижен с 30 до 21 года — ещё один день, ещё одна славная новость. ?]{!</p>!}

{!<p class="dnvp">!}[? if year = 1928 and month = 6 : Новый виток внутрипартийной борьбы разгорелся в <span style="color: #3E88B3;">**НННП**</span> после её плохих результатов на прошлых выборах. В скандальной статье Вальтер Ламбах, видный член <span style="color: #6D5298;">«христианско-социального»</span> крыла партии, в упадке популярности обвинил нереалистичные обещания о скорой реставрации монархии и призвал партию стать более открытой для консервативных <span style="color: #000000;">рес</span><span style="color: #DD0000;">публ</span><span style="color: #FFCC00;">иканцев</span>. [? if in_right_coalition or in_right_coalition_prussia : Кроме того, участие партии в прошлом правительстве в рамках системы, которую она стремится низвергнуть, вызвало раскол с праворадикальными элементами в её рядах. ?] [? if pro_republic >= 65 or ((pro_republic >= 57 and in_right_coalition and in_right_coalition_prussia) or (pro_republic >= 59 and in_right_coalition) or (pro_republic >= 62 and in_right_coalition_prussia)): Его спорная точка зрения неожиданно нашла определённую поддержку внутри партии. ?]Альфред Гугенберг и его союзники из правого крыла партии хотят использовать гнев монархистов, направленный против Ламбаха, чтобы возглавить партию на съезде в октябре этого года. ?]{!</p>!}

{!<p class="other">!}[? if year = 1928 and month = 6 : Слабые результаты либеральных партий убедили их руководство, что Германия больше не может позволить себе роскошь наличия двух либеральные партии. Однако перспективе слияния мешают левые <span style="color: #D3C24D;">**[+ ddp_name +]**</span> и правыми из <span style="color: #C0A054;">**ННП**</span>, которые категорически не хотят идти на компромисс. Несмотря на это, создание общей парламентской фракции между <span style="color: #D3C24D;">**[+ ddp_name +]**</span> и <span style="color: #C0A054;">**ННП**</span> вероятно. ?]{!</p>!}

{!<p class="dnvp">!}[? if year = 1928 and month = 7 : Куно фон Вестарп, умеренный лидер <span style="color: #3E88B3;">**НННП**</span>, подал в отставку с поста лидера партии из-за конфликта с Гугенбергом и его союзниками. Вестарп, хотя и противник взглядов Ламбаха, воздержался от его исключения из партии, чтобы предотвратить возможный откол её левого крыла. Этот шаг разозлил многих монархистов. [? if pro_republic < 65 and not ((pro_republic >= 57 and in_right_coalition and in_right_coalition_prussia) and not (pro_republic >= 59 and in_right_coalition) and not (pro_republic >= 62 and in_right_coalition_prussia)): Это подтолкнуло Вестарпа уйти в отставку с поста лидера, а Ламбаха исключили из партии благодаря неослабевающим нападкам от союзников Гугенберга. ?][? if pro_republic >= 65 or ((pro_republic >= 57 and in_right_coalition and in_right_coalition_prussia) or (pro_republic >= 59 and in_right_coalition) or (pro_republic >= 62 and in_right_coalition_prussia)): Это подтолкнуло Вестарпа уйти в отставку с поста лидера из-за неослабевающих нападок от союзников Гугенберга. Однако Ламбаха спасло от исключения из партии левое крыло <span style="color: #3E88B3;">**НННП**</span>'s left wing. ?] Тем временем, Гугенберг и его соратники из Пангерманского союза заручились значительной поддержкой в местных партийных организациях. ?]{!</p>!}

{!<p class="other">!}[? if year = 1928 and month = 7 and (liberal_vote >= 12.5 and peoples_party_support < 2) or (in_right_coalition or in_weimar_coalition) and next_election_time - time >= 3: Усилия Штреземана и <span style="color: #D3C24D;">**[+ ddp_name +]**</span> под руководством Коха-Везера укрепить связи между двумя партиями провалились из-за сильного сопротивления со стороны крайних флангов обеих партий. Штреземан всё больше разочаровывается в собственной партии, считая её инструментом для продвижения интересов промышленников, а не либеральных ценностей. Левое крыло в <span style="color: #D3C24D;">**[+ ddp_name +]**</span> утверждают, что при слиянии необходимо будет учитывать интересы рабочего класса, против чего яростно выступают промышленники. ?]{!</p>!}

{!<p class="other">!}[? if year = 1928 and flavour_5_trigger and flavour_5_trigger_time == time: Стремление к сотрудничеству между двумя либеральными партиями, усилившееся по итогам последних выборов, привело к созданию их общей парламентской фракции. Крайние крылья обеих партий неохотно пошли на этот шаг, чтобы усилить своё парламентское влияние в условиях падения популярности либералов. <br><br> Новая Либеральная ассоциация, финансируемая обеими партиями, набирает популярность. Ожидается, что она откроет земельные и местные отделения и разработает политическую программу. Похоже, это прелюдия к основанию единой либеральной партии, но пока неясно, согласятся ли на это обе партии. ?]{!</p>!}

{!<p class="other">!}[? if year = 1928 and n_elections == 1 and next_election_time - time = 2: Наши призывы к проведению новых выборов сразу после предыдущих сблизили либеральные партии, стремящиеся избежать дальнейшего упадка. Появилась новая Либеральная ассоциация, координирующая усилия обеих партий. Похоже, это прелюдия к основанию новой, единой либеральной партии, но пока неясно, дадут ли на это согласие обе стороны. <br><br> Идея создания общей либеральной парламентской фракции получила значительную поддержку в обеих партиях, и, вероятно, после выборов они будут вести переговоры как единый блок. ?]{!</p>!}

{!<p class="other">!}[? if lvp_merger_timer == 4: В деле объединения либералов наметился прогресс: влияние Либеральной ассоциации в местных отделениях <span style="color: #D3C24D;">**[+ ddp_name +]**</span> и <span style="color: #C0A054;">**ННП**</span> на местном уровне растёт. В оплоте либералов, Баден-Вюртемберге, уже идёт слияние двух партий, даже без официального одобрения их национальных руководств. ?]{!</p>!}

{!<p class="other">!}[? if year = 1928 and month = 8 : Вильгельм Маркс, лидер [? if z_party_name != "CVP": <span style="color: #000000;">Партии Центра</span> ?][? if z_party_name == "CVP": <span style="color: #000000;">**ХНП**</span> ?], бывший канцлер и кандидат в президенты, подал в отставку из-за плохих результатов партии на последних выборах. Нового лидера изберут в декабре этого года. <br><br> <span style="color: #750e0e;">Советский Союз</span> обнародовал первый «пятилетний план» по ускоренной индустриализации страны. <br><br> Мы заняли второе место на летних Олимпийских играх в Амстердаме! ?] {!</p>!}

{!<p class="dnvp">!}[? if year = 1928 and month = 8 and pro_republic_7 < 65 and not (pro_republic_7 >= 57 and in_right_coalition and in_right_coalition_prussia) and not ((pro_republic_7 >= 59 and in_right_coalition) and not (pro_republic_7 >= 62 and in_right_coalition_prussia)): Ламбаха восстановили в рядах <span style="color: #3E88B3;">**НННП**</span> и в её фракцию в рейхстаге под давлением христианского рабочего движения и организаций «белых воротничков».[? if in_right_coalition or in_right_coalition_prussia = 1: <br><br> Попытки Гугенберга усилить своё влияние в партии осложнились: если он развалит нынешнюю [? if in_right_coalition_prussia and in_right_coalition: прусскую и федеральную ?][? if in_right_coalition_prussia and not in_right_coalition: прусскую ?][? if in_right_coalition and not in_right_coalition_prussia: федеральную ?] коалицию после избрания, то единственной альтернативой для парламентского большинства будет правительство во главе с нами. ?] ?]{!</p>!}

{!<p class="other">!}[? if lvp_merger_timer == 3: Штреземан и другие высокопоставленные партийные деятели, в том числе лидер <span style="color: #D3C24D;">**[+ ddp_name +]**</span> Кох-Везер, в последние несколько недель устраивали тайные переговоры о возможном слиянии их партий. Тем временем, формируется множество либеральных молодёжных организаций для развития сотрудничества между <span style="color: #D3C24D;">**[+ ddp_name +]**</span> и <span style="color: #C0A054;">**ННП**</span> ради создания объединённой центристской партии. ?]{!</p>!}

{!<p class="both">!}[? if year = 1928 and month = 9 : После слабых результатов <span style="color: #7A3C00;">**НСДАП**</span> на недавних выборах, в Пруссии сняли запрет на публичные выступления Адольфа Гитлера. ?] {!</p>!}

{!<p class="both">!}[? if year = 1928 and month = 9 and spd_in_government = 0 : Буржуазное правительство одобрило строительство нового военного корабля в рамках перевооружения Германии. Как оппозиционная партия, выступающая за еду детям вместо броненосцев, мы получили некоторую общественную поддержку. ?]{!</p>!}

{!<p class="other">!}[? if year = 1928 and month = 9 : Адам Штегервальд, председатель католических профсоюзов[? if prussia_leader == "Stegerwald": и министр-президент Пруссии, ?] — ведущий кандидат на смену Вильгельма Маркса. Он выступает за широкий межконфессиональный «народный блок» вместо текущего бренда партии католиков. Штегервальд скептически относится к сотрудничеству с нами. ?]{!</p>!}

{!<p class="other">!}[? if year = 1928 and month = 9 : Поражение <span style="color: #3E88B3;">**НННП**</span> на выборах привело к росту анти<span style="color: #000000;">рес</span><span style="color: #DD0000;">пуб</span><span style="color: #FFCC00;">ликанских</span> настроений в рядах <span style="color: #3E88B3;">**Стального шлема**</span>, а лидер её бранденбургской ячейки опубликовал «Фюрстенвальдскую декларацию ненависти». В ней он объявил о бескомпромиссной ненависти к республике как форме правления и о начале борьбы против <span style="color: #000000;">рес</span><span style="color: #DD0000;">пуб</span><span style="color: #FFCC00;">ликанской</span> системы. После этого Штреземан приказал всем избранным от <span style="color: #C0A054;">**ННП**</span> должностным лицам покинуть свои посты в этой ветеранской организации. ?]{!</p>!}

{!<p class="other">!}[? if year = 1928 and month = 9 : Президент Албании провозгласил страну конституционной монархией, короновав себя под именем Зогу I. ?]{!</p>!}

{!<p class="other">!}[? if year = 1928 and month = 9 : <span style="color: #D70926;">Шведские социал-демократы</span> потерпели поражение на недавних всеобщих выборах. ?]{!</p>!}

{!<p class="dnvp">!}[? if year = 1928 and month = 9 : Отказ Вестарпа баллотироваться за переизбрание оставил умеренных, выступающих против Гугенберга, в <span style="color: #3E88B3;">**НННП**</span> без кандидата. Сам Гугенберг проявил двойственное отношение к занятию поста председателя партии и выказал интерес к триумвирату. ?]{!</p>!}

{!<p class="other">!}[? if lvp_merger_timer == 2: Представители левого крыла <span style="color: #D3C24D;">**[+ ddp_name +]**</span>, которые решительно выступают против слияния двух партий, вынуждены покинуть партию или отодвинуты на второстепенные роли, чтобы расчистить путь к объединению. Однако правое крыло <span style="color: #C0A054;">**ННП**</span> имеет значительное влияние в партии и на переговорах, что побудило Штреземана созвать экстренный партийный съезд для решения этого вопроса. ?]{!</p>!}

{!<p class="other">!}[? if year = 1928 and month = 10 and in_grand_coalition and (foreign_minister_party = "DVP" or foreign_minister_party = "LVP") and lvp_timer_trigger == 0: Штреземан планирует масштабную внутреннюю реформу <span style="color: #C0A054;">**ННП**</span> во главе с либеральным профсоюзным деятелем Отто Тилем. Его деятельность напоминает работу Ламбаха по расширению электората партии через привлечение в неё всех слоев общества. Однако здоровье Штреземана ухудшается, и внешнеполитическая деятельность для него сейчас важнее, чем риск спровоцировать правое крыло партии на развал коалиции. А пока что оно будет лишь усиливаться. ?]{!</p>!}

{!<p class="other">!}[? if year = 1928 and month = 10 and not in_grand_coalition or not (foreign_minister_party = "DVP" or foreign_minister_party = "LVP") and lvp_timer_trigger == 0: Штреземан планирует масштабную внутреннюю реформу <span style="color: #C0A054;">**ННП**</span> во главе с либеральным профсоюзным деятелем Отто Тилем. Его работа по расширению социальной базы партии и привлечению всех слоёв общества напоминает деятельность Ламбаха. Хоть здоровье Штреземана и ухудшается, он наконец-то сосредоточился на внутренних делах своей партии. ?]{!</p>!}

{!<p class="other">!}[? if year = 1928 and month = 10 : Гуго Эккенер успешно завершил первый межконтинентальный полет на цеппелине! Дирижабль <i>«Граф Цеппелин»</i> вылетел из Германии и приземлился в Нью-Джерси, совершив самый длительный на сегодняшний день беспосадочный перелет, проведя в воздухе более 111 часов. ?]{!</p>!}

{!<p class="other">!}[? if year = 1928 and month = 11 and not prussia_leader == "Stegerwald": Несмотря на сильные позиции Штегервальда в [? if z_party_name != "CVP": <span style="color: #000000;">партии Центра</span> ?][? if z_party_name == "CVP": <span style="color: #000000;">**ХНП**</span> ?] в борьбе за лидерство, он столкнулся со значительным сопротивлением от среднего класса партии из-за его связей с рабочим движением и его порицания инициативы о повышении зарплаты госслужащим. К декабрьскому съезду партии появились новые кандидаты. ?]{!</p>!}

{!<p class="other">!}[? if year = 1928 and month = 11 and prussia_leader == "Stegerwald": Позиции Штегервальда в [? if z_party_name != "CVP": <span style="color: #000000;">партии Центра</span> ?][? if z_party_name == "CVP": <span style="color: #000000;">**ХНП**</span> ?] ослабевают из-за значительного сопротивления от среднего класса в партии из-за его связей с рабочим движением и порицания с инициативой о повышении жалованья госслужащим. К декабрьскому съезду партии появились новые кандидаты, в результате борьба развернётся между тремя претендентами. ?]{!</p>!}

{!<p class="other">!}[? if year = 1928 and month = 11 and not (in_grand_coalition == 0 or ((in_grand_coalition == 1 and in_grand_coalition_prussia == 1 and coalition_dissent < 1 and (foreign_minister_party = "DVP" or foreign_minister_party = "LVP")) or (in_grand_coalition == 1 and in_grand_coalition_prussia == 1 and coalition_dissent < 2 and (foreign_minister_party != "DVP" and foreign_minister_party != "LVP")))) and not lvp_formed and lvp_timer_trigger == 0: Штреземан отложил свои планы по противостоянию правому крылу <span style="color: #C0A054;">**ННП**</span>, чтобы не рисковать развалом нашего правительства из-за споров с прусским правительством и [? if z_party_name != "CVP": <span style="color: #000000;">партией Центра</span> ?][? if z_party_name == "CVP": <span style="color: #000000;">**ХНП**</span> ?]. Хотя это и хорошая новость для стабильности здесь и сейчас, правое крыло <span style="color: #C0A054;">**ННП**</span> в будущем создаст нам ещё больше проблем. ?]{!</p>!}

{!<p class="other">!}[? if year = 1928 and month = 11 and (in_grand_coalition == 0 or ((in_grand_coalition == 1 and in_grand_coalition_prussia == 1 and coalition_dissent < 1 and (foreign_minister_party = "DVP" or foreign_minister_party = "LVP")) or (in_grand_coalition == 1 and in_grand_coalition_prussia == 1 and coalition_dissent < 2 and (foreign_minister_party != "DVP" and foreign_minister_party != "LVP")))) and not lvp_formed and lvp_timer_trigger == 0: Штреземан и его союзники из левого крыла <span style="color: #C0A054;">**ННП**</span> созвали партийный съезд для обсуждения внутренних реформ, которые дали бы большее влияние представителям среднего класса и рабочих в партии. Само собой, промышленники из правого крыла яростно выступают против этого плана и поднимут бучу на следующем партийном съезде. ?]{!</p>!}

{!<p class="other">!}[? if year = 1928 and month = 11 : Герберт Гувер от <span style="color: #E81B23;">Республиканской партии</span> одержал убедительную победу над <span style="color: #00AEF3;">демократом</span> Элом Смитом на президентских выборах в <span style="color: #B31942;">Соединённых</span> <span style="color: #0A3161;">Штатах</span>. ?]{!</p>!}

{!<p class="other">!}[? if year = 1928 and month = 11 : Вышел мультфильм под названием <i>«Пароходик Вилли»</i> — первый в своём роде звуковой мультфильм. ?]{!</p>!}

{!<p class="other">!}[? if year = 1928 and month = 12 and (in_center_right_coalition or in_right_coalition) and not lvp_formed and lvp_timer_trigger == 0: Вхождение <span style="color: #D3C24D;">**[+ ddp_name +]**</span> в правящую коалицию укрепило сотрудничество между двумя либеральными партиями, которые в последнее время сместились вправо. Они сформировали общую парламентскую фракцию с <span style="color: #C0A054;">**ННП**</span> в рейхстаге, и партийные лидеры ведут переговоры о дальнейшем сотрудничестве. ?]{!</p>!}

{!<p class="other">!}[? if year = 1928 and month = 12 : Китайские националисты из <span style="color: #000099;">**Гоминьдана**</span> объединили Китай, положив конец эре милитаристов. Однако Япония по-прежнему остаётся империалистической силой в регионе. ?]{!</p>!}

{!<p class="other">!}[? if year = 1929 and month = 1 and z_leader == "Stegerwald": Избрание Штегервальда председателем [? if z_party_name != "CVP": <span style="color: #000000;">партии Центра</span> ?][? if z_party_name == "CVP": <span style="color: #000000;">**ХНП**</span> ?] привело к серьёзным последствиям: массовому оттоку избирателей из среднего класса и католиков. Некогда стагнирующая партия превращается в динамичную силу, которую более не скрепляет католицизм. Штегервальд продвигает идею межконфессиональной, общехристианской партии и [? if dnvp_ideology == "Moderate": устанавливает дружеские отношения с протестантскими профсоюзными лидерами в <span style="color: #3E88B3;">**НННП**</span> ?][? if dnvp_ideology == "Radical": открывает отделения партии в некатолических регионах ?], но этот процесс будет долгим и трудным. ?]{!</p>!}

{!<p class="other">!}[? if year = 1929 and month = 1 and reichswehr_minister_party != "SPD": Военное министерство учредило новую должность — главу управления по министерским делам. В его обязанности входит координация и реализация стратегии рейхсвера по взаимодействию с правительством, рейхстагом, различными политическими партиями и, что, пожалуй, важнее всего, с аппаратом рейхспрезидента. На эту должность Вильгельм Грёнер назначил Курта фон Шлейхера, недавно произведённого в генералы. ?]{!</p>!}

{!<p class="other">!}[? if year = 1929 and month = 1: Лев Троцкий выслан из <span style="color: #750e0e;">Советского Союза</span> после поражения в борьбе за власть со <span style="color: #8B0000;">Сталиным</span>. ?]{!</p>!}

{!<p class="other">!}[? if year = 1929 and month = 1: Король Югославии Александр I под предлогом внутриполитических беспорядков установил <span style="color: #808080;">королевскую диктатуру</span>. ?]{!</p>!}

{!<p class="other">!}[? if year = 1929 and month = 1: Выход книги <i>«На Западном фронте без перемен»</i> вызвал бурные споры. В романе описывается опыт немецких солдат в Великой войне и то, как они постепенно разочаровывались в идеях патриотизма и национализма. ?]{!</p>!}

{!<p class="other">!}[? if year = 1929 and month = 3 and lvp_formed: The <span style="color: #D3C24D;">**[+ ddp_name +]**</span>, её бывшие профсоюзные лидеры и левые, и даже некоторые <span style="color: #C0A054;">**ННП**</span> левые, такие как Отто Тиль, основали «Социал-республиканский кружок». Эта фракция стремится сместить партийную платформу с нынешним фокусом на средний класс к той, что будет отстаивать ещё и интересы рабочих. ?]{!</p>!}

{!<p class="other">!}[? if year = 1929 and month = 3 and not lvp_formed: The <span style="color: #D3C24D;">**[+ ddp_name +]**</span> продолжает терять членов своего левого и рабочего крыла, которые уходят к <span style="color: #c00000;">социалистам</span>, поскольку в буржуазных партиях воцаряется атмосфера пессимизма и разочарования в Веймарской системе. Некогда одна из столпов Веймарской демократии, она теперь неуклонно скатывается к национализму и теряет былое значение. ?]{!</p>!}

{!<p class="other">!}[? if year = 1929 and month = 4: Датские <span style="color: #C82518;">социал-демократы</span> одержали победу на недавних выборах в <i>фолькетинг</i> и сформировали коалицию с <span style="color: #733280;">социал-либералами</span>. На пост премьер-министра вернулся Торвальд Стаунинг, который продолжит курс на создание обширного государства всеобщего благосостояния. Быть может, и нам стоит взять с них пример? ?]{!</p>!}

{!<p class="dnvp">!}[? if year = 1929 and month = 5 and in_right_coalition = 0 or in_center_right_coalition = 0 : The <span style="color: #3E88B3;">**НННП**</span> и множество других правых организаций готовятся инициировать референдум[? if dnvp_ideology == "Radical": &nbsp;с благословения Гугенберга ?] о пересмотре <span style="color: #000000;">Ве</span><span style="color: #DD0000;">йм</span><span style="color: #FFCC00;">ар</span>ской конституции, который позволит президенту назначать канцлера без согласия рейхстага и снимать неприкосновенность с депутатов рейхстага, обвинённых в государственной измене. Хотя референдум вряд ли будет успешен, он может способствовать сплочению правых[? if dnf_formed = 1: &nbsp;несмотря на неучастие Гугенберга ?]. [? if dnf_formed = 1: Гугенберг и <span style="color: #003755;">**НФГ**</span> вместо этого планируют инициировать референдум по внешней политике, хотя маловероятно, что удастся собрать необходимое количество подписей. ?] ?]{!</p>!}

{!<p class="other">!}[? if year = 1929 and month = 5 and not lvp_formed: Многие молодёжные группы формируются вокруг <span style="color: #C0A054;">**ННП**</span>, чтобы омолодить партию вопреки интересам промышленников и выступить за слияние буржуазных партий для конкуренции с [? if z_party_name != "CVP": <span style="color: #000000;">Партией Центра</span> ?][? if z_party_name == "CVP": <span style="color: #000000;">**ХНП**</span> ?]. Кроме того, Штреземан вёл тайные переговоры с <span style="color: #D3C24D;">**[+ ddp_name +]**</span> Кохом-Везером в последние несколько месяцев. ?]{!</p>!}

{!<p class="other">!}[? if year = 1929 and month = 5 and lvp_formed: The <span style="color: #FFCC00;">**ЛНП**</span> добилась успеха в сплочении под своими знаменами молодежи из среднего класса: множество молодежных групп объединились в их «Молодых либералов». Это молодежное крыло заметно более левое, чем партия в целом, и будет продвигать политику, которая направит <span style="color: #FFCC00;">**ЛНП**</span> к более прогрессивным взглядам. ?]{!</p>!}

{!<p class="other">!}[? if year = 1929 and month = 5 : Всеобщие выборы в Соединённом Королевстве завершились крупной победой <span style="color: #f0456a;">лейбористов</span>, получивших более 100 мест. Несмотря на это, им не удалось набрать большинство, и они сформируют правительство меньшинства, где решающая роль достанется <span style="color: #FFD700;">либералам</span>. ?]{!</p>!}

{!<p class="other">!}[? if year = 1929 and month = 5 : <span style="color: #D70926;">Бельгийская рабочая партия</span> набрала относительное большинство на недавних всеобщих выборах, однако у власти остаётся действующая <span style="color: #FFD700;">католическо</span>-<span style="color: #3C40D2;">либеральная</span> коалиция. ?]{!</p>!}

{!<p class="both">!}[? if year = 1929 and month = 6 : После многомесячных совещаний в Париже, которые вели [+ foreign_minister +], державы-Союзники разработали ряд предложений, известный как план Юнга, который должен сократить наши репарационные выплаты и предоставить Германии больше финансовой автономии. <span style="color: #002654;">Французы</span> также согласились на досрочный вывод своих войск из Рейнской области в июне 1930 года. [? if in_right_coalition = 1 or in_center_right_coalition = 1: Переговоры по плану Юнга вызвали серьёзные разногласия с <span style="color: #3E88B3;">**НННП**</span>, которая выступает против этого плана и заявляет, что любые репарации — это форма национального рабства. Коалиция вряд ли просуществует долго. ?][? if in_right_coalition = 0 and in_center_right_coalition = 0: Хотя это и кажется позитивным событием для страны, правые ведут активную кампанию против этого плана[? if kpd_leader == "Thälmann": , как и <span style="color: #700000;">**Коммунисты**</span>, ведь план, по их мнению, закрепляет и усиливает капиталистическую эксплуатацию немецкого пролетариата ?]. ?] ?]{!</p>!}

{!<p class="other">!}[? if year = 1929 and month = 6: Государство Ватикан создано по соглашению между Бенито Муссолини и Святым Престолом — и стало самым молодым государством в мире. ?]{!</p>!}

{!<p class="dnvp">!}[? if year = 1929 and month = 6 and dnvp_ideology = "Radical" : Противодействие референдуму со стороны <span style="color: #7A3C00;">**НСДАП**</span> заставило Гугенберга отказаться от планов по проведению референдума о пересмотре <span style="color: #000000;">Вей</span><span style="color: #DD0000;">мар</span><span style="color: #FFCC00;">ской</span> конституции, к разочарованию многих членов [? if dnvp_leader == "Hugenberg": <span style="color: #3E88B3;">**НННП**</span> party members. ?][? if dnvp_leader == "Triumvirate": , включая Вестарпа. ?] Началась кампания за проведение референдума против плана Юнга, перечёркивающая прогресс, достигнутый <span style="color: #3E88B3;">**НННП**</span> в сближении с [? if not lvp_formed: <span style="color: #C0A054;">**ННП**</span> ?][? if lvp_formed: <span style="color: #FFCC00;">**ЛНП**</span> ?] и <span style="color: #A2D8E0;">**БНП**</span>. ?]{!</p>!}

{!<p class="dnvp">!}[? if year = 1929 and month = 7 and dnvp_ideology = "Radical" : The <span style="color: #7A3C00;">**НСДАП**</span> отведена важная роль в организации референдума против плана Юнга, это снизило подозрительное отношение к гитлеровской <span style="color: #7A3C00;">**НСДАП**</span> со стороны традиционных правых. Гугенберг особенно охотно шёл на уступки, чтобы удержать эту, казалось бы, крошечную партию в «Национальном фронте». Отсутствие значительной поддержки этой инициативы со стороны промышленников вынудило Гугенберга тратить немалые личные средства. ?]{!</p>!}

{!<p class="dnvp">!}[? if year = 1929 and month = 7 and dnf_formed = 1 and not was_in_center_right_coalition : The <span style="color: #003755;">**НФГ**</span> организует референдум против плана Юнга в тесном сотрудничестве с <span style="color: #7A3C00;">**НСДАП**</span>. The <span style="color: #3E88B3;">**НННП**</span> ведет внутреннюю борьбу по поводу сотрудничества с <span style="color: #003755;">**НФГ**</span> на референдуме за единых правых — или же инициировать собственный референдум по <span style="color: #000000;">Ве</span><span style="color: #DD0000;">йм</span><span style="color: #FFCC00;">ар</span>ской конституции. ?]{!</p>!}

{!<p class="dnvp">!}[? if year = 1929 and month = 7 and dnf_formed = 1 and was_in_center_right_coalition : The <span style="color: #003755;">**НФГ**</span> организует референдум против плана Юнга в тесном сотрудничестве с <span style="color: #7A3C00;">**НСДАП**</span>. The <span style="color: #3E88B3;">**НННП**</span> ведет внутреннюю борьбу по поводу сотрудничества с <span style="color: #003755;">**и НФГ**</span> на референдуме за единых правых — или же сохранить отношения с буржуазными партиями. ?]{!</p>!}

{!<p class="dnvp">!}[? if year = 1929 and month = 8 and dnf_formed = 1 and was_in_center_right_coalition and pro_republic < 70: Партии <span style="color: #7A3C00;">**НСДАП**</span> отведена важная роль в организации референдума против плана Юнга, это снизило подозрительное отношение к гитлеровской <span style="color: #7A3C00;">**НСДАП**</span> со стороны традиционных правых. В частности, включён пункт, призывающий к тюремному заключению ответственных за подписание плана, включая президента Гинденбурга. Это привело к удалению данного пункта, чтобы убедить <span style="color: #3E88B3;">**НННП**</span> поддержать их инициативу, ведь без их поддержки она обречена на унизительный провал. Внутренние разногласия в <span style="color: #3E88B3;">**НННП**</span> усилились из-за решения о сотрудничестве с Гугенбергом и Гитлером. ?]{!</p>!}

{!<p class="dnvp">!}[? if year = 1929 and month = 8 and dnf_formed = 1 and was_in_center_right_coalition and pro_republic >= 70 : The <span style="color: #7A3C00;">**НСДАП**</span> отведена важная роль в подготовке референдума против плана Юнга, это снизило подозрительное отношение к гитлеровской <span style="color: #7A3C00;">**НСДАП**</span> со стороны правых. В том числе добавлен пункт с призывом заключить в тюрьму всех ответственных за подписание договора, включая президента Гинденбурга. Даже после удаления этого пункта <span style="color: #3E88B3;">**НННП**</span> по-прежнему не готова поддержать референдум вместе с <span style="color: #7A3C00;">крайне</span>-<span style="color: #003755;">правыми</span>. Внутренние разногласия в <span style="color: #3E88B3;">**НННП**</span> усилились из-за решения не сотрудничать с правыми в борьбе против «национального рабства». ?]{!</p>!}

{!<p class="dnvp">!}[? if year = 1929 and month = 8 and dnf_formed = 1 and pro_republic >= 70 and not was_in_center_right_coalition : The <span style="color: #7A3C00;">**НСДАП**</span> отведена важная роль в подготовке референдума против плана Юнга, это снизило подозрительное отношение к гитлеровской <span style="color: #7A3C00;">**НСДАП**</span> со стороны правых. В том числе добавлен пункт с призывом заключить в тюрьму всех ответственных за подписание договора, включая президента Гинденбурга. Даже после удаления этого пункта <span style="color: #3E88B3;">**НННП**</span> всё равно намерена провести собственный референдум. Внутренние разногласия в <span style="color: #3E88B3;">**НННП**</span> усилились из-за решения не сотрудничать с правыми в борьбе против «национального рабства». ?]{!</p>!}

{!<p class="other">!}[? if year = 1929 and month = 8 and stolper_program_adopted and not lvp_formed: The <span style="color: #D3C24D;">**[+ ddp_name +]**</span> провела партийный съезд, на котором не произошло ничего примечательного. Однако уважаемый экономист Густав Штольпер представил свою «программу Штольпера», переориентировавшую социально-экономический фокус партии с поддержки промышленного рабочего класса на поддержку испытывающего трудности среднего класса. Несмотря на сопротивление со стороны левого крыла партии и либеральных профсоюзов, она стала официальной экономической программой партии, вызвав новый энтузиазм среди рядовых членов партии и немецкого среднего класса. ?]{!</p>!}

{!<p class="other">!}[? if year = 1929 and month = 8 and not stolper_program_adopted and not lvp_formed: The <span style="color: #D3C24D;">**[+ ddp_name +]**</span> провела партийный съезд, на котором не произошло ничего примечательного. Однако уважаемый экономист Густав Штольпер представил «программу Штольпера», переориентировавшую социально-экономический фокус партии с поддержки промышленного рабочего класса на поддержку испытывающего трудности среднего класса. Однако из-за сопротивления левого крыла партии этот план тихо положен под сукно, несмотря на значительный энтузиазм рядовых членов. ?]{!</p>!}

{!<p class="other">!}[? if lvp_merger_1_timer == 4: Тайные переговоры Штреземана с <span style="color: #D3C24D;">**[+ ddp_name +]**</span> принесли плоды: обе партии сблизили свои политические позиции. Недавно принятая «программа Штольпера» и преобразование <span style="color: #C0A054;">**ННП**</span> в настоящую народную партию при одновременном сдерживании крыла промышленников значительно облегчили путь к более тесному сотрудничеству между двумя либеральными партиями. В ближайшие несколько месяцев продолжатся более масштабные переговоры. ?]{!</p>!}

{!<p class="other">!}[? if year = 1929 and month = 8 : Гуго Эккенер успешно завершил первое в истории кругосветное путешествие на цеппелине! Путешествие протяжённостью 33 234 километра заняло примерно 21 день, причём началось и закончилось оно в одном и том же месте. ?]{!</p>!}

{!<p class="dnvp">!}[? if year = 1929 and month = 8 and dnf_formed = 1 and pro_republic < 70 and not was_in_center_right_coalition: The <span style="color: #7A3C00;">**НСДАП**</span> отведена важная роль в организации референдума против плана Юнга, что шло вразрез с традиционным подозрительным отношением правых к гитлеровской <span style="color: #7A3C00;">**НСДАП**</span>. В частности, добавлен пункт, призывающий к тюремному заключению лиц, ответственных за подписание плана, включая президента Гинденбурга. В итоге этот пункт удалили, чтобы убедить <span style="color: #3E88B3;">**НННП**</span> поддержать их инициативу, поскольку без её поддержки их ждало бы лишь унизительное поражение. Внутренние разногласия в рядах <span style="color: #3E88B3;">**НННП**</span> усилились из-за решения отказаться от прежних планов. ?]{!</p>!}

{!<p class="both">!}[? if year = 1929 and month = 9 and dnf_formed = 1 and pro_republic_8 >= 70 and not was_in_center_right_coalition and not lvp_formed: The <span style="color: #3E88B3;">**НННП**</span> заручилась поддержкой буржуазных партий, <span style="color: #C0A054;">**ННП**</span> и <span style="color: #A2D8E0;">**БНП**</span>, в проведении референдума о реформе <span style="color: #000000;">Вей</span><span style="color: #DD0000;">ма</span><span style="color: #FFCC00;">рской</span> конституции. [? if dvp_relation >= 40 and dvp_ideology_9 != "Right" : Однако наши с ними дружеские отношения не позволили им выступить против нас. ?] <span style="color: #7A3C00;">Ультра</span><span style="color: #003755;">правые</span> партии готовят собственный референдум и не будут принимать участия. ?]{!</p>!}

{!<p class="both">!}[? if year = 1929 and month = 9 and dnf_formed = 1 and pro_republic_8 >= 70 and not was_in_center_right_coalition and lvp_formed: The <span style="color: #3E88B3;">**НННП**</span> не смогла заручиться поддержкой буржуазных партий, правые <span style="color: #FFCC00;">**ЛНП**</span> и[? if z_party_name != "CVP": <span style="color: #000000;">Партии Центра</span> ?][? if z_party_name == "CVP": <span style="color: #000000;">**ХНП**</span> ?], которые высказались за референдум по реформе <span style="color: #000000;">Ве</span><span style="color: #DD0000;">йм</span><span style="color: #FFCC00;">ар</span>ской конституции. Лишь <span style="color: #A2D8E0;">**БНП**</span> согласилась поддержать референдум. <span style="color: #7A3C00;">Ультра</span><span style="color: #003755;">правые</span> партии готовят собственный референдум и не будут принимать участия. ?]{!</p>!}

{!<p class="dnvp">!}[? if year = 1929 and month = 9 and dnvp_leader = "Hugenberg": В последнем параграфе «Закона о свободе», вынесенного на референдум, содержится крайне спорный «карательный параграф», требующий обвинить в государственной измене и заключить в тюрьму всех ответственных за подписание плана Юнга, — вплоть до президента Гинденбурга, — что вызвало серьёзные разногласия в рядах <span style="color: #3E88B3;">**НННП**</span> и <span style="color: #3E88B3;">**Стального Шлема**</span>, но Гугенберг, как всегда непреклонный, твёрдо намерен сохранить этот пункт, поскольку <span style="color: #7A3C00;">**НСДАП**</span> поставила свою поддержку в зависимость от его сохранения. ?]{!</p>!}

{!<p class="dnvp">!}[? if year = 1929 and month = 9 and dnvp_leader = "Triumvirate": Последний параграф вынесенного на референдум «Закона о свободе» содержит крайне спорный пункт о тюремном заключении, который требует обвинить в государственной измене и посадить в тюрьму всех ответственных за подписание плана Юнга, включая даже президента Гинденбурга. Гугенберг, как всегда непреклонный, настаивает на сохранении этого пункта, поскольку <span style="color: #7A3C00;">**НСДАП**</span> поставила свою поддержку в зависимость от его сохранения. Этот пункт, разумеется, вызвал резкую критику в адрес Гугенберга, а Вестарп в знак протеста покинул правящий триумвират. ?]{!</p>!}

{!<p class="both">!}[? if year = 1929 and month = 9 and spd_in_government and not lvp_formed: Правое крыло <span style="color: #C0A054;">**ННП**</span> выразило разочарование нашим правительством и призывает нас провести крупную фискальную реформу в соответствии с условиями плана Юнга. Она предполагает урезание программы страхования по безработице, которая стоит на грани банкротства из-за роста числа безработных. <span style="color: #C0A054;">**ННП**</span> настаивает на урезании пособий, а не на увеличении взносов работодателей в программу. Штреземану же становится всё труднее находить компромисс внутри собственной партии. ?]{!</p>!}

{!<p class="other">!}[? if lvp_merger_1_timer == 3: Несмотря на эту неудачу, реформа партийной структуры <span style="color: #C0A054;">**ННП**</span> сделала требования её промышленников куда менее угрожающими.[? if not stresemann_dead: Штреземан ?][? if stresemann_dead: Курциус ?] и другие высокопоставленные партийные деятели, в том числе <span style="color: #D3C24D;">**[+ ddp_name +]**</span>, Кох-Везер, договорились исключить наиболее радикальных членов из своих партий, чтобы способствовать объединению. Тем временем Либеральная ассоциация, доселе пребывавшая в упадке, совместно с различными молодёжными группами начала разрабатывать политическую программу и создавать местные отделения. ?]{!</p>!}

{!<p class="other">!}[? if year = 1929 and month = 9: Промышленный индекс Доу-Джонса достиг пика в 381,17$, «Золотые двадцатые» продолжаются! ?]{!</p>!}

{!<p class="both">!}[? if year = 1929 and month = 10: Инициатива против плана Юнга завершила сбор подписей для проведения референдума. Подписи поставили [+ young_plan_signatures +]% избирателей, имеющих право голоса,[? if young_plan_signatures >= 10 : [? if young_plan_signatures < 11 : &nbsp;едва ?]превысив минимальный порог в 10%. ?][? if young_plan_signatures < 10 : [? if young_plan_signatures > 9 : &nbsp;едва ?] дотянув до минимального порога в 10%. Это, несомненно, вызовет споры в правых партиях. ?] ?]{!</p>!}

{!<p class="both">!}[? if year = 1929 and month = 10 and pro_republic_8 >= 70 and not was_in_center_right_coalition and dnf_formed = 1: Инициатива по пересмотру конституции завершила сбор подписей для проведения референдума. Её поддержали[+ weimar_ref_signatures +]% избирателей, имеющих право голоса. Голосование на референдуме состоится в конце этого года, и для принятия решения потребуется поддержка 50% всех избирателей при явке в минимум 50% ?]{!</p>!}

{!<p class="other">!}[? if year = 1929 and month = 10 and not lvp_formed: Небольшая националистическая военизированная организация Младогерманский орден сформировала новую политическую организацию — <i>Народно-национальное объединение Рейха</i> (<span style="color: #D3D3A9;">**ННОР**</span>), стремясь стать точкой кристаллизации, вокруг которой сможет сформироваться «великая партия национального возрождения». Разочарованные <span style="color: #D3C24D;">**[+ ddp_name +]**</span> политики, такие как Кох-Везер и Эрнст Леммер, проявили интерес к сотрудничеству с этой новой партией, чтобы объединить немецкий средний класс в новую «государственную партию». Однако это осложняет текущие и любые будущие переговоры о слиянии между <span style="color: #C0A054;">**ННП**</span> и <span style="color: #D3C24D;">**[+ ddp_name +]**</span>. ?]{!</p>!}

{!<p class="other">!}[? if lvp_merger_1_timer == 2: Преждевременная смерть Штреземана осложнила переговоры о создании <span style="color: #FFCC00;">единой либеральной партии</span>. Его союзники из левого крыла <span style="color: #C0A054;">**ННП**</span>, такие как Отто Тиль и Юлиус Курциус, могут продолжить переговоры, но есть вероятность, что объединение в конечном итоге будет заблокировано правыми силами, если те станут слишком влиятельными из-за отсутствия Штреземана. Несмотря на это, в оплоте либералов Баден-Вюртемберге слияние двух партий уже идёт полным ходом, даже без официального одобрения их национальных руководств. ?]{!</p>!}

{!<p class="other">!}[? if year = 1929 and month = 10: <span style="color: #f0456a;">Лейбористы</span> пришли к власти в Австралии. ?]{!</p>!}

{!<p class="other">!}[? if year = 1929 and month = 10 : <span style="color: #D70926;">Чехословацкие социал-демократы</span> получили большинство голосов на недавних всеобщих выборах, а более реформистская <span style="color: #FAC469;">Чехословацкая (национальная) социалистическая партия</span> не сильно от них отстала. <span style="color: #A00500;">Коммунисты</span> и другие правые партии потерпели неудачу. ?]{!</p>!}

{!<p class="other">!}[? if lvp_merger_1_timer == 1 and vnr_formed: Противники создания <span style="color: #FFCC00;">объединённой либеральной партии</span> есть не только в правом крыле <span style="color: #C0A054;">**ННП**</span>. Многие политики из всех фракций внутри <span style="color: #D3C24D;">**[+ ddp_name +]**</span>, в том числе и сам Кох-Везер, проявили интерес к альтернативному слиянию с националистической <span style="color: #D3D3A9;">**ННОР**</span>. [? if lvp_trigger_2_time == time + 1: Однако Кох-Везер и промышленно-деловое крыло партии дискредитировали скептиков внутри партии и намерены продолжить объединение. ?] ?]{!</p>!}

{!<p class="other">!}[? if year = 1929 and month = 11 and z_leader == "Stegerwald" and dnvp_ideology == "Radical": Партия[? if z_party_name != "CVP": <span style="color: #000000;">Партия Центра</span> ?][? if z_party_name == "CVP": <span style="color: #000000;">**ХНП**</span> ?] под руководством Штегервальда привлекает к себе немало разочарованных избирателей и членов <span style="color: #3E88B3;">**НННП**</span>, направляя их в [? if z_party_name != "CVP": <span style="color: #000000;">Партию Центра</span> ?][? if z_party_name == "CVP": <span style="color: #000000;">**ХНП**</span> ?] вместо мелких нишевых партий, которые они поддержали бы в ином случае. Всё это благодаря его недавним партийным реформам. Похоже, что [? if z_party_name != "CVP": <span style="color: #000000;">Центр</span> ?][? if z_party_name == "CVP": <span style="color: #000000;">**ХНП**</span> ?] станет ведущей правой партией, заняв место <span style="color: #3E88B3;">**НННП**</span>. ?]{!</p>!}

{!<p class="other">!}[? if year = 1929 and month = 12 : В конституцию Австрии внесены поправки, расширяющие полномочия президента, включая право распускать парламент, а также вводящие всенародные президентские выборы. Это превратило Австрию в страну с полупрезидентской системой правления, во многом похожей на нашу собственную. Поправка стала результатом компромисса с <span style="color: #000000;">Христианско-социальной партией</span>, которая стремилась к более авторитарному и централизованному правительству, поскольку для принятия поправки ей требовалось одобрение <span style="color: #C8102E;">австрийских социал-демократов</span>. ?]{!</p>!}

{!<p class="dnvp">!}[? if year = 1929 and month = 12 and csvd_formed = 1 and stegerwald_path = 0: <span style="color: #6D5298;">Христианско-социальное движение</span> <span style="color: #3E88B3;">**НННП**</span> образовала собственную политическую партию, объединившись с партией Христианской народной службы (ХНС) и создав <span style="color: #8ED8E4;">Христианско-Социальную народную службу</span> (<span style="color: #8ED8E4;">**ХСНС**</span>). Партия пользуется поддержкой в основном среди рабочих-протестантов и отказывается сотрудничать с другими буржуазными партиями. Что удивительно, они занимают жёсткую позицию по отношению к <span style="color: #7A3C00;">нацистам</span>, осуждая их «нехристианскую чрезмерную ненависть к <span style="color: #005EB8;">евреям</span>». ?]{!</p>!}

{!<p class="dnvp">!}[? if year = 1929 and month = 12 and dnvp_historical_1929: The <span style="color: #3E88B3;">**НННП**</span> раскольники объединили усилия с <span style="color: #7FCEB1;">Христианско-национальной партией крестьян и земледельцев</span>(<span style="color: #7FCEB1;">**ХНПКЗ**</span>) создать Христианско-национальную коалицию, новую парламентскую фракцию в Рейхстаге под руководством Тревирануса. Хотя это сотрудничество, по всей видимости, шаг к единству среди правых, выступавших против Гугенберга <span style="color: #7FCEB1;">**ХНПКЗ**</span>, всё ещё утверждает, что этот союз — лишь временная мера, вызванная парламентской слабостью обеих групп. Главное препятствие к дальнейшему объединению правой оппозици — стремление партий сохранить идеологическую и социальную самобытность. ?]{!</p>!}

{!<p class="dnvp">!}[? if year = 1930 and month = 1 and dnvp_historical_1929 and not (other_votes < 11 or peoples_party or weimar_coalition >= 50 or pro_republic < 40): Фракция «младоконсерваторов», отколовшаяся от <span style="color: #3E88B3;">**НННП**</span> несколько месяцев назад, официально учредила «Народно-Консервативное объединение». Это произошло после провальной встречи с раскольниками из <span style="color: #3E88B3;">**НННП**</span>, что закончилось неудачной попыткой создать хотя бы рыхлую федерацию консервативных сил. Ассоциация еще не официальная партия, но стремится объединить <span style="color: #8ED8E4;">ХСНД</span> и <span style="color: #7FCEB1;">**ХНПКЗ**</span> в единый блок, надеясь выставить общий список на следующих выборах. ?]{!</p>!}

{!<p class="dnvp">!}[? if year = 1930 and month = 1 and dnvp_historical_1929 and (peoples_party or weimar_coalition >= 50 or stegerwald_path or (z_leader == "Joos" and dvp_reform)): Фракция «младоконсерваторов», отколовшаяся от <span style="color: #3E88B3;">**НННП**</span> несколько месяцев назад, официально учредила «<span style="color: #0087DC;">Консервативную Народную Партию</span>» (<span style="color: #0087DC;">**КНП**</span>). Один из её крупнейших спонсоров — генерал Курт фон Шлейхер, близкий советник президента Гинденбурга и милитарист. Они приняли средства от Шлейхера из-за [? if stegerwald_path and z_leader == "Stegerwald": резкого сокращения пожертвований от германской промышленности, несмотря на опасения об утрате своей независимости. ?][? if (z_leader == "Joos" and dvp_reform) or z_leader == "Kaiser": условной поддержки со стороны немецких промышленников, лишившихся своего пристанища в партийной системе Германии, несмотря на опасения об утрате своей независимость. ?][? if (weimar_coalition >= 50 or peoples_party) and not stegerwald_path and not (z_leader == "Joos" and dvp_reform): отчаянного желания противостоять нашей популярности, несмотря на опасения утраты своей независимости. ?] Средства оказались слишком значительными, чтобы от них отказываться: это заставило замолчать инакомыслящих среди других <span style="color: #3E88B3;">**НННП**</span> отколовшихся групп и объединило консервативные силы в единое целое. ?]{!</p>!}

{!<p class="both">!}[? if flavour_4_trigger and flavour_4_trigger_time == time: Ходят слухи, что президент Гинденбург разочарован нынешним <span style="color: #c00000;">социалистическим</span> правительством и, возможно, попытается сформировать другое правительство без нашего участия. Он ведет тайные переговоры с одним из наших партнёров по коалиции. Если разразится кризис, его непременно используют как предлог, чтобы исключить нас из правительства. ?]{!</p>!}

{!<p class="other">!}[? if year = 1930 and month = 1 and pro_republic < 65 and ddp_ideology != "Left" and z_ideology == "Right" and not lvp_formed: The <span style="color: #D3C24D;">**[+ ddp_name +]**</span>, как и другие буржуазные партии, всё чаще отказываются от коалиций с нами на местном уровне, предпочитая вместо этого формировать <i>Буржуазный Блок</i>. Обе либеральные партии вошли в коалицию [? if z_party_name != "CVP": <span style="color: #000000;">Центра</span> ?][? if z_party_name == "CVP": <span style="color: #000000;">**ХНП**</span> ?] и <span style="color: #3E88B3;">**НННП**</span> в Вюртемберге. ?]{!</p>!}

{!<p class="other">!}[? if year = 1930 and month = 1 : Испанский диктатор Мигель Примо де Ривера подал в отставку, так как испанский народ устал от диктатуры, особенно после начала экономической депрессии. Король Альфонсо XIII назначил нового диктатора править вместо него, но республиканские силы в этом хрупком королевстве получают всё большую поддержку народа. ?]{!</p>!}

{!<p class="both">!}[? if year = 1930 and month = 2: Франц фон Папен, консерватор-католик, несколько лет назад препятствовавший назначению Брауна министром-президентом Пруссии, выдвинут Каасом и Брюнингом на вакантное место в прусском ландтаге. Принадлежащий к крайне правому крылу своей партии, Папен возвращается к политической деятельности, хоть ему и отказали в мандате Йозеф Гесс и левое крыло [? if z_party_name != "CVP": <span style="color: #000000;">партии Центра</span> ?][? if z_party_name == "CVP": <span style="color: #000000;">**ХНП**</span> ?] отказали ему в мандате на прошлых выборах. Мягко говоря, это недобрый знак для нашего многолетнего сотрудничества с [? if z_party_name != "CVP": <span style="color: #000000;">партией Центра</span> ?][? if z_party_name == "CVP": <span style="color: #000000;">**ХНП**</span> ?] на протяжении всего существования Республики. ?]{!</p>!}

{!<p class="other">!}[? if year = 1930 and month = 2 and dvp_leader = "Scholz" and in_grand_coalition and not lvp_formed: The <span style="color: #C0A054;">**ННП**</span> созвали партийный съезд для обсуждения вопросов, касающихся сотрудничества с нами и будущего нашей правительственной коалиции. Во время съезда они открыто поддержали Большую Коалицию. Шольц изменил позицию, отказавшись от своего прежнего неприятия сотрудничества с другими буржуазными партиями. Мы сомневаемся в искренности их заявлений. ?]{!</p>!}

{!<p class="other">!}[? if year = 1930 and month = 2 and dvp_leader != "Scholz" and in_grand_coalition and not lvp_formed: The <span style="color: #C0A054;">**ННП**</span> созвала партийный съезд для обсуждения вопросов, касающихся сотрудничества с нами и будущего нашей правительственной коалиции. В ходе съезда её представители решительно поддержали большую коалицию и уделили особое внимание развитию сотрудничества между буржуазными партиями. Возможно, <span style="color: #C0A054;">**ННП**</span> наконец-то взялись за ум. ?]{!</p>!}

{!<p class="other">!}[? if year = 1930 and month = 2 and dvp_leader = "Scholz" and not in_grand_coalition and not lvp_formed: The <span style="color: #C0A054;">**ННП**</span> созвала партийный съезд, чтобы обсудить вопросы относительно будущего сотрудничества с нами и единства буржуазных партий. В ходе съезда её члены исключили возможность создания любых будущих коалиций с нами. Однако Шольц под давлением Ганса Лютера и покровителей-промышленников отказался от своего прежнего неприятия сотрудничества с буржуазными партиями. ?]{!</p>!}

{!<p class="other">!}[? if year = 1930 and month = 2 and dvp_leader != "Scholz" and not in_grand_coalition and not lvp_formed: The <span style="color: #C0A054;">**ННП**</span> созвала партийный съезд, чтобы обсудить вопросы относительно будущего сотрудничества с нами и единства буржуазных партий. В ходе съезда её члены уделили особое внимание развитию сотрудничества между буржуазными партиями и подтвердили тёплые отношения с нами. ?]{!</p>!}

{!<p class="both">!}[? if year = 1930 and month = 3 and dvp_leader != "Luther" and lvp_leader != "Luther": Президент Рейхсбанка Ялмар Шахт ушёл в отставку. Бывший канцлер и член <span style="color: #C0A054;">**ННП**</span> Ганс Лютер назначен на эту должность. ?]{!</p>!}

{!<p class="other">!}[? if year = 1930 and month = 3 and not lvp_formed: Всё больше левых из <span style="color: #D3C24D;">**[+ ddp_name +]**</span> оттесняют на второй план или изживают из партии в попытке избавиться от имиджа пацифистов и <span style="color: #c00000;">социалистов</span>, угодить богатым покровителям из деловых кругов и привлечь на свою сторону правеющий немецкий электорат. Бывший многолетний лидер <span style="color: #D3C24D;">**[+ ddp_name +]**</span> левого крыла, Антон Эркеленц, ушел в отставку в конце прошлого года, поскольку его левые взгляды становятся всё более неуместными в партии. Левые, оставшиеся в <span style="color: #D3C24D;">[+ ddp_name +]</span>, ныне объединённые в «Социально-республиканский кружок», в основном смирились с правым уклоном партии. Несмотря на это, они по-прежнему остаются препятствием, которое <span style="color: #D3C24D;">**[+ ddp_name +]**</span> деловому крылу придётся преодолеть. ?]{!</p>!}

{!<p class="dnvp">!}[? if year = 1930 and month = 4 and csvd_formed = 1 and stegerwald_path = 0: The <span style="color: #8ED8E4;">**ХСНС**</span> прошёл первый съезд, на котором лидеры партии осудили либерализм и индивидуализм, а также раскритиковали координацию между правыми силами, выступающими против Гугенберга, назвав её «не более чем заговором с целью укрепить существующие классовые границы за счёт немецкого рабочего». Кроме того, по их мнению, другие нишевые партии — «проявляют материалистический эгоизм, который развращает ткань политической жизни Германии и враждебен духу христианской веры». ?]{!</p>!}

{!<p class="other">!}[? if bourgeois_negotiations_1930_timer == 6 and dnvp_ideology == "Radical" and not lvp_formed: Формирование кабинета Брюнинга, состоящего из министров от всех основных буржуазных партий, предоставило уникальную возможность для [? if dvp_leader == "Scholz": Шольца выполнить обещание о буржуазном единстве, данное на партийном съезде 1930 года ?][? if dvp_leader != "Scholz": для <span style="color: #C0A054;">**ННП**</span> возглавить объединение различных буржуазных партий под руководством Брюнинга ?]. Переговоры инициированы <span style="color: #C0A054;">**ННП**</span>, в которых участвуют партии от <span style="color: #D3C24D;">**[+ ddp_name +]**</span> до бывшего левого крыла <span style="color: #3E88B3;">**НННП**</span>. В настоящее время основное внимание уделяется возможности заключения электорального альянса на случай будущих выборов. ?]{!</p>!}

{!<p class="other">!}[? if bourgeois_negotiations_1930_timer == 6 and dnvp_ideology == "Moderate" and not lvp_formed: Формирование кабинета Брюнинга, состоящего из министров от всех основных буржуазных партий, предоставило уникальную возможность для [? if dvp_leader == "Scholz": Шольца выполнить обещание о буржуазном единстве, данное на партийном съезде 1930 года ?][? if dvp_leader != "Scholz": для <span style="color: #C0A054;">**ННП**</span> возглавить объединение различных буржуазных партий под руководством Брюнинга ?]. Переговоры инициированы <span style="color: #C0A054;">**ННП**</span>, в которых участвуют партии от <span style="color: #D3C24D;">**[+ ddp_name +]**</span> до слабеющих профессионально-сословных партий справа. В настоящее время основное внимание уделяется возможности заключения электорального перемирия на случай будущих выборов. ?]{!</p>!}

{!<p class="other">!}[? if bourgeois_negotiations_1930_timer == 6 and dnvp_ideology == "Radical" and lvp_formed: Формирование кабинета Брюнинга, состоящего из министров от всех основных буржуазных партий, предоставило малым буржуазным партиям уникальную возможность сплотиться вокруг него. Переговоры инициированы [+ lvp_leader +] со стороны <span style="color: #FFCC00;">**ЛНП**</span>, пытаясь объединить умеренно-правые и профессионально-сословные партии. В настоящее время основное внимание уделяется возможности заключить предвыборное перемирие на случай будущих выборов. ?]{!</p>!}

{!<p class="other">!}[? if bourgeois_negotiations_1930_timer == 6 and dnvp_ideology == "Moderate" and lvp_formed: Формирование кабинета Брюнинга, состоящего из министров от всех основных буржуазных партий, предоставило малым буржуазным партиям уникальную возможность сплотиться вокруг Брюнинга. Переговоры начаты [+ lvp_leader +] из <span style="color: #FFCC00;">**ЛНП**</span>, который пытается объединить теряющие влияние профессионально-сословные и правые партии для поддержки Брюнинга. В настоящее время основное внимание уделяется возможности заключить предвыборное перемирие на случай будущих выборов. ?]{!</p>!}

{!<p class="both">!}[? if bruning_event_timer = 5 and dnvp_ideology == "Radical" and not kvp_formed: Канцлер Брюнинг предложил масштабную реформу германских финансов, включающую непопулярное повышение потребительских налогов, которую он связал с помощью сельскому хозяйству. Это явная уловка, чтобы обеспечить введение новых налогов, которые в противном случае были бы отклонены голосованием. Гугенберг приказал партии выступить против этого законопроекта, но Вестарп и его группа умеренных не последовали этому приказу, продолжая поддерживать правительство Брюнинга. ?]{!</p>!}

{!<p class="both">!}[? if bruning_event_timer = 5 and dnvp_ideology == "Radical" and kvp_formed: Канцлер Брюнинг предложил масштабную реформу германских финансов, включающую непопулярное повышение потребительских налогов, которую он связал с помощью сельскому хозяйству. Это явная уловка, чтобы обеспечить введение новых налогов, которые в противном случае были бы отклонены голосованием. Гугенберг приказал партии выступить против этого законопроекта, похоронив надежды на создание широкой правой коалиции. ?]{!</p>!}

{!<p class="other">!}[? if bruning_event_timer = 5 and ddp_ideology != "Right" and not lvp_formed: Левое крыло <span style="color: #D3C24D;">**[+ ddp_name +]**</span>, с которым не посоветовались о решении войти в кабинет Брюнинга, угрожает отказать в поддержке при любом голосовании о вотуме недоверия. Однако популярность и влияние Германа Дитриха среди рядовых членов партии в конечном счёте убеждают делегацию в рейхстаге поддержать его пост в кабинете и Брюнинга при голосовании о вотуме недоверия. ?]{!</p>!}

{!<p class="dnvp">!}[? if bruning_event_timer = 5 and dnvp_ideology == "Radical" and young_plan_signatures >= 10 and dnvp_bruning: The <span style="color: #7A3C00;">**НСДАП**</span> вышла из Национального комитета по проведению референдума — правого альянса Гугенберга, созданного для кампании против референдума по плану Юнга, — после решения Гугенберга поддержать новый кабинет Брюнинга. Хотя Гитлер готов к примирению, дав Гугенбергу 14 дней на разрыв с Брюнингом, Грегор Штрассер, лидер левого крыла <span style="color: #7A3C00;">**НСДАП**</span>, нарушил партийную дисциплину и всё равно прекратил участие — к большому раздражению Гитлера. ?]{!</p>!}

{!<p class="other">!}[? if bourgeois_negotiations_1930_timer == 5 and (dvp_leader == "Scholz" or dvp_leader == "Dingeldey") and bourgeois_negotiations_election_soon and not lvp_formed: Официальные переговоры между буржуазными партиями завершились принятием совместной декларации в поддержку политики Брюнинга и объявлением предвыборного перемирия. Теперь они сосредоточены на предложении о создании парламентского альянса для поддержки правительства Брюнинга.[+ dvp_leader +] — его главная цель это усилить анти-<span style="color: #c00000;">социалистические</span> силы в рейхстаге и оказать решающее влияние на экономическую политику кабинета Брюнинга. Как и ожидалось, <span style="color: #D3C24D;">**[+ ddp_name +]**</span>, единственной партии, не выступающей против сотрудничества с <span style="color: #c00000;">**СДПГ**</span>, оказала решительное сопротивление этому предложению. [? if dstp_formed: Кроме того, создание <span style="color: #D3C24D;">**[+ ddp_name +]**</span> и её попытки переманить членов <span style="color: #C0A054;">**ННП**</span> серьёзно обострили отношения между двумя партиями. ?] ?]{!</p>!}

{!<p class="other">!}[? if bourgeois_negotiations_1930_timer == 5 and (dvp_leader != "Scholz" and dvp_leader != "Dingeldey") and bourgeois_negotiations_election_soon and not lvp_formed: Официальные переговоры между буржуазными партиями завершились принятием совместной декларации в поддержку политики Брюнинга и объявлением предвыборного перемирия. Теперь они сосредоточены на предложении о создании парламентского альянса для поддержки правительства Брюнинга. Мотивы такого альянса — усилить анти<span style="color: #c00000;">социалистические</span> силы в рейхстаге и оказать решающее влияние на экономическую политику кабинета Брюнинга. Однако <span style="color: #C0A054;">**ННП**</span> и особенно <span style="color: #D3C24D;">**[+ ddp_name +]**</span>, единственных партий, которые не до конца выступают против сотрудничества с <span style="color: #c00000;">**СДПГ**</span> в ходе переговоров столкнулись с <span style="color: #b8996f;">**ЭП**</span> и <span style="color: #7FCEB1;">**ХНПКЗ**</span> из-за их позиции по отношению к нам.[? if dstp_formed: Однако создание <span style="color: #D3C24D;">**[+ ddp_name +]**</span> и её попытки переманить членов <span style="color: #C0A054;">**ННП**</span> серьёзно обострили отношения между двумя партиями, сорвав любые, казалось бы, многообещающие переговоры. ?] ?]{!</p>!}

{!<p class="other">!}[? if bourgeois_negotiations_1930_timer == 5 and bourgeois_negotiations_election_soon and lvp_formed: Официальные переговоры между буржуазными партиями завершились принятием совместной декларации в поддержку политики Брюнинга и заключением электорального альянса. Теперь переговоры перешли к обсуждению предлагаемой парламентской группы в поддержку правительства Брюнинга. Главная цель правых — усилить анти<span style="color: #c00000;">социалистические</span> силы в рейхстаге и оказывать влияние на экономическую политику кабинета Брюнинга. Как и ожидалось, <span style="color: #FFCC00;">**ЛНП**</span>, единственной партии, не выступающей категорически против сотрудничества с <span style="color: #c00000;">**СДПГ**</span> оказала этому предложению решительное сопротивление и, возможно, не войдёт в этот парламентский альянс. ?]{!</p>!}

{!<p class="other">!}[? if bourgeois_negotiations_1930_timer == 5 and (dvp_leader == "Scholz" or dvp_leader == "Dingeldey") and not bourgeois_negotiations_election_soon and not lvp_formed: Официальные переговоры между буржуазными партиями сместились с обсуждения предвыборной стратегии на обсуждение предлагаемого парламентского союза в поддержку правительства Брюнинга. Главная цель [+ dvp_leader +]а — усилить анти<span style="color: #c00000;">социалистические</span> силы в рейхстаге и оказывать решающее влияние на экономическую политику кабинета Брюнинга. Как и ожидалось, <span style="color: #D3C24D;">**[+ ddp_name +]**</span>, единственной партии, не выступающей против сотрудничества с <span style="color: #c00000;">**СДПГ**</span>, оказала решительное сопротивление этому предложению. [? if dstp_formed: Кроме того, создание <span style="color: #D3C24D;">**[+ ddp_name +]**</span> и её попытки переманить членов <span style="color: #C0A054;">**ННП**</span> серьёзно обострили отношения между двумя партиями. ?] ?]{!</p>!}

{!<p class="other">!}[? if bourgeois_negotiations_1930_timer == 5 and (dvp_leader != "Scholz" and dvp_leader != "Dingeldey") and not bourgeois_negotiations_election_soon and not lvp_formed: Официальные переговоры между буржуазными партиями сместились с обсуждения предвыборной стратегии на обсуждение предлагаемого парламентского союза в поддержку правительства Брюнинга. Такой союз призван усилить анти<span style="color: #c00000;">социалистические</span> силы в рейхстаге и оказывать решающее влияние на экономическую политику кабинета Брюнинга. Однако <span style="color: #C0A054;">**ННП**</span> и особенно <span style="color: #D3C24D;">**[+ ddp_name +]**</span>, единственных партий, которые не до конца выступают против сотрудничества с <span style="color: #c00000;">**СДПГ**</span> в ходе переговоров столкнулись с <span style="color: #b8996f;">**ЭП**</span> и <span style="color: #7FCEB1;">**ХНПКЗ**</span> из-за их позиции по отношению к нам.[? if dstp_formed: Однако создание <span style="color: #D3C24D;">**[+ ddp_name +]**</span> и её попытки переманить членов <span style="color: #C0A054;">**ННП**</span> серьёзно обострили отношения между двумя партиями, сорвав любые, казалось бы, многообещающие переговоры. ?] ?]{!</p>!}

{!<p class="other">!}[? if bourgeois_negotiations_1930_timer == 5 and not bourgeois_negotiations_election_soon and lvp_formed: Официальные переговоры между буржуазными партиями перешли от обсуждения предвыборной стратегии к предложению о создании парламентского союза в поддержку правительства Брюнинга. Главная цель правых — усиление анти-<span style="color: #c00000;">социалистических</span> сил в рейхстаге и оказание влияния на экономическую политику кабинета Брюнинга. Как и ожидалось, <span style="color: #FFCC00;">**ЛНП**</span>, единственной партии, не выступающей категорически против сотрудничества с <span style="color: #c00000;">**СДПГ**</span> оказала этому предложению решительное сопротивление и, возможно, не войдёт в этот парламентский альянс. ?]{!</p>!}

{!<p class="other">!}[? if bruning_event_timer = 4 and in_weimar_coalition_prussia or in_social_catholic_coalition_prussia or in_grand_coalition_prussia or in_popular_front_prussia: Брюнинг оказывает давление на прусскую [? if z_party_name != "CVP": <span style="color: #000000;">Партию Центра</span> ?][? if z_party_name == "CVP": <span style="color: #000000;">**ХНП**</span> ?] , требуя распустить и тамошнюю правящую коалицию. К счастью, наш Отто Браун и лидер прусской ячейки [? if z_party_name != "CVP": <span style="color: #000000;">Центра</span> ?][? if z_party_name == "CVP": <span style="color: #000000;">**ХНП**</span> ?] Йозеф Гесс обладают достаточным влиянием, чтобы противостоять требованиям Брюнинга. ?]{!</p>!}

{!<p class="other">!}[? if bourgeois_negotiations_1930_timer == 4 and (dvp_leader == "Scholz" or dvp_leader == "Dingeldey") and bourgeois_negotiations_election_soon and not lvp_formed and not dstp_formed: [+ dvp_leader +] и лидеры других буржуазных партий теряют терпение из-за <span style="color: #D3C24D;">**[+ ddp_name +]**</span> уклончивости в вопросе о формировании парламентского союза и в последний раз потребовали дать окончательный ответ. Хотя руководство партии и сам Кох-Везер считают, что «что-то» необходимо предпринять для обеспечения выживания парламентской формы правления, агитация со стороны Социально-республиканского кружка и других левых в рядах <span style="color: #D3C24D;">**[+ ddp_name +]**</span> мешает им полностью одобрить создание новой всеобъемлющей буржуазной центристской партии. Несмотря на это, отчаяние внутри <span style="color: #D3C24D;">**[+ ddp_name +]**</span> и стремление не показаться своим богатым покровителям виновниками в срыве переговоров в преддверии выборов — заставили их упорствовать. ?]{!</p>!}

{!<p class="other">!}[? if bourgeois_negotiations_1930_timer == 4 and (dvp_leader != "Scholz" and dvp_leader != "Dingeldey") and bourgeois_negotiations_election_soon and not lvp_formed and not dstp_formed: Переговоры зашли в тупик из-за позиции предлагаемого парламентского союза по вопросу о сотрудничестве с <span style="color: #c00000;">**СДПГ**</span> и того, какой политики союз будет придерживаться. Хотя руководство либеральных партий и сам Кох-Везер считают, что нужно «что-то делать» для сохранения парламентского правления, агитация со стороны левого крыла обеих партий не позволяет им полностью одобрить создание новой всеобъемлющей буржуазной центристской партии. Несмотря на это, отчаяние внутри <span style="color: #D3C24D;">**[+ ddp_name +]**</span> и стремление не показаться своим богатым покровителям виновниками в срыве переговоров в преддверии выборов — заставили их упорствовать. ?]{!</p>!}

{!<p class="other">!}[? if bourgeois_negotiations_1930_timer == 4 and bourgeois_negotiations_election_soon and lvp_formed: The <span style="color: #FFCC00;">**ЛНП**</span> вышла из переговоров о парламентском союзе буржуазных партий, оставив любое соглашение между различными буржуазными партиями между <span style="color: #FFCC00;">**ЛНП**</span> и <span style="color: #3E88B3;">**НННП**</span>. Из-за отчаянного стремления немецкой буржуазии создать видимость буржуазного единства перед предстоящими выборами и ради своих богатых спонсоров, <span style="color: #7FCEB1;">**ХНПКЗ**</span> и <span style="color: #b8996f;">**ЭП**</span> смогли объединить свои парламентские фракции, к ним присоединились некоторые более мелкие партии, например <span style="color: #007A00;">Немецкая крестьянская партия</span>[? if dnvp_ideology == "Radical": &nbsp;и даже[? if not kvp_formed: отколовшиеся от <span style="color: #3E88B3;">**НННП**</span> ?][? if kvp_formed: <span style="color: #0087DC;">**КНП**</span> ?] ?]. ?]{!</p>!}

{!<p class="other">!}[? if bourgeois_negotiations_1930_timer == 4 and not lvp_formed and dstp_formed: Поскольку соглашения с участием <span style="color: #D3C24D;">**[+ ddp_name +]**</span> достичь не удалось, они вышли из переговоров, столкнувшись с враждебностью других буржуазных партий из-за своих прошлых действий. Несмотря на это, [+ dvp_leader +] а оставшиеся буржуазные партии стремятся продолжить переговоры без <span style="color: #D3C24D;">**[+ ddp_name +]**</span>. ?]{!</p>!}

{!<p class="other">!}[? if bourgeois_negotiations_1930_timer == 4 and (dvp_leader == "Scholz" or dvp_leader == "Dingeldey") and (ddp_ideology != "Right" or ddp_ideology == "Right" and ddp_relation >= 45) and not lvp_formed and not dstp_formed: [+ dvp_leader +] и лидеры других буржуазных партий теряют терпение из-за <span style="color: #D3C24D;">**[+ ddp_name +]**</span> уклончивости в вопросе о формировании парламентского союза и в последний раз потребовали дать окончательный ответ. Хотя руководство партии и сам Кох-Везер считают, что «что-то» необходимо предпринять для обеспечения выживания парламентской формы правления, агитация со стороны Социально-республиканского кружка и других левых в рядах <span style="color: #D3C24D;">**[+ ddp_name +]**</span> сделала невозможным для них полное одобрение создания новой, всеобъемлющей буржуазной центристской партии. В результате принята компромиссная резолюция, подчёркивающая, что социальный и республиканский характер <span style="color: #D3C24D;">**[+ ddp_name +]**</span> будет сохранён, что ещё больше осложнило переговоры. ?]{!</p>!}

{!<p class="other">!}[? if bourgeois_negotiations_1930_timer == 4 and (dvp_leader == "Scholz" or dvp_leader == "Dingeldey") and ddp_ideology == "Right" and ddp_relation < 45 and not bourgeois_negotiations_election_soon and not lvp_formed and not dstp_formed: [+ dvp_leader +] и лидеры других буржуазных партий теряют терпение из-за <span style="color: #D3C24D;">**[+ ddp_name +]**</span> уклончивости в вопросе о формировании парламентского союза и в последний раз потребовали дать окончательный ответ. Хотя руководство партии и сам Кох-Везер считают, что «что-то» необходимо предпринять для обеспечения выживания парламентской формы правления, агитация со стороны Социально-республиканского кружка и других левых в рядах <span style="color: #D3C24D;">**[+ ddp_name +]**</span> затруднила им возможность полностью одобрить создание новой единой буржуазной центристской партии. Несмотря на это, Кох-Везер и правое крыло <span style="color: #D3C24D;">**[+ ddp_name +]**</span> продолжают настаивать на этом предложении, продолжая переговоры. ?]{!</p>!}

{!<p class="other">!}[? if bourgeois_negotiations_1930_timer == 4 and (dvp_leader != "Scholz" and dvp_leader != "Dingeldey") and not bourgeois_negotiations_election_soon and not lvp_formed and not dstp_formed: Переговоры зашли в тупик из-за позиции предполагаемого парламентского альянса по вопросу сотрудничества с <span style="color: #c00000;">**СДПГ**</span> и его будущей политической платформы. Хотя руководство либеральных партий и сам Кох-Везер считают: для спасения парламентской формы правления нужно «что-то» делать, агитация левых крыльев обеих партий не позволила им полностью поддержать создание новой всеобъемлющей буржуазной центристской партии. В результате принята компромиссная резолюция, предложенная <span style="color: #D3C24D;">**[+ ddp_name +]**</span>, в которой подчёркивается, что социальный и республиканский характер <span style="color: #D3C24D;">**[+ ddp_name +]**</span> будет сохранён, что ещё больше осложняет переговоры. ?]{!</p>!}

{!<p class="other">!}[? if bourgeois_negotiations_1930_timer == 4 and bourgeois_cooperation < 5 and not bourgeois_negotiations_election_soon and lvp_formed: The <span style="color: #FFCC00;">**ЛНП**</span> отказались от переговоров о парламентском союзе буржуазных партий, оставив любое соглашение среди различных буржуазных партий между <span style="color: #FFCC00;">**ЛНП**</span> и <span style="color: #3E88B3;">**НННП**</span>. Маловероятно, что нишевые партии, которые так сильно желают сохранить свою профессиональную и идеологическую идентичность, когда-либо смогут прийти к всеобъемлющему соглашению. ?]{!</p>!}

{!<p class="other">!}[? if bourgeois_negotiations_1930_timer == 4 and bourgeois_cooperation >= 5 and not bourgeois_negotiations_election_soon and lvp_formed: The <span style="color: #FFCC00;">**ЛНП**</span> отказались от переговоров о парламентском союзе буржуазных партий, оставив любое соглашение среди различных буржуазных партий между <span style="color: #FFCC00;">**ЛНП**</span> и <span style="color: #3E88B3;">**НННП**</span>. Удивительно, <span style="color: #7FCEB1;">**ХНПКЗ**</span> и <span style="color: #b8996f;">**ЭП**</span> смогли объединить свои парламентские фракции, к ним присоединились некоторые более мелкие партии, например <span style="color: #007A00;">Немецкая крестьянская партия</span>[? if dnvp_ideology == "Radical": &nbsp;и даже[? if not kvp_formed: отколовшиеся от <span style="color: #3E88B3;">**НННП**</span> ?][? if kvp_formed: <span style="color: #0087DC;">**КНП**</span> ?] ?]. ?]{!</p>!}

{!<p class="other">!}[? if bourgeois_negotiations_1930_timer == 3 and bourgeois_parliament_trigger and not lvp_formed: Переговоры между буржуазными партиями наконец-то привели к прорыву. Понадобилось лишь дополнительное поощрение со стороны промышленных спонсоров, чтобы объединить их в парламентский альянс, состоящий из <span style="color: #D3C24D;">**[+ ddp_name +]**</span>, <span style="color: #C0A054;">**ННП**</span>, <span style="color: #b8996f;">**ЭП**</span> и <span style="color: #7FCEB1;">**ХНПКЗ**</span>. Позднее к ним присоединяется <span style="color: #007A00;">Немецкая крестьянская партия</span>[? if dnvp_ideology == "Radical": &nbsp;и даже[? if not kvp_formed: отколовшиеся от <span style="color: #3E88B3;">**НННП**</span> ?][? if kvp_formed: <span style="color: #0087DC;">**КНП**</span> ?] ?]. ?]{!</p>!}

{!<p class="other">!}[? if bourgeois_negotiations_1930_timer == 3 and bourgeois_parliament_trigger_1 and not lvp_formed: The <span style="color: #D3C24D;">**[+ ddp_name +]**</span> исключена из переговоров после событий прошлого месяца, вследствие чего буржуазные партии наконец достигли прорыва. Чтобы объединить их в парламентский союз, потребовалась дополнительная поддержка со стороны промышленников-спонсоров. В этот союз вошли <span style="color: #C0A054;">**ННП**</span>, <span style="color: #b8996f;">**ЭП**</span> и <span style="color: #7FCEB1;">**ХНПКЗ**</span>. Позднее к ним присоединяется <span style="color: #007A00;">Немецкая крестьянская партия</span>[? if dnvp_ideology == "Radical": &nbsp;и даже[? if not kvp_formed: отколовшиеся от <span style="color: #3E88B3;">**НННП**</span> ?][? if kvp_formed: <span style="color: #0087DC;">**КНП**</span> ?]. ?] ?]{!</p>!}

{!<p class="other">!}[? if bourgeois_negotiations_1930_timer == 3 and bourgeois_parliament_trigger_2 and not lvp_formed: Переговоры между буржуазными партиями завершились тем, что <span style="color: #D3C24D;">**[+ ddp_name +]**</span> и <span style="color: #C0A054;">**ННП**</span> предпочли создать парламентский союз между собой, а не с другими буржуазными партиями. Хотя это и шаг вперёд к единству буржуазии, такой союз закрывает путь к дальнейшему сотрудничеству с не входящими в <span style="color: #3E88B3;">**НННП**</span> правыми. ?]{!</p>!}

{!<p class="other">!}[? if bourgeois_negotiations_1930_timer == 3 and bourgeois_parliament_trigger_3 and not lvp_formed: Переговоры между буржуазными партиями завершились, причём для достижения соглашения либеральным партиям пришлось пойти на значительные уступки. Для создания парламентской группы потребовалась дополнительная поддержка в виде финансирования на определённых условиях, предложенного крупными промышленниками, однако маловероятно, что участвующие партии возобновят соглашение после следующих выборов. В парламентскую группу вошли <span style="color: #D3C24D;">**[+ ddp_name +]**</span>, <span style="color: #C0A054;">**ННП**</span>, <span style="color: #b8996f;">**ЭП**</span> и <span style="color: #7FCEB1;">**ХНПКЗ**</span>. Позднее к ним присоединяется <span style="color: #007A00;">Немецкая крестьянская партия</span>[? if dnvp_ideology == "Radical": &nbsp;и даже[? if not kvp_formed: отколовшиеся от <span style="color: #3E88B3;">**НННП**</span> ?][? if kvp_formed: <span style="color: #0087DC;">**КНП**</span> ?]. ?] ?]{!</p>!}

{!<p class="other">!}[? if bourgeois_negotiations_1930_timer == 3 and bourgeois_parliament_trigger_4 and not lvp_formed: [+ dvp_leader +] успешно сформировала парламентский альянс из буржуазных партий, не считая <span style="color: #D3C24D;">**[+ ddp_name +]**</span>. Несмотря на то, что весь этот провал подорвал доверие немецкой промышленности, давление буржуазного единства оказалось слишком сильным для старой гвардии <span style="color: #7FCEB1;">**ХНПКЗ**</span> и <span style="color: #b8996f;">**ЭП**</span>, чьё сопротивление предстояло преодолеть. В парламентскую фракцию входят <span style="color: #C0A054;">**ННП**</span>, <span style="color: #b8996f;">**ЭП**</span> и <span style="color: #7FCEB1;">**ХНПКЗ**</span>. Позже к ней присоединяется <span style="color: #007A00;">Немецкая крестьянская партия</span>[? if dnvp_ideology == "Radical": &nbsp;и даже[? if not kvp_formed: отколовшиеся от <span style="color: #3E88B3;">**НННП**</span> ?][? if kvp_formed: <span style="color: #0087DC;">**КНП**</span> ?]. ?] ?]{!</p>!}

{!<p class="other">!}[? if bourgeois_negotiations_1930_timer == 3 and bourgeois_parliament_trigger_event and kvp_formed: Включение <span style="color: #0087DC;">**КНП**</span> в буржуазную парламентскую группу вызвало разногласия внутри партии, которая желает сохранить свою самобытность. [? if not schleicher_kvp and bourgeois_cooperation < 5: Это вынудило руководство партии отказаться от своего решения о вступлении в парламентскую группу, заявив, что они предпочли бы сперва сосредоточиться на развитии собственной партии. ?][? if bourgeois_cooperation >= 5 and not schleicher_kvp: Несмотря на это, стремление к буржуазному единству слишком соблазнительно, чтобы это предложение отклонили на внутреннем голосовании. ?][? if schleicher_kvp: Однако Шлейхер использовал своё значительное влияние в партии, чтобы протолкнуть это предложение. ?] ?]{!</p>!}

{!<p class="other">!}[? if bourgeois_negotiations_1930_timer == 2 and bourgeois_parliament and not bourgeois_parliament_trigger_event and kvp_formed: Включение <span style="color: #0087DC;">**КНП**</span> в буржуазную парламентскую группу вызвало разногласия внутри партии, которая желает сохранить свою самобытность. [? if not schleicher_kvp and bourgeois_cooperation < 8: Это вынудило руководство партии отказаться от своего решения о вступлении в парламентскую группу, заявив, что они предпочли бы сперва сосредоточиться на развитии собственной партии. ?][? if bourgeois_cooperation >= 8 and not schleicher_kvp: Несмотря на это, стремление к буржуазному единству слишком соблазнительно, чтобы это предложение отклонили на внутреннем голосовании. ?][? if schleicher_kvp: Однако Шлейхер использовал своё значительное влияние в партии, чтобы протолкнуть это предложение. ?] ?]{!</p>!}

{!<p class="other">!}[? if bourgeois_negotiations_1930_timer == 3 and bourgeois_negotiations_fail and not lvp_formed: Переговоры между буржуазными партиями наконец завершились, но создание парламентского альянса провалилось из-за скептиков в рядах <span style="color: #D3C24D;">**[+ ddp_name +]**</span> и <span style="color: #7FCEB1;">**ХНПКЗ**</span>. Похоже, сотрудничество буржуазных партий остаётся не более чем несбыточной мечтой, даже при том, что крупные спонсоры ставят дальнейшую финансовую поддержку в зависимость от более тесного буржуазного сотрудничества. ?]{!</p>!}

{!<p class="other">!}[? if bourgeois_negotiations_1930_timer == 3 and bourgeois_negotiations_fail_dstp and not lvp_formed: Переговоры между буржуазными партиями наконец завершились, но создание парламентского альянса провалилось в основном из-за непредсказуемого поведения <span style="color: #D3C24D;">**[+ ddp_name +]**</span>, что оттолкнуло от неё все партии справа. Похоже, сотрудничество буржуазных партий остаётся не более чем несбыточной мечтой, даже несмотря на то, что крупные спонсоры ставят условием дальнейшей поддержки более тесное сотрудничество. ?]{!</p>!}

{!<p class="other">!}[? if bourgeois_negotiations_1930_timer == 3 and bourgeois_negotiations_fail_liberal and not lvp_formed: Переговоры между буржуазными партиями наконец-то завершились. Создание широкого буржуазного парламентского альянса провалилось из-за скептиков в либеральных партиях и ярого анти-<span style="color: #c00000;">социализма</span> в рядах <span style="color: #7FCEB1;">**ХНПКЗ**</span> и <span style="color: #b8996f;">**ЭП**</span>. Похоже, широкое буржуазное единство остаётся недостижимым, даже несмотря на то, что крупные спонсоры ставят условием дальнейшей поддержки более тесное сотрудничество. ?]{!</p>!}

{!<p class="other">!}[? if bourgeois_negotiations_1930_timer == 3 and bourgeois_negotiations_fail and lvp_formed: Переговоры между буржуазными партиями наконец-то завершились, однако парламентский альянс не состоялся из-за левого крыла в <span style="color: #FFCC00;">**ЛНП**</span> И старой гвардии внутри <span style="color: #7FCEB1;">**ХНПКЗ**</span> и <span style="color: #b8996f;">**ЭП**</span>. Похоже, сотрудничество буржуазных партий остаётся не более чем несбыточной мечтой, даже при том, что крупные спонсоры ставят дальнейшую финансовую поддержку в зависимость от более тесного буржуазного сотрудничества. ?]{!</p>!}

{!<p class="other">!}[? if lvp_merger_2_timer == 4 and not lvp_formed: Примирительные отношения между <span style="color: #D3C24D;">**[+ ddp_name +]**</span> и <span style="color: #C0A054;">**ННП**</span>, а также предыдущие случаи сотрудничества либералов, сделали возможным создание <span style="color: #FFCC00;">единой либеральной партии</span>. [? if dvp_leader == "Scholz" or dvp_leader == "Dingeldey": Однако руководство <span style="color: #C0A054;">**ННП**</span>, вероятно, станет главным камнем преткновения на пути к возможному слиянию. ?][? if ddp_leader == "Lemmer": Руководство <span style="color: #D3C24D;">**[+ ddp_name +]**</span> по-прежнему скептически относится к дальнейшему сотрудничеству[? if dvp_leader == "Scholz" or dvp_leader == "Dingeldey": &nbsp;также ?]. ?] В ближайшие несколько месяцев пройдут официальные переговоры, чтобы оценить взаимную заинтересованность и выработать согласованную обеими сторонами политическую платформу. ?]{!</p>!}

{!<p class="both">!}[? if bruning_event_timer = 3 and dvp_ideology != "Right" and not lvp_formed: Пауль Мольденхауэр, министр финансов в кабинете Брюнинга и член [? if dvp_exist: <span style="color: #C0A054;">**ННП**</span> ?][? if not dvp_exist: <span style="color: #3E88B3;">**НННП**</span> ?], столкнулся с резкой критикой после своего предложения о введении 3-процентного сбора с зарплат всех государственных служащих. Это предложение вызвало значительное недовольство со стороны делового и чиновничьего крыла его партии, которое [? if dvp_exist: <span style="color: #C0A054;">**ННП**</span> ?][? if not dvp_exist: <span style="color: #3E88B3;">**НННП**</span>, на которую теперь ?] сильно опирается в своей электоральной поддержке. Несмотря на это, он последовал совету Брюнинга и осудил действия собственной партии, что вызвало значительные споры. ?]{!</p>!}

{!<p class="both">!}[? if bruning_event_timer = 3 and dvp_ideology == "Right" and not lvp_formed: Пауль Мольденгауэр, министр финансов в кабинете Брюнинга и член [? if dvp_exist: <span style="color: #C0A054;">**ННП**</span> ?][? if not dvp_exist: <span style="color: #3E88B3;">**НННП**</span> ?], подал в отставку после того, как предложил ввести 3%-ный налог на зарплаты всех госслужащих. Это предложение вызвало резкую негативную реакцию со стороны предпринимательского и чиновничьего крыла его партии, от которого [? if dvp_exist: <span style="color: #C0A054;">**ННП**</span> ?][? if not dvp_exist: <span style="color: #3E88B3;">**НННП**</span> теперь ?]сильно опирается в своей электоральной поддержке. Этот скандал нанёс серьёзный урон их репутации среди государственных служащих и поставил под сомнение их дальнейшую поддержку правительства Брюнинга. ?]{!</p>!}

{!<p class="both">!}[? if bruning_event_timer = 3 and lvp_ideology != "Right" and lvp_formed: Пауль Мольденгауэр, министр финансов в кабинете Брюнинга и член <span style="color: #FFCC00;">**ЛНП**</span> подвергся жесткой критике после предложения ввести 3%-ный сбор с зарплат всех государственных служащих. Это предложение вызвало значительное недовольство делового и чиновничьего крыла его партии, которое <span style="color: #FFCC00;">**ЛНП**</span>, на которых партия сильно полагается в своей электоральной поддержке. Несмотря на это, он последовал совету Брюнинга и осудил действия собственной партии, что вызвало значительные споры. ?]{!</p>!}

{!<p class="both">!}[? if bruning_event_timer = 3 and lvp_ideology == "Right" and lvp_formed: Пауль Мольденгауэр, министр финансов в кабинете Брюнинга и член <span style="color: #FFCC00;">**ЛНП**</span> ушел в отставку после своего предложения о 3%-ном сборе с зарплат всех государственных служащих. Это предложение вызвало значительное недовольство делового и чиновничьего крыла его партии, которое <span style="color: #FFCC00;">**ЛНП**</span>, на которых партия сильно полагается в своей электоральной поддержке. Этот скандал нанёс серьёзный урон её репутации среди государственных служащих и подтолкнёт их к <span style="color: #7A3C00;">**НСДАП**</span>. ?]{!</p>!}

{!<p class="other">!}[? if year = 1930 and month = 6: Президент <span style="color: #B31942;">Соединённых</span> <span style="color: #0A3161;">Штатов</span> Герберт Гувер подписал закон Смута — Хоули о тарифах, который резко повышает таможенные пошлины в стране и провоцирует другие государства на ответные меры. Маловероятно, что эта политика поможет справиться с продолжающейся депрессией, — скорее она лишь глубже погрузит мир в пучину кризиса. ?]{!</p>!}

{!<p class="other">!}[? if year = 1930 and month = 6 and not lvp_formed: В ландтаге Саксонии наблюдается значительное падение поддержки либеральных партий.[? if not lvp_formed and vnr_r_saxony >= 1.4: Эти выборы также ознаменовались первым появлением в бюллетенях <span style="color: #D3D3A9;">**ННОР**</span>, которая получила [+ vnr_saxony_elections_vote +]% голосов и привлекла к себе внимание в <span style="color: #D3C24D;">[+ ddp_name +]</span>. ?] Эти результаты усилили настоятельную потребность в единстве либералов и буржуазии, которое должно стать решением проблемы падения их доли голосов. ?]{!</p>!}

{!<p class="other">!}[? if lvp_merger_2_timer == 3 and not lvp_formed: Наметился прогресс на пути к созданию <span style="color: #FFCC00;">единой либеральной партии</span>: ранее находившаяся в упадке «Либеральная ассоциация» возрождена и профинансирована видными промышленниками, которые считают единую либеральную партию необходимой для борьбы с <span style="color: #c00000;">социализмом</span> и набирающими силу <span style="color: #7A3C00;">нацистами</span>. Более того, в Баден-Вюртемберге, оплоте либералов, процесс слияния двух партий уже идёт, даже без официального одобрения со стороны их общенационального руководства. ?]{!</p>!}

{!<p class="dnvp">!}[? if flavour_0_trigger and flavour_0_trigger_time == time: Распыление голосов сельских избирателей между несколькими партиями, прямое следствие политики Гугенберга во главе <span style="color: #3E88B3;">**НННП**</span>, создало возможность для <span style="color: #7A3C00;">**НСДАП**</span> возможность привлечь на свою сторону эту недовольную часть населения. ?]{!</p>!}

{!<p class="both">!}[? if flavour_1_trigger and flavour_1_trigger_time == time: В преддверии выборов <span style="color: #7A3C00;">**НСДАП**</span> под руководством Адольфа Гитлера стремительно набирает популярность; в его харизме есть нечто, что привлекает людей всех классов, независимо от их прежних политических симпатий. В нашей партии начались споры о том, следует ли считать их более серьёзной угрозой, чем буржуазных правых. ?]{!</p>!}

{!<p class="other">!}[? if lvp_merger_2_timer == 2 and not lvp_formed: Создание <span style="color: #FFCC00;">единой либеральной партии</span> представляется всё более вероятным, поскольку переговоры между умеренными силами обеих партий принесли на удивление плодотворные результаты. Несмотря на этот успех, как и всегда, правое крыло <span style="color: #C0A054;">**ННП**</span> и левое крыло <span style="color: #D3C24D;">**[+ ddp_name +]**</span> остаются огромным препятствием на пути к единству либералов. Лидеры обеих партий созвали экстренный съезд, чтобы разрешить это разногласие раз и навсегда, но падение популярности обеих партий — это главный фактор, склоняющий рядовых членов к объединению, и вряд ли мнение меньшинства в итоге возобладает. ?]{!</p>!}

{!<p class="both">!}[? if year = 1930 and month = 8: Последние <span style="color: #002654;">французские</span> и <span style="color: #FFD500;">бельгийские</span> войска в Рейнской области эвакуированы в соответствии с планом Юнга. Хотя для республики это позитивное событие, консервативные элиты в рейхсвере и ближнем круге Гинденбурга теперь свободны от внешних ограничений и могут заменить нашу систему правления на <span style="color: #808080;">авторитарную</span> и <span style="color: #7A3C00;">милитаристскую</span>. ?]

{!<p class="other">!}[? if flavour_7_trigger and flavour_7_trigger_time == time: Давний и некогда влиятельный <span style="color: #D3C24D;">**НДП**</span> профсоюзный лидер Антон Эркеленц перешел в <span style="color: #c00000;">**СДПГ**</span>! Однако его ограниченное влияние в партии, наряду с сильным энтузиазмом по поводу создания <span style="color: #D3C24D;">**[+ ddp_name +]**</span> многими представителями левого крыла, не позволило произойти более широкому расколу. Возможно, их общая ненависть к плутократии и подпитывает их поддержку этого слияния? ?]{!</p>!}

{!<p class="other">!}[? if bourgeois_negotiations_elections_1930_timer == 2 and bourgeois_negotiations_1930_done and (dnvp_split_2 or kvp_formed) and (dvp_leader == "Scholz" or dvp_leader == "Dingeldey") and not liberal_parliament and not lvp_formed: После того как Вестарп откололся от [партии] Гугенберга, <span style="color: #3E88B3;">**НННП**</span>, [+ dvp_leader +]проявил(а) живой интерес к налаживанию более тесных связей с ним и его группой умеренных. Назначение новых выборов предоставило[? if dvp_leader == "Scholz": Шольцу ?][? if dvp_leader != "Scholz": и <span style="color: #C0A054;">**ННП**</span> ?] ещё одну возможность договориться о буржуазном единстве. Однако на этот раз усилия куда более амбициозны — это призыв к консолидации всех государственнических сил, а не просто к созданию парламентской фракции. И хотя сам Вестарп не слишком заинтересован в слиянии с другими партиями, он готов принять участие в этом процессе из-за финансирования со стороны промышленников, которое будет предоставлено только при условии достижения буржуазного единства. ?]{!</p>!}

{!<p class="other">!}[? if bourgeois_negotiations_1930_aftermath_timer == 2 and not liberal_parliament and not lvp_formed: [? if dnvp_split_2 or kvp_formed: После выхода Вестарпа из <span style="color: #3E88B3;">**НННП**</span>, [+ dvp_leader +]проявил(а) живой интерес к налаживанию более тесных связей с ним и его группой умеренных. ?] Успех переговоров о создании буржуазной парламентской группы придал импульс движению за единство буржуазии и открыл доступ к дополнительным средствам от крупных промышленников при условии, что государственнические силы в той или иной форме консолидируются. Новый раунд переговоров начат [+ dvp_leader +]ом, с призывом к созданию совместного избирательного списка всех буржуазных партий в случае проведения новых выборов. ?]{!</p>!}

{!<p class="other">!}[? if bourgeois_negotiations_elections_1930_timer == 2 and bourgeois_negotiations_1930_done and (dnvp_split_2 or kvp_formed) and liberal_parliament and not lvp_formed: После того как Вестарп откололся от [партии] Гугенберга, <span style="color: #3E88B3;">**НННП**</span>, [+ dvp_leader +] проявил заинтересованность в сотрудничестве с ним и с умеренными немецкими правыми. Назначение новых выборов предоставило <span style="color: #C0A054;">**ННП**</span> ещё одну возможность для переговоров о единстве буржуазных сил. Однако на этот раз задача куда более амбициозна — призыв к консолидации всех государственнических сил, а не просто к созданию парламентской фракции. И хотя сам Вестарп не слишком заинтересован в слиянии с другими партиями, он готов участвовать в этом, так как промышленники согласны предоставить финансирование лишь при условии достижения буржуазного единства. Предательство <span style="color: #C0A054;">**ННП**</span> всё ещё свежо в их памяти, и многие немецкие правые неохотно идут на сотрудничество [+ dvp_leader +]в этом начинании. ?]{!</p>!}

{!<p class="dnvp">!}[? if bourgeois_negotiations_1930_aftermath_timer == 2 and liberal_parliament and not lvp_formed and (dnvp_split_2 or kvp_formed): После успешного объединения либералами своих парламентских фракций крупный бизнес усилил давление, чтобы либо расширить существующую фракцию за счёт других буржуазных партий, либо побудить другие правые буржуазные партии создать собственную. В настоящее время возможным представляется лишь второй вариант, учитывая враждебность, возникшую между либеральными партиями и консервативными правыми. Новые переговоры инициировал Тревиранус из [? if (dnvp_split_2 or kvp_formed): <span style="color: #0087DC;">**КНП**</span> ?][? if not (dnvp_split_2 or kvp_formed): <span style="color: #0087DC;">Народно-консервативного объединения</span> ?], при участии <span style="color: #7FCEB1;">**ХНПКЗ**</span> и <span style="color: #b8996f;">**ЭП**</span>. ?]{!</p>!}

{!<p class="other">!}[? if bourgeois_negotiations_elections_1930_timer == 2 and bourgeois_negotiations_1930_done and not (dnvp_split_2 or kvp_formed) and (dvp_leader == "Scholz" or dvp_leader == "Dingeldey") and not liberal_parliament and not lvp_formed: Назначение новых выборов предоставило[? if dvp_leader == "Scholz": Шольцу ?][? if dvp_leader != "Scholz": и <span style="color: #C0A054;">**ННП**</span> ?] ещё одну возможность для переговоров о единстве буржуазных сил. Однако на этот раз задача куда амбициознее — призыв к консолидации всех государственнических сил, а не просто к созданию парламентской фракции. Провал последних переговоров оставил у партий неприятный осадок, и многие немецкие правые неохотно идут на сотрудничество [+ dvp_leader +]в этом начинании. ?]{!</p>!}

{!<p class="other">!}[? if bourgeois_negotiations_elections_1930_timer == 2 and bourgeois_negotiations_1930_done and not (dnvp_split_2 or kvp_formed) and liberal_parliament and not lvp_formed: Назначение новых выборов предоставило <span style="color: #C0A054;">**ННП**</span> ещё одну возможность для переговоров о единстве буржуазных сил. Однако на этот раз задача куда амбициознее — призыв к консолидации всех государственнических сил, а не просто к созданию парламентской фракции. Предательство <span style="color: #C0A054;">**ННП**</span> до сих пор не выходит у них из головы, и многие немецкие правые неохотно идут на сотрудничество с [+ dvp_leader +]в этом деле. ?]{!</p>!}

{!<p class="dnvp">!}[? if bourgeois_negotiations_elections_1930_timer == 2 and bourgeois_negotiations_1930_done and (dnvp_split_2 or kvp_formed) and bourgeois_parliament and lvp_formed: После раскола Вестарпа с гугенберговской <span style="color: #3E88B3;">**НННП**</span> крупные промышленники и политики, такие как Тревиранус, предприняли серьёзные усилия, чтобы склонить <span style="color: #0087DC;">**КНП**</span> к установлению более тесных связей с другими правыми партиями. Они преуспели в этом, убедив партию войти в буржуазную парламентскую группу, но пока не смогли убедить её рассмотреть возможность объединения с другими правыми партиями. Назначение новых выборов спровоцировало новый раунд переговоров по этому вопросу. В них участвуют <span style="color: #b8996f;">**ЭП**</span>, <span style="color: #7FCEB1;">**ХНПКЗ**</span> и <span style="color: #0087DC;">**КНП**</span>. ?]{!</p>!}

{!<p class="dnvp">!}[? if bourgeois_negotiations_elections_1930_timer == 2 and bourgeois_negotiations_1930_done and (dnvp_split_2 or kvp_formed) and not bourgeois_parliament and lvp_formed: После провала переговоров о создании буржуазной парламентской группы в поддержку Брюнинга назначение новых выборов предоставило ещё одну возможность для переговоров о буржуазном единстве. Крупный бизнес и промышленники предприняли серьёзные усилия, чтобы финансировать только стремящиеся к единству партии, что вновь заставило несговорчивые <span style="color: #7FCEB1;">**ХНПКЗ**</span> и <span style="color: #b8996f;">**ЭП**</span> сесть за стол переговоров с <span style="color: #0087DC;">**КНП**</span>. ?]{!</p>!}

{!<p class="dnvp">!}[? if bourgeois_negotiations_elections_1930_timer == 2 and bourgeois_negotiations_1930_done and csvd_formed and not lvp_formed: Партии <span style="color: #8ED8E4;">**ХСНС**</span> подавляющим большинством проголосовало за участие в выборах с собственным списком кандидатов, категорически отвергая любые соглашения с другими партиями из-за страха утратить свою идентичность. По той же причине <span style="color: #7FCEB1;">**ХНПКЗ**</span> и <span style="color: #b8996f;">**ЭП**</span> также отклонили[+ dvp_leader +]предложение о переговорах.[? if liberal_cooperation < 5 and not liberal_parliament: Кроме того, <span style="color: #D3C24D;">**[+ ddp_name +]**</span> раскритиковала это предложение, назвав его преждевременной инициативой, не подкреплённой необходимым консенсусом по столь фундаментальным вопросам. ?][? if liberal_cooperation >= 5 or liberal_parliament: Кроме того, близость <span style="color: #C0A054;">**ННП**</span> с более левой <span style="color: #D3C24D;">**[+ ddp_name +]**</span> оттолкнула умеренно правых. ?] ?]{!</p>!}

{!<p class="dnvp">!}[? if bourgeois_negotiations_elections_1930_timer == 2 and bourgeois_negotiations_1930_done and not csvd_formed and dnvp_historical_1929 and lvp_formed: Партии <span style="color: #7FCEB1;">**ХНПКЗ**</span> и <span style="color: #b8996f;">**ЭП**</span> прохладно отнеслись к объединению профессиональных партий с более идеологически ориентированной <span style="color: #0087DC;">**КНП**</span>. Теперь таким людям, как Мартин Шиле, бывшему члену <span style="color: #3E88B3;">**НННП**</span>, выступающему за создание партии, подобной догугенберговской <span style="color: #3E88B3;">**НННП**</span>, предстоит убедить несговорчивую старую гвардию малых консервативных партий. ?]{!</p>!}

{!<p class="other">!}[? if bourgeois_negotiations_elections_1930_timer == 1 and bourgeois_merger_trigger_scholz and not liberal_parliament: К всеобщему удивлению, [+ dvp_leader +] удалось сплотить буржуазные партии — то ли из-за взаимного страха перед <span style="color: #c00000;">социализмом</span>, то ли благодаря прежнему опыту сотрудничества, то ли из-за щедрых пожертвований их богатых спонсоров; большинство буржуазных партий согласовало единый избирательный список. Кандидаты от [? if kvp_cnblp_sister: <span style="color: #385A38;">**Ландбунд,**</span> ?][? if not kvp_cnblp_sister: <span style="color: #7FCEB1;">**ХНПКЗ**</span> ?] и <span style="color: #007A00;">Немецкой крестьянской партии</span> будут преобладать в сельских списках, в то время как более городские [? if kvp_formed or dnvp_split_2: <span style="color: #0087DC;">**КНП**</span>, ?] <span style="color: #b8996f;">**ЭП**</span>[? if bourgeois_list_ddp: , <span style="color: #D3C24D;">**[+ ddp_name +]**</span> ?] и <span style="color: #C0A054;">**ННП**</span> будут основными партиями в бюллетенях в городах. Места в общенациональном списке справедливо распределены между партиями. Это серьёзно подорвёт <span style="color: #7A3C00;">**НСДАП**</span> способность привлекать на свою сторону немецкий средний класс. Однако правый уклон участвующих партий, вероятно, сделает дальнейшее сотрудничество почти невозможным. ?]{!</p>!}

{!<p class="other">!}[? if bourgeois_negotiations_elections_1930_timer == 1 and bourgeois_merger_trigger_moderate and not liberal_parliament: К всеобщему удивлению, [+ dvp_leader +] удалось сплотить буржуазные партии — то ли из-за взаимного страха перед <span style="color: #c00000;">социализмом</span>, то ли благодаря прежнему опыту сотрудничества, то ли из-за щедрых пожертвований их богатых спонсоров; большинство буржуазных партий согласовало единый избирательный список. Кандидаты от [? if kvp_cnblp_sister: <span style="color: #385A38;">**Ландбунд,**</span> ?][? if not kvp_cnblp_sister: <span style="color: #7FCEB1;">**ХНПКЗ**</span> ?] и <span style="color: #007A00;">Немецкой крестьянской партии</span> будут преобладать в сельских списках, в то время как более городские [? if kvp_formed or dnvp_split_2: <span style="color: #0087DC;">**КНП**</span>, ?] <span style="color: #b8996f;">**ЭП**</span>[? if bourgeois_list_ddp: , <span style="color: #D3C24D;">**[+ ddp_name +]**</span> ?] и <span style="color: #C0A054;">**ННП**</span> станут основными партиями в избирательных списках в городах. Места по общенациональному списку справедливо распределены между партиями. Это значительно ограничит возможности <span style="color: #7A3C00;">**НСДАП**</span> способность завоевывать симпатии немецкого среднего класса. Несмотря на правый уклон вовлечённых партий, относительно дружелюбное руководство <span style="color: #D3C24D;">**[+ ddp_name +]**</span> и <span style="color: #C0A054;">**ННП**</span> сделает будущее сотрудничество отчасти возможным. ?]{!</p>!}

{!<p class="other">!}[? if bourgeois_negotiations_1930_aftermath_timer == 1 and bourgeois_list: Движение за единство буржуазии увенчалось соглашением о создании общего избирательного списка, который поддержало большинство буржуазных партий. [? if kvp_cnblp_sister: <span style="color: #385A38;">**Ландбунд**</span> ?][? if not kvp_cnblp_sister: <span style="color: #7FCEB1;">**ХНПКЗ**</span> ?] и <span style="color: #007A00;">Немецкая крестьянская партия</span> станут преобладающими в сельских списках, в то время как более городские [? if kvp_formed or dnvp_split_2: <span style="color: #0087DC;">**КНП**</span>, ?]<span style="color: #b8996f;">**ЭП**</span>[? if bourgeois_list_ddp: , <span style="color: #D3C24D;">**[+ ddp_name +]**</span> ?] и <span style="color: #C0A054;">**ННП**</span> станут основными партиями в избирательных списках в городах. Места по общенациональному списку справедливо распределены между партиями. Это значительно ограничит возможности <span style="color: #7A3C00;">**НСДАП**</span> способность завоевывать симпатии немецкого среднего класса. ?]{!</p>!}

{!<p class="other">!}[? if bourgeois_negotiations_1930_aftermath_timer == 1 and bourgeois_list_fail: На этот раз движение за единство буржуазии не смогло достичь каких-либо значимых целей. Руководство профессиональных партий отвергло предложение о создании общего списка с участием множества буржуазных партий, поскольку это уничтожило бы их профессиональную самобытность. Несмотря на это поражение, удалось достичь некоторых менее значительных соглашений с целью минимизировать межпартийную вражду. ?]{!</p>!}

{!<p class="dnvp">!}[? if bourgeois_negotiations_1930_aftermath_timer == 1 and bourgeois_parliament_no_liberals: Переговоры между нелиберальными буржуазными партиями во главе с Тревиранусом из <span style="color: #0087DC;">**КНП**</span> наконец завершились соглашением о создании парламентского союза с участием <span style="color: #0087DC;">**КНП**</span>, <span style="color: #b8996f;">**ЭП**</span> и <span style="color: #7FCEB1;">**ХНПКЗ**</span>. Позже к нему присоединяется <span style="color: #007A00;">Немецкая крестьянская партия</span>, которая, несмотря на свои возражения, в ином случае осталась бы в парламенте без фракции. ?]{!</p>!}

{!<p class="dnvp">!}[? if bourgeois_negotiations_1930_aftermath_timer == 1 and bourgeois_negotiations_fail_parliament: Как и ожидалось, переговоры между нелиберальными буржуазными партиями во главе с <span style="color: #0087DC;">**КНП**</span> завершились без каких-либо определённых соглашений. Большое количество партий на умеренно-правом фланге в Германии позволит <span style="color: #7A3C00;">**НСДАП**</span> воспользоваться этой раздробленностью среди немецкого среднего класса. ?]{!</p>!}

{!<p class="dnvp">!}[? if bourgeois_negotiations_elections_1930_timer == 1 and bourgeois_merger_kvp_trigger: Весьма неожиданно, [+ kvp_leader +] удалось сплотить буржуазные партии: то ли из-за взаимного страха перед <span style="color: #c00000;">социализмом</span>, то ли благодаря прошлому опыту сотрудничества, а то и пачкам денег от богатых спонсоров: [? if dnvp_split_2: Объединение умеренных немецких правых партий вокруг <span style="color: #0087DC;">**КНП**</span> (<span style="color: #0087DC;">Консервативной народной партии</span>) идёт полным ходом. ?][? if complete_dnvp_split: Присоединение умеренных немецких правых партий к блоку вокруг <span style="color: #0087DC;">**КНП**</span> (<span style="color: #0087DC;">Консервативной народной партия</span>) идёт полным ходом. ?] [? if dnvp_split_2: В результате многочисленных расколов в <span style="color: #3E88B3;">**НННП**</span>, её умеренное крыло, в зависимости от своего происхождения, оказалось в самых разных партиях. Теперь же, похоже, стремление к воссоединению взяло верх над желанием представлять свои нишевые интересы ?][? if complete_dnvp_split: Руководства <span style="color: #b8996f;">**ЭП**</span> и <span style="color: #7FCEB1;">**ХНПКЗ**</span>, которые ранее не желали поступаться своей идентичностью, теперь признали, что вопрос объединения буржуазии более насущная проблема ?]. ?]{!</p>!}

{!<p class="dnvp">!}[? if bourgeois_negotiations_elections_1930_timer == 1 and bourgeois_parliament_trigger_5: Удивительно, но <span style="color: #7FCEB1;">**ХНПКЗ**</span>, <span style="color: #b8996f;">**ЭП**</span> и <span style="color: #0087DC;">**КНП**</span> пришли к соглашению о создании единой буржуазной парламентской фракции. Они опубликовали совместную декларацию в поддержку Брюнинга и его политики, а также заключили электоральное перемирие. Однако <span style="color: #007A00;">Немецкая крестьянская партия</span> недовольна доминированием дворянства и крупных землевладельцев в [? if not kvp_cnblp_sister: <span style="color: #7FCEB1;">**ХНПКЗ**</span> ?][? if kvp_cnblp_sister: <span style="color: #385A38;">**Ландбунд**</span> ?] и <span style="color: #0087DC;">**КНП**</span>. Несмотря на их возражения, они вынуждены согласиться с этим планом, так как без фракции они будут бессильны в парламенте. ?]{!</p>!}

{!<p class="other">!}[? if bourgeois_negotiations_elections_1930_timer == 1 and bourgeois_negotiations_fail_elections and not liberal_parliament: Упрямство многих в рядах <span style="color: #D3C24D;">**[+ ddp_name +]**</span> уничтожило всякий шанс на соглашение между ними и остальными правыми буржуазными силами. Несмотря на это, переговоры между партиями [+ dvp_leader +] продолжаются, вызывая прохладную реакцию других партий на [+ dvp_leader +]предложение о создании единой центристской партии. Это заставило [+ dvp_leader +]умерить амбиции и вместо этого предложить предвыборное перемирие и совместное предвыборное обращение в поддержку[? if chancellor == "Brüning": &nbsp;Брюнинга и ?] президента Гинденбурга. Хотя поначалу это предложение приняли все партии, сопротивление со стороны старой гвардии <span style="color: #7FCEB1;">**ХНПКЗ**</span> и <span style="color: #b8996f;">**ЭП**</span> воспрепятствовало этому предложению, но в конце концов, благодаря промышленному финансированию с определёнными условиями, «Программу Гинденбурга» поддержали лишь <span style="color: #C0A054;">**ННП**</span>[? if dnvp_split_2 or kvp_formed: , <span style="color: #b8996f;">**ЭП**</span> и <span style="color: #0087DC;">**КНП**</span> ?][? if not dnvp_split_2 and not kvp_formed: &nbsp;и <span style="color: #b8996f;">**ЭП**</span> ?]. ?]{!</p>!}

{!<p class="other">!}[? if bourgeois_negotiations_elections_1930_timer == 1 and bourgeois_negotiations_fail_elections and liberal_parliament: Недоверие, возникшее из-за формирования либеральной парламентской группы, фактически обрекло переговоры на провал с самого начала. Единственным итогом этих переговоров стало туманное совместное обращение в поддержку политики президента Гинденбурга и канцлера Брюнинга. Предложение о предвыборном перемирии отвергнуто партиями, представляющими нишевые интересы: вместо этого они сосредоточились на полемике друг с другом. Хотя на первый взгляд разобщённость буржуазных партий может показаться нам выгодной, хаос и раздробленность в немецком центре дадут <span style="color: #7A3C00;">нацистам</span> значительную возможность извлечь выгоду из ситуации. ?]{!</p>!}

{!<p class="other">!}[? if bourgeois_negotiations_elections_1930_timer == 1 and bourgeois_negotiations_fail_elections_dstp and not liberal_parliament: Создание <span style="color: #D3C24D;">**[+ ddp_name +]**</span> и безуспешные попытки переманить членов <span style="color: #C0A054;">**ННП**</span> оставили у них неприятный осадок. Несмотря на это, переговоры между партиями [+ dvp_leader +] продолжаются, вызывая прохладную реакцию других партий на [+ dvp_leader +]предложение о создании единой центристской партии. Это заставило[+ dvp_leader +]умерить амбиции и вместо этого предложить предвыборное перемирие и совместное предвыборное обращение в поддержку[? if chancellor == "Brüning": &nbsp;Брюнинга и ?] президента Гинденбурга. Хотя сначала это предложение приняли все партии, оппозиция со стороны старой гвардии в <span style="color: #7FCEB1;">**ХНПКЗ**</span> и <span style="color: #b8996f;">**ЭП**</span> воспрепятствовала его реализации, но в конце концов, благодаря условному финансированию со стороны промышленников, «программу Гинденбурга» поддержали лишь <span style="color: #C0A054;">**ННП**</span>[? if dnvp_split_2 or kvp_formed: , <span style="color: #b8996f;">**ЭП**</span> и <span style="color: #0087DC;">**КНП**</span> ?][? if not dnvp_split_2 and not kvp_formed: и <span style="color: #b8996f;">**ЭП**</span> ?]. ?]{!</p>!}

{!<p class="other">!}[? if flavour_2_trigger and flavour_2_trigger_time == time: Земельные организации <span style="color: #D3C24D;">**[+ ddp_name +]**</span> и <span style="color: #C0A054;">**ННП**</span> в Бадене и Вюртемберге договорились выставить единый список кандидатов на предстоящих выборах в рейхстаг, не советуясь с соответствующим национальным руководством. Это вдохновило на аналогичное предложение в Шлезвиг-Гольштейне, однако национальное руководство обеих партий вмешалось, быстро прекратив как текущие, так и будущие переговоры. Это вмешательство центрального аппарата вызвало сильное недовольство в местных партийных организациях, углубив раскол между партийными лидерами и рядовыми членами по вопросу о единстве буржуазии. ?]{!</p>!}

{!<p class="other">!}[? if flavour_3_trigger and flavour_3_trigger_time == time: Земельные организации <span style="color: #D3C24D;">**[+ ddp_name +]**</span> и <span style="color: #C0A054;">**ННП**</span> в Бадене и Вюртемберге договорились выставить единый список кандидатов на предстоящих выборах в рейхстаг, не посоветовавшись со своим общенациональным руководством. Этот шаг вдохновил на аналогичное предложение в Шлезвиг-Гольштейне, и вскоре по всей Германии стали появляться единые либеральные списки. Хотя эти соглашения и не одобрены официально общенациональным руководством партий, им также никто и не препятствовал. Крупные либеральные лидеры, такие как Герман Дитрих и Юлиус Курциус, даже выдвинули друг друга во главе совместных списков в своих избирательных округах. ?]{!</p>!}

{!<p class="other">!}[? if bourgeois_negotiations_elections_1930_timer == 1 and bourgeois_negotiations_fail_elections_kvp: Переговоры о создании единой буржуазной парламентской фракции правее <span style="color: #FFCC00;">**ЛНП**</span>, но левее <span style="color: #3E88B3;">**НННП**</span> потерпела неудачу. <span style="color: #b8996f;">**ЭП**</span> и <span style="color: #7FCEB1;">**ХНПКЗ**</span>, с их профессионально-сословной ориентацией, выступили категорически против сближения с идеологически ангажированной <span style="color: #0087DC;">**КНП**</span>. Это оказалось неприемлемым для промышленников, которые в очередной раз принудили партии к сотрудничеству, заставив их подписать совместную декларацию о поддержке Брюнинга и о предвыборном перемирии. Разобщённость буржуазных партий и последовавшее за этим сокращение пожертвований от деловых кругов приведёт к усилению экстремистской <span style="color: #7A3C00;">**НСДАП**</span>, которая стремится извлечь выгоду из их разобщённости. ?]{!</p>!}

{!<p class="dnvp">!}[? if dnvp_split_2_timer == 1: Вестарп и его группа <span style="color: #3E88B3;">**НННП**</span> умеренных нашли новый дом в недавно основанной <span style="color: #0087DC;">Консервативной народной партии</span> (<span style="color: #0087DC;">**КНП**</span>), <span style="color: #7FCEB1;">**ХНПКЗ**</span>[? if stegerwald_path == 0: &nbsp;и <span style="color: #8ED8E4;">**ХСНС**</span> ?]. ?]{!</p>!}

{!<p class="dnvp">!}[? if dnvp_split_2_timer == 1 and bourgeois_cooperation < 7: Мартин Шиле, президент Имперского аграрного союза (RLB)[? if not spd_in_government and chancellor == "Brüning": , министр сельского хозяйства, ?] и самая влиятельная фигура в сельскохозяйственных кругах Германии, старался восстановить связь между организованным сельским хозяйством и правыми силами Германии. Это произошло после раскола, вызванного действиями Гугенберга, которые разрушили историческую связь между ними и <span style="color: #3E88B3;">**НННП**</span>. Шиле предложил план создания новой аграрной партии путем слияния RLB с <span style="color: #7FCEB1;">**ХНПКЗ**</span>, стремясь сделать её сестринской партией для <span style="color: #0087DC;">Народных консерваторов</span> — партии, более привлекательной для городского населения. Это предложение отвергнуто старой гвардией <span style="color: #7FCEB1;">**ХНПКЗ**</span>, которая категорически возражает против восстановления связи сельского хозяйства с идеологически ангажированной партией. ?]{!</p>!}

{!<p class="dnvp">!}[? if dnvp_split_2_timer == 1 and bourgeois_cooperation >= 7: Мартин Шиле, президент Имперского аграрного союза (RLB)[? if not spd_in_government and chancellor == "Brüning": , министр сельского хозяйства, ?] и самая влиятельная фигура в сельскохозяйственных кругах Германии, старался восстановить связь между организованным сельским хозяйством и правыми силами Германии. Это произошло после раскола, вызванного действиями Гугенберга, которые разрушили историческую связь между ними и <span style="color: #3E88B3;">**НННП**</span>. Шиле предложил план создания новой аграрной партии путем слияния RLB с <span style="color: #7FCEB1;">**ХНПКЗ**</span>, с целью сделать её сестринской партией для <span style="color: #0087DC;">**КНП**</span> и быть более привлекательной для городского населения. Несмотря на сильное сопротивление со стороны старой гвардии партии, Шиле вместе с Гюнтером Гереке — ещё одним <span style="color: #3E88B3;">**НННП**</span> недовольным, обладавшим значительным влиянием, — сумел склонить партию к заключению соглашения с <span style="color: #0087DC;">«Народными консерваторами»</span>. ?]{!</p>!}

{!<p class="dnvp">!}[? if dnvp_split_2_timer == 2 and not kvp_cnblp_sister: Гюнтер Гереке, бывший член <span style="color: #3E88B3;">**НННП**</span> и движущая сила в <span style="color: #7FCEB1;">**ХНПКЗ**</span>, сумел убедить старую гвардию партии пойти на предвыборный альянс с <span style="color: #0087DC;">**КНП**</span>. За свои старания по достижению единства буржуазии он щедро вознаграждён немецкими деловыми кругами, что и позволило ему убедить широкие партийные массы. Если бы не это, <span style="color: #0087DC;">**КНП**</span>, скорее всего, останется без мест, а <span style="color: #7FCEB1;">**ХНПКЗ**</span>[? if stegerwald_path == 0: &nbsp;и <span style="color: #8ED8E4;">**ХСНС**</span> ?]что серьёзно уменьшило бы их шансы на получение хотя бы одного места. ?]{!</p>!}

{!<p class="dnvp">!}[? if dnvp_split_2_timer == 2 and kvp_cnblp_sister: В <span style="color: #7FCEB1;">**ХНПКЗ**</span> распущена: ее преемницей стала <span style="color: #385A38;">**Ландбунд**</span>, объединение Имперского Аграрного Союза (RLB) и <span style="color: #7FCEB1;">**ХНПКЗ**</span>. Региональные отделения Ландбунда в таких землях, как Бавария и Вюртемберг, достаточно влиятельны, чтобы обеспечить им двузначную поддержку в нескольких землях. Однако <span style="color: #007A00;">Немецкая крестьянская партия</span> недовольна засильем дворянства и крупных землевладельцев в <span style="color: #385A38;">**Ландбунд**</span>, и пойдет на выборы по отдельному списку. Несмотря на это, договоренность о партнерстве между <span style="color: #385A38;">**Ландбунд**</span> и <span style="color: #0087DC;">Народные консерваторы</span> позволят более мелкой <span style="color: #0087DC;">**КНП**</span> под руководством Вестарпа процветать при финансовой поддержке крупных промышленников, довольных их усилиями по содействию буржуазному единству. ?]{!</p>!}

{!<p class="dnvp">!}[? if dnvp_split_2_timer == 2 and not kvp_cnblp_sister : В <span style="color: #7FCEB1;">**ХНПКЗ**</span>, отвергнув предложение Шиле, теперь призывает к профессиональной солидарности сельскохозяйственного сообщества. Для этого RLB убеждает свои региональные отделения выступить единым аграрным списком, объединяя различные местные консервативные организации с целью их присоединения к <span style="color: #7FCEB1;">**ХНПКЗ**</span> в рейхстаге. И хотя это принесло им поддержку на уровне двузначных чисел в землях вроде Баварии и Вюртемберга, крупные организации, такие как Ассоциация союзов немецких крестьян, сохраняют надпартийный нейтралитет. [? if not cnblp_dbp: <span style="color: #007A00;">Немецкая крестьянская партия</span> также недовольна засильем дворянства и крупных землевладельцев в руководстве <span style="color: #7FCEB1;">**ХНПКЗ**</span> и будет баллотироваться по отдельному списку. ?][? if cnblp_dbp: <span style="color: #007A00;">Немецкая крестьянская партия</span>, хотя и недовольна доминированием дворянства и крупных землевладельцев в руководстве <span style="color: #7FCEB1;">**ХНПКЗ**</span>, решила идти на выборы по единому списку с <span style="color: #7FCEB1;">**ХНПКЗ**</span> на основе профессиональной солидарности. ?] ?]{!</p>!}

{!<p class="other">!}[? if year = 1930 and month = 8: Экранизация скандально известного антивоенного романа <i>«На Западном фронте без перемен»</i> вышла в Америке, но до наших берегов ещё не добралась. ?]{!</p>!}

{!<p class="other">!}[? if flavour_8_trigger and flavour_8_trigger_time == time: Многие молодёжные организации и объединения за буржуазное единство, изначально поддержавшие <span style="color: #D3C24D;">**[+ ddp_name +]**</span>, впоследствии дистанцировались от партии из-за резкого отпора со стороны <span style="color: #C0A054;">**ННП**</span>'s [+ dvp_leader +]Эти связанные с <span style="color: #C0A054;">**ННП**</span>-аффилированные организации, изначально разочарованные отсутствием прогресса на пути к буржуазной концентрации, теперь изменили свою позицию. Они осуждают основание <span style="color: #D3C24D;">**[+ ddp_name +]**</span>, утверждая, что её создание несовместимо с буржуазным единством, и призвали основателей <span style="color: #D3C24D;">**[+ ddp_name +]**</span> присоединиться к <span style="color: #C0A054;">**ННП**</span> для создания поистине всеобъемлющей центристской партии. Эти события, вкупе с враждебностью, возникшей по отношению к партии, значительно ослабили первоначальный энтузиазм по поводу её основания. ?]{!</p>!}

{!<p class="other">!}[? if flavour_9_trigger and flavour_9_trigger_time == time: Антисемитизм и романтизм Младогерманского ордена вызвали острый конфликт с <span style="color: #005EB8;">евреями</span> и <span style="color: #D3C24D;">демократами</span> старой закалки в рядах <span style="color: #D3C24D;">**[+ ddp_name +]**</span>. Яркий тому пример — Густав Штольпер, <span style="color: #005EB8;">еврей</span>, который подвергся ожесточённым нападкам со стороны младогерманцев и едва не лишился места в партийном списке, избежав этой участи лишь благодаря угрозам отставки со стороны старых <span style="color: #D3C24D;">демократов</span>. Конфликт между младогерманцами и <span style="color: #D3C24D;">демократами</span> настолько силен, что ни один из <span style="color: #D3D3A9;">**ННОР**</span> кандидатов не удалось выдвинуть без сопротивления со стороны местных организаций.[? if dvp_ideology == "Right": По крайней мере, <span style="color: #D3C24D;">**[+ ddp_name +]**</span> заняла твёрдую позицию против <span style="color: #7A3C00;">**НСДАП**</span>, чего не скажешь о <span style="color: #C0A054;">**ННП**</span>, которая затаила обиду из-за фиаско, которым обернулось это начинание. ?] ?]{!</p>!}

{!<p class="both">!}[? if flavour_6_trigger and flavour_6_trigger_time == time: То, как мало внимания гугенберговская <span style="color: #3E88B3;">**НННП**</span> уделяет нападкам на [? if nsdap_leader == "Hitler": Адольфа Гитлера ?][? if nsdap_leader == "Goebbels": Йозефа Геббельса ?] и его партию <span style="color: #7A3C00;">**НСДАП**</span>, что грозит обернуться колоссальным просчётом. Несмотря на молчание партии в отношении <span style="color: #7A3C00;">нацистов</span>, сами <span style="color: #7A3C00;">нацисты</span> не платят ей той же монетой и могут многое выиграть от того, что <span style="color: #3E88B3;">**НННП**</span> нападает на нас в их интересах. <span style="color: #3E88B3;">**НННП**</span>, стремясь сплотить вокруг себя консервативные и националистические силы, в конечном счёте приносит больше пользы <span style="color: #7A3C00;">нацистам</span>, чем самой себе. ?]{!</p>!}

{!<p class="dnvp">!}[? if year = 1930 and month = 9 and dnvp_ideology == "Moderate": [? if dnvp_leader == "Hergt": Поскольку <span style="color: #3E88B3;">**НННП**</span>, до партийного съезда которой осталось всего два месяца, Гергт и его правящая старая гвардия руководят относительно стабильной партией. Однако два ключевых вопроса остаются спорными. Тревиранус и его младоконсерваторы выступают за переход партии от монархизма к умеренному принятию демократии, в то время как остро стоит вопрос о сотрудничестве с набирающей силу <span style="color: #7A3C00;">**НСДАП**</span>, поскольку <span style="color: #7A3C00;">нацисты</span> угрожают затмить <span style="color: #3E88B3;">**НННП**</span> в качестве доминирующей силы на правом фланге. ?][? if dnvp_leader == "Lambach": За последние несколько месяцев Ламбах нажил себе немало врагов в рядах <span style="color: #3E88B3;">**НННП**</span>. Он продвигал <span style="color: #6D5298;">христианско-социальные</span> идеалы в партийную программу и расширял роль рабочих и профсоюзов в партии. Близкие к старой гвардии и <span style="color: #385A38;">аграрному</span> крылу, теперь угрожают перейти в <span style="color: #003755;">**НФГ**</span>, если Ламбах и дальше будет пренебрегать их интересами. ?][? if dnvp_leader == "Treviranus": Тревиранус всё чаще вступает в столкновения со старой гвардией <span style="color: #3E88B3;">**НННП**</span>, возглавляемой национал-консерваторами вроде Вестарпа. Стремления Тревирануса принять демократию и отодвинуть монархизм на второй план в официальной повестке партии вызвали их гнев. Кроме того, его позиция по ключевым «национальным вопросам» — в особенности по репарациям — радикально расходится с <span style="color: #3E88B3;">**НННП**</span> и её традиционной позиции. ?] ?]{!</p>!}

{!<p class="other">!}[? if year = 1930 and month = 9 and dvp_leader == "Scholz" and not lvp_formed and not lvp_merger_2_timer : Резкое ослабление <span style="color: #C0A054;">**ННП**</span>, её электоральной поддержки и партийных организаций вызвало внутреннюю оппозицию лидеру партии Эрнсту Шольцу, которого многие считают ответственным за срыв переговоров о консолидации буржуазных сил. Вальтер Шнелль — лидер одной из окружных организаций — сыт по горло бездействием Шольца и убеждает его в том, что сама судьба немецкой буржуазии зависит от её объединения в единую партию. ?]{!</p>!}

{!<p class="other">!}[? if dkp_merger_timer == time + 2 and (dvp_leader == "Dingeldey" or dvp_leader == "Hugo") : Обеспокоенные ростом ультраправого популизма и успехами левых, финансисты из кругов тяжёлой промышленности Германии начали негласно оказывать давление на КНП/НННП и ННП, склоняя их к обсуждению более тесного сотрудничества. Промышленники, стоящие за этими партиями, надеются, что их сближение поможет усилить влияние в рейхстаге. Члены КНП/НННП и ННП, в особенности Тревиранус и Дингельдей, с оптимизмом смотрят на перспективы подобных переговоров. После нескольких недель закулисного давления КНП/НННП и ННП официально начали серию совместных встреч, направленных на координацию законодательной стратегии в рейхстаге. И хотя Тревиранус и Дингельдей ведут переговоры с осторожным оптимизмом, аграрное крыло КНП/НННП сохраняет опасения, боясь усиления влияния промышленных кругов ННП, представляющих интересы горожан. Умеренное крыло ННП сопротивляется не меньше, поскольку видит в этом очередной отход от наследия Штреземана. ?]{!</p>!}

{!<p class="other">!}[? if dkp_merger_timer == time + 1 and (dvp_leader == "Dingeldey" or dvp_leader == "Hugo") : После нескольких недель тщательных обсуждений КНП/НННП и ННП добились неожиданно быстрого прогресса в согласовании своих партийных программ и координации отбора кандидатов. Этот импульс поставил вопрос об официальном слиянии ребром. Тревиранус и Дингельдей приветствуют это беспрецедентное единение, открыто признавая, что полное слияние может быть не за горами. И умеренное крыло ННП, и юнкера из КНП/НННП по-прежнему выражают обеспокоенность, но их сопротивление всё больше отходит на второй план, поскольку широкое большинство членов партий сплачивается вокруг идеи более глубокой интеграции. ?]{!</p>!}

{!<p class="other">!}[? if dkp_merger_timer == time + 2 and dvp_leader == "Glatzel" : Стремясь противостоять подъёму крайне правого популизма и осмелевших левых, КНП/НННП и ННП начали обсуждать более тесное сотрудничество. Они надеются, что союз укрепит их влияние в рейхстаге и поможет сохранить поддержку избирателей. Члены обеих партий, в особенности Тревиранус и Глатцель, с оптимизмом смотрят на эти возможные встречи. После нескольких недель тайных переговоров КНП/НННП и ННП официально провели ряд совместных заседаний с целью координации законодательной стратегии в рейхстаге. Тревиранус и Глатцель ведут переговоры с осторожным оптимизмом, однако у юнкерского крыла КНП/НННП сохраняются сомнения: оно опасается усиления влияния ННП, представляющей интересы городского среднего класса. Умеренное крыло ННП также выступает против, видя в этом ещё один шаг в сторону от наследия Штреземана. ?]{!</p>!}

{!<p class="other">!}[? if dkp_merger_timer == time + 2 and dvp_leader == "Glatzel" : После нескольких недель тщательных обсуждений КНП/НННП и ННП добились неожиданно быстрого прогресса в согласовании своих партийных платформ и координации выдвижения кандидатов. Эта динамика поставила вопрос об официальном слиянии ребром. Тревиранус и Глатцель приветствуют это беспрецедентное единство и открыто признают, что полное слияние может быть не за горами. Умеренное крыло ННП и аграрии из КНП/НННП по-прежнему выражают обеспокоенность, но их сопротивление всё больше отходит на второй план по мере того, как широкое большинство консолидируется вокруг идеи более глубокой интеграции. ?]{!</p>!}

{!<p class="other">!}[? if flavour_12_trigger and flavour_12_trigger_time == time: Наше решение воздерживаться от вотума недоверия правительству Брюнинга, хотя и встречено с одобрением, стало серьёзной проблемой, которая грозит серьёзно подорвать поддержку Брюнинга со стороны более консервативных фракций германской буржуазной элиты. Это особенно верно в отношении представителей тяжёлой промышленности Германии, которые удвоили усилия по налаживанию сближения между Брюнингом и <span style="color: #7A3C00;">крайне</span>-<span style="color: #3E88B3;">правыми</span> партиями, чтобы канцлер не стал слишком зависим от нашей поддержки. Отношения правительства Брюнинга с капиталистическими экономическими кругами, которые поначалу так восторженно его поддерживали, теперь становятся всё более напряжёнными. [? if dvp_ideology == "Right" and not lvp_formed and dvp_exist: Правая <span style="color: #C0A054;">**ННП**</span> настолько недовольна таким развитием событий, что больше не питает особой верности Брюнингу и его правительству. Словно <span style="color: #C0A054;">**ННП**</span> до этого свергла мало правительств. ?][? if lvp_ideology == "Right" and lvp_formed: Правые элементы <span style="color: #FFCC00;">**ЛНП**</span> недовольно таким развитием событий и больше не питает особой верности Брюнингу и его правительству. ?] ?]{!</p>!}

{!<p class="other">!}[? if flavour_10_trigger and flavour_10_trigger_time == time : По той или иной причине <span style="color: #D3C24D;">**[+ ddp_name +]**</span> не хватает депутатов рейхстага для формирования парламентской фракции, и теперь она вынуждена вести переговоры с другой партией об объединении усилий. В данном случае <span style="color: #D3C24D;">**[+ ddp_name +]**</span> решила сотрудничать с <span style="color: #C0A054;">**ННП**</span>, чтобы создать парламентскую фракцию. Удивительно, но <span style="color: #C0A054;">**ННП**</span> заинтересована в сотрудничестве с <span style="color: #D3C24D;">**[+ ddp_name +]**</span>, [? if dvp_leader == "Scholz" and dstp_formed: но как раз когда они были готовы заключить соглашение, разгневанный Эрнст Шольц торпедировал переговоры, всё ещё в ярости из-за того, как <span style="color: #D3C24D;">**[+ ddp_name +]**</span> сорвала его усилия по достижению буржуазного единства. К счастью, <span style="color: #D3C24D;">**[+ ddp_name +]**</span> смогла принять нескольких перебежчиков из <span style="color: #b8996f;">**ЭП**</span>, чтобы достичь численности, необходимой для создания парламентской фракции. ?][? if dvp_leader != "Scholz" or not dstp_formed: [? if chancellor == "Brüning" and not spd_in_government: прекратив свои интриги против правительства Брюнинга, чтобы заключить соглашение. ?][? if not (chancellor == "Brüning" and not spd_in_government): отбросив былые обиды, чтобы заключить соглашение. ?] ?] ?]{!</p>!}

{!<p class="other">!}[? if flavour_11_trigger and flavour_11_trigger_time == time : По той или иной причине <span style="color: #D3C24D;">**[+ ddp_name +]**</span> не хватает депутатов рейхстага для формирования парламентской фракции, и теперь она вынуждена вести переговоры с другой партией об объединении усилий. В данном случае <span style="color: #D3C24D;">**[+ ddp_name +]**</span> решила сотрудничать с <span style="color: #C0A054;">**ННП**</span>, чтобы создать парламентскую фракцию. Удивительно, но <span style="color: #C0A054;">**ННП**</span> заинтересована в сотрудничестве с <span style="color: #D3C24D;">**[+ ddp_name +]**</span>, [? if dvp_leader == "Scholz" and dstp_formed: но как раз когда они собирались заключить соглашение, разгневанный Эрнст Шольц сорвал переговоры, всё ещё в ярости из-за того, как <span style="color: #D3C24D;">**[+ ddp_name +]**</span> сорвала его усилия по достижению буржуазного единства. В результате этого <span style="color: #D3C24D;">**[+ ddp_name +]**</span> заключила соглашение с <span style="color: #b8996f;">**ЭП**</span>, исчерпав другие варианты. ?][? if dvp_leader != "Scholz" or not dstp_formed: [? if chancellor == "Brüning" and not spd_in_government: прекратив интриги против правительства Брюнинга, чтобы заключить соглашение. ?][? if not (chancellor == "Brüning" and not spd_in_government): отбросив былые обиды, чтобы заключить соглашение. ?] ?] ?]{!</p>!}

{!<p class="other">!}[? if flavour_32_trigger and flavour_32_trigger_time == time : По той или иной причине <span style="color: #D3C24D;">**[+ ddp_name +]**</span> не хватает депутатов рейхстага для формирования парламентской фракции, и теперь ей приходится вести переговоры с другой партией об объединении сил. Поскольку буржуазные партии уже сгруппировались, <span style="color: #D3C24D;">**[+ ddp_name +]**</span> вынуждена вести переговоры с ними. К удивлению, буржуазные партии забыли о прошлых обидах и открыты для сотрудничества. [? if dvp_leader == "Scholz" and dstp_formed: Однако, как раз когда они были готовы заключить соглашение, разгневанный Эрнст Шольц сорвал переговоры — он всё ещё в ярости из-за того, как <span style="color: #D3C24D;">**[+ ddp_name +]**</span> сорвала его усилия по достижению буржуазного единства. К счастью, <span style="color: #D3C24D;">**[+ ddp_name +]**</span> смогла принять в свои ряды нескольких перебежчиков из различных партий, входящих в группу, чтобы достичь численности, необходимой для парламентской фракции. ?][? if dvp_leader != "Scholz" or not dstp_formed: [? if chancellor == "Brüning" and not spd_in_government: Чтобы заключить соглашение, все они согласились прекратить интриги против правительства Брюнинга. ?][? if not (chancellor == "Brüning" and not spd_in_government): Отбросив прошлые разногласия, они заключили соглашение. ?] ?] ?]{!</p>!}

{!<p class="other">!}[? if flavour_33_trigger and flavour_33_trigger_time == time : По той или иной причине <span style="color: #D3C24D;">**[+ ddp_name +]**</span> не хватает депутатов рейхстага для формирования парламентской фракции, и теперь ей приходится вести переговоры с другой партией об объединении сил. Поскольку буржуазные партии уже сгруппировались, <span style="color: #D3C24D;">**[+ ddp_name +]**</span> вынуждена вести переговоры с ними. К удивлению, буржуазные партии забыли о прошлых обидах и открыты для сотрудничества. [? if dvp_leader == "Scholz" and dstp_formed: Однако, как раз когда они были готовы заключить соглашение, разгневанный Эрнст Шольц сорвал переговоры — он всё ещё в ярости из-за того, как <span style="color: #D3C24D;">**[+ ddp_name +]**</span> сорвала его усилия по достижению буржуазного единства. В результате этого <span style="color: #D3C24D;">**[+ ddp_name +]**</span> вынуждена войти в[? if z_party_name != "CVP": парламентскую фракцию <span style="color: #000000;">Центра</span> ?][? if z_party_name == "CVP": <span style="color: #000000;">**(ХНП)**</span> ?]'s parliamentary group. ?][? if dvp_leader != "Scholz" or not dstp_formed: [? if chancellor == "Brüning" and not spd_in_government: Чтобы заключить соглашение, все они согласились прекратить интриги против правительства Брюнинга. ?][? if not (chancellor == "Brüning" and not spd_in_government): Оставив прошлые разногласия в стороне, они заключили соглашение. ?] ?] ?]{!</p>!}

{!<p class="other">!}[? if flavour_54_trigger and flavour_54_trigger_time == time : Партии <span style="color: #D3C24D;">**[+ ddp_name +]**</span> по той или иной причине не хватает делегатов Рейхстага для формирования парламентской фракции. В результате она вынуждена заключить соглашение[? if wp_r + ddp_r >= 3.6: с <span style="color: #b8996f;">**ЭП**</span> и другими мелкими буржуазными партиями ?][? if wp_r + ddp_r < 3.6: о вхождении в[? if z_party_name != "CVP": парламентскую фракцию <span style="color: #000000;">Центра</span> ?][? if z_party_name == "CVP": <span style="color: #000000;">**(ХНП)**</span> ?]парламентская фракция ?]. Слияние <span style="color: #C0A054;">**ННП**</span> с <span style="color: #3E88B3;">**НННП**</span> фактически исключило возможность создания единой либеральной парламентской фракции. ?]{!</p>!}

{!<p class="other">!}[? if year = 1930 and month = 9 : В небольшом Свободном государстве Брауншвейг проходят выборы. Их результат — [? if not brunswick_hitler: очередное большинство для <span style="color: #c00000;">**СДПГ**</span> ?][? if brunswick_hitler: победа единого списка буржуазных партий и <span style="color: #7A3C00;">**НСДАП**</span>, которые сформировали буржуазно-нацистскую правительственную коалицию, хоть мы и получили относительное большинство голосов ?]. [? if brunswick_hitler: Ожидается, что <span style="color: #7A3C00;">**НСДАП**</span> воспользуется своим участием в правительстве земли, чтобы выдать Гитлеру гражданство, поскольку он остаётся человеком без гражданства. ?] ?]{!</p>!}

{!<p class="dnvp">!}[? if year = 1930 and month = 9 : Адольф Гитлер из <span style="color: #7A3C00;">**НСДАП**</span> принёс «клятву легальности». Он обязался использовать для прихода к власти исключительно конституционные методы. Это произошло в ходе суда над <span style="color: #7A3C00;">нацистами</span> и офицерами рейхсвера Рихардом Шерингером и Хансом Людином. Их обвинили в заговоре с целью государственного переворота путём создания ячеек <span style="color: #7A3C00;">**НСДАП**</span> в рейхсвере. При обычных обстоятельствах заявления Гитлера привели бы к судебному преследованию. Вместо этого власти попустительствуют и даже легитимизируют повестку <span style="color: #7A3C00;">нацистов</span>. ?]{!</p>!}

{!<p class="dnvp">!}[? if flavour_18_trigger and flavour_18_trigger_time == time: The <span style="color: #b8996f;">**ЭП**</span>, некогда горячо поддерживавшая буржуазное правительство Брюнинга — и единственная нишевая партия, получившая место в кабинете министров, — теперь спешит дистанцироваться от правительства после поражения на выборах. Хотя партия заявляет о некоторых успехах благодаря расширению электоральной базы в новых землях, они с лихвой перекрываются непропорционально тяжелыми потерями в тех регионах, где она изначально добилась успеха. Такая же тенденция наблюдается и у <span style="color: #7FCEB1;">**ХНПКЗ**</span>. В настоящее время в партии развернулась ожесточённая внутренняя борьба между её председателем Германом Древицем и правым крылом, выступающим против Брюнинга. Последние стремятся принудить своего единственного министра в правительстве уйти в отставку, чтобы заставить Брюнинга отказаться от опоры на наши голоса и вместо этого сформировать коалицию с <span style="color: #7A3C00;">**НСДАП**</span>. ?]{!</p>!}

{!<p class="dnvp">!}[? if flavour_29_trigger and flavour_29_trigger_time == time: The <span style="color: #b8996f;">**ЭП**</span>, некогда горячо поддерживавшая буржуазное правительство Брюнинга, теперь спешит дистанцироваться после своего поражения на выборах. Хотя партия выиграла от расширения в новых землях, это с лихвой перекрывается резкими потерями в ее первоначальных опорных пунктах. Аналогичная тенденция наблюдается и у <span style="color: #7FCEB1;">**ХНПКЗ**</span>. Внутри партии развернулась борьба за власть между пробрюнингской фракцией, возглавляемой председателем Германом Древицем и министром юстиции Иоганном Бредтом, и набирающими силу антибрюнингскими районными организациями. Эти антибрюнингские фракции требуют, чтобы партия оказала давление на Брюнинга с целью заставить его сформировать коалицию с <span style="color: #7A3C00;">**НСДАП**</span>[? if spd_toleration: &nbsp;чтобы уменьшить его зависимость от наших голосов ?], в противном случае они угрожают расколом партии или даже выходом из неё. ?]{!</p>!}

{!<p class="other">!}[? if year = 1930 and month = 10 and spd_prussia: The <span style="color: #3E88B3;">**Стальной Шлем**</span> снова пытается дестабилизировать и расколоть Германию на фоне экономического кризиса, последовавшего за провалом референдума по плану Юнга. На своём ежегодном съезде <span style="color: #3E88B3;">**Стальной Шлем**</span> объявил о планах провести референдум о досрочном роспуске прусского ландтага. Их не устраивает доминирующее положение <span style="color: #c00000;">социалистов</span> в Пруссии со времён основания Веймарской республики. Они стремятся к проведению досрочных выборов, которые бы лучше отразили общенациональный сдвиг вправо. [? if dnvp_ideology == "Radical": Несмотря на горячий энтузиазм со стороны других правых партий, ?][? if dnvp_ideology == "Moderate": Правые партии отнеслись к этому скептически, и ?] Сам Гитлер проявил мало интереса к этой инициативе и отказался задействовать <span style="color: #7A3C00;">**НСДАП**</span>, хотя некоторые лидеры <span style="color: #7A3C00;">нацистов</span> и выражают ей решительную поддержку. [? if dvp_ideology == "Right" and not in_grand_coalition_prussia and (dvp_leader == "Scholz" or dvp_leader == "Dingeldey"): The <span style="color: #C0A054;">**ННП**</span> также получила приглашение присоединиться к «национальному фронту», но её руководство отказалось давать согласие, пока <span style="color: #7A3C00;">нацисты</span> не определятся со своей позицией. Тот факт, что партия не отвергла предложение категорически, свидетельствует о том, как далеко она отошла от демократии. ?] На данном этапе успех плана, по-видимому, зависит от поддержки Гитлера. ?]{!</p>!}

{!<p class="other">!}[? if year = 1930 and month = 10 and dvp_leader == "Scholz" and not lvp_formed and not lvp_merger_2_timer : Вальтер Шнелль предпринял конкретные шаги для достижения своей цели — консолидации буржуазии, пригласив чиновников со всей Германии на специальную конференцию. Его группа считает, что парламентской фракции буржуазных партий недостаточно и что для выживания немецкого среднего класса необходимо предпринять более решительные шаги. Группа Шнелля намерена взять на себя инициативу и попытаться убедить <span style="color: #C0A054;">**ННП**</span> — её национальное руководство — поддержать его цели на заседании исполнительного комитета <span style="color: #C0A054;">**ННП**</span>, которое должно было состояться в этом месяце, но, к их несчастью, отложено до следующего. ?]{!</p>!}

{!<p class="other">!}[? if year = 1930 and month = 10 and dvp_leader != "Scholz" and not lvp_formed and not lvp_merger_2_timer : Резкое сокращение числа голосов за <span style="color: #C0A054;">**ННП**</span> и ослабление её партийных организаций вызвали внутреннюю оппозицию против лидера партии[+ dvp_leader +]. Многие в правом крыле партии связывают этот спад с предполагаемой близостью её руководства к <span style="color: #c00000;">**СДПГ**</span>. ?]{!</p>!}

{!<p class="other">!}[? if year = 1930 and month = 10: В <span style="color: #009739;">Бр</span><span style="color: #FEDD00;">аз</span><span style="color: #009739;">илии</span> произошла революция: по итогам спорных президентских выборов, прошедших в начале года, на смену Первой республике пришла Вторая, а к власти пришёл Жетулиу Варгас. ?]{!</p>!}

{!<p class="dnvp">!}[? if year = 1930 and month = 10 and dnvp_ideology == "Moderate" and (dnvp_leader != "Hergt" or spd_prussia): [? if dnvp_leader == "Hergt": Выдвинутый <span style="color: #3E88B3;">**Стальным Шлемом**</span>план по дестабилизации германской демократии путём проведения референдума о досрочном роспуске прусского ландтага вызвал раскол в рядах <span style="color: #3E88B3;">**НННП**</span>. Хотя многие в партии и поддерживают эту инициативу, направленную на прекращение контроля <span style="color: #c00000;">социалистов</span> над Пруссией, Тревиранус и его младоконсерваторы выступают против, так как это потребует сотрудничества с <span style="color: #7A3C00;">**НСДАП**</span>. ?][? if dnvp_leader == "Lambach": Ламбах представил новую партийную программу, в которой монархизм отодвинут на второй план. Программа концентрируется на конкретных мерах по улучшению жизни немецких рабочих. Этот сдвиг возмутил старую гвардию. Для них очевидно: Ламбах продвигает идеи, изложенные им много лет назад в «статье Ламбаха». В преддверии партийного съезда они уже открыто плетут заговор с целью его смещения. По крайней мере, Ламбах заручился поддержкой Тревирануса. ?][? if dnvp_leader == "Treviranus": Тревиранус и его сторонники внесли предложение об обновлении платформы <span style="color: #3E88B3;">**НННП**</span>, сдвигающее её в сторону <span style="color: #0087DC;">христианско-демократического</span> курса. В проекте новой программы отсутствуют значимые упоминания о монархизме и неявно поддерживается республиканский строй, хоть и с расширением президентских полномочий. Это привело в ярость старую гвардию, [? if not true_christian_democracy: и та, воспользовавшись своим влиянием на Тревирануса, заставила его отозвать предложение и сохранить статус-кво. ?][? if true_christian_democracy: которая считает, что монархизм — неотъемлемая часть <span style="color: #3E88B3;">**НННП**</span>. ?]Эти разногласия предстоит разрешить на партийном съезде в следующем месяце. ?] ?]{!</p>!}

{!<p class="other">!}[? if flavour_58_trigger and flavour_58_trigger_time == time: В руководстве Имперского Аграрного Союза (RLB) произошли значительные перемены, вызванные ростом радикальных настроений на фоне усугубляющегося экономического и аграрного кризиса. Это вылилось в открытое выступление против аграрной политики кабинета Брюнинга. В результате министр сельского хозяйства и председатель RLB Шиле ушел в отставку вместе с представителем <span style="color: #7FCEB1;">**ХНПКЗ**</span> Карлом Хеппом, покинувшим руководство RLB. Лидером RLB избран граф Эберхард фон Калькройт, ярый реакционер и сторонник Гугенберга. ?]{!</p>!}

{!<p class="dnvp">!}[? if flavour_57_trigger and flavour_57_trigger_time == time: Кабинет Брюнинга представил Закон о помощи восточным землям — политическую меру, направленную на облегчение долгового бремени сельскохозяйственных предприятий на востоке, несмотря на значительную финансовую нагрузку, которую она создаёт. Этот шаг прямо противоречит общей стратегии Брюнинга по восстановлению экономики за счёт строгой бюджетной экономии. Чтобы частично профинансировать эту политику, правительство сохранило устаревшие репарационные налоги, которые стали неактуальны после принятия плана Юнга. Однако отсутствие полного финансирования мер по списанию долгов вызвало недовольство многих влиятельных землевладельцев, что побудило их обратиться с жалобами напрямую к Гинденбургу, на которого они имеют значительное влияние. ?]{!</p>!}

{!<p class="other">!}[? if year = 1930 and month = 11 and dvp_leader == "Scholz" and not lvp_formed and not lvp_merger_2_timer : Группа Шнелля успешно добилась избрания Эдуарда Дингельдея на должность заместителя самого Шольца. Этот выбор обоснован двойной ролью Шольца — председателя <span style="color: #C0A054;">**ННП**</span> и главы делегации в рейхстаге — а также его постоянными проблемами со здоровьем. Шаг предпринят, чтобы переложить ответственность за возрождение <span style="color: #C0A054;">**ННП**</span> и реализацию плана Шнелля по созданию единой буржуазной партии с Шольца на более сговорчивую фигуру. Из-за плохого состояния здоровья Шольц после назначения Дингельдея в конечном итоге решил уйти в отставку в его пользу. ?]{!</p>!}

{!<p class="other">!}[? if year = 1930 and month = 11 and dvp_leader != "Scholz" and not lvp_formed and not lvp_merger_2_timer : [? if dvp_leader == "Curtius": Правое крыло <span style="color: #C0A054;">**ННП**</span> успешно добилось создания новой должности заместителя председателя, назначив на неё Эдуарда Дингельдея с целью переложить на него часть обязанностей Курциуса [? if foreign_minister_party == "DVP": ввиду его занятости на посту министра иностранных дел ?][? if foreign_minister_party != "DVP": ввиду его участия в государственных делах ?]. Однако Курциус возразил против этого шага, ссылаясь на консервативные взгляды Дингельдея — особенно в вопросе сотрудничества с <span style="color: #c00000;">**СДПГ**</span>, — и отказался передавать ему руководство партией. Это побудило правое крыло <span style="color: #C0A054;">**ННП**</span> начать подготовку к смещению Курциуса на заседании исполнительного комитета в следующем месяце. ?][? if dvp_leader == "Luther": Широкая поддержка, которой пользовался Ганс Лютер, когда его впервые избрали лидером <span style="color: #C0A054;">**ННП**</span> в прошлом году, подорвана. Во многом из-за его позиции о конструктивном сотрудничестве с <span style="color: #c00000;">**СДПГ**</span>. Эта позиция значительно охладила энтузиазм деловых кругов, которые изначально приветствовали его руководство. Теперь правое крыло <span style="color: #C0A054;">**ННП**</span> готовит его смещение на заседании исполнительного комитета в следующем месяце. ?] ?]{!</p>!}

{!<p class="other">!}[? if year = 1930 and month = 11 and dstp_collapsed and not lvp_formed and not lvp_merger_2_timer : The <span style="color: #D3C24D;">**[+ ddp_name +]**</span> официально провела съезд, чтобы завершить процесс формирования <span style="color: #D3C24D;">**Государственной партии**</span>. Чтобы <span style="color: #D3C24D;">**[+ ddp_name +]**</span> новая партия отличалась от своей предшественницы, Герман Дитрих постарался исключить из неё пацифистов и радикальных демократов, дабы придать ей более консервативный облик. В результате оставшиеся крайне левые члены <span style="color: #D3C24D;">**НДП**</span> откололись, образовав незначительную <span style="color: #E0B0FF;">Радикально-демократическую партию</span> (<span style="color: #E0B0FF;">**РДП**</span>), к которой примкнули лишь несколько младодемократов. К сожалению, одних лишь благих намерений и благородных идей оказалось недостаточно для создания политической партии. ?]{!</p>!}

{!<p class="other">!}[? if year = 1930 and month = 11 and dstp_maintained and not lvp_formed and not lvp_merger_2_timer : The <span style="color: #D3C24D;">**[+ ddp_name +]**</span> официально провела съезд, чтобы завершить формирование <span style="color: #D3C24D;">**Государственной партии**</span>. Возросшее число делегатов от <span style="color: #D3D3A9;">**ННОР**</span> привело к тому, что партия приняла более националистическую программу, в которой используются такие термины, как «национальный», «социальный» и *Фольксгемайншафт*, но отсутствуют упоминания о «<span style="color: #586593;">демократии</span>» или «<span style="color: #FFCC00;">либерализме</span>». Кроме того, партия постаралась исключить из своих рядов пацифистов и радикальных демократов, чтобы создать себе более консервативный имидж. Это привело к тому, что оставшиеся крайне левые члены <span style="color: #D3C24D;">**НДП**</span> откололись и образовали незначительную <span style="color: #E0B0FF;">Радикально-демократическую партию</span> (<span style="color: #E0B0FF;">**РДП**</span>), к которой примкнули лишь несколько младодемократов. К сожалению, одних лишь благих намерений и благородных идей оказалось недостаточно для создания политической партии. ?]{!</p>!}

{!<p class="other">!}[? if year = 1930 and month = 11 : <span style="color: #C8102E;">Австрийские социал-демократы</span> победили на недавних парламентских выборах, получив большинство мест в своём <i>Nationalrat</i>. Однако правоконсервативная коалиция <span style="color: #000000;">Христианско-социальной партии</span> и мелких буржуазных партий вновь не допустила их в правительство. Австрийское отделение <span style="color: #7A3C00;">**НСДАП**</span> получило 3% голосов, а политическое крыло <span style="color: #ABDDA4;">Хеймвер</span> (аналог нашего <i>Фрайкора</i>) — 6%. Это вызывает особое беспокойство, поскольку <span style="color: #C8102E;">австрийские социал-демократы</span> потеряли голоса, несмотря на разразившийся экономический кризис, когда они в оппозиции. По-видимому, электорат ищет ответы справа. ?]{!</p>!}

{!<p class="dnvp">!}[? if flavour_15_trigger and flavour_15_trigger_time == time: Сочетание нашего влияния на правительство Брюнинга, неэффективности его аграрного плана помощи, радикализации сельского электората, знаком которой стала отставка Мартина Шиле из RLB, а также <span style="color: #7FCEB1;">**ХНПКЗ**</span>, занявшей третье место в сельских районах после <span style="color: #3E88B3;">**НННП**</span> и <span style="color: #7A3C00;">**НСДАП**</span> заставил партию пересмотреть свою поддержку Брюнинга. Теперь правая антибрюнинговская фракция доминирует в <span style="color: #7FCEB1;">**ХНПКЗ**</span>, успешно проведя резолюцию, осуждающую канцлера и требующую реорганизации коалиции с включением в нее <span style="color: #7A3C00;">нацистов</span>. Брюнинг отказался подчиниться, что побудило <span style="color: #7FCEB1;">**ХНПКЗ**</span> стать одной из первых партий, покинувших его коалицию, и теперь она голосует против его декретов и поддерживает вотумы недоверия правых. ?]{!</p>!}

{!<p class="dnvp">!}[? if flavour_25_trigger and flavour_25_trigger_time == time: Общие неудачи аграрной политики Брюнинга, проводимой министром сельского хозяйства Мартином Шиле [? if dnvp_split_2: <span style="color: #7FCEB1;">**ХНПКЗ**</span> ?][? if kvp_formed: <span style="color: #0087DC;">**КНП**</span> ?][? if dnvp_ideology == "Moderate": <span style="color: #3E88B3;">**НННП**</span> ?], привела к растущему недовольству в его собственной партии. Чтобы сохранить их поддержку, Шиле и Брюнинг представили официальный <i>«Закон о помощи восточным землям»</i> — программу, призванную облегчить долговое бремя сельскохозяйственных предприятий на востоке, несмотря на тяжёлое финансовое бремя, которое она налагала. Хотя эта мера и успокоила аграрное лобби и самого Гинденбурга, она прямо противоречила более широкой стратегии Брюнинга по восстановлению экономики за счёт сбалансированного бюджета. ?]{!</p>!}

{!<p class="other">!}[? if year = 1930 and month = 12 and kpd_leader == "Thälmann" : Эрнст Тельман взял на вооружение новую <span style='color: #7A3C00;'>национал-популистскую</span> стратегию, выступая под лозунгом <i>Volksrevolution</i>. Этот шаг — попытка <span style='color: #700000;'>**КПГ**</span> расширить своё влияние в буржуазных социальных группах, где <span style='color: #7A3C00;'>**НСДАП**</span> наиболее сильны. Лев Троцкий и многие другие <span style='color: #700000;'>**Коммунисты**</span> осудили этот сдвиг, объявив использование лозунга «народная революция» вместо «пролетарская революция» искажением <span style="color: #9B0000;">марксизма</span>. Они также указали, что это тот же самый лозунг, который использовал Отто Штрассер и левое крыло <span style='color: #7A3C00;'>**НСДАП**</span>. ?]{!</p>!}

{!<p class="dnvp">!}[? if flavour_17_trigger and flavour_17_trigger_time == time: Переход членов рейхстага от северного крыла из <span style="color: #007A00;">Немецкой крестьянской партии</span> в <span style="color: #D3C24D;">**[+ ddp_name +]**</span> фактически положил конец существованию партии как общенациональной политической силы. Всё, что от неё осталось, — это изначальный <span style="color: #38C538;">Баварский крестьянский союз</span>, который, как ожидается, на следующих выборах получит лишь малую толику былой поддержки, поскольку большинство крестьян в поисках выхода из охватившего Германию кризиса склоняются всё правее. ?]{!</p>!}

{!<p class="dnvp">!}[? if flavour_19_trigger and flavour_19_trigger_time == time: [? if bruning_time: The <span style="color: #b8996f;">**ЭП**</span> вынесла вотум недоверия Брюнингу, официально положив конец любой возможности примирения с его правительством и пополнив растущие ряды некогда поддерживавших его буржуазных партий, теперь находящихся в оппозиции. Это решение последовало за отставкой единственного министра от партии, ушедшего под давлением её правого крыла, настроенного против Брюнинга. Он не единственный, кто ушёл в отставку, вице-председатель и главный пропагандист ?][? if not bruning_time: The <span style="color: #b8996f;">**ЭП**</span>'s ?] Отто Колоссер также подал в отставку в знак протеста против «единоличной диктатуры» Древица, обвинив его в финансовых махинациях и прочих злоупотреблениях. Внутренние распри обострились до такой степени, что многие местные отделения вышли из её состава, фактически положив конец существованию <span style="color: #b8996f;">**ЭП**</span> как влиятельной общенациональной политической силе. ?]{!</p>!}

{!<p class="dnvp">!}[? if flavour_30_trigger and flavour_30_trigger_time == time: Несмотря на давление со стороны антибрюнингского правого крыла <span style="color: #b8996f;">**ЭП**</span>, требовавшего отставки её единственного министра, Иоганна Бредта, председатель партии Герман Древиц сумел заручиться поддержкой большинства парламентской фракции [? if not in_right_coalition and not in_center_right_coalition: добившись на переговорах с Брюнингом ключевых уступок для среднего класса ?][? if in_right_coalition or in_center_right_coalition: убедив кабинет министров отказаться от повышения налогов, которое ударило бы по среднему классу ?]. Однако за эту победу пришлось заплатить — в знак протеста подал в отставку вице-председатель и главный пропагандист Отто Колоссер, осудив «единоличную диктатуру» Древица и обвинив его в финансовых махинациях и прочих злоупотреблениях. Внутренние распри обострились до такой степени, что многие местные отделения вышли из её состава, серьёзно ослабив <span style="color: #b8996f;">**ЭП**</span> как влиятельной общенациональной политической силы. ?]{!</p>!}

{!<p class="other">!}[? if year = 1931 and month = 1 and dvp_leader == "Dingeldey" and not bourgeois_list and (dnvp_split_2 or kvp_formed) and not lvp_formed and not lvp_merger_2_timer: Несмотря на прежние неудачи в деле объединения либералов и буржуазии, стремление к более тесным связям между центристскими и умеренно-правыми партиями не угасает, особенно на местном уровне. [? if dstp_formed: <span style="color: #E0B0FF;">**Радикальные демократы**</span> ?][? if not dstp_formed: <span style="color: #D3C24D;">**Демократы**</span> ?], the <span style="color: #0087DC;">**КНП**</span> и <span style="color: #8ED8E4;">**ХСНС**</span> в Гессене встретились, чтобы обсудить более тесное сотрудничество. Их инициатива получила на удивление положительный отклик. Это привело к созданию новой общенациональной организации и рассылке приглашений таким деятелям, как Ганс Лютер и Отто Гесслер. Однако эти усилия не увенчались большим успехом, поскольку многие отказались от участия[? if spd_prussia: — во многом из-за глубоких разногласий, вызванных планами <span style="color: #3E88B3;">**Стального шлема**</span> по проведению референдума в Пруссии, который расколол <span style="color: #D3C24D;">**[+ ddp_name +]**</span> от остальных умеренно правых. ?][? if not spd_prussia: — главным образом из-за острой неприязни между руководством национальных партий. ?] ?]{!</p>!}

{!<p class="other">!}[? if flavour_23_trigger and flavour_23_trigger_time == time: [+ dvp_leader +] из <span style="color: #C0A054;">**ННП**</span> пытался заставить Брюнинга реорганизовать кабинет и уволить министров с относительно левыми взглядами, включая их однопартийца Юлиуса Курциуса, <span style="color: #D3C24D;">**[+ ddp_name +]**</span>, вице-канцлера Германа Дитриха, и [? if z_party_name != "CVP": <span style="color: #000000;">Партии Центра</span> ?][? if z_party_name == "CVP": <span style="color: #000000;">**ХНП**</span> ?], министра внутренних дел Йозефа Вирта. Однако этим попыткам не удалось заручиться поддержкой большинства во <span style="color: #C0A054;">**ННП**</span> фракции в рейхстаге, что заставило [+ dvp_leader +] его отложить этот план, поскольку он всё ещё недоволен тем, как [+ chancellor +]фактически отстранил поддерживающие его партии от разработки своих указов. Тем временем[+ dvp_leader +] работает над установлением более тесных отношений с «<span style="color: #7A3C00;">национальной</span> <span style="color: #3E88B3;">оппозицией</span>». ?]{!</p>!}

{!<p class="other">!}[? if flavour_39_trigger and flavour_39_trigger_time == time: [? if lvp_leader == "Dingeldey": Дингельдей из <span style="color: #FFCC00;">**ЛНП**</span> плёл интриги, чтобы заставить Брюнинга уволить министров с относительно левыми взглядами, включая их собственного вице-канцлера Германа Дитриха и [? if z_party_name != "CVP": <span style="color: #000000;">Партии Центра</span> ?][? if z_party_name == "CVP": <span style="color: #000000;">**ХНП**</span> ?], министра внутренних дел Йозефа Вирта. Однако эти попытки вызвали резкое неприятие почти во всех кругах партии. Тем не менее медленно зарождается правое крыло, настроенное против Брюнинга и подпитываемое недовольством тем, как [+ chancellor +]фактически отстранил поддерживающие его партии от разработки своих указов. ?][? if lvp_leader != "Dingeldey": Отстранение политических партий от принятия большинства решений в правительстве Брюнинга вызвало недовольство среди тех, кто когда-то с энтузиазмом его поддерживал, в том числе и <span style="color: #FFCC00;">**ЛНП**</span>. Некоторые члены её парламентской фракции, особенно из правого крыла <span style="color: #C0A054;">**ННП**</span>, многие из которых также члены <span style="color: #3E88B3;">**Стального Шлема**</span>, публично раскритиковали некоторых министров относительно левого толка, включая их собственного вице-канцлера Германа Дитриха и [? if z_party_name != "CVP": <span style="color: #000000;">Партии Центра</span> ?][? if z_party_name == "CVP": <span style="color: #000000;">**ХНП**</span> ?]министра внутренних дел Йозефа Вирта. ?] ?]{!</p>!}

{!<p class="other">!}[? if flavour_35_trigger and flavour_35_trigger_time == time: [+ dvp_leader +] из <span style="color: #C0A054;">**ННП**</span> пытался заставить Брюнинга реорганизовать кабинет и уволить министров с относительно левыми взглядами, включая их однопартийца Юлиуса Курциуса, <span style="color: #D3C24D;">**[+ ddp_name +]**</span> вице-канцлера Германа Дитриха. Однако эти попытки не получили поддержки внутри <span style="color: #C0A054;">**ННП**</span> делегации ННП в рейхстаге, что вынудило [+ dvp_leader +] отказаться от своих планов. Включение в правительство правой <span style="color: #3E88B3;">**НННП**</span> удовлетворило <span style="color: #C0A054;">**ННП**</span> отказаться от попыток добиться расположения партии Гугенберга <span style="color: #003755;">**НФГ**</span> и гитлеровскую <span style="color: #7A3C00;">**НСДАП**</span>, поскольку они считают, что кабинет уже достаточно правый. ?]{!</p>!}

{!<p class="other">!}[? if flavour_56_trigger and flavour_56_trigger_time == time: Дингельдей и правое крыло <span style="color: #C0A054;">**ННП**</span> пытались оказать давление на Брюнинга, чтобы тот реорганизовал кабинет и сместил относительно левых министров, включая их однопартийца Юлиуса Курциуса и <span style="color: #D3C24D;">**[+ ddp_name +]**</span> вице-канцлера Германа Дитриха. Однако эти попытки не получили поддержки в <span style="color: #C0A054;">**ННП**</span>фракции в Рейхстаге, и [+ dvp_leader +] решительно осудили попытку сместить своих же министров. И хотя правое крыло партии останется занозой в боку Брюнинга, пока что оно больше лает, чем кусает. ?]{!</p>!}

{!<p class="other">!}[? if flavour_43_trigger and flavour_43_trigger_time == time: Дингельдей из <span style="color: #FFCC00;">**ЛНП**</span> плёл интриги, чтобы заставить Брюнинга уволить министров с относительно левыми взглядами, включая их собственного вице-канцлера Германа Дитриха и [? if z_party_name != "CVP": <span style="color: #000000;">Центра</span> ?][? if z_party_name == "CVP": <span style="color: #000000;">**ХНП**</span> ?]министра внутренних дел Йозефа Вирта. Однако эти попытки вызвали резко негативную реакцию почти во всех кругах партии, что заставило его отказаться от своих планов. ?]{!</p>!}

{!<p class="other">!}[? if year = 1931 and month = 2 and bruning_time and not bruning_event_timer: Гугенберговское [? if dnvp_ideology == "Radical": <span style="color: #3E88B3;">**НННП**</span> ?][? if dnvp_ideology == "Moderate": <span style="color: #003755;">**НФГ**</span> ?] и <span style="color: #7A3C00;">**НСДАП**</span> покинули рейхстаг в знак протеста против правительства Брюнинга, образовав свободное объединение, известное как <span style="color: #7A3C00;">национальная</span> [? if dnvp_ideology == "Radical": <span style="color: #3E88B3;">оппозиция</span> ?][? if dnvp_ideology == "Moderate": <span style="color: #003755;">оппозиция</span>. ?]. ?]{!</p>!}

{!<p class="other">!}[? if year = 1931 and month = 2 and saxony_nsdap: Выдвинутый нами вотум недоверия Грегору Штрассеру в саксонском кабинете принят при поддержке буржуазных партий. Постоянные оскорбления и клевета со стороны <span style="color: #7A3C00;">нацистов</span> в адрес других членов кабинета, а также антикапиталистические взгляды Штрассера привели к разрыву сотрудничества с буржуазными партиями. В результате для сохранения стабильности в правительстве мы заключили с ними соглашение о воздержании от вотума недоверия. ?]{!</p>!}

{!<p class="dnvp">!}[? if flavour_16_trigger and flavour_16_trigger_time == time: Четыре члена <span style="color: #7FCEB1;">**ХНПКЗ**</span> в рейхстаге покинули фракцию, примкнув к <span style="color: #7A3C00;">нацистам</span> в рядах национальной оппозиции. Внутренний раскол между умеренными сторонниками Брюнинга и его радикально правыми противниками разрушил и без того хрупкое единство партии и подорвал её авторитет среди собственного электората. <span style="color: #7FCEB1;">**ХНПКЗ**</span> практически перестала существовать как жизнеспособная политическая сила. ?]{!</p>!}

{!<p class="other">!}[? if year = 1931 and month = 2 and dstp_formed and not lvp_formed and not lvp_merger_2_timer : Большинство местных организаций, ранее принадлежавших <span style="color: #D3C24D;">**НДП**</span>, крайне неохотно вступают в новую партию, а многие из <span style="color: #D3C24D;">**НДП**</span>, таких как её молодёжные и женские группы, распались, и их нужно создавать заново. Всё это, в сочетании с тяжёлым психологическим бременем, под которым лидеры <span style="color: #D3C24D;">**Государственной партии**</span> уже находились в результате усугубляющегося экономического кризиса, создает атмосферу растущего уныния и пессимизма о будущем партии. ?]{!</p>!}

{!<p class="both">!}[? if year = 1931 and month = 3 and PLR_launched : The <span style="color: #7A3C00;">**НСДАП**</span> наконец согласилась поддержать референдум о роспуске ландтага[? if not hitler_deported: , хотя лично Гитлер по-прежнему скептически относится к его шансам на успех ?].[? if dnvp_ideology == "Moderate": При поддержке как <span style="color: #3E88B3;">**Стального шлема**</span>, так и <span style="color: #7A3C00;">**НСДАП**</span>, the <span style="color: #3E88B3;">**НННП**</span> также поддержала эту инициативу.[? if dnvp_leader == "Treviranus": Однако Тревиранус колеблется, но всё же позволяет членам своей партии голосовать по совести. ?] ?] [? if landtag_ref_dvp: Кроме того, <span style="color: #C0A054;">**ННП**</span> примкнула к <span style="color: #7A3C00;">крайне</span> <span style="color: #3E88B3;">правым</span>, а Дингельдей вновь подтвердил приверженность своей партии борьбе с <span style="color: #c00000;">социализмом</span>. ?] К счастью, <span style="color: #700000;">**КПГ**</span> отказалась сотрудничать с такими деятелями, как Гугенберг, [+ nsdap_leader +]в этой инициативе[? if kpd_leader != "Conciliators": , что разделило голоса антидемократов ?]. ?]{!</p>!}

{!<p class="other">!}[? if year = 1931 and month = 3 and kpd_leader == "Thälmann" : Рихард Шерингер, бывший офицер рейхсвера и видный член <span style='color: #7A3C00;'>**НСДАП**</span> и <span style='color: #7A3C00;'>**СА**</span>, заключен в тюрьму за попытку создания <span style='color: #7A3C00;'>нацистских</span> ячеек в армии. Совершенно неожиданно, после долгих дискуссий со своими <span style='color: #700000;'>**коммунистической**</span> сокамерниками, он перешел на сторону <span style='color: #700000;'>**КПГ**</span>. Воспользовавшись этой возможностью, <span style="color: #700000;">**КПГ**</span> теперь взяла на вооружение так называемую «линию Шерингера», включая в свою агитацию больше националистической риторики, чтобы привлечь перебежчиков из рядов <span style="color: #7A3C00;">нацистов</span>. ?]{!</p>!}

{!<p class="dnvp">!}[? if flavour_27_trigger and flavour_27_trigger_time == time: Закон о помощи восточным землям, принятый несколько месяцев назад для облегчения долгового бремени сельскохозяйственных предприятий на востоке, создал напряжённость внутри коалиции, поскольку он прямо противоречит цели Брюнинга по поддержанию сбалансированного бюджета. Репарационный налог — ныне отменённый благодаря плану Юнга — продолжает использоваться для финансирования сельскохозяйственных субсидий, что вызывает яростные протесты со стороны [? if not lvp_formed: <span style="color: #C0A054;">**ННП**</span> ?][? if lvp_formed: <span style="color: #FFCC00;">**ЛНП**</span> ?]. Они утверждают, что этот налог, взимаемый в основном с предприятий, — необоснованное бремя для работодателей в условиях экономического кризиса. К счастью для Брюнинга, [? if budget >= 0: профицит бюджета ?][? if reparations == -2: приостановка выплаты репараций ?] даёт ему возможность отменить налог и сохранить при этом полное финансирование программы. ?]{!</p>!}

{!<p class="dnvp">!}[? if flavour_28_trigger and flavour_28_trigger_time == time: Закон о помощи восточным землям, принятый несколько месяцев назад для облегчения долгового бремени сельскохозяйственных предприятий на востоке, создал напряжённость внутри коалиции, поскольку он прямо противоречит цели Брюнинга по поддержанию сбалансированного бюджета. Репарационный налог — ныне отменённый благодаря плану Юнга — продолжает использоваться для финансирования сельскохозяйственных субсидий, что вызывает яростные протесты со стороны [? if not lvp_formed: <span style="color: #C0A054;">**ННП**</span> ?][? if lvp_formed: <span style="color: #FFCC00;">**ЛНП**</span> ?]. Они утверждают, что этот налог, взимаемый в основном с предприятий, — непомерное бремя для предпринимателей в условиях экономического кризиса. Теперь Брюнинг оказался меж двух огней: с одной стороны — необходимость пойти на уступки крупной промышленности, а с другой — успокоить организованных аграриев и Гинденбурга справа. ?]{!</p>!}

{!<p class="dnvp">!}[? if flavour_26_trigger and flavour_26_trigger_time == time: Кабинет Брюнинга представил Закон о помощи восточным землям — политическую меру, направленную на облегчение долгового бремени сельскохозяйственных предприятий на востоке, несмотря на значительную финансовую нагрузку, которую она создаёт. Этот шаг прямо противоречит общей стратегии Брюнинга по восстановлению экономики за счёт строгой бюджетной экономии. Чтобы частично профинансировать эту политику, правительство сохранило устаревшие репарационные налоги, которые стали неактуальны после принятия плана Юнга. Однако отсутствие полного финансирования мер по списанию долгов вызвало недовольство многих влиятельных землевладельцев, что побудило их обратиться с жалобами напрямую к Гинденбургу, на которого они имеют значительное влияние. ?]{!</p>!}

{!<p class="other">!}[? if flavour_13_trigger and flavour_13_trigger_time == time: Решение Брюнинга отстранить рейхстаг и представленные в нём партии от какого-либо значимого участия в формировании его фискальной и экономической политики сильно подорвало легитимность буржуазных партий в глазах их традиционного электората из-за их неспособности отменить его наиболее одиозные меры. Ярким примером тому служит тяжёлое положение государственных служащих, на которых легло основное бремя сокращения зарплат примерно на 20 процентов, что подтолкнуло многих из них в сторону <span style="color: #7A3C00;">нацистов</span>. Его дефляционная политика и меры жёсткой экономии усугубили экономический кризис, радикализировав те самые социальные группы, которые составляли электоральную базу этих умеренных партий. Это привело к обострению напряжённости между Брюнингом и поддерживающими его партиями, некоторые из которых даже угрожают выйти из его коалиции. ?]{!</p>!}

{!<p class="other">!}[? if flavour_14_trigger and flavour_14_trigger_time == time: Решение Брюнинга предоставить парламенту значительную роль в принятии и формировании его фискальной и экономической политики[? if in_right_coalition or in_center_right_coalition: , а не править посредством чрезвычайных указов, ?] помогло сохранить легитимность буржуазных партий в глазах их традиционного электората. Способность партий <span style="color: #b8996f;">нишевых</span> <span style="color: #7FCEB1;">интересов</span> и <span style="color: #FFCC00;">либеральных</span> партий отменять некоторые из его самых одиозных мер — например, сокращение зарплат госслужащим — и оказывать на него давление для увеличения помощи аграриям, укрепила их авторитет. Однако это также привело к напряженности между Брюнингом и поддерживающими его партиями, поскольку он настаивает на том, что для надлежащей реализации его экономического плана необходимы жертвы. ?]{!</p>!}

{!<p class="other">!}[? if year = 1931 and month = 4 and PLR_launched : Сбор подписей за проведение референдума о роспуске прусского ландтага завершён, [+ landtag_ref_signatures +]% избирателей поддержали петицию.[? if landtag_ref_signatures < 20: Таким образом, при необходимом пороге в 20% петиция провалилась. Это маленькая победа в борьбе за выживание нашей демократии. Поражение деморализовало <span style="color: #7A3C00;">ультра</span><span style="color: #3E88B3;">правых</span>, ведь они впустую потратили средства на сбор петиций. ?][? if landtag_ref_signatures >= 20: Таким образом, при необходимом пороге в 20% петиция прошла. Это неожиданно: теперь нам нужно срочно усилить нашу пропаганду, чтобы противостоять буре от <span style="color: #3E88B3;">правых</span>. Плебисцит назначен на август этого года. ?] ?]{!</p>!}

{!<p class="other">!}[? if year = 1931 and month = 4 and thuringia_nsdap: Наш вотум недоверия Вильгельму Фрику, министру в правительстве Тюрингии, успешно принят при поддержке буржуазных партий. Непрекращающиеся оскорбления и клевета со стороны <span style="color: #7A3C00;">нацистов</span> в адрес других членов правительства Тюрингии привели к разрыву сотрудничества между ними и буржуазными партиями. В результате мы теперь «терпим» буржуазное правительство меньшинства в Тюрингии. ?]{!</p>!}

{!<p class="other">!}[? if year == 1931 and month == 4 and dvp_leader == "Dingeldey" and not lvp_formed: В попытке обратить вспять <span style="color: #C0A054;">**ННП**</span>, переживающей не лучшие времена, и остановить дальнейший отток её членов к <span style="color: #7A3C00;">крайне</span> <span style="color: #3E88B3;">правым</span>, руководство партии взяло на вооружение новый подход к пропаганде, вдохновляясь примером <span style="color: #7A3C00;">нацистов</span>. Они опубликовали программу, которая облекает традиционные <span style="color: #FFCC00;">либеральные</span> цели в риторику <span style="color: #7A3C00;">крайне</span> <span style="color: #3E88B3;">правых</span>. Например, в вопросе о правах личности программа обязывает <span style="color: #C0A054;">**ННП**</span> защищать права «нравственно ответственной личности» — под которой понимается человек, чья индивидуальность коренится в вере и религиозности — от <span style="color: #700000;">революции</span>, <span style="color: #c00000;">социализма</span> и материализма. Это явный отход от бескомпромиссной защиты <span style="color: #FFCC00;">либеральных</span> принципов, свойственной Штреземану в бытность его председателем партии. ?]{!</p>!}

{!<p class="other">!}[? if year = 1931 and month = 4 : Провозглашена Вторая Испанская Республика, пришедшая на смену монархии Альфонсо XIII. Этому предшествовали муниципальные выборы, на которых кандидаты-республиканцы одержали убедительную победу, выиграв в столице и во всех провинциях. Это вынудило короля отправиться в изгнание. В стране создана новая, молодая республика. ?]{!</p>!}

{!<p class="other">!}[? if year = 1931 and month = 5 and kpd_leader == "Thälmann" and kpd_relation < 40 : По приказу <span style="color: #D50000;">Коминтерна</span> <span style="color: #700000;">**КПГ**</span> отказалась от прежней установки, согласно которой главным врагом считался гитлеровский <span style="color: #7A3C00;">фашизм</span>. Теперь они «исправляют» свою позицию, якобы «сводя оценку <span style="color: #7A3C00;">фашизма</span> к его истинным масштабам», что означает возврат к их концепции <span style="color: #c00000;">социал</span>-<span style="color: #7A3C00;">фашизма</span>. Для них мы ничем не отличаемся от настоящих <span style="color: #7A3C00;">фашистов</span>. ?]{!</p>!}

{!<p class="dnvp">!}[? if year = 1931 and month = 6 and dnvp_ideology == "Radical": Попытки Гугенберга создать себе образ в духе Гитлера провалились: из-за своего аристократического снобизма и высокомерия он далёк от простых людей, страдающих от экономического кризиса. Разочарованная отсутствием у него харизмы группа промышленников даже предложила крупное вознаграждение всякому, кто поможет его сместить. Они уверены, что он ведёт <span style="color: #3E88B3;">**НННП**</span> к катастрофе. В довершение ко всему, экономическая депрессия резко сократила доходы его медиаимперии, так что ему пришлось урезать бюджет <span style="color: #3E88B3;">**НННП**</span> на 30%, лишь бы партия осталась на плаву. ?]{!</p>!}

{!<p class="other">!}[? if banking_crisis_timer == 3 : Создание австро-германского таможенного союза побудило <span style="color: #002654;">Францию</span> оказать на Австрию серьёзное экономическое давление. Пользуясь значительным влиянием на австрийскую экономику, <span style="color: #002654;">Франция</span> не только отказывает в финансовой помощи крупнейшим банкам страны, но и намеренно выводит оттуда большие суммы денег, ещё сильнее дестабилизируя финансовый сектор Австрии. ?]{!</p>!}

{!<p class="other">!}[? if banking_crisis_timer == 2 : Крупнейший австрийский банк Creditanstalt обанкротился в результате политического и экономического давления со стороны <span style="color: #002654;">Франции</span>, направленного на срыв австро-германского таможенного союза. В этом отношении они, безусловно, преуспели. Остаётся лишь надеяться, что этот кризис не перекинется на Германию или, что ещё хуже, не распространится на всю Европу. ?]{!</p>!}

{!<p class="other">!}[? if banking_crisis_timer == 1 : После банкротства банка Creditanstalt инвесторы начали стремительно выводить средства из немецких банков. Сильная зависимость Германии от краткосрочных иностранных займов превратила банковский кризис Австрии в прямую угрозу для нашей стабильности. В ответ на это президент Рейхсбанка [? if luther_reichsbank: Ганс Лютер ?][? if not luther_reichsbank: Фридрих Дрейзе ?] принял меры по пресечению оттока капитала, затруднив перевод денег за границу. Однако эффективность этой политики под вопросом, она может привести к непредвиденным последствиям. ?]{!</p>!}

{!<p class="other">!}[? if year = 1931 and month == 6 and not kaas_explode_seen and z_leader == "Kaas": Ходят слухи о намерении лидера <span style="color: #000000;">Партии Центра</span> Людвига Кааса уйти в отставку. В частных беседах он выражал желание оставить обременительный пост. Каас часто отсутствует в Германии — он нередко ездит в Рим и Ватикан. Поэтому фактическое руководство партией перешло к его заместителю Йозефу Йоосу и лидеру парламентской фракции Брюнингу. Кроме того, Каас — один из самых злостных прогульщиков в Рейхстаге. Однако сам Каас объясняет своё долгое отсутствие плохим здоровьем. Также он дал широкую автономию коллегам по партии, что пресекло попытки заменить его на более деятельного и противоречивого лидера. ?]{!</p>!}

{!<p class="other">!}[? if year = 1931 and month = 6 and dstp_formed and not lvp_formed and not lvp_merger_2_timer : Организационный упадок <span style="color: #D3C24D;">**[+ ddp_name +]**</span> очевиден на фоне сокращения числа её членов. По всей стране от 30% до 60% тех, кто состоял в <span style="color: #D3C24D;">**НДП**</span> летом 1930 года, в нынешнем году так и не вступили в ряды её преемницы. В некоторых городах сдвиг партии вправо, по оценкам, стоил ей более половины прежних сторонников. В землях, где либеральные традиции не так сильны, ситуация настолько плачевна, что даже местные отделения, которые в своё время ратовали за создание <span style="color: #D3C24D;">**[+ ddp_name +]**</span> в прошлом году, теперь чуть ли не призывают признать поражение и полностью распустить партию. ?]{!</p>!}

{!<p class="other">!}[? if year = 1931 and month = 6 : Состоялись первые выборы во Второй Испанской Республике, принёсшие крупную победу <span style="color: #EF1C27;">испанским социалистам</span> и <span style="color: #E25822;">республиканским левым</span>. Вместе они сформировали правительство, которое возглавил Мануэль Асанья. ?]{!</p>!}

{!<p class="dnvp">!}[? if flavour_20_trigger and flavour_20_trigger_time == time: Лидеры <span style="color: #b8996f;">**ЭП**</span> отчаянно пытаются справиться с последствиями конфликта между Древицем и Колоссером, но их усилия постоянно срываются из-за возобновившихся требований отставки Древица. В ответ Древиц вынес вопрос на рассмотрение общенационального партийного съезда в этом месяце. Заручившись мощной поддержкой пробрюнинговской фракции, он успешно добился переизбрания на пост председателя партии. Тем временем лидеры нескольких районных организаций, отколовшихся месяцами ранее, как раз к съезду вернулись в лоно партии. Быть может, партии всё же удастся выжить? ?]{!</p>!}

{!<p class="other">!}[? if flavour_22_trigger and flavour_22_trigger_time == time: [+ dvp_leader +] и правое крыло <span style="color: #C0A054;">**ННП**</span> возмущены чрезвычайным указом Брюнинга и обрушились с критикой на новые налоговые сборы и сокращение зарплат государственных служащих.[+ dvp_leader +] настоятельно призвал Брюнинга восстановить доверие буржуазии к своему правительству, разорвав все связи с <span style="color: #c00000;">**СДПГ**</span>. Чтобы оказать давление на Брюнинга, [+ dvp_leader +] он пригрозил проголосовать за возобновление работы Рейхстага, чтобы <span style="color: #7A3C00;">национальная</span> <span style="color: #3E88B3;">оппозиция</span> при его поддержке смогла вынести вотум недоверия. Эта инициатива получила значительную поддержку среди правого крыла <span style="color: #C0A054;">**ННП**</span>, которое давно стремилось добиться перестановок в кабинете министров. Однако, поскольку его поддерживало лишь незначительное большинство делегации, Брюнинг — вместе с [? if luther_reichsbank: президентом Рейхсбанка, ?][? if not luther_reichsbank: бывшим канцлером ?] и членом <span style="color: #C0A054;">**ННП**</span> Гансом Лютером — призвал к терпению, пообещав постепенный сдвиг вправо и смягчение трудового законодательства. Столкнувшись с этими заверениями, а также с угрозами отставки со стороны Курциуса и других ключевых фигур левого крыла партии, делегация в конечном счёте изменила свою позицию. ?]{!</p>!}

{!<p class="other">!}[? if flavour_34_trigger and flavour_34_trigger_time == time: [+ dvp_leader +] и правое крыло <span style="color: #C0A054;">**ННП**</span> возмущены чрезвычайным указом Брюнинга и критикуют новые налоговые сборы и сокращение зарплат государственных служащих.[+ dvp_leader +] настоятельно призвал Брюнинга восстановить доверие буржуазии к своему правительству, разорвав все связи с <span style="color: #c00000;">**СДПГ**</span>. Эта инициатива получила значительную поддержку правого крыла <span style="color: #C0A054;">**ННП**</span>, которое давно выступало за перестановки в кабинете. В ответ Брюнинг — вместе с [? if luther_reichsbank: президентом Рейхсбанка ?][? if not luther_reichsbank: бывшим канцлером ?] и <span style="color: #C0A054;">**ННП**</span> Гансом Лютером — призвал к терпению, пообещав сдвиг вправо при реорганизации кабинета и смягчение трудового законодательства. Получив эти заверения, [+ dvp_leader +]больше не пытается добиться отставки правительства. ?]{!</p>!}

{!<p class="other">!}[? if flavour_38_trigger and flavour_38_trigger_time == time: [? if lvp_leader == "Dingeldey": Дингельдей и правое крыло <span style="color: #FFCC00;">**ЛНП**</span> разочарованы чрезвычайным указом Брюнинга и критикуют новые налоги и сокращение зарплат государственных служащих. Дингельдей лично призывал Брюнинга создать коалицию с <span style="color: #7A3C00;">национальной</span> <span style="color: #3E88B3;">оппозицией</span>, чтобы покончить с его зависимостью от наших голосов. Однако ему не удалось бы убедить большинство своей партии выступить против Брюнинга, поэтому он не в состоянии осуществить свои планы — по крайней мере, пока что. ?][? if lvp_leader != "Dingeldey": The <span style="color: #FFCC00;">**ЛНП**</span> разочарована чрезвычайными указами Брюнинга и критикует новые налоги и сокращение зарплат государственных служащих. Некоторые представители правого крыла партии призывали Брюнинга создать коалицию с <span style="color: #7A3C00;">национальной</span> <span style="color: #3E88B3;">оппозицией</span>, чтобы покончить с его зависимостью от наших голосов. Однако, [+ lvp_leader +] а партия в целом по-прежнему поддерживает его правительство и продолжит добиваться, чтобы он отказался от политики, вредящей среднему классу. ?] ?]{!</p>!}

{!<p class="other">!}[? if flavour_42_trigger and flavour_42_trigger_time == time: Дингельдей и правое крыло <span style="color: #FFCC00;">**ЛНП**</span> разочарованы чрезвычайным указом Брюнинга и критикуют новые налоги и сокращение зарплат государственных служащих. Дингельдей лично призывал Брюнинга создать коалицию с <span style="color: #7A3C00;">национальной</span> <span style="color: #003755;">оппозицией</span>[? if spd_toleration_right: &nbsp;чтобы покончить с его зависимостью от наших голосов ?]. Однако он в целом доволен своим правительством благодаря включению в его состав <span style="color: #3E88B3;">**НННП**</span>. ?]{!</p>!}

{!<p class="other">!}[? if flavour_45_trigger and flavour_45_trigger_time == time: Партия <span style="color: #FFCC00;">**ЛНП**</span> разочарована последними чрезвычайными декретами Брюнинга, критикуя новые налоги и сокращение зарплат госслужащих. В правом крыле партии всё громче звучат призывы к Брюнингу сформировать коалицию с <span style="color: #7A3C00;">национальной</span> <span style="color: #003755;">оппозицией</span>[? if spd_toleration_right: &nbsp;чтобы покончить с его зависимостью от наших голосов ?]. Однако партия по-прежнему в целом довольна его правительством, особенно благодаря включению в его состав <span style="color: #3E88B3;">**НННП**</span>[? if not spd_toleration_right: , что фактически вытесняет нас в оппозицию ?]. ?]{!</p>!}

{!<p class="dnvp">!}[? if flavour_51_trigger and flavour_51_trigger_time == time: Курт фон Шлейхер, который изначально и убедил Гинденбурга назначить Брюнинга, разочаровался в канцлере и его потенциале провести реформы, необходимые для восстановления Германии как великой державы. В результате Шлейхер идет на контакт с антипарламентскими правыми. ?]{!</p>!}

{!<p class="other">!}[? if flavour_24_trigger and flavour_24_trigger_time == time: Банковский кризис[? if emergency_decree_seen: &nbsp;и последствиями второго чрезвычайного декрета Брюнинга ?] значительно усилили антибрюнинговские настроения среди буржуазных партий, особенно <span style="color: #C0A054;">**ННП**</span>[? if emergency_decree_seen: , которой лишь с трудом удалось обеспечить внутрипартийное большинство для поддержки Брюнинга ?]. Правое крыло <span style="color: #C0A054;">**ННП**</span> всё больше разочаровано невыполнением Брюнингом своего обещания сместить кабинет ещё правее. Однако [+ dvp_leader +] не решается отправить правительство в отставку, опасаясь дальнейшей дестабилизации финансового положения Германии. Кроме того, <span style="color: #7A3C00;">национальная</span> <span style="color: #3E88B3;">оппозиция</span> не проявила интереса к вхождению в кабинет Брюнинга. В этих обстоятельствах <span style="color: #C0A054;">**ННП**</span> не остаётся иного выбора, кроме как и дальше поддерживать Брюнинга. ?]{!</p>!}

{!<p class="other">!}[? if flavour_57_trigger and flavour_57_trigger_time == time: Банковский кризис[? if emergency_decree_seen: и последствия второго чрезвычайного декрета Брюнинга ?] значительно усилили антибрюнингские настроения среди буржуазных партий, особенно <span style="color: #C0A054;">**ННП**</span>[? if emergency_decree_seen: , которой лишь с трудом удалось обеспечить большинство в своих рядах для поддержки Брюнинга ?]. Правое крыло партии всё больше разочаровывается из-за того, что Брюнинг не выполнил своего обещания сместить кабинет вправо. Однако [+ dvp_leader +] утверждает, что такой шаг лишь ещё больше дестабилизирует шаткое финансовое положение Германии, и настаивает на том, что <span style="color: #7A3C00;">национальная</span> <span style="color: #3E88B3;">оппозиция</span> никогда не согласится войти в правительство. Несмотря на свои претензии, <span style="color: #C0A054;">**ННП**</span> не имеет иного выбора, кроме как продолжать поддерживать Брюнинга — пока что. ?]{!</p>!}

{!<p class="other">!}[? if flavour_40_trigger and flavour_40_trigger_time == time: [? if lvp_leader == "Dingeldey": Банковский кризис и последовавшие за ним меры жёсткой экономии ухудшили отношение <span style="color: #FFCC00;">**ЛНП**</span> к правительству Брюнинга и вынудили её лидера[+ lvp_leader +] выступить с публичной критикой в его адрес, а ведь архитектор провального австро-германского таможенного союза — их же однопартиец Юлиус Курциус. Значительная часть <span style="color: #FFCC00;">**ЛНП**</span> по-прежнему выступает против полного разрыва с правительством, особенно те её члены, что пришли из <span style="color: #D3C24D;">**[+ ddp_name +]**</span>. ?][? if lvp_leader != "Dingeldey": Банковский кризис и последовавшие за ним меры жёсткой экономии ухудшили отношение <span style="color: #FFCC00;">**ЛНП**</span> к правительству Брюнинга, а ведь их однопартиец Юлиус Курциус архитектор катастрофического австро-германского таможенного союза. Небольшое меньшинство радикально правых промышленников и врагов демократии внутри <span style="color: #FFCC00;">**ЛНП**</span> выступают за полный разрыв с правительством — но, по крайней мере пока, это пустой звук. ?] ?]{!</p>!}

{!<p class="other">!}[? if flavour_44_trigger and flavour_44_trigger_time == time: Банковский кризис и последующие меры жёсткой экономии ещё больше испортили отношение <span style="color: #FFCC00;">**ЛНП**</span> к правительству Брюнинга, что побудило их лидера, Дингельдея, публично раскритиковать его. А ведь их сопартиец Юлиус Курциус — архитектор катастрофического австро-германского таможенного союза. В то время как небольшое меньшинство радикально правых промышленников и врагов демократии внутри <span style="color: #FFCC00;">**ЛНП**</span> выступают за полный разрыв с правительством, но их призывы — пустой звук. ?]{!</p>!}

{!<p class="other">!}[? if flavour_46_trigger and flavour_46_trigger_time == time: Банковский кризис и последующие меры жёсткой экономии ещё больше испортили отношение <span style="color: #FFCC00;">**ЛНП**</span> к правительству Брюнинга, но [+ lvp_leader +] остаётся твёрдым сторонником Брюнинга[? if lvp_leader != "Heuss" and lvp_leader != "Luther": , занимая пост [? if lvp_leader != "Dietrich": министра в правительстве самого Брюнинга ?][? if lvp_leader == "Dietrich": вице-канцлером при самом Брюнинге ?] ?]. Хотя незначительное меньшинство праворадикальных промышленников и врагов демократии внутри <span style="color: #FFCC00;">ЛНП</span> выступает за полный разрыв с правительством, их голоса — фоновый шум. ?]{!</p>!}

{!<p class="other">!}[? if flavour_36_trigger and flavour_36_trigger_time == time: Банковский кризис[? if emergency_decree_seen: &nbsp;и последствия второго чрезвычайного декрета Брюнинга ?][? if emergency_act_seen: &nbsp;и последствия чрезвычайного закона Брюнинга ?] усилили антибрюнинговские настроения среди буржуазных партий, особенно <span style="color: #C0A054;">**ННП**</span>[? if emergency_decree_seen: , которая и без того недовольна его действиями ?][? if emergency_act_seen: , которую и без того раздражало отсутствие консультаций с поддерживающими его партиями ?]. Однако[+ dvp_leader +] не решается добиваться отставки правительства, опасаясь, что это ещё больше дестабилизирует финансовое положение Германии. Кроме того, <span style="color: #7A3C00;">национальная</span> <span style="color: #003755;">оппозиция</span> по-прежнему не проявляет интереса к вхождению в кабинет Брюнинга. В таких обстоятельствах у <span style="color: #C0A054;">**ННП**</span> почти не остаётся иного выбора, кроме как продолжать поддерживать Брюнинга. ?]{!</p>!}

{!<p class="other">!}[? if year = 1931 and month == 7 and landtag_ref_signatures_passed and not landtag_ref_dvp and not lvp_formed: Неожиданно <span style="color: #C0A054;">**ННП**</span> выступила против референдума о роспуске прусского ландтага, агитируя за стабильность и демократию. Этот шаг сорвал план <span style="color: #3E88B3;">**Стального Шлема**</span> по созданию единого правого фронта в поддержку референдума, снизив его шансы на успех. ?]{!</p>!}

{!<p class="other">!}[? if year = 1931 and month == 7 and landtag_ref_votes and landtag_ref_dvp and not lvp_formed: Оставшиеся влиятельные члены левого крыла <span style="color: #C0A054;">**ННП**</span> из левого крыла осудили решительную поддержку партией референдума о роспуске прусского ландтага. Некоторые даже называют отказ от поддержки референдума «патриотическим долгом», а Курциус выступил по радио с речью, в которой объявил, что не будет придерживаться позиции своей партии по данному плебисциту. К сожалению, продемократические силы внутри партии бессильны и беспомощны, но и малая помощь ценна. ?]{!</p>!}

{!<p class="other">!}[? if year = 1931 and month == 8 and blutmai: Берлинская <span style="color: #700000;">**КПГ**</span> взяла на вооружение тактику ответных убийств: один берлинский полицейский за каждого убитого полицией члена <span style="color: #700000;">**КПГ**</span>. В соответствии с этой политикой капитаны полиции Пауль Анлауф и Франц Ленк убиты Эрихом Мильке и Эрихом Цимером. Не сумев устранить третьего офицера, который мог их опознать, двое боевиков не стали рисковать и немедленно бежали в Москву. Эти убийства вызвали широкое возмущение, направленное против <span style="color: #700000;">коммунистов</span>, и возобновили призывы буржуазии к скорейшему подавлению их движения. ?]{!</p>!}

{!<p class="dnvp">!}[? if flavour_21_trigger and flavour_21_trigger_time == time: Скандал, связанный с лидером <span style="color: #b8996f;">**ЭП**</span> Германом Древицем и его скандалами, наконец заставил его отказаться от поста председателя партии, чтобы предотвратить ещё более губительный раскол, чем тот, что произошёл несколькими месяцами ранее. [? if not lvp_formed: Многие из их членов Рейхстага, включая Отто Колоссера, перешли в <span style="color: #D3C24D;">**[+ ddp_name +]**</span>, которая стремится извлечь выгоду из их внутренних разногласий. ?]Из-за продолжающихся внутренних распрей и отставки её самых эффективных лидеров <span style="color: #b8996f;">**ЭП**</span> уже едва ли способна функционировать как политическая сила. ?]{!</p>!}

{!<p class="dnvp">!}[? if flavour_31_trigger and flavour_31_trigger_time == time: Скандал, связанный с лидером <span style="color: #b8996f;">**ЭП**</span> лидера Германа Древица и его скандалов наконец утих, поскольку он ушёл с поста председателя в пользу уважаемого Иоганна Бредта. Этот шаг вернул в ряды партии Отто Колоссера и мятежные районные организации. Несмотря на внутренние распри и многочисленные расколы, <span style="color: #b8996f;">**ЭП**</span> сумела выжить как общенациональная сила, продолжая представлять интересы консервативного среднего класса, который в противном случае мог бы примкнуть к <span style="color: #7A3C00;">**НСДАП**</span>. ?]{!</p>!}

{!<p class="dnvp">!}[? if flavour_37_trigger and flavour_37_trigger_time == time: The <span style="color: #3E88B3;">**НННП**</span> подверглась жёсткой критике со стороны <span style="color: #7A3C00;">национальной</span> <span style="color: #003755;">оппозиции</span> за продолжающуюся поддержку кабинета Брюнинга после банковского кризиса, причём <span style="color: #003755;">**НФГ**</span> стремится переманить на свою сторону разочарованных <span style="color: #3E88B3;">националистов</span>. Это вызвало серьёзную озабоченность внутри партии, поскольку она[? if dnvp_votes >= nsdap_votes: &nbsp;рискует оказаться ?] в тени более радикальной <span style="color: #7A3C00;">**НСДАП**</span>, чей подъём заставил промышленных покровителей <span style="color: #3E88B3;">**НННП**</span> оказать на неё давление, чтобы та пошла на сотрудничество с ними, заставив Брюнинга допустить <span style="color: #7A3C00;">ультра</span><span style="color: #003755;">правых</span> в правительство. ?]{!</p>!}

{!<p class="dnvp">!}[? if flavour_52_trigger and flavour_52_trigger_time == time: Стремительный рост популярности <span style="color: #7A3C00;">**НСДАП**</span> за счёт <span style="color: #3E88B3;">**НННП**</span> вызвал беспокойство у многих членов партии. В своём упадке они винят связь с непопулярным правительством Брюнинга и считают, что для возвращения утраченной поддержки крайне важно наладить более тесные связи с <span style="color: #7A3C00;">национальной</span> <span style="color: #003755;">оппозицией</span>. В результате многие члены <span style="color: #3E88B3;">**НННП**</span> начали открыто критиковать канцлера Брюнинга и агитируют за создании коалиции с национальной оппозицией. Это не сулит ничего хорошего будущей стабильности его кабинета. ?]{!</p>!}

{!<p class="other">!}[? if year = 1931 and month == 9 and banking_crisis_seen: Австро-германский таможенный союз официально прекратил своё существование: международные суды отклонили этот проект. [? if foreign_minister_party == "DVP": Юлиус Курциус из <span style="color: #C0A054;">**ННП**</span>, архитектор этого проекта, понёс серьёзный репутационный урон, и в его собственной партии всё громче звучат призывы к его отставке. [? if bruning_toleration_time and dvp_ideology == "Right": Если он уйдёт в отставку, <span style="color: #C0A054;">**ННП**</span> больше не будет представлена в кабинете, что развяжет ей руки и позволит поддержать вотум недоверия Брюнингу. ?] ?] ?]{!</p>!}

{!<p class="other">!}[? if year = 1931 and month = 9 : Великобритания отказалась от золотого стандарта! Кратковременный бунт на флоте, вызванный снижением жалования, привёл к панике на Лондонской фондовой бирже и бегству от фунта. Британское правительство вынуждено принять эту меру, чтобы стимулировать промышленный экспорт без пагубных последствий дефляции, чего удалось достичь путём девальвации фунта. Ведущие экономисты Германии сочли это актом отчаяния, который разорит английские банки и страховые компании. Страх граждан Германии перед инфляцией, а также обязательство по плану Юнга сохранять стоимость марки на уровне 0,358 грамма чистого золота, не позволили президенту Рейхсбанка [? if luther_reichsbank: Лютеру ?][? if not luther_reichsbank: Дрейзе ?] отказаться от золотого стандарта. Однако, поскольку и Соединённые Штаты, и Великобритания сочувственно отнеслись к нашей просьбе о более гибком регулировании, возможно, это решение всё же принято по экономическим соображениям. ?]{!</p>!}

{!<p class="other">!}[? if year = 1931 and month = 9: Японцы вторглись в Маньчжурию после Мукденского инцидента. ?]{!</p>!}

{!<p class="other">!}[? if flavour_41_trigger and flavour_41_trigger_time == time: После провала проекта австро-германского таможенного союза и его катастрофических последствий архитектор этого плана, Юлиус Курциус из [? if not lvp_formed and dvp_exist: <span style="color: #C0A054;">**ННП**</span> ?][? if not lvp_formed and not dvp_exist: <span style="color: #D3C24D;">**[+ ddp_name +]**</span> ?][? if lvp_formed: <span style="color: #FFCC00;">**ЛНП**</span> ?] взял на себя ответственность за неудачу и ушёл в отставку. Это серьёзно пошатнуло стабильность правительства Брюнинга, поскольку Курциус — один из его самых верных сторонников. Теперь, когда Брюнинг возглавил министерство иностранных дел, у [? if not lvp_formed: <span style="color: #C0A054;">**ННП**</span> ?][? if not lvp_formed and not dvp_exist: <span style="color: #D3C24D;">**[+ ddp_name +]**</span> ?][? if lvp_formed: <span style="color: #FFCC00;">**ЛНП**</span> ?] стало меньше причин поддерживать его правительство.[? if dvp_leader == "Curtius" or lvp_leader == "Curtius" and lvp_formed: Кроме того, Курциус покинул пост в руководстве партии, и, как ожидается, его преемником во главе [? if not lvp_formed: <span style="color: #C0A054;">**ННП**</span> ?][? if lvp_formed: <span style="color: #FFCC00;">**ЛНП**</span> ?], поскольку сторонники Брюнинга внутри партии также ослабли. ?] ?]{!</p>!}

{!<p class="other">!}[? if year == 1931 and month == 10 and not bourgeois_list and not bourgeois_parliament and (dnvp_split_2 or kvp_formed) and dvp_leader == "Dingeldey" and not lvp_formed and not lvp_merger_2_timer: The <span style="color: #D3C24D;">**[+ ddp_name +]**</span> обратилась к умеренно правым партиям вместо <span style="color: #C0A054;">**ННП**</span>, лидер которой, Дингельдей, не планирует предпринимать значимых действий по этому вопросу. Эти усилия вызваны общим страхом политического уничтожения со стороны <span style="color: #7A3C00;">ультра</span><span style="color: #3E88B3;">правых</span>[? if bruning_toleration_time: , и желанием повлиять на законодательную повестку Брюнинга ?]. Ганс Шланге-Шёнинген, один из [? if not bruning_toleration_time: самых ярых сторонников единства буржуазных партий, ?][? if bruning_toleration_time: один из самых ярых сторонников Брюнинга ?] в [? if not kvp_formed: <span style="color: #7FCEB1;">**ХНПКЗ**</span> ?][? if kvp_formed: <span style="color: #0087DC;">**КНП**</span> ?][? if cnblp_defect: , которая с тех пор откололась от Брюнинга ?], обратился к Вестарпу[? if csvd_formed: , the <span style="color: #8ED8E4;">**ХСНС**</span>, ?] и некоторым представителям <span style="color: #C0A054;">**ННП**</span> с просьбой забыть о разногласиях.[? if bruning_toleration_time: При горячей поддержке Брюнинга они согласились выступить в рейхстаге с совместным заявлением, подтверждающим поддержку его правительства. Однако информация об этом плане просочилась в прессу, что вынудило их отказаться от него после того, как несколько партий вышли из переговоров. ?] ?]{!</p>!}

{!<p class="other">!}[? if year = 1931 and month = 10: Недавние всеобщие выборы в Соединённом Королевстве завершились самой сокрушительной победой в истории страны: <span style="color: #f0456a;">лейбористы</span> получили всего лишь 52 места, потеряв 235 по сравнению с предыдущими выборами. Несмотря на это, действующий премьер-министр <span style="color: #008000;">национал-лейборист</span> Рамсей Макдональд сохранил пост, управляя страной совместно с <span style="color: #0087DC;">тори</span>. ?]{!</p>!}

{!<p class="other">!}[? if flavour_47_trigger and flavour_47_trigger_time == time: [? if year == 1931 and month >= 11: В ходе предвыборной кампании в ландтаг Гессена ?][? if year != 1931 or month < 11: Во время предвыборной кампании в местные органы власти ?], Дингельдей предложил Гитлеру, чтобы их партии воздержались от взаимных нападок и выступили единым фронтом против партий <span style="color: #000000;">Ве</span><span style="color: #DD0000;">йм</span><span style="color: #FFCC00;">арской</span> коалиции. Их сдвиг в сторону <span style="color: #7A3C00;">ультра</span><span style="color: #3E88B3;">правых</span> [? if dvp_defect: в сочетании с выходом из кабинета Брюнинга ?] мобилизовал левое крыло партии, которое теперь сплотилось вокруг группы «Кунц — Дона», названной так по фамилиям её лидеров. Их цель — вернуть <span style="color: #C0A054;">**ННП**</span> к политическому курсу её покойного основателя и председателя Штреземана и не допустить союза с <span style="color: #7A3C00;">национальной</span> <span style="color: #3E88B3;">оппозицией</span>. ?]{!</p>!}

{!<p class="other">!}[? if year = 1931 and month = 12 and (reparations == -2 or hoover_moratorium_seen) and bruning_time: Брюнинг стал играть всё более активную роль во внешней политике и успешно убедил западных союзников вновь пересмотреть репарационное бремя Германии. Попытки правительства предотвратить полный коллапс экономики не оставили средств для выплаты репараций даже после введения моратория на выплату долгов. Группой профессиональных банкиров подготовлен «Доклад Бендуче». Его суть: Германия не только не сможет выплачивать репарации в обозримом будущем, но и необходимо сокращение её долгового бремени. Тактика Брюнинга привела к соглашению, которое значительно расширило Германии пространство для манёвра. ?]{!</p>!}

{!<p class="other">!}[? if flavour_59_trigger and flavour_59_trigger_time == time: Канцлер [+ chancellor +] публично дистанцировался от попыток включить <span style="color: #7A3C00;">**НСДАП**</span> в состав правительства, поставив под сомнение их приверженность исключительно законным методам. Это произошло после того, как Брюнинг в обход Гугенберга провел прямые переговоры с Гитлером в рамках так называемого союза Брюнинга и Гитлера. Встречи Брюнинга с представителями <span style="color: #7A3C00;">**НСДАП**</span> Гитлером и Штрассером показали: обе стороны искренне заинтересованы в достижении договорённости, причём Брюнинг даже перенаправил свою критику с Гитлера на Гугенберга. К счастью, эти переговоры провалились, так как успехи <span style="color: #7A3C00;">нацистов</span> на выборах убедили их, что их путь к власти лежит не через Брюнинга. ?]{!</p>!}

{!<p class="other">!}[? if flavour_48_trigger and flavour_48_trigger_time == time: Нежелание Дингельдея бросать вызов промышленному крылу <span style="color: #C0A054;">ННП</span> обострило отношения с DHV (Немецким национальным профсоюзом служащих) — профсоюзом «белых воротничков», который неизменно поддерживал партию с момента основания республики. Его отказ признать роль профсоюзов в коллективных договорах заставил DHV почувствовать себя отодвинутым на второй план и усомниться в будущем партии. Группа Кунца-Доны решила поднять свои проблемы на заседании исполнительного комитета в этом месяце, где их изоляция и бессилие стали очевидны: против резолюции, однозначно осуждающей Брюнинга, подано лишь 14 из 344 голосов. Теперь группа рассматривает возможность выхода из партии вслед за крайними правыми, выступающими за слияние с [? if dnvp_ideology == "Moderate": с ?][? if dnvp_ideology == "Radical": представляемой Гугенбергом ?] <span style="color: #3E88B3;">**НННП**</span> на том же заседании. ?]{!</p>!}

{!<p class="other">!}[? if year = 1931 and month = 12 : Вторая Испанская Республика приняла новую демократическую конституцию, провозгласив светское, прогрессивное и республиканское правительство. Для Испании наступают светлые времена. ?]{!</p>!}

{!<p class="other">!}[? if flavour_49_trigger and flavour_49_trigger_time == time: С тех пор как на заседании исполнительного комитета партии победу одержали крайне правые силы, Дингельдей находится под всё возрастающим давлением с требованием наладить более тесные связи с партиями <span style="color: #7A3C00;">национальной</span> <span style="color: #3E88B3;">оппозиции</span>. Эрих фон Гильза, представитель партии по связям с <span style="color: #3E88B3;">**Стальным Шлемом**</span>, заставил Дингельдея встретиться с лидерами местных районных организаций, чтобы оказать давление на партию с целью её сближения с [? if dnvp_ideology == "Moderate": с ?][? if dnvp_ideology == "Radical": представляемой Гугенбергом ?] <span style="color: #3E88B3;">**НННП**</span>, и в конечном счёте, слияния с ней. [? if dnvp_ideology == "Radical": До сих пор он сопротивлялся этим попыткам, утверждая, что Гугенберг потребует одностороннее и полное поглощение <span style="color: #C0A054;">**ННП**</span>. ?][? if dnvp_ideology == "Moderate": В условиях падения доли голосов, отданных за буржуазные партии, этот вариант кажется весьма привлекательным: между двумя партиями начались переговоры. ?] ?]{!</p>!}

{!<p class="other">!}[? if flavour_50_trigger and flavour_50_trigger_time == time: Эрих фон Гильза вышел из <span style="color: #C0A054;">**ННП**</span> в знак протеста против незаинтересованности Дингельдея в слиянии с <span style="color: #3E88B3;">**НННП**</span>. Это спровоцировало цепную реакцию: многие местные районные организации и ключевые лидеры крайне правого крыла партии вышли из неё и перешли в <span style="color: #3E88B3;">**НННП**</span>. [? if bruning_time: Более того, когда Рейхстаг возобновил свою работу, Дингельдей попытался навязать жесткую партийную дисциплину, заставив делегацию единогласно проголосовать против Брюнинга. Это привело к исключению из партии Курциуса и Зигфрида фон Кардорфа — самых уважаемых представителей левого крыла. ?] Можно с уверенностью сказать, что <span style="color: #C0A054;">**ННП**</span> больше не жизнеспособная политическая сила. ?]{!</p>!}

{!<p class="dnvp">!}[? if year = 1932 and month = 3 and dnvp_ideology == "Radical" and presidential_election_seen: Недавние события на президентских выборах — и предательство ближайших союзников Гугенберга в пользу <span style="color: #7A3C00;">**НСДАП**</span> — глубоко деморализовали его, и он оказался на грани отставки. В его собственной партии всё громче звучат призывы к смене руководства, поскольку многие надеются спасти её угасающее влияние. Но Гугенберг есть Гугенберг. Он ещё о себе заявит. ?]{!</p>!}

{!<p class="other">!}[? if flavour_53_trigger and flavour_53_trigger_time == time: [? if dnvp_leader == "Lambach": Переговоры между <span style="color: #C0A054;">**ННП**</span> и <span style="color: #3E88B3;">**НННП**</span> до сих пор не увенчались успехом, поскольку <span style="color: #6D5298;">христианско-социальные</span> и нелиберальные идеалы Ламбаха вступают в противоречие с <span style="color: #C0A054;">**ННП**</span> практически по каждому вопросу. Однако праворадикальное крыло в <span style="color: #C0A054;">**ННП**</span> продолжает настаивать на более тесном сближении, полагая, что слияние может повлечь за собой смену руководства в <span style="color: #3E88B3;">**НННП**</span>. ?][? if dnvp_leader != "Lambach": Переговоры между <span style="color: #C0A054;">**ННП**</span> и <span style="color: #3E88B3;">**НННП**</span> продвинулись вперёд, что привело к дальнейшему сотрудничеству между двумя партиями. Признав сокращение своей электоральной поддержки и идеологическое сходство, они договорились выставить единый список на следующих выборах. [? if dnvp_leader == "Treviranus": Тревиранус выступает за более тесное сотрудничество буржуазных партий, поскольку давно стремится к консолидации демократических правых буржуазных сил. ?][? if dnvp_leader == "Schiele": Аграрный консерватизм Шиле вступил в противоречие с промышленным капитализмом <span style="color: #C0A054;">**ННП**</span>, что вызвало беспокойство среди спонсоров партии. Они опасаются, что их влияние может ослабнуть в рамках более широкой партии. ?][? if dnvp_leader == "Hergt" or dnvp_leader == "Westarp": [+ dnvp_leader +] выразил скептицизм по поводу предлагаемого слияния. Он утверждает, что хоть <span style="color: #C0A054;">**ННП**</span> и сместилась вправо, сохраняются фундаментальные разногласия — особенно по таким вопросам, как монархия и [? if reparations >= 0: репарации ?][? if reparations == -2: «национальные вопросы» ?]. ?] ?] ?]{!</p>!}

{!<p class="other">!}[? if year = 1932 and month = 4 and pro_republic < 50 and dvp_exist and (luther_reichsbank or dvp_leader == "Luther" or (lvp_leader == "Luther" and lvp_formed)): На Ганса Лютера совершено покушение! К счастью, он лишь ранен в плечо и сможет продолжать исполнять свои обязанности в качестве [? if luther_reichsbank: президента Рейхсбанка ?][? if dvp_leader == "Luther" or (lvp_leader == "Luther" and lvp_formed): лидера [? if not lvp_formed: <span style="color: #C0A054;">**ННП**</span> ?][? if lvp_formed: <span style="color: #FFCC00;">**ЛНП**</span> ?] ?]. [? if luther_reichsbank: Нападавшие заранее написали письмо, в котором раскритиковали его денежно-кредитную политику. ?][? if dvp_leader == "Luther" or (lvp_leader == "Luther" and lvp_formed): Нападавшие заранее написали письмо, в котором раскритиковали его как лидера [? if not lvp_formed: <span style="color: #C0A054;">**ННП**</span> ?][? if lvp_formed: <span style="color: #FFCC00;">**ЛНП**</span> ?] ?]. ?]{!</p>!}

{!<p class="other">!}[? if year = 1932 and month = 5 and not lvp_formed and not bourgeois_parliament and not bourgeois_list and liberal_vote < 5 and dvp_exist: Крах буржуазных и либеральных партий под натиском <span style="color: #7A3C00;">нацистского</span> движения убедил руководство <span style="color: #D3C24D;">**[+ ddp_name +]**</span> и <span style="color: #C0A054;">**ННП**</span> в том, что их партии — и либерализм в целом — это пережитки прошлого, и что их патриотический долг — как можно скорее умереть, чтобы из пепла могла возникнуть новая, единая буржуазная партия. [? if dvp_leader == "Dingeldey": Несмотря на сложившуюся ситуацию, <span style="color: #C0A054;">**ННП**</span> по-прежнему требует единства на своих условиях. ?] ?]{!</p>!}

{!<p class="other">!}[? if year = 1932 and month = 5 : Австрийское правительство ушло в отставку из-за значительных успехов австрийской <span style="color: #7A3C00;">**НСДАП**</span> на недавних местных выборах, в результате чего президент назначил канцлером Энгельберта Дольфуса. Теперь Дольфус правит в коалиции с <span style="color: #ABDDA4;">Heimwehr</span>. ?]{!</p>!}

{!<p class="other">!}[? if flavour_62_trigger and (flavour_62_trigger_time == time or (flavour_62_trigger_time == rubicon_time and rubicon)): К нашему удивлению, мы наблюдаем некоторую оттепель в наших обычно враждебных отношениях с <span style="color: #700000;">**КПГ**</span>. Этот сдвиг связан с тем, что их руководство наконец осознало, что <span style="color: #7A3C00;">**НСДАП**</span> теперь представляет главную угрозу их выживанию. Рабочие всё чаще приходят к пониманию, что <span style="color: #9B0000;">марксистское</span> единство необходимо перед лицом нарастающего <span style="color: #7A3C00;">фашизма</span>. ?]{!</p>!}

{!<p class="other">!}[? if papen_time == 1 and z_leader == "Kaas": Людвиг Каас из <span style="color: #000000;">партии Центра</span> объявил о намерении уйти с поста председателя. Он сослался на плохое здоровье и выдвинул преемником Генриха Брюнинга. Однако его убедили остаться на посту — при условии, что его заместитель Йозеф Йоос и Брюнинг возьмут на себя основную часть управления партией. Вскоре после этого Каас отбыл в длительный отпуск на лечение в Южный Тироль. ?]{!</p>!}

{!<p class="other">!}[? if papen_time == 1 and not lvp_formed: The <span style="color: #D3C24D;">[+ ddp_name +]</span> заявила о своей решительной оппозиции кабинету баронов Папена и пытается мобилизовать антипапеновский буржуазный электорат вокруг своей партии, которая более не обременена правительственной ответственностью. [? if dvp_exist and dvp_leader == "Dingeldey": Тем временем <span style="color: #C0A054;">**ННП**</span> более благосклонно отнеслась к новому правительству, несмотря на его аристократический облик и то, что в его состав не вошла <span style="color: #7A3C00;">**НСДАП**</span>. Тем не менее они считают это шагом вперёд по сравнению с прошлым канцлером и воздерживаются от антиправительственных выпадов. Это серьёзно затруднит любые попытки либералов объединиться. ?][? if dvp_exist and dvp_leader != "Dingeldey": Партия <span style="color: #C0A054;">**ННП**</span> также резко выступила против нового правительства, раскритиковав его сугубо аристократический состав и крайне непопулярные решения. В результате у Папена остаётся чрезвычайно узкая база поддержки в любом будущем составе парламента. ?] ?]{!</p>!}

{!<p class="other">!}[? if papen_time == 2: Йозеф Геббельс, гений пропаганды <span style="color: #7A3C00;">нацистов</span>, всего через несколько дней после назначения Папена канцлером пришёл к выводу: для сохранения популярности партия должна порвать с этим правительством. Партия не может поддерживать правительство, против которого непримиримо выступают до 90% немецкого народа. Но пока это решение держится в тайне: Папен продолжает попытки заручиться их поддержкой. ?]{!</p>!}

{!<p class="other">!}[? if papen_time == 2 and not lvp_formed and not bourgeois_parliament and not bourgeois_list and dvp_exist and dvp_leader == "Dingeldey": Попытки достичь единства среди буржуазных партий зашли в тупик, поскольку <span style="color: #D3C24D;">**[+ ddp_name +]**</span> отказывается сотрудничать с антидемократическими партиями, стоящими правее неё. Даже Дитрих не желает вести переговоры о соглашении между буржуазными партиями, которые сместились на крайне правый фланг. [? if dvp_exist: Кроме того, отставка члена <span style="color: #C0A054;">**ННП**</span>, депутата Рейхстага, в знак протеста против создания единой центристской партии укрепила Дингельдея в его решимости прервать переговоры с <span style="color: #D3C24D;">**[+ ddp_name +]**</span> и вместо этого искать соглашения с <span style="color: #3E88B3;">**НННП**</span>. Более того, он отказался участвовать в каких-либо проектах, направленных на борьбу с движением <span style="color: #7A3C00;">нацистов</span>. ?] С тех пор деловые круги приостановили все политические пожертвования, пока не будет достигнут прогресс. ?]{!</p>!}

{!<p class="other">!}[? if papen_time == 3 and nsdap_r_prussia >= 25 and not in_far_right_coalition_prussia: Переговоры между <span style="color: #000000;">партией Центра</span> и <span style="color: #7A3C00;">**НСДАП**</span> в Пруссии провалились из-за враждебного отношения <span style="color: #000000;">партии Центра</span> к своему уже исключенному члену, а ныне канцлеру Папену. ?]{!</p>!}

{!<p class="other">!}[? if papen_time == 4 and not lvp_formed and not bourgeois_parliament and not bourgeois_list and dvp_exist and dvp_leader == "Dingeldey": Поскольку Дингельдей возложил всю вину на <span style="color: #D3C24D;">**[+ ddp_name +]**</span> за срыв переговоров, руководство <span style="color: #C0A054;">**ННП**</span> предоставило ему карт-бланш на поиск «альтернативного» соглашения с <span style="color: #3E88B3;">националистами</span>. ?]{!</p>!}

{!<p class="other">!}[? if papen_time == 5 and hugenberg_dvp: Из всех буржуазных партий <span style="color: #D3C24D;">**[+ ddp_name +]**</span>, несмотря на острую нехватку средств, наиболее решительно защищает <span style="color: #000000;">Ве</span><span style="color: #DD0000;">йм</span><span style="color: #FFCC00;">ар</span>скую республику — даже решительнее, чем партия <span style="color: #000000;">Центра</span>. Тем временем <span style="color: #C0A054;">**ННП**</span> сблизилась с Папеном в соответствии с условиями их союза. Грани между двумя партиями всё больше стираются, и один из членов <span style="color: #C0A054;">**ННП**</span> даже подал в отставку в знак протеста против отказа Дингельдея сделать последний шаг и объединиться с <span style="color: #3E88B3;">**НННП**</span> полностью. ?]{!</p>!}

{!<p class="other">!}[? if papen_time == 6 and nsdap_r_prussia >= 25 and not in_far_right_coalition_prussia and spd_prussia and not presidential_powers and not prussian_reichsexekution: По слухам, канцлер Папен заручился поддержкой своего кабинета и президента Гинденбурга для издания указа о проведении <i>Reichsexekution (Имперская экзекуция)</i> против Пруссии, оправдывая это сфабрикованным заявлением о слиянии <span style="color: #c00000;">**СДПГ**</span> с <span style="color: #700000;">**КПГ**</span> — это ложь. Вранье, по-видимому, оказалось достаточно убедительным, чтобы повлиять на Гинденбурга. Кажется, ему нужен лишь предлог, чтобы предъявить уже подписанный указ. ?]{!</p>!}

{!<p class="other">!}[? if papen_time == 7 and prussia_leader == "Papen": Против захвата прусского правительства Папеном немедленно подан судебный иск, инициированный <span style="color: #c00000;">**СДПГ**</span> и <span style="color: #000000;">Партией Центра</span> вместе запросом о предварительном судебном запрете, чтобы помешать Папену и назначенным им комиссарам взять контроль в свои руки во время судебного процесса. <span style="color: #808080;">Реакционный</span> суд отклонил запрос, а начало основного разбирательства отложено на целых три месяца. ?]{!</p>!}

{!<p class="other">!}[? if papen_time == 7: Канцлер Папен приказал германской делегации покинуть Женевскую конференцию по разоружению после того, как <span style="color: #002654;">Франция</span> выразила решительный протест против требования Германии о равноправии в вооружениях. Папен заявил: Германия не вернётся на конференцию до тех пор, пока другие державы не согласятся на его условия. ?]{!</p>!}

{!<p class="other">!}[? if papen_time == 8 and prussia_leader == "Papen": Новый правый и беспартийный прусский кабинет, сформированный <i>рейхскомиссаром</i> Папеном, начал масштабную чистку <span style="color: #c00000;">социалистических</span> и <span style="color: #D3C24D;">демократических</span> чиновников в государственном аппарате, вынуждая их досрочно уходить в отставку. Большинство пришедших им на смену — консерваторы, многие из которых <span style="color: #3E88B3;">националисты</span>. Чистка в первую очередь направлена против <span style="color: #c00000;">социалистов</span> на постах обер-президентов провинций и полицейских начальников. Около 69 <span style="color: #000000;">рес</span><span style="color: #DD0000;">публ</span><span style="color: #FFCC00;">иканских</span> чиновников лишены полномочий. Можно с уверенностью сказать: оплот демократии в Пруссии разрушен. ?]{!</p>!}

{!<p class="other">!}[? if flavour_60_trigger and ((flavour_60_trigger_time == time and not rubicon) or (flavour_60_trigger_time == rubicon_time and rubicon)): The <span style="color: #D3C24D;">**[+ ddp_name +]**</span> результаты, принёсшие ничтожно малый [+ ddp_r +]% мест в Рейхстаге из-за невыгодного положения, обусловленного отсутствием предвыборного союза, вызвали новый виток дебатов о дальнейшем существовании партии. Смирение с её судьбой особенно сильно проявляется в деловом крыле: многие его члены поддаются давлению и настаивают на роспуске. [? if ddp_leader == "Dietrich": Даже Дитрих сдался, объявив о своей отставке, но никто не желает занять его место. ?] Однако активным земельным организациям партии в их оплотах, Баден-Вюртемберге и Гамбурге, удалось убедить однопартийцев отказаться от роспуска. В результате партия взяла более энергичный тон, а власть разделили Дитрих, энергичный министр Вюртемберга Рейнгольд Майер и бургомистр Гамбурга Карл Петерсен — бывший председатель <span style="color: #D3C24D;">**НДП**</span>. ?]{!</p>!}

{!<p class="other">!}[? if year = 1932 and month = 8 and (week == 1 or not rubicon) and unemployed >= 25 : Возможно, на горизонте наконец-то забрезжило мировое экономическое восстановление. Многие экономисты считают: спад достиг дна, а франкфуртская фондовая биржа уверенно растёт — стоимость акций и облигаций с весны выросла более чем на 30%. Но этот подъём остаётся чем-то абстрактным для миллионов безработных немцев, по-прежнему прозябающих в нищете. ?]{!</p>!}

{!<p class="other">!}[? if papen_time == 9 and hitler_right_coalition >= 50: Последствия выборов в рейхстаг и формирование чёрно-коричневого большинства положили начало переговорам между <span style="color: #7A3C00;">**НСДАП**</span> и <span style="color: #000000;">Партией Центра</span>. Последняя надеется сдержать <span style="color: #7A3C00;">нацистов</span>, обязав потенциального канцлера [+ nsdap_chancellor +] править через парламент, а не посредством чрезвычайных указов. Тем самым канцлер был бы вынужден согласовывать решения с более консервативным и надёжным, не<span style="color: #7A3C00;">нацистским</span> кабинетом — в руках которого и была бы сосредоточена вся реальная власть. ?]{!</p>!}

{!<p class="other">!}[? if papen_time == 9: Генерал Шлейхер выступил с заманчивым предложением к [+ nsdap_chancellor +], предложив сформировать президентский кабинет, который будет править посредством чрезвычайных указов. При таком раскладе Грегор Штрассер стал бы министром внутренних дел Пруссии и Германии, а сам Шлейхер, заняв пост военного министра, по его мнению, смог бы контролировать <span style="color: #7A3C00;">нацистов</span>. Однако энтузиазм руководства <span style="color: #7A3C00;">нацистов</span> быстро угасает, когда президент Гинденбург отказывается назначить [+ nsdap_chancellor +]а канцлером. Папен, глубоко оскорблённый явной готовностью Шлейхера отказаться от него, воспользовался своим растущим взаимопониманием с Гинденбургом, чтобы подорвать влияние Шлейхера на президента. ?]{!</p>!}

{!<p class="other">!}[? if papen_time == 10: По результатам выборов в рейхстаг Папен и президент Гинденбург встретились с [+ nsdap_chancellor +]ом, чтобы выслушать его требования относительно участия партии в правительстве. [+ nsdap_chancellor +] вновь потребовал для себя пост канцлера, но Гинденбург ему отказал. Воодушевлённые победой на выборах, <span style="color: #7A3C00;">нацисты</span> теперь официально отказались от своих прежних обещаний мириться с правительством Папена. Впредь они будут придерживаться стратегии «всё или ничего»: канцлерский пост для [+ nsdap_chancellor +], или ничего. ?]{!</p>!}

{!<p class="other">!}[? if papen_time == 11: Папен передал прессе содержание состоявшихся на прошлой неделе переговоров с [+ nsdap_chancellor +]ом, заявив, что [+ nsdap_chancellor +] ворвался в кабинет Гинденбурга с требованием «полной власти над государством» — то есть жестокой однопартийной диктатуры — и получил от президента гневный отпор. Этот пресс-релиз призван ознаменовать начало контрнаступления против <span style="color: #7A3C00;">нацистов</span>. Но теперь ни одна партия не желает — да и не может — последовать за канцлером и пойти на открытую конфронтацию с экстремистами. Даже <span style="color: #000000;">Партия Центра</span> считает версию событий [+ nsdap_chancellor +]а более правдоподобной, чем версию Папена. ?]{!</p>!}

{!<p class="other">!}[? if papen_time == 11 and hitler_right_coalition >= 50: Переговоры о коалиции между <span style="color: #000000;">Партией Центра</span> и <span style="color: #7A3C00;">**НСДАП**</span> продолжаются, вынуждая Папена опередить свою бывшую партию в борьбе за благосклонность <span style="color: #7A3C00;">нацистов</span>. Брюнинг с разрешения руководства своей партии встретился с представителем <span style="color: #7A3C00;">**НСДАП**</span> Штрассером и пообещал ему поддержку, если тот сможет убедить [+ nsdap_chancellor +] сформировать парламентский кабинет, в котором Шлейхер станет министром обороны, а Гёрделер — комиссаром Пруссии. ?]{!</p>!}

{!<p class="other">!}[? if papen_time == 11 and schleicher_kvp: Под давлением своего главного покровителя, генерала фон Шлейхера, <span style="color: #0087DC;">**КНП**</span> вынуждена поддерживать непопулярное правительство Папена — иначе она рискует лишиться тайного финансирования от Шлейхера из средств рейхсвера. Возмущённые тем, что партия поддерживает столь элитарного канцлера, <span style="color: #6D5298;">представители христианско-социального движения</span> в знак протеста покидают свои посты. ?]{!</p>!}

{!<p class="other">!}[? if papen_time == 12 and hitler_right_coalition >= 50: Встреча, организованная Штрассером в продолжение прошлонедельного обсуждения возможного чёрно-коричневого альянса, привела к [+ nsdap_chancellor +]соглашению отложить голосование о вотуме недоверия Папену.[+ nsdap_chancellor +] Также, по-видимому, достигнуто согласие и по другим требованиям Брюнинга. В ближайшем будущем ожидается более тесное сотрудничество, если обе стороны искренни в своём стремлении совместно управлять страной через парламент. [? if nsdap_chancellor == "Hitler": Однако[+ nsdap_chancellor +]— великий лжец. ?] ?]{!</p>!}

{!<p class="other">!}[? if year = 1932 and month = 8 and (week == 3 or not rubicon): Австрия получила заем от Лиги Наций, условие которого — 20-летний запрет на аншлюс, однако противодействие со стороны <span style="color: #C8102E;">социал-демократов</span> и <span style="color: #0E428E;">Великогерманской партии</span> тормозило принятие закона. Но в конце концов его, наконец, приняли с перевесом всего в один голос. ?]{!</p>!}

{!<p class="other">!}[? if papen_time == 13 and hitler_right_coalition >= 50: Переговоры о коалиции между <span style="color: #000000;">Партией Центра</span> и <span style="color: #7A3C00;">**НСДАП**</span> прекращены, поскольку Брюнинг всё сильнее опасается сопряжённых с этим серьёзных рисков. На это решение также повлиял его друг и член нашей партии Гильфердинг, который утверждает, что <span style="color: #7A3C00;">**НСДАП**</span> никогда не восстановит парламентское правление. Гильфердинг также указал, что многие однопартийцы Брюнинга попали под влияние <span style="color: #7A3C00;">нацистов</span>, что и подтвердилось, когда в рамках планируемой сделки они практически согласились на импичмент президенту Гинденбургу. Кроме того, Гильфердинг — единственный в нашей партии, кто выступает за воздерживание от вотума недоверия кабинету Папена, видя в этом единственный способ предотвратить диктатуру <span style="color: #7A3C00;">нацистов</span>. Теперь цель Брюнинга — убедить <span style="color: #7A3C00;">нацистов</span> дать правительству Папена «честный шанс» на возрождение экономики. ?]{!</p>!}

{!<p class="other">!}[? if papen_time == 15 and hitler_right_coalition >= 50: <span style="color: #000000;">Партия центра</span> и её рядовые сторонники всё больше поддаются унынию, во многом из-за полусекретных переговоров Брюнинга с <span style="color: #7A3C00;">**НСДАП**</span>. На местах партийные активисты сталкивались с <span style="color: #7A3C00;">нацистами</span> как с жестокими головорезами, срывающими их митинги и запугивающими оппонентов, — что совершенно не вяжется с образом потенциального партнёра по коалиции. Некоторые активисты даже берутся за оружие в целях самообороны, теряя веру в свою партию и её руководство. ?]{!</p>!}

{!<p class="other">!}[? if papen_time == 16 and papen_explode: Грегор Штрассер из <span style="color: #7A3C00;">**НСДАП**</span> публично выступил против недавно вынесенного его партией вотума недоверия и спровоцированных им досрочных выборов, предупредив, что подобные шаги лишь подорвут народную поддержку <span style="color: #7A3C00;">нацистов</span> и лишат их единственного реального шанса прийти к власти. В ответ на это вокруг Штрассера сплотилась неофициальная фракция из примерно шестидесяти <span style="color: #7A3C00;">нацистских</span> депутатов рейхстага, разочарованная [+ nsdap_leader +]овской тактикой «всё или ничего». ?]{!</p>!}

{!<p class="other">!}[? if year = 1932 and month = 9 and (week == 3 or not rubicon) : В Швеции прошли всеобщие выборы, завершившиеся убедительной победой Пера Альбина Ханссона и его <span style="color: #D70926;">социал-демократов</span>, которые теперь правят во главе правительства меньшинства. <span style="color: #D70926;">Шведские социал-демократы</span> взяли на вооружение концепцию «дома для народа» — форму реформистского социализма, направленную на сокращение классовых различий в рамках капиталистической системы. Может, и нам стоит последовать их «скандинавской» модели? ?]{!</p>!}

{!<p class="other">!}[? if papen_time == 17 and prussia_leader == "Papen": Начались основные слушания по делу о неконституционном применении Папеном <i>Reichsexekution (Имперская экзекуция)</i> в отношении прусского правительства; вердикт ожидается в ближайшие недели. Однако исторически <span style="color: #808080;">реакционные</span> взгляды судейского корпуса ставят нас в заведомо невыгодное положение — несмотря на поддержку со стороны правительств земель Бавария и Баден, которые присоединились к нам в оспаривании законности этого указа. ?]{!</p>!}

{!<p class="other">!}[? if year = 1932 and month = 10 and (week == 1 or not rubicon) : Канцлер Австрии Энгельберт Дольфус воспользовался «Законом о военных полномочиях» — законом, принятым ещё во времена Австро-Венгерской империи, — который позволил ему реструктурировать банк Creditanstalt без одобрения парламента. И хотя <span style="color: #C8102E;">австрийские социал-демократы</span> выразили протест, действия Дольфуса формально законны. ?]{!</p>!}

{!<p class="other">!}[? if papen_time == 18 and papen_explode and not lvp_formed and ddp_ideology == "Right": The <span style="color: #D3C24D;">**[+ ddp_name +]**</span>, в попытке повысить свой рейтинг, изложила концепцию «национальной демократии», цель которой — возродить националистический порыв, сыгравший столь важную роль в немецком либеральном движении. По сути, это лишь переформулировка классической либеральной идеологии, призванная привлечь более националистически настроенный немецкий средний класс. Программа национальной демократии также подтверждает приверженность <span style="color: #D3C24D;">**[+ ddp_name +]**</span> <span style="color: #000000;">Ве</span><span style="color: #DD0000;">йм</span><span style="color: #FFCC00;">ар</span>ской республике и предлагает конституционные изменения для её укрепления. ?]{!</p>!}

{!<p class="dnvp">!}[? if papen_time == 18 and papen_explode and hugenberg_dvp and not lvp_formed: Благодаря предвыборному союзу с <span style="color: #3E88B3;">НННП</span>, <span style="color: #C0A054;">**ННП**</span> становится всё более ограниченной. Её риторика всё больше сближается с риторикой <span style="color: #3E88B3;">**НННП**</span> и теперь призывает к «ликвидации <span style="color: #000000;">Ве</span><span style="color: #DD0000;">йм</span><span style="color: #FFCC00;">ар</span>ской системы», авторитарному пересмотру её конституции и отстранению народных масс от власти. ?]{!</p>!}

{!<p class="dnvp">!}[? if papen_time == 20 and papen_explode and hugenberg_dvp and not lvp_formed: Дингельдея и его соратников больше не устраивает простое продление общих избирательных списков с <span style="color: #3E88B3;">**НННП**</span>. Вместо этого они настаивают на создании единого Rechtsblock с участием <span style="color: #C0A054;">**ННП**</span>, <span style="color: #3E88B3;">**НННП**</span>, <span style="color: #3E88B3;">**Стального шлема**</span> и различных объединений промышленников и предпринимателей для оказания сплочённой поддержки Гинденбургу и Папену. Однако Гугенберг проявил полное безразличие, отказавшись брать на себя какие-либо обязательства, кроме возобновления общих избирательных списков. ?]{!</p>!}

{!<p class="other">!}[? if papen_time == 21 and papen_post_2: Президент Гинденбург по итогам недавних выборов вновь попытался прозондировать позицию <span style="color: #7A3C00;">нацистов</span>. [+ nsdap_chancellor +] сигнализировал о своей готовности заручиться поддержкой других партий, если его сначала назначат канцлером. Вскрыв блеф [+ nsdap_chancellor +]а, президент предложил назначить его, но только если он сможет обеспечить рабочее большинство в рейхстаге и позволить президенту самому выбрать министров обороны и иностранных дел. Как и ожидалось, [+ nsdap_chancellor +] отклонил предложение Гинденбурга и вместо этого заявил, что с чрезвычайными полномочиями смог бы в кратчайшие сроки сформировать приемлемое правительство. Убедившись, что [+ nsdap_chancellor +] добивается не чего иного, как поста канцлера с чрезвычайными полномочиями, Гинденбург снял его кандидатуру с рассмотрения. ?]{!</p>!}

{!<p class="other">!}[? if ((flavour_61_trigger_time == time and not rubicon) or (flavour_61_trigger_time == rubicon_time and rubicon)): После очередных катастрофических для <span style="color: #D3C24D;">**[+ ddp_name +]**</span> результатов группа из шести бывших депутатов рейхстага и высокопоставленных членов партии сообщила: [+ ddp_leader +] нужно провести партийный съезд о роспуске партии, иначе они выйдут из неё. Однако этот призыв не получил широкой поддержки, и Карл Петерсен, бывший председатель <span style="color: #D3C24D;">**НДП**</span>, использовал своё умение вести переговоры, чтобы не дать раскольникам публично объявить о разрыве с партией. ?]{!</p>!}

{!<p class="other">!}[? if year = 1932 and month = 11 and (week == 1 or not rubicon): <span style="color: #00AEF3;">Демократ</span> Франклин Д. Рузвельт одержал убедительную победу над действующим президентом <span style="color: #E81B23;">республиканцем</span> Гербертом Гувером на президентских выборах в <span style="color: #B31942;">Соединённых</span> <span style="color: #0A3161;">Штатах</span>. Это объясняется Великой депрессией и предвыборной кампанией Рузвельта в поддержку «Нового курса», в рамках которой он предлагал масштабные общественные работы и реформу правительства. ?]{!</p>!}

{!<p class="other">!}[? if papen_time == 22 and papen_post_2: Широко распространились слухи о том, что генерал Шлейхер намеревается подорвать позиции канцлера, которому сам же и помог прийти к власти. В высших кругах прочат уже самого Шлейхера на место канцлера. ?]{!</p>!}

{!<p class="other">!}[? if papen_time == 23 and papen_post_2: Президент Гинденбург поручил [+ z_leader +]у предпринять последнюю попытку сформировать парламентскую коалицию большинства. Доложив о результатах на следующий день, [+ z_leader +] подтвердил: собрать такое большинство невозможно. Его рекомендация прямолинейна: единственный выход — чтобы президент отправил Папена в отставку, поскольку рейхстаг никогда не примет его в качестве канцлера. ?]{!</p>!}

{!<p class="other">!}[? if (papen_time or chancellor == "Schleicher") and year == 1932 and month == 12 and week == 1: The <span style="color: #7A3C00;">**НСДАП**</span> потерпела ещё одно сокрушительное поражение — на этот раз на местных выборах в Тюрингии. Результаты показывают, что партия потеряла почти четверть голосов по сравнению с предыдущими выборами в ландтаг. Хотя свою роль могла сыграть и низкая явка, эти и три других недавних местных выбора лишь укрепили растущее ощущение, что <span style="color: #7A3C00;">нацисты</span> достигли пика своей популярности и стремительно теряют поддержку. ?]{!</p>!}

{!<p class="other">!}[? if schleicher_time == 0 and chancellor == "Schleicher": Несмотря на свою отставку, Папен остаётся в гораздо большей физической близости к президенту, чем сам канцлер. По личной просьбе Гинденбурга он продолжает жить в апартаментах в здании Министерства внутренних дел — всего в нескольких шагах от покоев самого президента, — тогда как Шлейхер обитает в частной резиденции за много миль оттуда. Такое положение дел позволило Папену постоянно плести интриги, не привлекая внимания общественности. ?]{!</p>!}

{!<p class="other">!}[? if schleicher_time == 0 and chancellor == "Schleicher": Некогда близкий союзник, Оскар фон Гинденбург стал непримиримым врагом нового канцлера — по слухам, из-за бестактной шутки, которая смертельно ранила его гордость. В прусские времена подобные оскорбления могли закончиться дуэлью; на сей раз последствием может стать гибель Республики. Два члена камарильи теперь питают лютую ненависть к Шлейхеру и пытаются убедить президента пересмотреть своё решение о его назначении. ?]{!</p>!}

{!<p class="other">!}[? if schleicher_time == 0 and chancellor == "Schleicher": Вскоре после назначения Шлейхера, <span style="color: #0A3161;">западные</span> <span style="color: #C8102E;">союзники</span>, после затяжных переговоров на Женевской конференции по разоружению, в принципе признали право Германии на равенство в вооружениях. Практические условия этой уступки остаются неясными, но, по мнению Шлейхера, это открывает путь к созданию официального ополчения. ?]{!</p>!}

{!<p class="other">!}[? if schleicher_time == 1: В обращениях Шлейхера к нации красной нитью проходит центральная тема: «Создать рабочие места!». Он возобновил попытки переселить городских безработных в сельские поселения, созданные на землях обанкротившихся имений на малонаселённом Востоке. Хотя рейхстаг по-прежнему распущен и он не может издавать законы, Шлейхер публично выступил против предложенных Папеном изменений в системе страхования по безработице, позиционируя себя как противника и <span style="color: #C0A054;">капитализма</span>, и <span style="color: #c00000;">социализма</span>. Эта идеологическая неопределённость принесла ему прозвище «социальный генерал» — ярлык, который он с готовностью принял, заявляя, что это соответствует армейской традиции солидарности офицеров и солдат. ?]{!</p>!}

{!<p class="dnvp">!}[? if schleicher_time == 1 and hugenberg_dvp: Рост популярности <span style="color: #C0A054;">**ННП**</span> по результатам опросов сделал Дингельдея излишне самоуверенным: он безоговорочно поддержал сначала Папена, а затем и Шлейхера, и даже сформировал парламентскую фракцию с различными отколовшимися партиями, занимающими нишу между ННП и <span style="color: #3E88B3;">**НННП**</span>. Хотя этот шаг укрепил их влияние, он оттолкнул Гугенберга и <span style="color: #3E88B3;">**НННП**</span>, от которых они всё ещё зависят в рамках своего предвыборного союза. ?]{!</p>!}

{!<p class="other">!}[? if schleicher_time == 2: По какой-то странной причине фон Шлейхер уверился: [+ nsdap_chancellor +] не смог стать парламентским канцлером просто потому, что тот «в глубине души» не хотел этого поста. К [+ month : month +]ю, это подозрение превратилось в твёрдую уверенность; он неоднократно делился с журналистами и кабинетом мыслью: самопровозглашенный Фюрер просто не жаждет власти. Это убеждение приводит к тому, что Шлейхер переоценивает свои шансы заручиться поддержкой <span style="color: #7A3C00;">**НСДАП**</span> для своего кабинета — без [+ nsdap_chancellor +]а в качестве канцлера. ?]{!</p>!}

{!<p class="other">!}[? if schleicher_time == 2: Серьёзные электоральные потери <span style="color: #7A3C00;">**НСДАП**</span> на местных выборах ещё больше усилили разочарование избирателей, которые и привели это движение к успеху. Многие из тех, кто вступал в партию и жертвовал ей деньги в расчёте на плоды скорой победы, начинают отчаиваться и забирают свои пожертвования. Плата за вход на митинги, некогда бывшая основным источником дохода на местном уровне, рухнула, несмотря на значительное снижение цен. Провал попыток [+ nsdap_chancellor +]а заполучить пост канцлера или войти в правительство для конструктивного решения экономических проблем Германии вызвал ещё большее разочарование в движении. Однако <span style="color: #7A3C00;">нацистские</span> лидеры спешат пресекать любые утечки о разногласиях или слухи об упадке, не давая им дойти до общественности. ?]{!</p>!}

{!<p class="other">!}[? if schleicher_time == 3: Мировая экономика на подъёме, а вместе с ней продолжается ослабление <span style="color: #7A3C00;">**НСДАП**</span>. <span style="color: #000000;">Рес</span><span style="color: #DD0000;">публ</span><span style="color: #FFCC00;">иканская</span> полиция, ведущая наблюдение за <span style="color: #7A3C00;">**НСДАП**</span> в Мюнхене отметила явные признаки распада. Ежедневно происходят выходы из партии, членские взносы поступают нерегулярно, а исключения за задолженность становятся всё более частым явлением. Каждое отделение партии, по-видимому, в упадке. Что касается морального духа, в полицейском докладе отмечалось: «Среди многих членов партии распространено мнение, что пик прошел, а благоприятные возможности упущены». ?]{!</p>!}

{!<p class="other">!}[? if schleicher_time == 3: Шлейхер всё ещё цепляется за иллюзорную надежду, что ныне бессильный Штрассер сможет каким-то образом убедить [+ nsdap_chancellor +]а разрешить <span style="color: #7A3C00;">нацистам</span> войти в его кабинет — теперь, когда Штрассер вернулся из отпуска. Отсутствие Штрассера на публике встревожило [+ nsdap_leader +]а, который теперь опасается возможных закулисных заговоров с целью расколоть партию, учитывая рвение оставшихся сторонников Штрассера сделать именно это. В действительности же Штрассер лишь предупреждает бывшего канцлера Брюнинга: Папен договорился о тайной встрече с Гитлером — которая состоится через одну-две недели, — чтобы сговориться против их общего врага: Шлейхера. ?]{!</p>!}

{!<p class="other">!}[? if schleicher_time == 4 and nazi_funds <= 1: Финансовое положение <span style="color: #7A3C00;">**НСДАП**</span> становится всё более плачевным. Оборудование и материалы всё чаще закупаются в кредит, который и сам уже иссякает под бременем существующих долгов партии. Нарастает напряжение между <span style="color: #7A3C00;">.**СА**</span> и партийным руководством: как делить иссякающие пожертвования. Некоторым членам партии приходится попрошайничать на улицах или организовывать лотереи, чтобы наскрести денег. Ещё одни выборы — и партия может столкнуться с полномасштабным финансовым кризисом. ?]{!</p>!}

{!<p class="other">!}[? if schleicher_time == 4: Несмотря на обещание президенту Гинденбургу не критиковать публично своего фаворита, бывшего канцлера, Шлейхер поступил именно так в попытке дистанцироваться от крайне непопулярного Папена. Гинденбург, недовольный таким нарушением доверия, всё больше отдаляется от Шлейхера. Папен, со своей стороны, внешне почти не проявлял враждебности из-за своего смещения, тщательно скрывая обиду и жажду мести за маской радушия. Тем временем Гинденбург втайне уполномочил его быть своим секретным посредником для связи с [+ nsdap_leader +]ом. ?]{!</p>!}

{!<p class="other">!}[? if schleicher_time == 4 and not schleicher_public_works_fast: Гюнтер Гереке, энергичный специальный уполномоченный по общественным работам, разочаровался в канцлере после того, как его просьба об устранении бюрократических препон категорически отклонена. Его амбициозные проекты застопорились. Разочарованный Гереке поделился своим огорчением со своим близким другом, которым оказался не кто иной, как Оскар фон Гинденбург. ?]{!</p>!}

{!<p class="other">!}[? if schleicher_time == 4 and schleicher_public_works_fast: Гюнтер Гереке, энергичный специальный уполномоченный по общественным работам, добился ускорения своего проекта после того, как его канцлер одобрил его  просьба  вмешаться и устранить бюрократические препоны. [? if schleicher_spd_r >= 4: Это решение продиктовано стремлением Шлейхера выполнить своё обещание профсоюзам и <span style="color: #c00000;">**СДПГ**</span>, а также оказать дополнительное давление на <span style="color: #7A3C00;">**НСДАП**</span>, пока их электорат не вернулся к работе. ?][? if schleicher_spd_r < 4 and workers_nsdap_normalized + workers_kpd_normalized >= 55: Этот шаг мотивирован стремлением Шлейхера выполнить обещание профсоюзам, а также сдержать рост голосов за <span style="color: #700000;">**коммунистов**</span> среди радикально настроенных рабочих. ?][? if schleicher_spd_r < 4 and workers_nsdap_normalized + workers_kpd_normalized < 55 and unemployed >= 42: Катастрофическое состояние немецкой экономики превратило перевооружение в несбыточную мечту, однако Шлейхер стремится вернуть экономику в нормальное русло. ?] ?]{!</p>!}

{!<p class="other">!}[? if (papen_time or chancellor == "Schleicher") and year == 1933 and month == 1 and week == 1: Началась кампания по выборам в ландтаг в крошечном Свободном государстве Липпе; <span style="color: #7A3C00;">нацисты</span> вкладывают значительные ресурсы, чтобы склонить на свою сторону всего сто тысяч избирателей. Однако, несмотря на его скромные размеры, победа здесь может развеять растущее убеждение, что <span style="color: #7A3C00;">нацисты</span> находятся на грани катастрофического упадка. ?]{!</p>!}

{!<p class="other">!}[? if schleicher_time == 5: На частном ужине с журналистами канцлер фон Шлейхер неоднократно выражал уверенность: Фюрер <span style="color: #7A3C00;">нацистов</span> в конечном счёте согласится воздерживаться от вотума недоверия его кабинету, хотя [+ nsdap_leader +] и заявлял о курсе «всё или ничего». И это притом что Шлейхер ясно дал понять: при необходимости он распустит рейхстаг — шаг, который, по его мнению, будет стоить <span style="color: #7A3C00;">нацистам</span> дополнительных мест (хотя он и стремится избежать этого шага, опасаясь, что <span style="color: #700000;">**коммунисты**</span> больше всех выиграют от их краха). «Они скоро будут есть у меня с руки», — таковы точные слова канцлера в тот вечер. Однако Шлейхер не понимает, что [+ nsdap_leader +] — не обычный политик. Он не станет рационально и осмотрительно реагировать ни на разрыв со Штрассером, ни на провалы <span style="color: #7A3C00;">**НСДАП**</span> на выборах. Он верит: сама судьба на его стороне. ?]{!</p>!}

{!<p class="other">!}[? if schleicher_time == 5: Канцлер фон Шлейхер и его пресс-секретарь намеренно допустили «утечку» планов назначить Штрассера вице-канцлером, министром внутренних дел и министром-президентом Пруссии, а лидера профсоюзов от <span style="color: #000000;">Партии Центра</span> Штегервальда — министром труда. По слухам, посты министров сельского хозяйства и экономики зарезервированы для самого Гугенберга. Весьма вероятно, что этот блеф — попытка оказать давление на <span style="color: #7A3C00;">**НСДАП**</span>, чтобы та отказалась от своей политики тотальной оппозиции, иначе она рискует оказаться полностью отстранённой от власти. ?]{!</p>!}

{!<p class="dnvp">!}[? if schleicher_time == 5 and hugenberg_dvp: С заносчивостью Дингельдея, подогреваемой <span style="color: #C0A054;">**ННП**</span>, рост популярности которой в опросах вывел её в лидеры «умеренного» правого крыла. Гугенберга всё больше раздражает их независимость, и он стремится разорвать избирательный союз в случае назначения новых выборов. Хотя <span style="color: #C0A054;">**ННП**</span> всё ещё надеется возобновить союз, она начинает изучать возможность договорённости с <span style="color: #D3C24D;">**[+ ddp_name +]**</span> и буржуазными партиями в качестве страховки от почти неминуемого разгрома, если Гугенберг разорвёт связи. Тем временем DNV (Немецкий национальный союз), беспартийная организация, стремящаяся объединить немецкий средний класс, начинает восстанавливать отношения с либералами, уже заручившись поддержкой нелиберальных правых в лице таких политиков, как Тревиранус. ?]{!</p>!}

{!<p class="other">!}[? if schleicher_time == 6: Блеф фон Шлейхера — предложение создать кабинет с участием и Штегервальда, и Гугенберга — полностью провалился. <span style="color: #000000;">Партия Центра</span> публично исключила возможность работы Штегервальда бок о бок с Гугенбергом, известным врагом профсоюзов. Более того, утечка информации о встрече президента со Штрассером привела к окончательному разрыву между лидером <span style="color: #7A3C00;">нацистов</span> и Шлейхером. Это похоронило всякую надежду: Штрассер не сможет убедить Гитлера поддержать кабинет с участием Шлейхера. Его противоречивая тактика и неосторожные высказывания лишь усилили недоверие и усугубили его политическую изоляцию. Теперь он осуждает попытки отложить выборы, хотя всего неделю назад сам же поддерживал эту идею. ?]{!</p>!}

{!<p class="other">!}[? if schleicher_time == 6: Поскольку прогресс застопорился практически во всех сферах, Шлейхер попытался сместить фокус, вновь подняв в обществе вопрос о перевооружении. Он объявил о плане в течение года сформировать ополчение-милицию, а также подтвердил намерение вооружить рейхсвер тяжёлой техникой и ввести всеобщую воинскую повинность. Однако эффект от этого предполагаемого пиар-триумфа оказался минимальным, поскольку всё внимание общественности приковано к политическим неудачам Шлейхера. ?]{!</p>!}

{!<p class="dnvp">!}[? if schleicher_time == 6: Не сумев добиться от канцлера уступок по превращению Германии в диктатуру, радикальные элементы немецких консерваторов заставили его перейти к тотальной оппозиции Шлейхеру. Опубликована резолюция в резких выражениях, обвиняющая его в «колебаниях» в готовности «реформировать» конституцию. Кроме того, его инициатива по воссозданию крестьянских хозяйств на обанкротившихся восточных поместьях разгневала консервативные элиты. На фоне приближающегося вотума недоверия дело вполне может дойти до противостояния Шлейхера и всей палаты. ?]{!</p>!}

{!<p class="other">!}[? if schleicher_time == 7: Рубикон пройден, и Шлейхер оказался на другом берегу. (Имейте в виду, что все последующие события носят сугубо гипотетический характер) ?]{!</p>!}

{!<p class="other">!}[? if schleicher_time == 8: В <span style="color: #7A3C00;">нацистской</span> партии царит полный хаос, а <span style="color: #7A3C00;">**СА**</span> — самая мятежная её фракция — пала первой. Эрнст Рём[? if rohm_explode: , ныне освобождённый из тюрьмы ?], разочаровавшись в курсе [+ nsdap_leader +]а, в последние дни тайно плёл интриги. ?]{!</p>!}

{!<p class="other">!}[? if year = 1933 and month = 3 and not ((spd_in_government and foreign_minister_party = "SPD") or (austria_relation >= 1)) and (week == 1 or not rubicon): Дольфус злоупотребил своими полномочиями, предоставленными ему «Законом о военных полномочиях», чтобы подавить забастовку железнодорожников, что привело к отставке всех трёх председателей парламента во время решающего голосования. Этот кризис предоставил Дольфусу прекрасную возможность упразднить парламентскую систему и ограничить демократические права, такие как свобода прессы и публичных протестов. Ещё одна демократия пала под натиском авторитаризма. ?]{!</p>!}

{!<p class="other">!}[? if year = 1933 and month = 5 and (week == 4 or not rubicon) : <span style="color: #7A3C00;">Австрофашистская</span> диктатура Дольфуса запретила <span style="color: #700000;">австрийских коммунистов</span> и военизированное крыло <span style="color: #C8102E;">австрийских социал-демократов</span>, <span style="color: #C8102E;">Республиканский шуцбунд</span>. Он также учредил <span style="color: #7A3C00;">Отечественный фронт</span> — партию, продвигавшую ультраправую <span style="color: #7A3C00;">фашистскую</span> и корпоративную идеологию. ?]{!</p>!}

{!<p class="other">!}[? if year = 1933 and month = 11 and (week == 3 or not rubicon): <span style="color: #EF1C27;">Испанские социалисты</span> и <span style="color: #E25822;">Левые республиканцы</span> потерпели сокрушительное поражение от правых сил в лице <span style="color: #303180;">**СЭДА**</span> и всё более правых <span style="color: #A871A8;">радикалов</span>. ?]{!</p>!}

{!<p class="other">!}[? if year = 1934 and month = 2 and (week == 2 or not rubicon) and not austrian_parliament_seen: Гражданская война в Австрии, начавшаяся и закончившаяся в течение трёх дней, велась между <span style="color: #C8102E;">Республиканским шуцбундом</span> и австрийским <span style="color: #7A3C00;">австрофашистским</span> режимом и завершилась поражением <span style="color: #C8102E;">социалистов</span> за границей. Восстание спровоцировано попытками подавить остатки <span style="color: #C8102E;">австрийских социал-демократов</span> и их военизированное крыло. Однако плохо скоординированное и ослабленное движение стремительно подавлено армией. Возможно, всё пошло бы совсем иначе, если бы они взялись за оружие раньше. ?]{!</p>!}

{!</div>!}

