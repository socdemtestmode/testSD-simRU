        Q.flavour_55_trigger_shown = 1;
    }
}
// non-dingeldey schemes to remove curtius, wirth, dietrich
if (Q.total_bruning_time == 9 && !Q.in_center_right_coalition && !Q.in_right_coalition && !Q.spd_toleration_right && (Q.dvp_leader != "Dingeldey" && Q.dvp_leader != "Scholz") && !Q.dvp_defect && !Q.lvp_formed && Q.dvp_exist && Q.chancellor == "Brüning" && Q.time !== Q.last_time_updated) {
    Q.flavour_56_trigger += 1; 
    if (Q.flavour_56_trigger == 1 && !Q.flavour_56_trigger_shown) {
        Q.flavour_56_trigger_time = Q.time;
