}
// dvp party conflict post 2nd bruning, pt 3
if (Q.dvp_leader == "Dingeldey" && !Q.lvp_formed && Q.time == Q.flavour_48_trigger_time + 1 && !Q.cvp_formed && Q.time !== Q.last_time_updated) {
