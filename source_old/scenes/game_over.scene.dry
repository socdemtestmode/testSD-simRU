[? if not achievement_victory_for_the_republic: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/victory_for_the_republic.png" alt="Иконка «Победа республики»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Sieg für die Republik</div> <div class="achievement_subtitle"> - победите в гражданской войне.</div> </div> {!</td>!} {!</tr>!}  ?] [? if not achievement_bollwerk_der_demokratie: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/bollwerk_der_demokratie.png" alt="Иконка «Bollwerk»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Bollwerk der Demokratie</div> <div class="achievement_subtitle"> - дайте отпор Прусскому путчу и победите.</div> </div> {!</td>!} {!</tr>!}  ?]

