[? if game_achievement_volksfront: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/volksfront.png" alt="Значок Volksfront" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Volksfront</div> <div class="achievement_subtitle"> — сформируйте правительство из <span style="color: #c00000; font-weight: bold;">СДПГ</span>, <span style="color: #700000; font-weight: bold;">КПГ</span> и <span style="color: #000000; font-weight: bold;">Партии Центра</span>.</div> </div> {!</td>!} {!</tr>!}  ?]

