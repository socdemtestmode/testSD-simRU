[? if game_achievement_alt_aber_gold: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}     <img src="img/achievement/alt_aber_gold.png" alt="Alt Aber Gold Icon" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Alt, Aber Gold</div> <div class="achievement_subtitle"> - на первых выборах в Саксонии <span style="color: #fe9e00;">**СДПГ(с)**</span> набирает более 5% голосов. </div>{!</td>!} {!</tr>!}  ?]


