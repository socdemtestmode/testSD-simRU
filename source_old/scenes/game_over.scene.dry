[? if game_achievement_hirschfeld: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/hirschfeld.png" alt="Значок Хиршфельда" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Hirschfeld</div> <div class="achievement_subtitle"> - проведите реформы в защиту прав <span style="color: red;">го</span><span style="color: orange;">м</span><span style="color: yellow;">о</span><span style="color: green;">се</span><span style="color: blue;">ксу</span><span style="color: purple;">алов</span> (ЛГБТ — экстремистское международное движение, запрещенное Верховным Судом России).</div> </div> {!</td>!} {!</tr>!}  ?]

