[? if not achievement_heidelberger_programm: {!<tr>!}   {!<td style="width: 60px; height: 100px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/heidelberger_programm.png" alt="Значок «Гейдельбергская программа»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(97, 24, 19, 0.2);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Heidelberger Programm</div> <div class="achievement_subtitle"> - достигните целей Гейдельбергской программы <span style="color: #c00000; font-weight: bold;">СДПГ</span>: рост социального обеспечения, судебная реформа, права женщин на рабочем месте и в семье, прогрессивное налогообложение, производственные советы на фабриках и создание <span style="color: #001489;">Европейского</span> <span style="color: #FFDD00;">союза</span>.</div> </div> {!</td>!} {!</tr>!}  ?]

