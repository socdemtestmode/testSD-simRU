[? if not achievement_soziale_politik_fur_dich: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/soziale_politik_fur_dich.png" alt="Значок «Социальная политика для тебя»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(97, 24, 19, 0.2);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Soziale Politik für Dich</div> <div class="achievement_subtitle"> — четыре года подряд оставаться у власти и ни разу не провалить «Бремя власти». </div> {!</td>!} {!</tr>!}  ?]

[? if not achievement_polizeistaat: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/polizeistaat.png" alt="Значок Polizeistaat" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Polizeistaat</div> <div class="achievement_subtitle"> — непрерывно в течение целого года удерживать контроль прусской полиции над улицами на уровне 50% и более. </div> {!</td>!} {!</tr>!}  ?]

[? if not achievement_wahre_bundesrepublik: {!<tr>!}   {!<td style="width: 60px; height: 100px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/wahre_bundesrepublik.png" alt="Иконка 'Истинная Федеративная Республика'" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(10, 24, 97, 0.25);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Wahre Bundesrepublik</div> <div class="achievement_subtitle"> - добейтесь избрания Хойса президентом, а Аденауэра — канцлером, при этом Аденауэр должен возглавлять <span style='color: #000000; font-weight: bold;'>ХНП</span>, а <span style='color: #FFCC00; font-weight: bold;'>ЛНП</span> сформирована. Все конституционные реформы приняты, <span style='color: #7A3C00; font-weight: bold;'>НСДАП</span> и <span style='color: #700000; font-weight: bold;'>КПГ</span> не преодолели 5% барьер, Шумахер доступен в качестве советника, а в <span style='color: #c00000; font-weight: bold;'>СДПГ</span> доминируют реформисты. </div> {!</td>!} {!</tr>!}  ?]

[? if not achievement_der_beliebte_prasident: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/der_beliebte_prasident.png" alt="Der beliebte Präsident Иконка" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Der beliebte Präsident</div> <div class="achievement_subtitle"> - Отто Браун получил 60% или более голосов в первом туре президентских выборов 1932 года. </div> {!</td>!} {!</tr>!}  ?]

[? if not achievement_notwendigkeit: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/notwendigkeit.png" alt="Иконка «Необходимость»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Notwendigkeit</div> <div class="achievement_subtitle"> — набирайте на каждых последующих выборах больше голосов, чем на предыдущих. </div> {!</td>!} {!</tr>!}  ?]

[? if not achievement_comeback: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/comeback.gif" alt="Иконка «Возвращение»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Comeback</div> <div class="achievement_subtitle"> — Ваше правительство отправил в отставку Гинденбург, но на досрочных выборах вы сформировали правительство большинства от <span style="color: #c00000; font-weight: bold;">СДПГ</span>. </div> {!</td>!} {!</tr>!}  ?]

[? if not achievement_grosse_weimarer_koalition: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/grosse_weimarer_koalition.png" alt="GroÃŸe Weimarer Koalition — значок" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Große Weimarer Koalition</div> <div class="achievement_subtitle"> - сформируйте Веймарскую коалицию, где Кайзер возглавляет <span style="color: #000000;">Партию Центра</span>/<span style="color: #000000; font-weight: bold;">ХНП</span>, а Хойс — <span style="color: #FFCC00; font-weight: bold;">ЛНП</span>. </div> {!</td>!} {!</tr>!}  ?]

