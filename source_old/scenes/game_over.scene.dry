[? if achievement_sozialchristliche_koalition: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/sozialchristliche_koalition.png" alt="Sozialchristliche Koalition Иконка" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Sozialchristliche Koalition</div> <div class="achievement_subtitle"> — сформировать <span style="color: #c00000;">социал</span>-<span style="color: #000000;">христианскую</span> коалицию. </div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_fur_gott_und_kaiser: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/fur_gott_und_kaiser.png" alt="Иконка «За Бога и Кайзера»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Für Gott und Kaiser</div> <div class="achievement_subtitle"> - Якоб Кайзер возглавляет <span style="color: #000000; font-weight: bold;">ХНП</span>. </div> </div> {!</td>!} {!</tr>!}  ?]

