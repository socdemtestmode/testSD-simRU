[? if achievement_deutsche_tory_demokratie: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/deutsche_tory_demokratie.png" alt="Значок Deutsche Tory Demokratie" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(97, 24, 19, 0.2);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Deutsche Tory Demokratie</div> <div class="achievement_subtitle"> - добейтесь того, чтобы партия <span style="color: #3E88B3; font-weight: bold;">НННП</span> под руководством Тревирануса с курсом «демократии тори» стала второй по величине партией в рейхстаге. </div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_schwarze_null: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/schwarze_null.png" alt="Иконка Schwarze Null" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Schwarze Null</div> <div class="achievement_subtitle"> — проведите 4 национализации или полностью реализуйте план ВТБ, не позволяя бюджету опуститься ниже 0. </div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_historischer_kompromiss: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/historischer_kompromiss.png" alt="Иконка Historischer Kompromiss" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(97, 24, 19, 0.2);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Historischer Kompromiss</div> <div class="achievement_subtitle"> - сформируйте <span style="color: #c00000;">социал</span>-<span style="color: #000000;">христианскую</span> коалицию с <i>настоящей</i> <span style="color: #000000; font-weight: bold;">ХНП</span>. </div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_frahm_und_brandt: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/frahm_und_brandt.png" alt="Значок «Historischer Kompromiss»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(10, 24, 97, 0.25);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Frahm und Brandt</div> <div class="achievement_subtitle"> - сформируйте <span style="color: #c00000;">социал</span>-<span style="color: #000000;">христианскую</span> коалицию с <i>настоящей</i> <span style="color: #000000; font-weight: bold;">ХНП</span>, при этом Левые должны остаться в составе <span style="color: #c00000; font-weight: bold;">СДПГ</span>. </div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_neue_arbeiterpartei: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/neue_arbeiterpartei.png" alt="Значок Neue Arbeiterpartei" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Neue Arbeiterpartei</div> <div class="achievement_subtitle"> - <span style="color: #3E88B3; font-weight: bold;">НННП</span> Ламбаха занимает 20% мест в рейхстаге и относительное большинство среди рабочих. </div> </div> {!</td>!} {!</tr>!}  ?]

