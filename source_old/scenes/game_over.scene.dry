[? if achievement_das_grosste_aller_zelte: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/das_grosste_aller_zelte.png" alt="Значок «Величайший из всех шатров»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(97, 24, 19, 0.2);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Das GrÃ¶ÃŸte Aller Zelte</div> <div class="achievement_subtitle"> - усилить фракции неоревизионистов и социал-патриотов, не допуская откола фракций. </div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_getrennt_marschieren_vereint_schlagen: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/getrennt_marschieren_vereint_schlagen.png" alt="Иконка «Маршировать раздельно, бить вместе»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Getrennt marschieren, vereint schlagen</div> <div class="achievement_subtitle"> — заставьте Шлейхера снять запрет на деятельность <span style="color: #700000; font-weight: bold;">КПГ</span>. </div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_nach_schleicher_wir: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/nach_schleicher_wir.png" alt="Иконка «Nach Schleicher, wir!»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(97, 24, 19, 0.2);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Nach Schleicher, wir!</div> <div class="achievement_subtitle"> — добейтесь, чтобы кандидат от <span style="color: #700000; font-weight: bold;">КПГ</span> победил на президентских выборах 1934 года, перейдя Рубикон. </div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_sozialdemokratische_blockpartei: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/sozialdemokratische_blockpartei.png" alt="Иконка «Sozialdemokratische Blockpartei»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Sozialdemokratische Blockpartei</div> <div class="achievement_subtitle"> - <span style="color: #c00000; font-weight: bold">СДПГ</span> «приручена» в состав <span style="color: #BFC8CC; font-weight: bold;">ФНЕГ</span>. </div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_aller_guten_dinge_sind_zwei: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/aller_guten_dinge_sind_zwei.png" alt="Значок «Хорошего по два»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Aller guten Dinge sind zwei</div> <div class="achievement_subtitle"> - Яррес избран президентом. </div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_wer_braucht_schon_freunde: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/wer_braucht_schon_freunde.png" alt="Wer braucht schon Freunde? Иконка" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(91, 154, 141, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Wer braucht schon Freunde?</div> <div class="achievement_subtitle"> — у вас враждебные отношения со всеми партиями. </div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_heuchelei: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/heuchelei.png" alt="Значок «Лицемерие»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Heuchelei</div> <div class="achievement_subtitle"> - преследуйте Эрнста Рёма за <span style="color: red;">го</span><span style="color: orange;">мо</span><span style="color: yellow;">сек</span><span style="color: green;">су</span><span style="color: blue;">аль</span><span style="color: purple;">ность</span>, а затем легализуйте её. </div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_warum_kampfen_wir_immer_noch: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/warum_kampfen_wir_immer_noch.png" alt="Warum kÃ¤mpfen wir immer noch? Значок" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Warum kämpfen wir immer noch?</div> <div class="achievement_subtitle"> - <span style="color: #D3C24D; font-weight: bold;">НДП</span> и <span style="color: #C0A054; font-weight: bold;">ННП</span> разделяют одну идеологию, но <span style="color: #FFCC00; font-weight: bold;">ЛНП</span> так и не была сформирована. </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_leere_parolen: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/leere_parolen.png" alt="Leere Parolen Иконка" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(97, 24, 19, 0.2);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Leere Parolen</div> <div class="achievement_subtitle"> — править во главе однопартийного большинства <span style="color: #c00000; font-weight: bold;">СДПГ</span> и провалить 10 или более правительственных обязательств. </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_weltfrieden: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/weltfrieden.png" alt="Weltfrieden — значок" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Weltfrieden</div> <div class="achievement_subtitle"> - заключите договор о создании <span style='color: #001489;'>Европейского</span> <span style='color: #FFDD00;'>союза</span>, ни разу не вступив в переговоры. </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_blauer_winter: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/blauer_winter.png" alt="Иконка «Blauer Winter»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Blauer Winter</div> <div class="achievement_subtitle"> - Густав Винтер набирает 1% или более голосов на президентских выборах 1932 года. </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_ampelkoalition: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/ampelkoalition.png" alt="Значок «Светофорная коалиция»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Ampelkoalition</div> <div class="achievement_subtitle"> — в Баварии сформирована <span style="color: #c00000;">Свето</span><span style="color: #FFCC00;">фор</span><span style="color: #38C538;">ная</span> коалиция. </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_staatspolitiker: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/staatspolitiker.png" alt="Иконка «Государственный деятель»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Staatspolitiker</div> <div class="achievement_subtitle"> - <span style="color: #c00000; font-weight: bold;">СДПГ</span> представлена в правительстве каждой земли. </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_soziale_politik_fur_dich: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/soziale_politik_fur_dich.png" alt="Значок «Soziale Politik für Dich»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(97, 24, 19, 0.2);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Soziale Politik fÃ¼r Dich</div> <div class="achievement_subtitle"> — продержаться у власти четыре года подряд и ни разу не провалить правительственное испытание. </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_polizeistaat: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/polizeistaat.png" alt="Значок «Polizeistaat»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Polizeistaat</div> <div class="achievement_subtitle"> — в течение целого года непрерывно поддерживать контроль прусской полиции на улицах на уровне 50% и более. </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_wahre_bundesrepublik: {!<tr>!}   {!<td style="width: 60px; height: 100px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/wahre_bundesrepublik.png" alt="Иконка «Истинная Федеративная Республика»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(10, 24, 97, 0.25);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Wahre Bundesrepublik</div> <div class="achievement_subtitle"> - добейтесь избрания Хойса президентом, а Аденауэра — канцлером, при этом Аденауэр должен возглавлять <span style='color: #000000; font-weight: bold;'>ХНП</span>, а <span style='color: #FFCC00; font-weight: bold;'>ЛНП</span> должна быть сформирована. Все конституционные реформы должны быть приняты, <span style='color: #7A3C00; font-weight: bold;'>НСДАП</span> и <span style='color: #700000; font-weight: bold;'>КПГ</span> не должны преодолеть 5-процентный барьер, Шумахер должен быть доступен в качестве советника, а в <span style='color: #c00000; font-weight: bold;'>СДПГ</span> должны доминировать реформисты. </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_der_beliebte_prasident: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/der_beliebte_prasident.png" alt="Der beliebte PrÃ¤sident Иконка" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Der beliebte PrÃ¤sident</div> <div class="achievement_subtitle"> — Отто Браун получил 60% или более голосов в первом туре президентских выборов 1932 года. </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_notwendigkeit: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/notwendigkeit.png" alt="Notwendigkeit Иконка" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Notwendigkeit</div> <div class="achievement_subtitle"> — набирайте на каждых выборах больше голосов, чем на предыдущих. </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_comeback: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/comeback.gif" alt="Иконка «Возвращение»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Камбэк</div> <div class="achievement_subtitle"> – получите отставку от Гинденбурга, а затем вернитесь с правительством большинства <span style="color: #c00000; font-weight: bold;">СДПГ</span>. </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_grosse_weimarer_koalition: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/grosse_weimarer_koalition.png" alt="Иконка Große Weimarer Koalition" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Große Weimarer Koalition</div> <div class="achievement_subtitle"> - сформируйте Веймарскую коалицию, где Кайзер возглавляет <span style="color: #000000;">Партию Центра</span>/<span style="color: #000000; font-weight: bold;">ХНП</span>, а Хойс — <span style="color: #FFCC00; font-weight: bold;">ЛНП</span>. </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_das_blatt_hat_sich_gewendet: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/das_blatt_hat_sich_gewendet.png" alt="Иконка Das Blatt hat sich gewendet" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Das Blatt hat sich gewendet</div> <div class="achievement_subtitle"> - одна из отколовшихся от <span style="color: #3E88B3; font-weight: bold;">НННП</span> партий занимает больше мест в рейхстаге, чем сама партия. </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_modeerscheinung: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/modeerscheinung.png" alt="Значок «Modeerscheinung»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Modeerscheinung</div> <div class="achievement_subtitle"> — <span style="color: #7A3C00; font-weight: bold;">НСДАП</span> на последних выборах набрала меньше голосов, чем в мае 1928 года. </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_catastrophepolitik: {!<tr>!}   {!<td style="width: 60px; height: 75px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/catastrophepolitik.png" alt="Значок «Catastrophepolitik»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(10, 24, 97, 0.25);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Catastrophepolitik</div> <div class="achievement_subtitle"> - сформировать однопартийный кабинет <span style="color: #c00000; font-weight: bold;">СДПГ</span> после 5 или более выборов, при условии, что <span style="color: #c00000; font-weight: bold;">СДПГ</span> ни разу не воздерживалась от вотума недоверия и не входила в правительство. </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_volkspartei_fur_das_volk: {!<tr>!}   {!<td style="width: 60px; height: 75px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/volkspartei_fur_das_volk.png" alt="Иконка «Народная партия (Volkspartei) für das Volk»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Volkspartei für das Volk</div> <div class="achievement_subtitle"> - <span style="color: #c00000; font-weight: bold;">СДПГ</span> — Народная партия, и достигнуто максимальное число партий со словами «Народная партия» в названии. </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_mit_allen_notwendigen_stimmen: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/mit_allen_notwendigen_stimmen.png" alt="Иконка «Mit allen notwendigen Stimmen»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Mit allen notwendigen Stimmen</div> <div class="achievement_subtitle"> - правьте, опираясь на однопартийное большинство <span style="color: #c00000; font-weight: bold;">СДПГ</span>, при полностью демилитаризованном Рейхсбаннер. </div> {!</td>!} {!</tr>!}  ?]


[? if achievement_wir_schaffen_das: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/wir_schaffen_das.png" alt="Wir schaffen das! Иконка" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Wir schaffen das!</div> <div class="achievement_subtitle"> - добейтесь уровня безработицы ниже 15% и профицита бюджета, не прибегая к помощи иностранных держав. </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_blockparteien_parade: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/blockparteien_parade.png" alt="Blockparteien-Parade Иконка" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(97, 24, 19, 0.2);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Blockparteien-Parade</div> <div class="achievement_subtitle"> - во главе каждой партии стоит её самый дружелюбный или «демократический» лидер. </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_der_arbeiterstaat: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/der_arbeiterstaat.png" alt="Иконка «Рабочее государство»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(97, 24, 19, 0.2);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Der Arbeiterstaat</div> <div class="achievement_subtitle"> — во главе каждой партии стоит её самый прорабочий лидер. </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_soziale_marktwirtschaft: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}     <img src="img/achievement/soziale_marktwirtschaft.png" alt="Soziale Marktwirtschaft Icon" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(91, 154, 141, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Soziale Marktwirtschaft</div> <div class="achievement_subtitle"> — уровень безработицы снижен на 10% или более при канцлере Брюнинге. </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_gegen_papen_hitler_thalmann: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/gegen_papen_hitler_thalmann.png" alt="Иконка «Против Папена, Гитлера, Тельмана»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(97, 24, 19, 0.2);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Gegen Papen, Hitler, Thälmann</div> <div class="achievement_subtitle"> — довести <span style="color: #7A3C00;">Гитлера</span> до самоубийства, Шлейхер заключил в тюрьму <span style="color: #700000;">Тельмана</span> — а вы победили <span style="color: #808080;">Папена</span> в гражданской войне. </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_wels: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/wels.png" alt="Иконка Отто Вельса" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(97, 24, 19, 0.2);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Wels' wilder Ritt</div> <div class="achievement_subtitle"> - изберите Отто Вельса президентом. </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_kommunistische_alternative: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/kommunistische_alternative.png" alt="Значок «Коммунистическая альтернатива»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Kommunistische Alternative</div> <div class="achievement_subtitle"> — рейтинг <span style="color: #9B0000; font-weight: bold;">СРПГ</span> по опросам выше, чем у <span style="color: #700000; font-weight: bold;">КПГ</span>. </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_die_rote_republik: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/die_rote_republik.png" alt="Иконка Die Rote Republik" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Die Rote Republik</div> <div class="achievement_subtitle"> — <span style="color: #c00000; font-weight: bold;">СДПГ</span> контролирует правительство, посты президента и канцлера, а также возглавляет Пруссию. </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_seeheimer: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/seeheimer.png" alt="Иконка Seeheimer" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(10, 24, 97, 0.25);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Seeheimer</div> <div class="achievement_subtitle"> — сформируйте однопартийное правительство большинства из <span style="color: #c00000; font-weight: bold;">СДПГ</span> при поддержке рабочих менее 10%. </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_champagner_sozialisten: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/champagner_sozialisten.png" alt="Иконка «Champagner-Sozialisten»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Champagner-Sozialisten</div> <div class="achievement_subtitle"> — получите больше поддержки среди старого среднего класса (не менее 40%), чем среди рабочих. </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_stabile_demokratie: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/stabile_demokratie.png" alt="Иконка «Stabile Demokratie»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Stabile Demokratie</div> <div class="achievement_subtitle"> — добейтесь большинства одновременно и для Веймарской коалиции, и для правоцентристской коалиции. </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_neue_geschaftsfuhrung: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/neue_geschaftsfuhrung.png" alt="Иконка Neue Geschäftsführung" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Neue Geschäftsführung</div> <div class="achievement_subtitle"> - кандидат от <span style="color: #c00000; font-weight: bold;">СДПГ</span> побеждает на президентских выборах 1932 года, воздерживаясь при этом от вотума недоверия Брюнингу. </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_rotes_bayern: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/rotes_bayern.png" alt="Иконка Rotes Bayern" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(97, 24, 19, 0.2);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Rotes Bayern</div> <div class="achievement_subtitle"> - сформировать в Баварии правительство большинства, состоящее только из <span style="color: #c00000; font-weight: bold;">СДПГ</span>. </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_1919_geracht: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/1919_geracht.png" alt="Значок 1919 Gerächt" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(97, 24, 19, 0.2);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">1919 Gerächt</div> <div class="achievement_subtitle"> — получите концовку «Спартак восстаёт вновь». </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_nach_der_spd_wir: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/nach_der_spd_wir.png" alt="Значок Nach der СДПГ wir" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(97, 24, 19, 0.2);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Nach der СДПГ, wir!</div> <div class="achievement_subtitle"> — получите концовку «Авангард берёт штурвал». </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_eurokommunismus: {!<tr>!}   {!<td style="width: 60px; height: 78px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/eurokommunismus.png" alt="Значок еврокоммунизма" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(10, 24, 97, 0.25);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Eurokommunismus</div> <div class="achievement_subtitle"> - к концу игры <span style="color: #700000; font-weight: bold;">КПГ</span> входит в состав национального правительства и правительств всех земель, все требования <span style="color: #700000; font-weight: bold;">КПГ</span> выполнены, и достигнута либерально-демократическая концовка. </div> {!</td>!}</span> победы. </div> {!</tr>!}  ?]

[? if achievement_kriegswirtschaft: {!<tr>!}   {!<td style="width: 60px; height: 78px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/kriegswirtschaft.png" alt="Значок Kriegswirtschaft" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(97, 24, 19, 0.2);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Kriegswirtschaft</div> <div class="achievement_subtitle"> - максимально повысить тарифы, иметь в рейхсвере не менее 200 тысяч человек, удерживать безработицу на уровне ниже 15% и добиться профицита бюджета. </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_sechs_sieben: {!<tr>!}   {!<td style="width: 60px; height: 78px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/sechs_sieben.png" alt="Значок Sechs Sieben" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(10, 24, 97, 0.25);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Sechs Sieben</div> <div class="achievement_subtitle"> - <span style='color: #c00000; font-weight: bold;'>СДПГ</span> получает не менее 67% голосов и мест в рейхстаге и правит в составе <span style="color: #c00000;">кетчупно</span>-<span style="color: #D3C24D;">горчичной</span> коалиции. </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_er_ist_wieder_da: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/er_ist_wieder_da.png" alt="Иконка Er ist wieder da" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(91, 154, 141, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Er ist wieder da</div> <div class="achievement_subtitle"> — добейтесь, чтобы <span style="color: #7A3C00;">Гитлер</span> был назначен канцлером дважды. </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_abgrundlaufer: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/abgrundlaufer.png" alt="Иконка Abgrundläufer" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(10, 24, 97, 0.25);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Abgrundläufer</div> <div class="achievement_subtitle"> — успешно потребовать от Шлейхера две уступки и не допустить <span style="color: #BFC8CC;">**ФНЕГ**</span> победы. </div>{!</td>!} {!</tr>!}  ?]

[? if achievement_bruning_uber_alles: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}     <img src="img/achievement/bruning_uber_alles.png" alt="Brüning Uber Alles Icon" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(91, 154, 141, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Brüning Uber Alles</div> <div class="achievement_subtitle"> — Генрих Брюнинг — президент, канцлер и министр-президент Пруссии. </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_der_aufstieg_skywalkers: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}     <img src="img/achievement/der_aufstieg_skywalkers.png" alt="Der Aufstieg Skywalkers Icon" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Der Aufstieg Skywalkers</div> <div class="achievement_subtitle"> — победите <span style="color: #7A3C00;">Гитлера</span> в гражданской войне после того, как он вернётся из мёртвых. </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_kulturkampf: {!<tr>!}   {!<td style="width: 60px; height: 78px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/kulturkampf.png" alt="Значок Kulturkampf" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Kulturkampf</div> <div class="achievement_subtitle"> - проведите все реформы о правах женщин и <span style="color: red;">го</span><span style="color: orange;">мо</span><span style="color: yellow;">се</span><span style="color: green;">кс</span><span style="color: blue;">уа</span><span style="color: purple;">лов</span>, секуляризуйте образование и сформируйте <span style="color: #c00000;">социал</span>-<span style="color: #D3C24D;">либеральную</span> коалицию. </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_mr_breitscheid: {!<tr>!}   {!<td style="width: 60px; height: 78px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}     <img src="img/achievement/mr_breitscheid.png" alt="Mr Breitscheid Icon" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Because I'm Mr. Breit-scheid</div> <div class="achievement_subtitle"> - к концу игры Брайтшайд становится канцлером, <span style="color: #FFC0C0;">Картель Левых</span> побеждает во Франции, вопрос репараций решен, Австрия остается демократической, а радиостанция профинансирована. </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_alt_aber_gold: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}     <img src="img/achievement/alt_aber_gold.png" alt="Alt Aber Gold Icon" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Alt, Aber Gold</div> <div class="achievement_subtitle"> - на первых выборах в Саксонии <span style="color: #fe9e00;">**СДПГ(с)**</span> набирает более 5% голосов. </div>{!</td>!} {!</tr>!}  ?]

[? if achievement_kleber_der_partei: {!<tr>!}   {!<td style="width: 60px; height: 78px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}     <img src="img/achievement/kleber_der_partei.png" alt="Kleber der Partei Icon" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Kleber der Partei</div> <div class="achievement_subtitle"> - первоначальные 3 советника остаются с вами от начала и до конца игры (ячейка Мюллера должна оставаться пустой после его смерти). </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_grosse_sauberung: {!<tr>!}   {!<td style="width: 60px; height: 78px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}     <img src="img/achievement/grosse_sauberung.png" alt="Große Säuberung Icon" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Große Säuberung</div> <div class="achievement_subtitle"> - к концу игры полностью реформируйте судебную систему, дважды проведите чистку прусской бюрократии и обеспечьте полную преданность полиции внутренних дел, прусской полиции и рейхсвера. </div> {!</td>!} {!</tr>!}  ?] {!</table>!}

