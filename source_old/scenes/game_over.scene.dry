[? if not achievement_blauer_winter: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/blauer_winter.png" alt="Иконка «Синяя зима»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Blauer Winter</div> <div class="achievement_subtitle"> — Густав Винтер получил 1% или более голосов на президентских выборах 1932 года. Его процент голосов растёт от инфляции. </div> {!</td>!} {!</tr>!}  ?]

