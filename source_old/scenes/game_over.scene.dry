title: Игра окончена.
new-page: true
go-to: eg_menu
on-arrival: {!
Q.game_over = 1;
// Achievements:
// Große Koalition - form a grand coalition
// Eiserne Front - Form the Iron Front.

// calculate normalized class voting for the achievements
for (var c of Q.classes) {
    var class_votes = 0;
    for (var party of Q.parties) {
        if (Q[c+'_'+party] < 0) {
            Q[c+'_'+party] = 0;
        }
        class_votes += Q[c+'_'+party];
    }
    for (var party of Q.parties) {
        Q[c + '_' + party + '_normalized'] = Math.round(100*Q[c+'_'+party]/class_votes);
    }
}

const q = dendryUI.dendryEngine.state.qualities;
const dynamicMode = q.dynamic_mode;
const historicalMode = q.historical_mode;

const newlyAddedAchievements = [];

if (!Array.isArray(Q.initialAchievements)) {
  if (Q.initialAchievements && typeof Q.initialAchievements === "object") {
    Q.initialAchievements = Object.keys(Q.initialAchievements);
  } else {
    Q.initialAchievements = [];
  }
}

for (const key in q) {
  if ((key.startsWith("game_achievement") || key.startsWith("achievement")) && q[key] === 1) {
    if (!Q.initialAchievements.includes(key)) {
      newlyAddedAchievements.push(key);
    }
  }
}

if (!dynamicMode && !historicalMode && Q.difficulty != 1) {
  for (const key of newlyAddedAchievements) {
    q[key] = 0;
  }
}

if ((Q.dynamic_mode || Q.historical_mode || Q.difficulty == 1) && !((Q.year == 1934 && Q.month > 7) || Q.year >= 1935)) {
  // Roter Zar von Preußen - At the end of the game, Otto Braun is president, chancellor, and minister-president of prussia at the same time.
  if (Q.president == 'Braun' && Q.chancellor == 'Braun' && Q.prussia_leader == "Braun") {
      this.achieve('red_tzar_of_prussia');
  }
  // Bürgerkrieg - enter a long civil war.
  if (Q.long_war) {
      this.achieve('civil_war');
  }
  // Sieg für die Republik - victory for the republic
  if (Q.republic_victory) {
      this.achieve('victory_for_the_republic');
  }
  // Einigkeit und Recht und Freiheit - survive without a civil war.

  // Einheitsfront - form a united front with the KPD, and win the civil war.

  // Volksfront - form a popular front government, and win the civil war.

  // Wirtschaftspolitik - enact an economic plan.
  // Wirtschaftswunder - reduce unemployment below 10% and have a non-negative budget by 1933.
  if (Q.year >= 1932  && Q.unemployed < 8.6 && Q.budget > 0 && Q.inflation < 5) {
      this.achieve('wirtschaftswunder');
  }
  // Bollwerk der Demokratie - resist the Prussian Coup, and win.
  if (Q.republic_victory && Q.resist_coup) {
      this.achieve('bollwerk_der_demokratie');
  }
  // Der österreichische Gefreite - deport hitler
  // Volkspartei - form a people's party
  // Hirschfeld - legalize 2 of homosexual rights and trans rights.
  if (Q.homosexual_rights >= 2) {
      this.achieve('hirschfeld');
  }
  // Mädchen und Uniform - a woman's place is in the Reichsbanner.
  // Gleichheit - Support and enact reforms for women's rights.
  if ((Q.womens_work && Q.womens_rights >= 5) || (Q.abortion_rights && Q.womens_rights >= 3)) {
      this.achieve('equality');
  }

  // Sohn seiner Klasse - elect Ernst Thälmann as president or chancellor.
  if (Q.chancellor == "Thälmann" || Q.president == "Thälmann") {
      this.achieve('sohn_seiner_klasse');
  }
  // Die Rote Fahne - join the KPD in the May Day march.
  // Mehrheitspartei - form an <span style="color: #c00000;">**SPD**</span> majority government in the Reichstag.
  // Panik im Mittelstand - have over 50% of New Middle Class support.
  if (Q.new_middle_spd_normalized && Q.new_middle_spd_normalized >= 50) {
      this.achieve('panik_im_mittelstand');
  }
  // Bauernrevolution - have over 50% rural support.
  if (Q.rural_spd_normalized && Q.rural_spd_normalized >= 50) {
      this.achieve('bauernrevolution');
  }
  if (Q.catholics_spd_normalized && Q.catholics_spd_normalized >= 50) {
      this.achieve('katholischer_sozialismus');
  }
  if (Q.workers_spd_normalized >= 80 && Q.new_middle_spd_normalized <= 20 && Q.old_middle_spd_normalized <= 20 && Q.rural_spd_normalized <= 20) {
      this.achieve('klassenkampf');
  }
  if (Q.workers_spd_normalized >= 40 && Q.new_middle_spd_normalized >= 40 && Q.old_middle_spd_normalized >= 40 && Q.rural_spd_normalized >= 40) {
      this.achieve('grosse_volkspartei');
  }
  // Räterepublik - begin the transformation to a socialist economy.
  if (Q.spd_in_government && ((Q.nationalization_progress >= 2 && Q.economic_democracy >= 3) || (Q.nationalization_progress >= 1 && Q.economic_democracy >= 4))) {
      this.achieve('raterepublik');
  }
  // Polykrise - survive both a fascist coup and a capital strike.
  if (Q.march_on_berlin_seen && Q.capital_strike_seen && Q.chancellor != "Hitler" && Q.president != "Hitler" && !Q.total_defeat) {
      this.achieve("polykrise");
  }
  // Wirtschaftsexperiment - implement two different economic plans.
  if ((Q.nationalization_progress >= 1 && Q.wtb_implemented >= 1) || (Q.wtb_implemented >= 1 && Q.moderate_plan_progress >= 1) || (Q.nationalization_progress >= 1 && Q.moderate_plan_progress >= 1)) {
      this.achieve("wirtschaftsexperiment");
  }
  // Syndikalismus - support factory takeovers by workers.
  if (Q.factory_takeovers >= 2) {
      this.achieve("syndikalismus");
  }
  // Stolperstein - lose the civil war against Hitler.
  if ((Q.chancellor_party == "NSDAP" || Q.chancellor == "Hitler" || Q.president == "Göring" || Q.president == "Frick" || Q.president == "Hitler") && Q.total_defeat) {
      this.achieve('stolperstein');
  }
  // Heidelberger Programm - fulfill the goals of the Heidelberg programm - increase welfare, reform justice, support women's rights, progressive taxation, works councils, build a European  Union.
  if ((Q.welfare > 0 && Q.judicial_reform >= 2 && Q.womens_work >= 1 && Q.family_law >= 1 && Q.upper_tax_rates > Q.lower_tax_rates && Q.works_councils > 0 && Q.eu > 0)) {
      this.achieve('heidelberger_programm');
  }
  if (Q.chancellor == "Adenauer" && Q.president == "Heuss") {
      this.achieve('traumteam');
  }
  if ((Q.president != "Hammerstein" && Q.president != "Hitler" && Q.president != "Göring" && Q.president != "Seldte" && Q.chancellor != "Hitler" && !Q.hammerstein_win) && (Q.return_to_normalcy || Q.spd_votes >= 50 || Q.spd_r >= 50 && Q.pro_republic >= 80 || Q.nsdap_votes < 8) && (Q.spd_votes >= 50 || Q.spd_r >= 50) && !Q.civil_war_seen && !Q.rubicon) {
      this.achieve('ldp');
  }
  if (Q.civil_war_seen && Q.long_war && Q.west_aid) {
      this.achieve('der_grosse_neustart');
  }

  const partySupport = {
    nsdap: Q.nsdap_r,
    spd: Q.spd_r,
    kpd: Q.kpd_r,
    z: Q.z_r,
    dnvp: Q.dnvp_r,
    ddp: Q.ddp_r,
    dvp: Q.dvp_r,
    lvp: Q.lvp_r,
    kvp: Q.kvp_r,
    dnf: Q.dnf_r,
    sapd: Q.sapd_r,
    other: Q.other_r,
    dnef: Q.dnef_r,
  };

  const filteredPartySupport = Object.entries(partySupport)
    .filter(([party]) => Q.parties.includes(party))
    .filter(([_, value]) => typeof value === 'number' && !isNaN(value));

  const sortedParties = filteredPartySupport.sort((a, b) => b[1] - a[1]);

  const secondLargestParty = sortedParties[1]?.[0] ?? null;

  if (secondLargestParty === 'dnvp') {
    Q.second_largest_party = 'dnvp';
  }

  if (Q.true_christian_democracy && Q.dnvp_leader == "Treviranus" && Q.second_largest_party == "dnvp") {
      this.achieve('deutsche_tory_demokratie');
  }

  if (Q.schwarze_null && (Q.nationalization_progress >= 4 || Q.wtb_implemented >= 4)) {
      this.achieve('schwarze_null');
  }

  if (Q.dnvp_leader == "Lambach" && Q.dnvp_r >= 20 && Q.workers_dnvp_normalized >= Q.workers_spd_normalized && Q.workers_dnvp_normalized >= Q.workers_kpd_normalized && Q.workers_dnvp_normalized >= Q.workers_z_normalized && Q.workers_dnvp_normalized >= Q.workers_nsdap_normalized) {
      this.achieve('neue_arbeiterpartei');
  }

  if (Q.ddp_r >= 8 && Q.ddp_r >= (Q.dvp_r * 2) && Q.dvp_exist && !Q.lvp_formed) {
      this.achieve('linksliberale_renaissance');
  }

  if (Q.z_relation <= 5 && ((Q.ddp_relation <= 5 && (Q.dvp_relation <= 5 || !Q.dvp_exist) && !Q.lvp_formed) || Q.lvp_relation <= 5 && Q.lvp_formed) && Q.kpd_relation <= 5 && (Q.kvp_relation <= 5 || !Q.kvp_formed) && Q.dnvp_relation <= 5 && Q.nsdap_relation <= 5 && (Q.dnef_relation <= 5 || !Q.dnef_formed)) {
      this.achieve('wer_braucht_schon_freunde');
  }

  if (Q.ddp_ideology == "Right" && !Q.dstp_formed && Q.dvp_ideology == "Left" && Q.dvp_exist && !Q.lvp_formed) {
      this.achieve('warum_kampfen_wir_immer_noch');
  }

  if (Q.gov_burden_fail >= 10 && Q.in_spd_majority) {
      this.achieve('leere_parolen');
  }

  if (Q.eu && !Q.eu_negotiation) {
      this.achieve('weltfrieden');
  }

  if (Q.bavaria_spd && Q.wurttemberg_spd && (Q.thuringia_spd || Q.red_thuringia) && (Q.saxony_spd || Q.red_saxony) && Q.spd_prussia) {
      this.achieve('staatspolitiker');
  }

  if (Q.polizeistaat) {
      this.achieve('polizeistaat');
  }

  if (Q.president == "Heuss" && Q.chancellor == "Adenauer" && Q.z_leader == "Adenauer" && Q.z_party_name == "CVP" && Q.lvp_formed && Q.constitutional_reform >= 3 && !Q.nsdap_r && !Q.kpd_r && Q.neorevisionism && Q.reformist_strength >= Q.left_strength && Q.reformist_strength >= Q.center_strength && Q.reformist_strength >= Q.labor_strength) {
      this.achieve('wahre_bundesrepublik');
  }

  if ((Q.kvp_r > Q.dnvp_r && Q.kvp_formed && Q.kvp_r && !Q.cvp_kvp_formed || Q.dnf_r > Q.dnvp_r && Q.dnvp_ideology == "Moderate" && Q.dnf_r) && !Q.cvp_formed) {
      this.achieve('das_blatt_hat_sich_gewendet');
  }

  if ((Q.nsdap_votes < Q.modeerscheinung_check && !Q.rubicon) || (Q.nsdap_hitler_votes < Q.modeerscheinung_check && Q.rubicon)) {
      this.achieve('modeerscheinung');
  }

  if (Q.peoples_party && Q.kvp_formed && (Q.lvp_formed || Q.dvp_exist) && Q.z_party_name == "CVP") {
      this.achieve('volkspartei_fur_das_volk');
  }

  if (Q.reparations == 0 && !Q.foreign_aid && !Q.eu && !Q.soviet_export && !Q.soviet_aid_forpol && Q.unemployed < 15 && Q.budget > 0 && Q.year >= 1930) {
      this.achieve('wir_schaffen_das');
  }

  if (((Q.ddp_leader == "Lemmer" || Q.ddp_leader == "Lüders") && (Q.dvp_leader == "Thiel" && Q.dvp_exist) && !Q.lvp_formed || ((Q.lvp_leader == "Heuss" || Q.lvp_leader == "Bäumer" || Q.lvp_leader == "Stolper") && Q.lvp_formed)) && Q.true_christian_democracy && Q.dnvp_leader == "Treviranus" && Q.kpd_leader == "Conciliators" && (((Q.z_leader == "Kaiser" || Q.z_leader == "Joos" && !Q.fake_joos) && !Q.cvp_formed) || Q.cvp_leader == "Stegerwald" && Q.cvp_formed)) {
      this.achieve('blockparteien_parade');
  }

  if 
    (((Q.ddp_leader == "Lemmer" || Q.lvp_formed) && (Q.dvp_leader == "Thiel" || Q.dvp_leader == "Glatzel" || !Q.dvp_exist || Q.lvp_formed) && (Q.lvp_leader == "Glatzel" || !Q.lvp_formed)) && ((Q.dnvp_leader == "Lambach" && Q.z_leader == "Kaiser") && !Q.cvp_formed || (Q.cvp_leader == "Lambach" || Q.cvp_leader == "Stegerwald") && Q.cvp_formed)) {
      this.achieve('der_arbeiterstaat');
  }

  if (Q.papen_republic_victory && Q.kpd_explode && Q.hitler_dead) {
      this.achieve('gegen_papen_hitler_thalmann');
  }

  if (Q.president == "Wels") {
      this.achieve('wels');
  }

  if (Q.sapd_votes > Q.kpd_votes) {
      this.achieve('kommunistische_alternative');
  }

  if (Q.labor_minister_party == "SPD" && Q.interior_minister_party == "SPD" && Q.finance_minister_party == "SPD" && Q.economic_minister_party == "SPD" && Q.foreign_minister_party == "SPD" && Q.justice_minister_party == "SPD" && Q.agriculture_minister_party == "SPD" && Q.reichswehr_minister_party == "SPD" && (Q.prussia_leader == "Braun" || Q.prussia_leader == "Rosenfeld") && Q.chancellor_party == "SPD" && (Q.president == "Braun" || Q.president == "Rosenfeld" && !Q.left_split || Q.president == "Schumacher" || Q.president == "Wels" || Q.president == "Grzesinski" || Q.president == "Juchacz" || (Q.president == "Rosenfeld" && !Q.left_split))) {
      this.achieve('die_rote_republik');
  }

  if (Q.old_middle_spd_normalized >= 40 && Q.old_middle_spd_normalized > Q.workers_spd_normalized) {
      this.achieve('champagner_sozialisten');
  }

  const achievementsKey = "Social Democracy: An Alternate History_achievements";

  const rawData = localStorage.getItem(achievementsKey);

  let achievements;
  try {
    achievements = JSON.parse(rawData);
  } catch (e) {
    achievements = null;
  }

  if ((!achievements || achievements.soziale_politik_fur_dich !== 1) && Q.soziale_politik_fur_dich) {
      this.achieve('soziale_politik_fur_dich');
  }

  if (Q.notwendigkeit) {
      this.achieve('notwendigkeit');
  }

  if (Q.president != "Hammerstein" && Q.president != "Hitler" && Q.president !=   "Göring" && Q.president != "Seldte" && Q.chancellor != "Hitler" && !Q.hammerstein_win && !(Q.president == "Hergt" && Q.chancellor == "Seldte")) {
    if ((Q.president == "Rosenfeld" || Q.president == "Thälmann" || Q.president == "Münzenberg" || Q.president == "Ossietzky" || Q.president == "Mann") && Q.in_left_front && !Q.civil_war_seen) {
      Q.kpd_points_calc = 0;
      Q.kpd_points_calc += Q.rfb_force;
      Q.kpd_points_calc += (100 - Q.pro_republic) / 2;
      Q.kpd_points_calc += Q.unemployed / 2;
      Q.kpd_points_calc += Q.kpd_votes;
      Q.kpd_points_calc += Q.soviet_relation;
      if (Q.presid_calcent == "Thälmann") Q.kpd_points_calc += 16;
      if (Q.president == "Münzenberg") Q.kpd_points_calc += 10;
      if (Q.kpd_leader == "Conciliators") Q.kpd_points_calc += 6;
      if (Q.sapd_formed) {
        Q.kpd_points_calc += 2;
        Q.kpd_points_calc += Q.sapd_votes;
      }
      if (Q.spd_votes < 26) Q.kpd_points_calc += 5;
      if (Q.eu) Q.kpd_points_calc -= 10;
      if (Q.spd_votes >= 36) Q.kpd_points_calc -= 5;
      if (Q.spd_votes >= 40) Q.kpd_points_calc -= 5;

      if (Q.kpd_points_calc >= 50) {
        this.achieve('nach_der_spd_wir');
      } else {
        this.achieve('1919_geracht');
      }
    }
  }
  if (Q.president != "Hammerstein" && Q.president != "Hitler" && Q.president != "Göring" && Q.president != "Seldte" && Q.chancellor != "Hitler" && !Q.hammerstein_win && !(Q.president ==   "Hergt" && Q.chancellor == "Seldte")) {
    Q.weimar_win_calc = 1;
  } else {
    Q.weimar_win_calc = 0;
  }
  if ((Q.in_left_front || Q.in_popular_front) && Q.kpd_coalition_success && Q.wurttemberg_kpd && Q.bavaria_kpd && Q.red_thuringia && Q.red_saxony && Q.weimar_win_calc && !Q.kpd_points_calc && !Q.civil_war_seen && Q.year >= 1934) {
    this.achieve('eurokommunismus');
  }
  if (Q.reichswehr_strength >= 200 && Q.unemployed < 15 && Q.budget > 0 && Q.tariffs > 5 && (Q.spd_in_government || Q.chancellor_party == "SPD")) {
    this.achieve('kriegswirtschaft');
  }
  if (Q.spd_votes >= 67 && Q.spd_r >= 67 && Q.in_social_liberal_coalition) {
    this.achieve('sechs_sieben');
  }
  if (Q.rubicon_mini_trigger && Q.rubicon_mini_leave && Q.chancellor == "Hitler") {
    this.achieve('er_ist_wieder_da');
  }
  if (!Q.hammerstein_win && Q.schleicher_spd_concession >= 2) {
    this.achieve('abgrundlaufer');
  }
  if (Q.chancellor == "Brüning" && Q.president == "Brüning" && Q.prussia_leader == "Brüning") {
    this.achieve('bruning_uber_alles');
  }
  if (Q.der_aufstieg_skywalkers) {
    this.achieve('der_aufstieg_skywalkers');
  }
  if (Q.chancellor == "Breitscheid" && Q.left_cartel_france && Q.reparations_resolved && (Q.sdapo_win || Q.austria_peace) && Q.radio) {
    this.achieve('mr_breitscheid');
  }
  if (Q.year == 1934 && Q.month == 7 && Q.hilferding_advisor && Q.wels_advisor && Q.kleber_der_partei) {
    this.achieve('kleber_der_partei');
  }
  if (Q.prussian_police_loyalty >= 0.95 && Q.reichswehr_loyalty >= 0.95 && Q.interior_police_loyalty >= 0.95 && Q.judicial_reform >= 2 && Q.prussia_purge >= 2) {
    this.achieve('grosse_sauberung');
  }
}
this.achieve('game_completed');
!}

= Конец

[? if (chancellor == nsdap_chancellor or president == "Hitler" or president == "Göring" or president == "Frick") and not republic_victory: <iframe src="https://en.wikipedia.org/wiki/The_Holocaust" height="800 " width="545" style=" margin-left: -20px; border: 1px solid #000; "></iframe> ?]


@eg_menu

- #endings
- @ending_slides: View ending slides.
- @modinfo.paths: View completed paths.
- @end_game: Закончить игру.



@hitler_wins
view-if: (chancellor == nsdap_chancellor or president == "Hitler" or president == "Göring" or president == "Frick") and (total_defeat==1 or civil_war_seen == 0)
title: Власть Адольфа Гитлера в Германии неоспорима.
tags: endings
go-to: eg_menu

Власть Адольфа Гитлера в Германии неоспорима. <span style="color: #c00000;">**СДПГ**</span>, вместе со всеми демократическими силами, потерпела поражение.

[? if civil_war_seen == 1 : По крайней мере, мы сопротивлялись. Возможно, в невообразимом будущем наше сопротивление воспоют. ?]


@war_against_hitler
view-if: (chancellor == nsdap_chancellor or president == "Hitler" or president == "Göring" or president == "Frick") and (long_war == 1)
title: Адольф Гитлер у власти, но мы боремся, чтобы его остановить.
tags: endings
go-to: eg_menu

Адольф Гитлер пришёл к власти в Германии. Однако мы сплотили демократические силы страны против него и даём отпор. Исход этой войны неясен.



@no_hitler
view-if: chancellor != "Hitler" and president != "Hitler" and president != "Göring" and chancellor_party != "NSDAP"
title: Гитлер ещё не контролирует Германию…
tags: endings
go-to: eg_menu

Гитлер ещё не контролирует Германию.[? if chancellor == "Papen" : Однако <span style="color: #808080;">авторитаризм</span> канцлера Папена и его <span style="color: #7A3C00;">ультра</span><span style="color: #3E88B3;">правая</span> политика прокладывают путь к власти Гитлеру или кому-то подобному ему.  ?] [? if chancellor == "Schleicher" : Однако <span style="color: #808080;">авторитаризм</span> и интриги канцлера Шлейхера готовят почву для прихода к власти Гитлера или кого-то вроде него.  ?][? if resist_coup == 1 and republic_victory == 0 and long_war == 0 and coup_victory == 0 : После нашего поражения в Прусском перевороте <span style="color: #7A3C00;">ультра</span><span style="color: #3E88B3;">правые</span>, похоже, берут верх.  ?][? if chancellor == "Brüning" : Однако политика жёсткой экономии канцлера Брюнинга и продолжающаяся депрессия готовят почву для прихода к власти Гитлера или кого-то вроде него. ?]

[? if hitler_deported == 1 : Мы депортировали Гитлера обратно в Австрию. Надеемся, он никогда не вернётся. ?]


@nsdap_win
view-if: chancellor == "Goebbels" or chancellor == "Göring" or president == "Göring" or president == "Frick"
title: Несмотря на депортацию Гитлера, <span style="color: #7A3C00;">нацисты</span> всё равно пришли к власти…
tags: endings
go-to: eg_menu

<p>Несмотря на депортацию Гитлера, <span style="color: #7A3C00;">**НСДАП**</span> каким-то образом всё же пробралась к власти.</p>[? if long_war == 1 : Мы боремся с ними за контроль над Германией. ?]



@civil_war_won
title: Мы победили в гражданской войне.
view-if: republic_victory == 1
tags: endings
go-to: eg_menu

Мы победили в гражданской войне против <span style="color: #808080;">реакционных</span> сил. Германия изменится навсегда, но пока слишком рано говорить, как именно.


@civil_war_lost
title: Мы проиграли гражданскую войну.
view-if: total_defeat == 1
tags: endings
go-to: eg_menu

Мы проиграли гражданскую войну. По крайней мере, это быстрый переворот, который закончился прежде, чем Германия успела погрузиться в тотальную войну.


@long_war
title: Германия охвачена гражданской войной.
view-if: long_war == 1
tags: endings
go-to: eg_menu

В данный момент Германия охвачена гражданской войной — жестоким противостоянием, которому не видно конца. Уже унесены тысячи жизней, и, вероятно, война не прекратится, пока города Германии не превратятся в руины.

[? if is_favorable == 0 : Нынешняя обстановка складывается не в нашу пользу. ?][? if west_relation >= 2: Наше дело пользуется поддержкой на Западе, но их закостенелые правительства не спешат отправлять нам помощь.  ?][? if soviet_aid >= 1 : <span style="color: #750e0e;">Советский Союз</span> оказывает помощь <span style="color: #700000;">коммунистам</span>, но не <span style="color: #c00000;">социалистам</span> и <span style="color: #D3C24D;">демократам</span>, в попытке определить будущее правительство Германии.  ?][? if east_aid >= 1 : <span style="color: #DC143C;">Поль</span><span style="color: #FFFFFF;">ша</span> и <span style="color: #11457E;">Чехо</span><span style="color: #FFFFFF;">сло</span><span style="color: #D7141A;">вакия</span> направили некоторую помощь для борьбы с фашистами. ?]



@braun_victorious
title: Победа Отто Брауна
view-if: president == "Braun"
tags: endings
go-to: eg_menu

Отто Браун избран президентом Германии. Он никогда не стремился стать самым влиятельным человеком в Германии, но теперь он им стал.


@rosenfeld_victorious
title: Победа Курта Розенфельда
view-if: president == "Rosenfeld"
tags: endings
go-to: eg_menu

Курт Розенфельд избран президентом Германии. Он никогда не стремился стать самым влиятельным человеком в стране, но вместе с <span style="color: #700000;">**КПГ**</span> нас ждёт <span style="color: #9B0000;">социалистическое</span> будущее.


@president_schumacher
title: Победа Курта Шумахера
view-if: president == "Schumacher"
tags: endings
go-to: eg_menu

Курт Шумахер избран президентом Германии. Как молодой и амбициозный представитель <span style="color: #c00000;">**СДПГ**</span>, он будет определять курс Германии на долгие годы.


@president_grzesinski
title: Альберт Гжезинский одержал победу
view-if: president == "Grzesinski"
tags: endings
go-to: eg_menu

Альберт Гжезинский избран президентом Германии. Будучи молодым и амбициозным членом <span style="color: #c00000;">**СДПГ**</span>, он будет определять судьбу Германии в грядущие годы.


@president_wels
title: Победа Отто Вельса
view-if: president == "Wels"
tags: endings
go-to: eg_menu

Отто Вельс избран президентом Германии. Какой долгий путь проделал председатель <span style="color: #c00000;">**СДПГ**</span> за время существования Республики! Ему предстоит определять будущее Германии на долгие годы.


@president_juchacz
title: Мари Юхач — президент
view-if: president == "Juchacz"
tags: endings
go-to: eg_menu

Мари Юхач избрана президентом Германии. Она стала первой в истории женщиной, избранной главой республиканского государства, и ей предстоит определять облик Германии на долгие годы.


@president_einstein
title: Альберт Эйнштейн — президент
view-if: president == "Einstein"
tags: endings
go-to: eg_menu

Альберт Эйнштейн, пожалуй, самый известный учёный в мире, избран президентом Германии. Будучи немецким <span style="color: #005EB8;">евреем</span> и пацифистом, он — живое опровержение всего, за что ратовали <span style="color: #7A3C00;">нацисты</span>, и символ новой Германской республики, сумевшей оставить позади своё неоднозначное прошлое.




@spd_victorious
title: <span style="color: #c00000;">**СДПГ**</span> по-прежнему в правительстве
view-if: spd_in_government == 1 and chancellor_party == "SPD" and total_defeat == 0 and long_war == 0 and not schleicher_spd
tags: endings
go-to: eg_menu

The <span style="color: #c00000;">**СДПГ**</span> по-прежнему в правительстве, во главе с канцлером [+ chancellor +]ом. Учитывая обстоятельства, это значительное достижение.


@spd_victorious_2
title: The <span style="color: #c00000;">**СДПГ**</span> одержала победу?
view-if: total_defeat == 0 and long_war == 0 and schleicher_spd and wtb_implemented
tags: endings
go-to: eg_menu

Мы вынуждены пойти на сделку с Куртом фон Шлейхером, отказавшись от своих пацифистских и антимилитаристских принципов. Учитывая его репутацию интригана, он может предать нас в любой момент.

Стоило ли оно того?


@communist_victory
title: <span style="color: #700000;">**Коммунистическая**</span> победа
view-if: chancellor_party == "KPD" or president == "Thälmann" and total_defeat == 0 and long_war == 0
tags: endings
go-to: eg_menu

К власти в Германии пришла <span style="color: #700000;">**КПГ**</span>, и в этом есть наша заслуга. Она попытается переделать страну по <span style="color: #750e0e;">советскому</span> образу и подобию. Насколько ей это удастся, покажет время.


@works_program
title: Программа общественных работ принята!
view-if: works_program > 0
tags: endings
go-to: eg_menu

Наше правительство приняло программу общественных работ!


@unemployment_reduced
title: Безработица снизилась по сравнению с пиковым значением.
view-if: unemployed <= 15 and unemployed >= 10 and black_thursday_seen
tags: endings
go-to: eg_menu

Хотя безработица всё ещё остаётся на неприятно высоком уровне, она далека от пиковых значений. Это успех нашей экономической политики.


@unemployment_reduced_2
title: Безработица успешно сокращена!
view-if: unemployed < 10 and black_thursday_seen
tags: endings
go-to: eg_menu

Уровень безработицы значительно снизился! Это успех нашей экономической политики.




@unemployment_high
title: Безработица всё ещё слишком высока.
view-if: unemployed >= 15 and (chancellor != "Hitler" and president != "Hitler") and (total_defeat == 0) and long_war == 0
tags: endings
go-to: eg_menu

Уровень безработицы остаётся опасно высоким. И хотя Гитлер не у власти, ситуация создаёт благодатную почву для нестабильности и экстремизма.



@emergency_government
title: <span style="color: #c00000;">**СДПГ**</span> правящая в составе чрезвычайного правительства.
view-if: in_emergency_government == 1
tags: endings
go-to: eg_menu

The <span style="color: #c00000;">**СДПГ**</span> правит в составе чрезвычайного правительства меньшинства во главе с президентом [+ president +]и канцлером [+ chancellor +]ом. Это временное и нестабильное положение дел, что открывает дорогу к дальнейшему <span style="color: #808080;">авторитаризму</span>.


@peoples_party_achieved
title: The <span style="color: #c00000;">**СДПГ**</span> — «Народная Партия».
view-if: peoples_party == 1
tags: endings
go-to: eg_menu

The <span style="color: #c00000;">**СДПГ**</span> объявлена «Народной партией», представляющей весь народ, а не только рабочий класс. У этой политики много как сторонников, так и противников. Что станет с партией — пока неясно.


@nationalization_achieved
title: Началась социализация экономики.
view-if: nationalization_progress >= 2
tags: endings
go-to: eg_menu

В рамках нашего <span style="color: #c00000;">социалистического</span> экономического плана мы национализировали значительную часть экономики, начав переход к реальному <span style="color: #9b0000;">социализму</span>.


@works_councils
title: Рабочие советы получили больше власти.
view-if: works_councils >= 3
tags: endings
go-to: eg_menu

Теперь рабочие советы обладают куда большим влиянием, что даёт трудящимся демократический контроль над их экономической жизнью.


@european_union
title: Создан <span style="color: #001489;">Европейский</span> <span style="color: #FFDD00;">союз</span>!
view-if: eu = 1
tags: endings
go-to: eg_menu

Мы помогли создать <span style="color: #001489;">Европейский</span> <span style="color: #FFDD00;">союз</span>, чтобы принести на континент мир и процветание. Время покажет, насколько он будет эффективен.


@achievements
title: Достижения
view-if: achievement_game_completed == 1
on-arrival: {!
const toolsWrapper = document.getElementById('tools_wrapper');
if (toolsWrapper) {
  toolsWrapper.style.display = 'none';
}
const elements = document.querySelectorAll('header, #content, footer');
elements.forEach(el => {
  el.style.maxWidth = '800px';
});

const achievements = [
  "achievement_eiserne_front",
