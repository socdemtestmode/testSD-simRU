[? if not achievement_bauernrevolution: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/bauernrevolution.png" alt="Значок Bauernrevolution" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Bauernrevolution</div> <div class="achievement_subtitle"> — поддержка <span style="color: #c00000; font-weight: bold;">СДПГ</span> среди сельского населения составляет не менее 50%.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if not achievement_katholischer_sozialismus: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/katholischer_sozialismus.png" alt="Иконка «Католический социализм»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Katholischer Sozialismus</div> <div class="achievement_subtitle"> – Поддержка <span style="color: #c00000; font-weight: bold;">СДПГ</span> католиками составляет не менее 50%.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if not achievement_grosse_volkspartei: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/grosse_volkspartei.png" alt="Иконка «GroÃŸe Народная партия (Volkspartei)»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(97, 24, 19, 0.2);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Große Volkspartei</div> <div class="achievement_subtitle"> — Поддержка <span style="color: #c00000; font-weight: bold;">СДПГ</span> среди всех классов составляет не менее 40%.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if not achievement_klassenkampf: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/klassenkampf.png" alt="Иконка «Классовая борьба»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Klassenkampf</div> <div class="achievement_subtitle"> - поддержка <span style="color: #c00000; font-weight: bold;">СДПГ</span> со стороны рабочих составляет не менее 80%, а со стороны среднего класса и сельского населения — менее 20%.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if not achievement_raterepublik: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/raterepublik.png" alt="Значок Räterepublik" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Räterepublik</div> <div class="achievement_subtitle"> - начать переход к <span style="color: #9B0000;">социалистической</span> экономике.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if not achievement_polykrise: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/polykrise.png" alt="Значок Polykrise" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(97, 24, 19, 0.2);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Polykrise</div> <div class="achievement_subtitle"> - пережить бегство капитала и <span style="color: #7A3C00;">фашистский</span> переворот.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if not achievement_syndikalismus: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/syndikalismus.png" alt="Иконка «Синдикализм»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Syndikalismus</div> <div class="achievement_subtitle"> — поддержите захват фабрик рабочими.</div> </div> {!</td>!} {!</tr>!}  ?]

