[? if game_achievement_neue_geschaftsfuhrung: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/neue_geschaftsfuhrung.png" alt="Neue GeschÃ¤ftsfÃ¼hrung значок" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Neue Geschäftsführung</div> <div class="achievement_subtitle"> — кандидат от <span style="color: #c00000; font-weight: bold;">СДПГ</span> побеждает на президентских выборах 1932 года, продолжая политику терпимости в отношении Брюнинга. </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_rotes_bayern: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/rotes_bayern.png" alt="Иконка Rotes Bayern" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(97, 24, 19, 0.2);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Rotes Bayern</div> <div class="achievement_subtitle"> — сформировать в Баварии правительство большинства, состоящее только из членов <span style="color: #c00000; font-weight: bold;">СДПГ</span>. </div> {!</td>!} {!</tr>!}  ?]

