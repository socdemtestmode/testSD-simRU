[? if achievement_bundesrepublik: {!<tr>!}   {!<td style="width: 60px; height: 78px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/bundesrepublik.png" alt="Значок Bundesrepublik" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Bundesrepublik</div> <div class="achievement_subtitle"> — Конрад Аденауэр или Курт Шумахер избран президентом, а конституционные реформы ограничили власть президента.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_republik_der_wissenschaft: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/republik_der_wissenschaft.png" alt="Иконка Республики науки" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Republik der Wissenschaft</div> <div class="achievement_subtitle"> — Альберт Эйнштейн избран президентом.</div> </div> {!</td>!} {!</tr>!}  ?]

