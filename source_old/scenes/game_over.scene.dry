[? if not achievement_einheitsfront: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/einheitsfront.png" alt="Иконка Einheitsfront" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Einheitsfront</div> <div class="achievement_subtitle"> - сформируйте правительство, состоящее из <span style="color: #c00000; font-weight: bold;">СДПГ</span> и <span style="color: #700000; font-weight: bold;">КПГ</span>.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if not achievement_einheitsfront_2: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}     <img src="img/achievement/einheitsfront_2.png" alt="Sieg für die Einheitsfront Icon" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(97, 24, 19, 0.2);">!}<div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Sieg für die Einheitsfront</div> <div class="achievement_subtitle"> — сформируйте Левый фронт, который выстоит перед требованиями <span style="color: #700000; font-weight: bold;">КПГ</span>.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if not achievement_volksfront: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/volksfront.png" alt="Иконка Volksfront" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Volksfront</div> <div class="achievement_subtitle"> — сформируйте правительство, состоящее из <span style="color: #c00000; font-weight: bold;">СДПГ</span>, <span style="color: #700000; font-weight: bold;">КПГ</span> и <span style="color: #000000; font-weight: bold;">Партии Центра</span>.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if not achievement_grosse_volksfront: {!<tr>!}   {!<td style="width: 60px; height: 75px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/grosse_volksfront.png" alt="Иконка GroÃŸe Volksfront" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(97, 24, 19, 0.2);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Große Volksfront</div> <div class="achievement_subtitle"> — Когда <span style="color: #000000;">партию Центра</span> возглавляет Йоос или Кайзер, а <span style="color: #700000; font-weight: bold;">КПГ</span> — примиренцы, сформируйте правительство, состоящее из <span style="color: #c00000; font-weight: bold;">СДПГ</span>, <span style="color: #700000; font-weight: bold;">КПГ</span> и <span style="color: #000000; font-weight: bold;">партии Центра</span>. </div> </div> {!</td>!} {!</tr>!}  ?]

[? if not achievement_volksfront_2: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/volksfront_2.png" alt="Значок Volksfront" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Sieg für die Volksfront</div> <div class="achievement_subtitle"> — Сформируйте Народный фронт, который выдержит требования <span style="color: #700000; font-weight: bold;">КПГ</span>.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if not achievement_weimar_coalition: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/weimar_coalition.png" alt="Значок Weimarer Koalition" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(91, 154, 141, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;"><span style="color: #000000;">Вей</span><span style="color: #DD0000;">мар</span><span style="color: #FFCC00;">ская</span> коалиция</div> <div class="achievement_subtitle"> — сформируйте Веймарскую коалицию.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if not achievement_majority_party: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/majority_party.png" alt="Иконка «Партия большинства»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Mehrheitspartei</div> <div class="achievement_subtitle"> — сформируйте однопартийное правительство большинства из членов <span style="color: #c00000; font-weight: bold;">СДПГ</span>.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if not achievement_minderheitsregierung: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/minderheitsregierung.png" alt="Иконка Minderheitsregierung" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Minderheitsregierung</div> <div class="achievement_subtitle"> - сформируйте правительство меньшинства <span style="color: #c00000; font-weight: bold;">СДПГ</span>.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if not achievement_volkspartei: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/volkspartei.png" alt="Иконка «Народной партии»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(91, 154, 141, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Народная партия (Volkspartei)</div> <div class="achievement_subtitle"> — <span style="color: #c00000; font-weight: bold;">СДПГ</span> стала Народной Партией.</div> </div> {!</td>!} {!</tr>!}  ?]

