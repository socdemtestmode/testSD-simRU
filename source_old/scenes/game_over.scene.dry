[? if game_achievement_heuchelei: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/heuchelei.png" alt="Значок «Лицемерие»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Heuchelei</div> <div class="achievement_subtitle"> - преследуйте Эрнста Рёма за <span style="color: red;">го</span><span style="color: orange;">мо</span><span style="color: yellow;">сек</span><span style="color: green;">су</span><span style="color: blue;">аль</span><span style="color: purple;">ность</span>, а затем легализуйте её. </div> </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_warum_kampfen_wir_immer_noch: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/warum_kampfen_wir_immer_noch.png" alt="Warum kÃ¤mpfen wir immer noch? Значок" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Warum kämpfen wir immer noch?</div> <div class="achievement_subtitle"> - <span style="color: #D3C24D; font-weight: bold;">НДП</span> и <span style="color: #C0A054; font-weight: bold;">ННП</span> разделяют одну идеологию, но <span style="color: #FFCC00; font-weight: bold;">ЛНП</span> так и не была сформирована. </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_leere_parolen: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/leere_parolen.png" alt="Leere Parolen Иконка" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(97, 24, 19, 0.2);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Leere Parolen</div> <div class="achievement_subtitle"> — править во главе однопартийного большинства <span style="color: #c00000; font-weight: bold;">СДПГ</span> и провалить 10 или более правительственных обязательств. </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_weltfrieden: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/weltfrieden.png" alt="Weltfrieden Иконка" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Weltfrieden</div> <div class="achievement_subtitle"> - подпишите договор о создании <span style='color: #001489;'>Европейского</span> <span style='color: #FFDD00;'>союза</span>, ни разу не вступив в переговоры. </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_blauer_winter: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/blauer_winter.png" alt="Значок Blauer Winter" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Blauer Winter</div> <div class="achievement_subtitle"> - Густав Винтер набрал 1% или более голосов на президентских выборах 1932 года. </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_ampelkoalition: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/ampelkoalition.png" alt="Значок Ampelkoalition" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Ampelkoalition</div> <div class="achievement_subtitle"> - в Баварии сформирована <span style="color: #c00000;">красно</span>-<span style="color: #FFCC00;">жёлто</span>-<span style="color: #38C538;">зелёная</span> коалиция. </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_staatspolitiker: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/staatspolitiker.png" alt="Иконка «Государственный деятель»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Staatspolitiker</div> <div class="achievement_subtitle"> – <span style="color: #c00000; font-weight: bold;">СДПГ</span> представлена в правительстве каждой федеральной земли. </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_soziale_politik_fur_dich: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/soziale_politik_fur_dich.png" alt="Soziale Politik für Dich значок" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(97, 24, 19, 0.2);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Soziale Politik für Dich</div> <div class="achievement_subtitle"> — четыре года подряд оставаться в правительстве и ни разу не провалить правительственное бремя. </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_polizeistaat: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/polizeistaat.png" alt="Значок «Полицейское государство»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Polizeistaat</div> <div class="achievement_subtitle"> - удерживайте контроль прусской полиции над улицами на уровне 50% или выше в течение целого года. </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_wahre_bundesrepublik: {!<tr>!}   {!<td style="width: 60px; height: 100px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/wahre_bundesrepublik.png" alt="Иконка «Wahre Bundesrepublik»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(10, 24, 97, 0.25);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Wahre Bundesrepublik</div> <div class="achievement_subtitle"> - добейтесь избрания Хойса президентом, а Аденауэра — канцлером, при этом Аденауэр должен возглавлять <span style='color: #000000; font-weight: bold;'>ХНП</span>, а <span style='color: #FFCC00; font-weight: bold;'>ЛНП</span> должна быть сформирована. Все конституционные реформы должны быть приняты, <span style='color: #7A3C00; font-weight: bold;'>НСДАП</span> и <span style='color: #700000; font-weight: bold;'>КПГ</span> не должны преодолеть 5-процентный барьер, Шумахер должен быть доступен в качестве советника, а в <span style='color: #c00000; font-weight: bold;'>СДПГ</span> должны доминировать реформисты. </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_der_beliebte_prasident: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/der_beliebte_prasident.png" alt="Значок «Популярный президент»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Der beliebte PrÃ¤sident</div> <div class="achievement_subtitle"> - Отто Браун набрал 60% или более голосов в первом туре президентских выборов 1932 г. </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_notwendigkeit: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}     <img src="img/achievement/notwendigkeit.png" alt="Notwendigkeit Icon" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Notwendigkeit</div> <div class="achievement_subtitle"> - Набирать на каждых выборах больше голосов, чем на предыдущих. </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_comeback: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/comeback.gif" alt="Значок «Возвращение»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Возвращение</div> <div class="achievement_subtitle"> — позвольте Гинденбургу отправить вас в отставку, а затем вернитесь и сформируйте правительство большинства <span style="color: #c00000; font-weight: bold;">СДПГ</span>. </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_grosse_weimarer_koalition: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/grosse_weimarer_koalition.png" alt="Значок «Große Weimarer Koalition»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Große Weimarer Koalition</div> <div class="achievement_subtitle"> - сформируйте Веймарскую коалицию, где Кайзер возглавляет <span style="color: #000000;">Партию Центра</span>/<span style="color: #000000; font-weight: bold;">ХНП</span>, а Хойс — <span style="color: #FFCC00; font-weight: bold;">ЛНП</span>. </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_das_blatt_hat_sich_gewendet: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/das_blatt_hat_sich_gewendet.png" alt="Значок «Das Blatt hat sich gewendet»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Das Blatt hat sich gewendet</div> <div class="achievement_subtitle"> - одна из отколовшихся от <span style="color: #3E88B3; font-weight: bold;">НННП</span> партий занимает больше мест в рейхстаге, чем сама партия. </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_modeerscheinung: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/modeerscheinung.png" alt="Иконка «Modeerscheinung»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Modeerscheinung</div> <div class="achievement_subtitle"> - <span style="color: #7A3C00; font-weight: bold;">НСДАП</span> получила меньше голосов, чем в мае 1928 года. </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_catastrophepolitik: {!<tr>!}   {!<td style="width: 60px; height: 75px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/catastrophepolitik.png" alt="Иконка «Catastrophepolitik»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(10, 24, 97, 0.25);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Catastrophepolitik</div> <div class="achievement_subtitle"> — возглавьте однопартийный кабинет <span style="color: #c00000; font-weight: bold;">СДПГ</span> по итогам 5 или более выборов, при том что <span style="color: #c00000; font-weight: bold;">СДПГ</span> никогда ранее не входила в правительство и не формировала правительство меньшинства. </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_volkspartei_fur_das_volk: {!<tr>!}   {!<td style="width: 60px; height: 75px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/volkspartei_fur_das_volk.png" alt="Иконка Народная партия (Volkspartei) für das Volk" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Volkspartei für das Volk</div> <div class="achievement_subtitle"> — <span style="color: #c00000; font-weight: bold;">СДПГ</span> — это Народная Партия. Добейтесь максимального числа партий, в названии которых есть «Народная партия». </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_mit_allen_notwendigen_stimmen: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/mit_allen_notwendigen_stimmen.png" alt="Иконка Mit allen notwendigen Stimmen" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Mit allen notwendigen Stimmen</div> <div class="achievement_subtitle"> — управлять страной, опираясь на однопартийное большинство <span style="color: #c00000; font-weight: bold;">СДПГ</span>, при полностью демилитаризованном «Рейхсбаннере». </div> {!</td>!} {!</tr>!}  ?]


[? if game_achievement_wir_schaffen_das: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/wir_schaffen_das.png" alt="Wir schaffen das! Иконка" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Wir schaffen das!</div> <div class="achievement_subtitle"> — достичь уровня безработицы ниже 15% и профицита бюджета без какой-либо помощи от иностранных держав. </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_blockparteien_parade: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/blockparteien_parade.png" alt="Blockparteien-Parade Иконка" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(97, 24, 19, 0.2);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Blockparteien-Parade</div> <div class="achievement_subtitle"> — добиться того, чтобы каждую партию возглавил её самый дружелюбный или «демократический» лидер. </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_der_arbeiterstaat: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/der_arbeiterstaat.png" alt="Иконка «Der Arbeiterstaat»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(97, 24, 19, 0.2);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Der Arbeiterstaat</div> <div class="achievement_subtitle"> — каждую партию возглавляет её самый прорабочий лидер. </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_soziale_marktwirtschaft: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/soziale_marktwirtschaft.png" alt="Значок Soziale Marktwirtschaft" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(91, 154, 141, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Soziale Marktwirtschaft</div> <div class="achievement_subtitle"> — уровень безработицы снижен на 10% или более при канцлере Брюнинге. </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_gegen_papen_hitler_thalmann: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/gegen_papen_hitler_thalmann.png" alt="Иконка «Gegen Papen, Hitler, Thälmann»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(97, 24, 19, 0.2);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Gegen Papen, Hitler, Thälmann</div> <div class="achievement_subtitle"> - доведите <span style="color: #7A3C00;">Гитлера</span> до самоубийства, отправьте <span style="color: #700000;">Тельмана</span> в тюрьму руками Шлейхера и победите <span style="color: #808080;">Папена</span> в гражданской войне. </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_wels: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/wels.png" alt="Иконка Отто Вельса" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(97, 24, 19, 0.2);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Wels' wilder Ritt</div> <div class="achievement_subtitle"> - изберите Отто Вельса президентом после импичмента Гинденбургу. </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_kommunistische_alternative: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/kommunistische_alternative.png" alt="Иконка «Коммунистическая альтернатива»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Коммунистическая альтернатива</div> <div class="achievement_subtitle"> - рейтинг <span style="color: #9B0000; font-weight: bold;">СРПГ</span> выше, чем у <span style="color: #700000; font-weight: bold;">КПГ</span>. </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_die_rote_republik: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/die_rote_republik.png" alt="Иконка Die Rote Republik" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Die Rote Republik</div> <div class="achievement_subtitle"> — <span style="color: #c00000; font-weight: bold;">СДПГ</span> контролирует весь кабинет, посты президента и канцлера, а также возглавляет Пруссию. </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_seeheimer: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/seeheimer.png" alt="Значок Seeheimer" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(10, 24, 97, 0.25);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Seeheimer</div> <div class="achievement_subtitle"> - сформировать однопартийное правительство большинства от <span style="color: #c00000; font-weight: bold;">СДПГ</span> при поддержке рабочих менее 10%. </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_champagner_sozialisten: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/champagner_sozialisten.png" alt="Иконка «Шампанские социалисты»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Champagner-Sozialisten</div> <div class="achievement_subtitle"> - поддержка среди старого среднего класса (не менее 40%) выше, чем среди рабочих. </div> {!</td>!} {!</tr>!}  ?]

