[? if game_achievement_einheitsfront: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/einheitsfront.png" alt="Иконка Einheitsfront" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Einheitsfront</div> <div class="achievement_subtitle"> - сформируйте правительство, состоящее из <span style="color: #c00000; font-weight: bold;">СДПГ</span> и <span style="color: #700000; font-weight: bold;">КПГ</span>.</div> </div> {!</td>!} {!</tr>!}  ?]

