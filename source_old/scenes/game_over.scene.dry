[? if game_achievement_bruder_zur_sonne: {!<tr>!}   {!<td style="width: 60px; height: 78px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/bruder_zur_sonne.png" alt="Значок «К солнцу, к свободе, братья!»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(97, 24, 19, 0.2);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Brüder, zur Sonne, zur Freiheit</div> <div class="achievement_subtitle"> - сократите безработицу, приостановите выплату репараций, расширьте права женщин, изберите президента от <span style="color: #c00000; font-weight: bold;">СДПГ</span> и депортируйте <span style="color: #7A3C00;">Гитлера</span> за одно прохождение.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_die_rote_fahne: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/die_rote_fahne.png" alt="Die Rote Fahne значок" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(91, 154, 141, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Die Rote Fahne</div> <div class="achievement_subtitle"> — присоединитесь к <span style="color: #700000; font-weight: bold;">КПГ</span> в их первомайской демонстрации.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_panik_im_mittelstand: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/panik_im_mittelstand.png" alt="Значок «Panik im Mittelstand»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Паника в среднем классе</div> <div class="achievement_subtitle"> - У <span style="color: #c00000; font-weight: bold;">СДПГ</span> поддержка среди нового среднего класса составляет не менее 50%.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_bauernrevolution: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/bauernrevolution.png" alt="Иконка Крестьянской революции" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Крестьянская революция</div> <div class="achievement_subtitle"> - поддержка <span style="color: #c00000; font-weight: bold;">СДПГ</span> в сельской местности составляет не менее 50%.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_katholischer_sozialismus: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/katholischer_sozialismus.png" alt="Иконка «Католический социализм»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Katholischer Sozialismus</div> <div class="achievement_subtitle"> - поддержка <span style="color: #c00000; font-weight: bold;">СДПГ</span> католиками не менее 50%.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_grosse_volkspartei: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/grosse_volkspartei.png" alt="Значок Большая Народная партия" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(97, 24, 19, 0.2);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">GroÃŸe Народная партия (Volkspartei)</div> <div class="achievement_subtitle"> — Поддержка <span style="color: #c00000; font-weight: bold;">СДПГ</span> среди всех классов составляет не менее 40%.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_klassenkampf: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/klassenkampf.png" alt="Значок Klassenkampf" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Klassenkampf</div> <div class="achievement_subtitle"> - поддержка <span style="color: #c00000; font-weight: bold;">СДПГ</span> среди рабочих — не менее 80%, а среди среднего класса и сельского населения — менее 20%.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_raterepublik: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/raterepublik.png" alt="Значок RÃ¤terepublik" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">RÃ¤terepublik</div> <div class="achievement_subtitle"> - начать переход к <span style="color: #9B0000;">социалистической</span> экономике.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_polykrise: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/polykrise.png" alt="Иконка «Поликризис»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(97, 24, 19, 0.2);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Поликризис</div> <div class="achievement_subtitle"> — пережить забастовку капитала и <span style="color: #7A3C00;">фашистский</span> переворот.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_syndikalismus: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/syndikalismus.png" alt="Иконка «Синдикализм»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Syndikalismus</div> <div class="achievement_subtitle"> - поддержите захват фабрик рабочими.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_drei_pfeile: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/drei_pfeile.png" alt="Иконка «Drei Pfeile»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Drei Pfeile</div> <div class="achievement_subtitle"> - подавите путч, не допустив гражданской войны.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_ausnahmezustand: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/ausnahmezustand.png" alt="Значок 'Чрезвычайное положение'" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Ausnahmezustand</div> <div class="achievement_subtitle"> - применить чрезвычайные полномочия для отмены выборов.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_eu: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/eu.png" alt="Значок «Vereinigte Staaten von Europa»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Vereinigte Staaten von Europa</div> <div class="achievement_subtitle"> - сформируйте «<span style="color: #001489;">Европейский</span> <span style="color: #FFDD00;">Союз</span>».</div> </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_heidelberger_programm: {!<tr>!}   {!<td style="width: 60px; height: 100px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/heidelberger_programm.png" alt="Иконка «Heidelberger Programm»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(97, 24, 19, 0.2);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Heidelberger Programm</div> <div class="achievement_subtitle"> - достигнуть целей Гейдельбергской программы <span style="color: #c00000; font-weight: bold;">СДПГ</span>: рост социального обеспечения, судебная реформа, права женщин на рабочем месте и в семье, прогрессивное налогообложение, производственные советы при фабриках и создание <span style="color: #001489;">Европейского</span> <span style="color: #FFDD00;">союза</span>.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_verfassungsreform: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/verfassungsreform.png" alt="Иконка «Конституционная реформа»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Конституционная реформа</div> <div class="achievement_subtitle"> — принять конституционную поправку.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_zeppelin_kapitan: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/zeppelin_kapitan.png" alt="Иконка «Капитан цеппелина»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(91, 154, 141, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Zeppelinkapitän</div> <div class="achievement_subtitle"> - Гуго Эккенер избран президентом.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_wahlrechts: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}     <img src="img/achievement/wahlrechts.png" alt="Wahlrechts für Frauen Icon" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Wahlrechts für Frauen</div> <div class="achievement_subtitle"> - Мари Юхач избрана президентом.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_bundesrepublik: {!<tr>!}   {!<td style="width: 60px; height: 78px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/bundesrepublik.png" alt="Иконка «Федеративная республика»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Bundesrepublik</div> <div class="achievement_subtitle"> - Конрад Аденауэр или Курт Шумахер избран президентом, а конституционные реформы ограничили полномочия президента.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_republik_der_wissenschaft: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/republik_der_wissenschaft.png" alt="Иконка Republik der Wissenschaft" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Republik der Wissenschaft</div> <div class="achievement_subtitle"> - Альберт Эйнштейн избран президентом.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_arbeiter_von_wien: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/arbeiter_von_wien.png" alt="Значок «Arbeiter von Wien»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Arbeiter von Wien</div> <div class="achievement_subtitle"> - Победа <span style="color: #A50034; font-weight: bold;">СДПА</span> в Австрии.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_stolperstein: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/stolperstein.png" alt="Иконка «Камень преткновения»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(91, 154, 141, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Stolperstein</div> <div class="achievement_subtitle"> - мы проиграли, но, возможно, история нас запомнит… </div> </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_sturm_und_drang: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/sturm_und_drang.png" alt="Иконка Sturm und Drang" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(91, 154, 141, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Sturm und Drang</div> <div class="achievement_subtitle"> - перейти Рубикон. </div> </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_hitler_tot: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/hitler_tot.png" alt="Иконка «Гитлер мёртв»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">HITLER TOT</div> <div class="achievement_subtitle"> — добейтесь, чтобы <span style="color: #7A3C00;">Адольф Гитлер</span> покончил с собой на 12 лет раньше. </div> </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_vive_le_cartel: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/vive_le_cartel.png" alt="Иконка «Vive le Cartel»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Vive le Cartel</div> <div class="achievement_subtitle"> — <span style="color: #FFC0C0;">Картель левых</span> побеждает на парламентских выборах во Франции. </div> </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_neuer_nationalismus: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/neuer_nationalismus.png" alt="Иконка «Neuer Nationalismus»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Neuer Nationalismus</div> <div class="achievement_subtitle"> - Франк Глацель — лидер <span style="color: #C0A054; font-weight: bold;">ННП</span> или <span style="color: #FFCC00; font-weight: bold;">ЛНП</span>. </div> </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_christliche_volkspartei: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/christliche_volkspartei.png" alt="Иконка «Христианская народная партия»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Christliche Volkspartei</div> <div class="achievement_subtitle"> - сформирована <i>настоящая</i> <span style="color: #000000;">Христианская народная партия</span> (<span style="color: #000000; font-weight: bold;">ХНП</span>). Объединение ХНП и НННП. </div> </div> {!</td>!} {!</tr>!}  ?]

[? if game_achievement_braun_koalition: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/braun_koalition.png" alt="Иконка «Braun Koalition»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Braun Koalition</div> <div class="achievement_subtitle"> - <span style="color: #c00000;">социалисты</span>, <span style="color: #D3C24D;">либералы</span>, <span style="color: #000000;">католики</span> и <span style="color: #700000;">коммунисты</span> поддержали Брауна на президентских выборах 1932 года. </div> </div> {!</td>!} {!</tr>!}  ?]

