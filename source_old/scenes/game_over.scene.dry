[? if achievement_civil_war: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/civil_war.png" alt="Иконка гражданской войны" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(91, 154, 141, 0.1)">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Bürgerkrieg</div> <div class="achievement_subtitle"> - начните затяжную гражданскую войну.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_einigkeit_und_recht_und_freiheit: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/einigkeit_und_recht_und_freiheit.png" alt="Иконка Einigkeit und Recht und Freiheit" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(91, 154, 141, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Einigkeit und Recht und Freiheit</div> <div class="achievement_subtitle"> - дойдите до конца игры, не допустив гражданской войны.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_victory_for_the_republic: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/victory_for_the_republic.png" alt="Иконка «Победа Республики»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Sieg für die Republik</div> <div class="achievement_subtitle"> — победить в гражданской войне.</div> </div> {!</td>!} {!</tr>!}  ?] [? if achievement_bollwerk_der_demokratie: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/bollwerk_der_demokratie.png" alt="Иконка Bollwerk" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Bollwerk der Demokratie</div> <div class="achievement_subtitle"> — окажите сопротивление Прусскому путчу и победите без боя. </div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_red_tzar_of_prussia: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/red_tzar_of_prussia.png" alt="Иконка «Красный царь»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Roter Zar von Preußen</div> <div class="achievement_subtitle"> — Отто Браун — рейхспрезидент, канцлер и министр-президент.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_einheitsfront: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/einheitsfront.png" alt="Значок «Einheitsfront»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Einheitsfront</div> <div class="achievement_subtitle"> - сформируйте правительство, состоящее из <span style="color: #c00000; font-weight: bold;">СДПГ</span> и <span style="color: #700000; font-weight: bold;">КПГ</span>.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_einheitsfront_2: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/einheitsfront_2.png" alt="Значок «Sieg für die Einheitsfront»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(97, 24, 19, 0.2);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Sieg für die Einheitsfront</div> <div class="achievement_subtitle"> — сформируйте Левый фронт, который выдержит требования <span style="color: #700000; font-weight: bold;">КПГ</span>.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_volksfront: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/volksfront.png" alt="Значок Volksfront" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Volksfront</div> <div class="achievement_subtitle"> — сформируйте правительство из <span style="color: #c00000; font-weight: bold;">СДПГ</span>, <span style="color: #700000; font-weight: bold;">КПГ</span> и <span style="color: #000000; font-weight: bold;">Партии Центра</span>.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_grosse_volksfront: {!<tr>!}   {!<td style="width: 60px; height: 75px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/grosse_volksfront.png" alt="Значок «Große Volksfront»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(97, 24, 19, 0.2);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Große Volksfront</div> <div class="achievement_subtitle"> — Когда <span style="color: #000000;">Партию Центра</span> возглавляет Йоос или Кайзер, а <span style="color: #700000; font-weight: bold;">КПГ</span> возглавляют примиренцы, сформируйте правительство, состоящее из <span style="color: #c00000; font-weight: bold;">СДПГ</span>, <span style="color: #700000; font-weight: bold;">КПГ</span> и <span style="color: #000000; font-weight: bold;">Партия Центра</span>. </div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_volksfront_2: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/volksfront_2.png" alt="Значок Volksfront" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Sieg für die Volksfront</div> <div class="achievement_subtitle"> — Сформируйте Народный фронт, который выдержит требования <span style="color: #700000; font-weight: bold;">КПГ</span>.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_weimar_coalition: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/weimar_coalition.png" alt="Иконка Веймарской коалиции" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(91, 154, 141, 0.1)">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;"><span style="color: #000000;">Wei</span><span style="color: #DD0000;">ma</span><span style="color: #FFCC00;">r</span> Koalition</div> <div class="achievement_subtitle"> - сформировать Веймарскую коалицию.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_majority_party: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/majority_party.png" alt="Значок «Партия большинства»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Mehrheitspartei</div> <div class="achievement_subtitle"> - сформировать однопартийное правительство большинства <span style="color: #c00000; font-weight: bold;">СДПГ</span>.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_minderheitsregierung: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/minderheitsregierung.png" alt="Иконка Minderheitsregierung" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Minderheitsregierung</div> <div class="achievement_subtitle"> — сформировать правительство меньшинства <span style="color: #c00000; font-weight: bold;">СДПГ</span>.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_volkspartei: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/volkspartei.png" alt="Иконка «Народная партия»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(91, 154, 141, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Volkspartei</div> <div class="achievement_subtitle"> — <span style="color: #c00000; font-weight: bold;">СДПГ</span> — Народная Партия.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_rote_millionar: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/rote_millionar.png" alt="Иконка Der rote Millionär" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Der rote Millionär</div> <div class="achievement_subtitle"> - Вилли Мюнценберг стал президентом.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_sohn_seiner_klasse: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/sohn_seiner_klasse.png" alt="Sohn seiner Klasse Иконка" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Sohn seiner Klasse</div> <div class="achievement_subtitle"> - Эрнст Тельман — президент или канцлер.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_versohnler: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/versohnler.png" alt="Versöhnler Иконка" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Versöhnler</div> <div class="achievement_subtitle"> - «Примиренцы» возглавили <span style="color: #700000; font-weight: bold;">КПГ</span>.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_deport_hitler: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #7A3C00; background-color: rgba(122, 60, 0, 0.1);">!}         <img src="img/achievement/deport_hitler.png" alt="Иконка Der österreichische Gefreite" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #7A3C00; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Der österreichische Gefreite</div> <div class="achievement_subtitle"> - Депортировали <span style="color: #7A3C00;">Гитлера</span>.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_wirtschaftspolitik: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/wirtschaftspolitik.png" alt="Иконка «Экономическая политика»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Wirtschaftspolitik</div> <div class="achievement_subtitle"> - примите экономический план.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_wirtschaftswunder: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/wirtschaftswunder.png" alt="Иконка «Экономическое чудо»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Wirtschaftswunder</div> <div class="achievement_subtitle"> - После 1932 года уровень безработицы ниже уровня 1928 года, инфляция — менее 5%, а бюджет — профицитный.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_wirtschaftsexperiment: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/wirtschaftsexperiment.png" alt="Иконка «Экономический эксперимент»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Wirtschaftsexperiment</div> <div class="achievement_subtitle"> — реализовать два разных экономических плана.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_freie_marktwirtschaft: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/freie_marktwirtschaft.png" alt="Иконка Freie Marktwirtschaft" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(91, 154, 141, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Freie Marktwirtschaft</div> <div class="achievement_subtitle"> — дожить до конца игры, не приняв экономического плана.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_equality: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/equality.png" alt="Иконка «Равенство»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(91, 154, 141, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Gleichheit</div> <div class="achievement_subtitle"> — проведите реформы в пользу прав женщин.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_hirschfeld: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/hirschfeld.png" alt="Иконка «Хиршфельд»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Hirschfeld</div> <div class="achievement_subtitle"> - проведите реформы в защиту прав <span style="color: red;">го</span><span style="color: orange;">мо</span><span style="color: yellow;">сек</span><span style="color: green;">су</span><span style="color: blue;">а</span><span style="color: purple;">лов</span> (ЛГБТ — экстремистское международное движение, запрещенное Верховным Судом России).</div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_women_reichsbanner: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/women_reichsbanner.png" alt="Иконка «Mädchen in Uniform»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Mädchen in Uniform</div> <div class="achievement_subtitle"> - место женщины — в Рейхсбаннере.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_anders_als_die_andern: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/anders_als_die_andern.png" alt="Иконка «Anders als die Andern»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Anders als die Andern</div> <div class="achievement_subtitle"> - сексуальные меньшинства защитят Республику.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_bruder_zur_sonne: {!<tr>!}   {!<td style="width: 60px; height: 78px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/bruder_zur_sonne.png" alt="Значок «Братья, к солнцу, к свободе»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(97, 24, 19, 0.2);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Brüder, zur Sonne, zur Freiheit</div> <div class="achievement_subtitle"> — снизить безработицу, приостановить репарации, расширить права женщин, избрать президента от <span style="color: #c00000; font-weight: bold;">СДПГ</span> и депортировать <span style="color: #7A3C00;">Гитлера</span> за одно прохождение.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_die_rote_fahne: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/die_rote_fahne.png" alt="Значок «Die Rote Fahne»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(91, 154, 141, 0.1)">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Die Rote Fahne</div> <div class="achievement_subtitle"> — присоединитесь к <span style="color: #700000; font-weight: bold;">КПГ</span> на первомайской демонстрации.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_panik_im_mittelstand: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/panik_im_mittelstand.png" alt="Иконка Panik im Mittelstand" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Panik im Mittelstand</div> <div class="achievement_subtitle"> — поддержка <span style="color: #c00000; font-weight: bold;">СДПГ</span> среди нового среднего класса составляет не менее 50%.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_bauernrevolution: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/bauernrevolution.png" alt="Иконка Bauernrevolution" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Bauernrevolution</div> <div class="achievement_subtitle"> — поддержка <span style="color: #c00000; font-weight: bold;">СДПГ</span> в сельской местности составляет не менее 50%.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_katholischer_sozialismus: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/katholischer_sozialismus.png" alt="Значок «Католический социализм»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Katholischer Sozialismus</div> <div class="achievement_subtitle"> - Поддержка католиками <span style="color: #c00000; font-weight: bold;">СДПГ</span> не менее 50%.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_grosse_volkspartei: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/grosse_volkspartei.png" alt="Значок GroÃŸe Народная партия (Volkspartei)" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(97, 24, 19, 0.2);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">GroÃŸe Народная партия (Volkspartei)</div> <div class="achievement_subtitle"> - Поддержка <span style="color: #c00000; font-weight: bold;">СДПГ</span> всеми классами составляет не менее 40%.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_klassenkampf: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/klassenkampf.png" alt="Иконка Klassenkampf" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Klassenkampf</div> <div class="achievement_subtitle"> - Поддержка <span style="color: #c00000; font-weight: bold;">СДПГ</span> со стороны рабочих составляет не менее 80%, а поддержка со стороны среднего класса и сельских жителей — менее 20%.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_raterepublik: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/raterepublik.png" alt="Иконка Räterepublik" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Räterepublik</div> <div class="achievement_subtitle"> - Начать переход к <span style="color: #9B0000;">социалистической</span> экономике.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_polykrise: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/polykrise.png" alt="Иконка Polykrise" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(97, 24, 19, 0.2);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Polykrise</div> <div class="achievement_subtitle"> - Пережить бегство капитала и <span style="color: #7A3C00;">фашистский</span> переворот.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_syndikalismus: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/syndikalismus.png" alt="Значок «Syndikalismus»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Syndikalismus</div> <div class="achievement_subtitle"> — поддержать захват фабрик рабочими.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_drei_pfeile: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/drei_pfeile.png" alt="Значок «Drei Pfeile»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Три стрелы</div> <div class="achievement_subtitle"> — подавить переворот без гражданской войны.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_ausnahmezustand: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/ausnahmezustand.png" alt="Значок «Чрезвычайное положение»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Ausnahmezustand</div> <div class="achievement_subtitle"> - воспользуйтесь чрезвычайными полномочиями, чтобы отменить выборы.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_eu: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/eu.png" alt="Иконка «Vereinigte Staaten von Europa»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Vereinigte Staaten von Europa</div> <div class="achievement_subtitle"> — сформируйте «<span style="color: #001489;">Европейский</span> <span style="color: #FFDD00;">Союз</span>».</div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_heidelberger_programm: {!<tr>!}   {!<td style="width: 60px; height: 100px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/heidelberger_programm.png" alt="Иконка «Гейдельбергская программа»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(97, 24, 19, 0.2);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Heidelberger Programm</div> <div class="achievement_subtitle"> — достичь целей Гейдельбергской программы <span style="color: #c00000; font-weight: bold;">СДПГ</span>: социальное обеспечение, судебная реформа, права женщин на работе и в семье, прогрессивное налогообложение, рабочие советы и создание <span style="color: #001489;">Европейского</span> <span style="color: #FFDD00;">Союза</span>.</div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_verfassungsreform: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/verfassungsreform.png" alt="Иконка Verfassungsreform" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Конституционная реформа</div> <div class="achievement_subtitle"> — примите конституционную поправку.</div> </div> {!</td>!} {!</tr>!}  ?]

