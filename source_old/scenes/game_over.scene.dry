[? if game_achievement_kulturkampf: {!<tr>!}   {!<td style="width: 60px; height: 78px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/kulturkampf.png" alt="Значок Kulturkampf" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Kulturkampf</div> <div class="achievement_subtitle"> — примите все законы о правах женщин и <span style="color: red;">го</span><span style="color: orange;">мо</span><span style="color: yellow;">се</span><span style="color: green;">кс</span><span style="color: blue;">уа</span><span style="color: purple;">лов</span>, проведите секуляризацию образования и создайте <span style="color: #c00000;">социал</span>-<span style="color: #D3C24D;">либеральную</span> коалицию. </div> {!</td>!} {!</tr>!}  ?]

