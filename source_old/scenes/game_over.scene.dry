[? if achievement_stolperstein: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #c00000; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/stolperstein.png" alt="Иконка «Камень преткновения»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #c00000; background-color: rgba(91, 154, 141, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Stolperstein</div> <div class="achievement_subtitle"> — мы проиграли, но, возможно, история сохранит память о нас… </div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_sturm_und_drang: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/sturm_und_drang.png" alt="Иконка Sturm und Drang" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(91, 154, 141, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Sturm und Drang</div> <div class="achievement_subtitle"> — Перейдите Рубикон. </div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_hitler_tot: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/hitler_tot.png" alt="Иконка «Гитлер мёртв»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">HITLER TOT</div> <div class="achievement_subtitle"> - Заставьте <span style="color: #7A3C00;">Адольфа Гитлера</span> покончить с собой на 12 лет раньше. </div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_vive_le_cartel: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/vive_le_cartel.png" alt="Значок «Vive le Cartel»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Vive le Cartel</div> <div class="achievement_subtitle"> - <span style="color: #FFC0C0;">Картель Левых</span> побеждает на парламентских выборах во Франции. </div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_neuer_nationalismus: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/neuer_nationalismus.png" alt="Значок «Neuer Nationalismus»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Neuer Nationalismus</div> <div class="achievement_subtitle"> - Франк Глацель — лидер <span style="color: #C0A054; font-weight: bold;">ННП</span> или <span style="color: #FFCC00; font-weight: bold;">ЛНП</span>. </div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_christliche_volkspartei: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/christliche_volkspartei.png" alt="Значок «Христианская народная партия»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Christliche Volkspartei</div> <div class="achievement_subtitle"> - сформирована <i>настоящая</i> <span style="color: #000000;">Христианская народная партия</span> (<span style="color: #000000; font-weight: bold;">ХНП</span>). Объединение ХНП и НННП. </div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_braun_koalition: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/braun_koalition.png" alt="Значок «Коричневая коалиция»" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Braun Koalition</div> <div class="achievement_subtitle"> — добейтесь, чтобы <span style="color: #c00000;">социалисты</span>, <span style="color: #D3C24D;">либералы</span>, <span style="color: #000000;">католики</span> и <span style="color: #700000;">коммунисты</span> поддержали Брауна на президентских выборах 1932 года. </div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_liberale_blocpartei: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/liberale_blocpartei.png" alt="Значок Liberale Blocpartei" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(128, 0, 0, 0.15);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Либеральная блоковая партия</div> <div class="achievement_subtitle"> — заключить избирательный союз с <span style="color: #D3C24D; font-weight: bold;">НДП</span> Леммера. </div> </div> {!</td>!} {!</tr>!}  ?]

[? if achievement_christlicher_sozialismus: {!<tr>!}   {!<td style="width: 60px; height: 60px; vertical-align: middle; text-align: center; border: 2px solid #0077FF; background-color: rgba(192, 0, 0, 0.1);">!}         <img src="img/achievement/christlicher_sozialismus.png" alt="Иконка христианского социализма" style="width: 100%; height: 100%; object-fit: cover; display: block;"> {!</td>!}   {!<td style="border: 2px solid #0077FF; background-color: rgba(196, 177, 86, 0.1);">!}         <div style="padding-left: 0.5em;"> <div style="font-weight: bold;">Christlicher "Sozialismus"</div> <div class="achievement_subtitle"> - Ламбах избран лидером <span style="color: #3E88B3; font-weight: bold;">НННП</span>/<span style="color: #000000; font-weight: bold;">ХНП</span> и успешно переизбран. </div> </div> {!</td>!} {!</tr>!}  ?]

